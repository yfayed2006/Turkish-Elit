<odoo>
<record id="view_route_visit_tree_geo_checkin" model="ir.ui.view">
<field name="name">route.visit.tree.geo.checkin</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_tree"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='visit_process_state']" position="after">
<field name="geo_checkin_status" string="Geo" widget="badge" optional="hide" decoration-success="geo_checkin_status == 'inside'" decoration-warning="geo_checkin_status == 'pending'" decoration-danger="geo_checkin_status == 'outside'" decoration-muted="geo_checkin_status in ('disabled', 'outlet_missing')"/>
<field name="geo_checkin_distance_m" string="Distance (m)" optional="hide"/>
</xpath>
</field>
</record>
<record id="view_route_visit_search_geo_checkin" model="ir.ui.view">
<field name="name">route.visit.search.geo.checkin</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_search"/>
<field name="arch" type="xml">
<xpath expr="//filter[@name='filter_cancelled']" position="after">
<separator/>
<filter name="filter_geo_checked_in" string="Geo Checked In" domain="[('geo_checkin_datetime', '!=', False)]"/>
<filter name="filter_geo_not_checked_in" string="No Geo Check-in" domain="[('geo_checkin_datetime', '=', False)]"/>
</xpath>
</field>
</record>
<record id="view_route_visit_form_geo_checkin" model="ir.ui.view">
<field name="name">route.visit.form.geo.checkin</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="before">
<field name="route_geo_enabled" invisible="1"/>
</xpath>
<xpath expr="//page[@string='Notes']" position="after">
<page string="Geo Check-in" invisible="not route_geo_enabled">
<group col="2">
<group string="Outlet Location">
<field name="route_geo_checkin_radius_m" readonly="1"/>
<field name="outlet_geo_status" readonly="1" widget="badge" decoration-success="outlet_geo_status == 'verified'" decoration-warning="outlet_geo_status == 'unverified'" decoration-muted="outlet_geo_status == 'missing'"/>
<field name="outlet_geo_coordinates" readonly="1"/>
<button name="action_open_visit_outlet_map" type="object" string="Open Outlet Map" class="btn-secondary" invisible="not outlet_id"/>
<button name="action_open_visit_outlet_navigation" type="object" string="Navigate to Outlet" class="btn-secondary" invisible="not outlet_geo_coordinates"/>
</group>
<group string="Visit Geo Check-in">
<field name="geo_checkin_status" readonly="1" widget="badge" decoration-success="geo_checkin_status == 'inside'" decoration-warning="geo_checkin_status == 'pending'" decoration-danger="geo_checkin_status == 'outside'" decoration-muted="geo_checkin_status in ('disabled', 'outlet_missing')"/>
<field name="geo_checkin_datetime" readonly="1"/>
<field name="geo_checkin_latitude"/>
<field name="geo_checkin_longitude"/>
<field name="geo_checkin_accuracy_m"/>
<field name="geo_checkin_distance_m" readonly="1"/>
<field name="geo_checkin_outside_zone_reason" placeholder="Reserved for the next enforcement phase if the check-in is outside the allowed radius."/>
</group>
</group>
<div class="alert alert-info mt-2" role="alert"> This is the Geo Check-in foundation stage. It records and reviews visit location data, but it does not block Start Visit yet. Device/browser location capture and enforcement rules will be added in the next phase. </div>
<group col="4">
<button name="action_geo_checkin_from_outlet_location" type="object" string="Use Outlet Coordinates as Check-in" class="btn-secondary" invisible="not outlet_geo_coordinates"/>
<button name="action_open_visit_checkin_map" type="object" string="Open Check-in Map" class="btn-secondary" invisible="not geo_checkin_latitude and not geo_checkin_longitude"/>
<button name="action_clear_geo_checkin_location" type="object" string="Clear Check-in" class="btn-secondary" invisible="not geo_checkin_datetime and not geo_checkin_latitude and not geo_checkin_longitude"/>
</group>
</page>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_form_geo_checkin" model="ir.ui.view">
<field name="name">route.visit.pda.form.geo.checkin</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="before">
<field name="route_geo_enabled" invisible="1"/>
</xpath>
<xpath expr="//page[@string='Notes']" position="after">
<page string="Geo Check-in" invisible="not route_geo_enabled">
<group col="2">
<group string="Outlet Location">
<field name="route_geo_checkin_radius_m" readonly="1"/>
<field name="outlet_geo_status" readonly="1" widget="badge" decoration-success="outlet_geo_status == 'verified'" decoration-warning="outlet_geo_status == 'unverified'" decoration-muted="outlet_geo_status == 'missing'"/>
<field name="outlet_geo_coordinates" readonly="1"/>
<button name="action_open_visit_outlet_navigation" type="object" string="Navigate to Outlet" class="btn-secondary" invisible="not outlet_geo_coordinates"/>
</group>
<group string="Visit Geo Check-in">
<field name="geo_checkin_status" readonly="1" widget="badge" decoration-success="geo_checkin_status == 'inside'" decoration-warning="geo_checkin_status == 'pending'" decoration-danger="geo_checkin_status == 'outside'" decoration-muted="geo_checkin_status in ('disabled', 'outlet_missing')"/>
<field name="geo_checkin_datetime" readonly="1"/>
<field name="geo_checkin_latitude"/>
<field name="geo_checkin_longitude"/>
<field name="geo_checkin_distance_m" readonly="1"/>
<field name="geo_checkin_outside_zone_reason"/>
</group>
</group>
<div class="alert alert-info mt-2" role="alert"> Foundation only: this screen records geo check-in data without blocking visit execution yet. </div>
<group col="4">
<button name="action_geo_checkin_from_outlet_location" type="object" string="Use Outlet Coordinates" class="btn-secondary" invisible="not outlet_geo_coordinates"/>
<button name="action_open_visit_checkin_map" type="object" string="Open Check-in Map" class="btn-secondary" invisible="not geo_checkin_latitude and not geo_checkin_longitude"/>
<button name="action_clear_geo_checkin_location" type="object" string="Clear Check-in" class="btn-secondary" invisible="not geo_checkin_datetime and not geo_checkin_latitude and not geo_checkin_longitude"/>
</group>
</page>
</xpath>
</field>
</record>
</odoo>
