<odoo>
<record id="paperformat_route_visit_consignment_receipt" model="report.paperformat">
<field name="name">Consignment Visit Receipt</field>
<field name="default" eval="False"/>
<field name="format">A4</field>
<field name="orientation">Portrait</field>
<field name="margin_top">12</field>
<field name="margin_bottom">12</field>
<field name="margin_left">10</field>
<field name="margin_right">10</field>
<field name="header_line" eval="False"/>
<field name="header_spacing">4</field>
<field name="dpi">96</field>
</record>
<record id="action_report_route_visit_consignment_receipt" model="ir.actions.report">
<field name="name">Consignment Visit Receipt</field>
<field name="model">route.visit</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">route_core.report_route_visit_consignment_receipt</field>
<field name="report_file">route_core.report_route_visit_consignment_receipt</field>
<field name="print_report_name">'Consignment Receipt - %s' % (object.name or '')</field>
<field name="paperformat_id" ref="route_core.paperformat_route_visit_consignment_receipt"/>
</record>
<template id="report_route_visit_consignment_receipt">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">
<t t-call="web.basic_layout">
<t t-set="summary" t-value="doc._get_consignment_receipt_summary()"/>
<t t-set="payments" t-value="doc._get_consignment_receipt_payments()"/>
<t t-set="payment_breakdown" t-value="doc._get_consignment_receipt_payment_breakdown()"/>
<div class="page" style="font-size:12px; color:#1f2937;">
<div style="border:1px solid #cbd5e1; background:#ffffff; margin-bottom:14px;">
<table style="width:100%; border-collapse:collapse; table-layout:fixed;">
<tr>
<td style="width:64%; padding:16px 18px; vertical-align:top; border-right:1px solid #e5e7eb;">
<div style="font-size:11px; letter-spacing:0.6px; text-transform:uppercase; color:#0f766e; font-weight:700; margin-bottom:6px;">Route Core</div>
<div style="font-size:25px; font-weight:700; color:#111827; line-height:1.15; margin-bottom:6px;">Consignment Visit Receipt</div>
<div style="font-size:12px; color:#475569; line-height:1.55; margin-bottom:10px;">Official summary for consignment sale, return transfer, refill, and confirmed collection activity.</div>
<div style="font-size:11px; color:#475569; line-height:1.6;">
<div>
<strong t-esc="doc.company_id.name or '-'"/>
</div>
<div t-if="doc.company_id.partner_id and doc.company_id.partner_id.contact_address" t-esc="doc.company_id.partner_id.contact_address"/>
</div>
</td>
<td style="width:36%; padding:16px 18px; vertical-align:top; text-align:right; background:#f8fafc;">
<div t-if="doc.company_id.logo" style="margin-bottom:12px;">
<img t-att-src="image_data_uri(doc.company_id.logo)" style="max-height:52px; max-width:150px; object-fit:contain;" alt="Company Logo"/>
</div>
<div style="display:inline-block; text-align:left; min-width:190px; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.5px; margin-bottom:4px;">Receipt Meta</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Visit No:</strong>
<span t-esc="doc.name or '-'"/>
</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Generated:</strong>
<span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/>
</div>
</div>
</td>
</tr>
</table>
</div>
<table style="width:100%; border-collapse:collapse; margin-bottom:14px; border:1px solid #cbd5e1;">
<tr>
<td colspan="4" style="padding:9px 12px; background:#ecfeff; color:#155e75; font-weight:700; font-size:13px; border-bottom:1px solid #cbd5e1;">Visit Summary</td>
</tr>
<tr>
<td style="width:18%; padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Outlet</td>
<td style="width:32%; padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.outlet_id"/>
</td>
<td style="width:18%; padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Customer</td>
<td style="width:32%; padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.partner_id"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Visit Date</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.date"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Salesperson</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.user_id"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Start DateTime</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.start_datetime" t-field="doc.start_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.start_datetime">-</span>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">End DateTime</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.end_datetime" t-field="doc.end_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.end_datetime">-</span>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Sale Order</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary.get('sale_order_ref') or '-'"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Refill Transfer</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary.get('refill_ref') or '-'"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155;">Return Transfers</td>
<td colspan="3" style="padding:8px 12px;">
<span t-esc="summary.get('return_ref') or '-'"/>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:separate; border-spacing:8px; margin:0 -8px 10px -8px;">
<tr>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Previous Due</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('previous_due', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Current Sale</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('current_sale', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Returned Value</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('current_return', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Refill Value</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('current_refill', 0.0), doc.currency_id.name or '')"/>
</td>
</tr>
<tr>
<td style="border:1px solid #bfdbfe; background:#eff6ff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#1d4ed8; margin-bottom:6px;">Grand Total Due</div>
<div style="font-size:20px; font-weight:700; color:#1e3a8a;" t-esc="'%.2f %s' % (summary.get('grand_total_due', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="border:1px solid #bbf7d0; background:#f0fdf4; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#15803d; margin-bottom:6px;">Collected</div>
<div style="font-size:20px; font-weight:700; color:#166534;" t-esc="'%.2f %s' % (summary.get('settled_amount', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="border:1px solid #fecaca; background:#fef2f2; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#b91c1c; margin-bottom:6px;">Remaining</div>
<div style="font-size:20px; font-weight:700; color:#991b1b;" t-esc="'%.2f %s' % (summary.get('remaining_amount', 0.0), doc.currency_id.name or '')"/>
</td>
<td style="border:1px solid #e5e7eb; background:#fafafa; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Promise Amount</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('promise_amount', 0.0), doc.currency_id.name or '')"/>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:collapse; margin-bottom:14px; border:1px solid #cbd5e1;">
<tr>
<td colspan="5" style="padding:9px 12px; background:#f8fafc; color:#334155; font-weight:700; font-size:13px; border-bottom:1px solid #cbd5e1;">Collection Breakdown</td>
</tr>
<tr style="background:#f8fafc;">
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Cash</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Bank Transfer</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">POS</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Deferred</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Promised</td>
</tr>
<tr>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['cash'], doc.currency_id.name or '')"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['bank'], doc.currency_id.name or '')"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['pos'], doc.currency_id.name or '')"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['deferred'], doc.currency_id.name or '')"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['promise'], doc.currency_id.name or '')"/>
</tr>
</table>
<div style="margin-top:10px; border:1px solid #dbe3ec;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Confirmed Payments</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Date</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Mode</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Collection</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Promise</th>
</tr>
</thead>
<tbody>
<tr t-if="not payments">
<td colspan="5" style="padding:10px; color:#64748b;">No confirmed payments.</td>
</tr>
<tr t-foreach="payments" t-as="payment">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.payment_date" t-options="{'widget': 'datetime'}"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['payment_mode'].selection).get(payment.payment_mode)"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['collection_type'].selection).get(payment.collection_type)"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9; text-align:right;" t-esc="'%.2f' % (payment.amount or 0.0)"/>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9; text-align:right;" t-esc="'%.2f' % (payment.promise_amount or 0.0)"/>
</tr>
</tbody>
</table>
</div>
</div>
</t>
</t>
</t>
</template>
</odoo>
