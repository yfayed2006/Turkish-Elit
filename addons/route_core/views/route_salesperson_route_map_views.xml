<odoo>
<record id="view_route_salesperson_route_map_form" model="ir.ui.view">
<field name="name">route.salesperson.route.map.form</field>
<field name="model">route.salesperson.route.map</field>
<field name="arch" type="xml">
<form string="Today's Route Map" create="0" edit="0" delete="0">
<header>
<button name="action_back_to_workspace" type="object" string="Back to Route Workspace" class="btn-primary" icon="fa-arrow-left"/>
<button name="action_refresh_map" type="object" string="Refresh" icon="fa-refresh"/>
<button name="action_open_today_visits" type="object" string="Open Today's Visits" icon="fa-list"/>
</header>
<sheet class="route_pda_home_sheet route_pda_detail_sheet route_salesperson_route_map_sheet">
<field name="name" invisible="1"/>
<field name="route_geo_enabled" invisible="1"/>
<field name="route_map_provider" invisible="1"/>
<field name="route_geo_checkin_policy" invisible="1"/>
<div class="route_pda_detail_header route_salesperson_route_map_title_header">
<h2 class="route_pda_detail_title">Today's Route Map</h2>
</div>
<div class="alert alert-info" role="alert" invisible="route_geo_enabled == False"> Your route map shows today's outlets, visit status, navigation buttons, and location check-in readiness. </div>
<div class="alert alert-warning" role="alert" invisible="route_geo_enabled == True"> Visit location is disabled in Route Settings. Enable outlet locations to use the route map. </div>
<div class="route_pda_section route_salesperson_route_map_summary_section route_salesperson_route_map_focus_section">
<div class="route_pda_section_title">Route Summary</div>
<div class="route_salesperson_route_map_counter_dashboard">
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_date">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-calendar-o"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">Visit Date</div>
<div class="route_salesperson_route_map_counter_value">
<field name="visit_date" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_total">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-map-marker"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">Today's Visits</div>
<div class="route_salesperson_route_map_counter_value">
<field name="total_visit_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_pending">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-clock-o"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">Pending</div>
<div class="route_salesperson_route_map_counter_value">
<field name="pending_visit_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_active">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-play-circle"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">In Progress</div>
<div class="route_salesperson_route_map_counter_value">
<field name="active_visit_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_done">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-check-circle"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">Done</div>
<div class="route_salesperson_route_map_counter_value">
<field name="done_visit_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_salesperson_route_map_counter_card route_salesperson_route_map_counter_next">
<div class="route_salesperson_route_map_counter_icon">
<i class="fa fa-location-arrow"/>
</div>
<div class="route_salesperson_route_map_counter_content">
<div class="route_salesperson_route_map_counter_label">Next Visit</div>
<div class="route_salesperson_route_map_counter_value route_salesperson_route_map_counter_text">
<field name="next_visit_label" readonly="1" nolabel="1"/>
</div>
</div>
</div>
</div>
</div>
<div class="route_pda_info_hint_inline">
<field name="route_map_note" readonly="1" nolabel="1"/>
</div>
<separator string="Map and Visit Cards"/>
<field name="route_map_iframe_html" readonly="1" nolabel="1" widget="html"/>
</sheet>
</form>
</field>
</record>
<record id="action_route_salesperson_today_route_map" model="ir.actions.act_window">
<field name="name">Today's Route Map</field>
<field name="res_model">route.salesperson.route.map</field>
<field name="view_mode">form</field>
<field name="view_id" ref="view_route_salesperson_route_map_form"/>
<field name="target">current</field>
<field name="context">{"create": 0, "edit": 0, "delete": 0}</field>
</record>
</odoo>
