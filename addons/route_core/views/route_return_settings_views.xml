<odoo>
<data>
<record id="view_res_company_form_route_return_settings" model="ir.ui.view">
<field name="name">res.company.form.route.return.settings</field>
<field name="model">res.company</field>
<field name="inherit_id" ref="base.view_company_form"/>
<field name="arch" type="xml">
<xpath expr="//sheet" position="inside">
<group string="Route Scenario Settings">
<group>
<field name="route_operation_mode"/>
<field name="route_enable_direct_sale"/>
<field name="route_enable_direct_return"/>
<field name="route_vehicle_loading_workflow"/>
<field name="route_default_source_warehouse_id" options="{'no_create': True}"/>
<field name="route_week_start_day"/>
<field name="route_weekly_off_day"/>
<field name="route_default_consignment_root_location_id" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="route_workspace_show_vehicle_closing"/>
<div class="text-muted" colspan="2"> Disabled = manual vehicle transfer only. Optional = proposal is available but not required. Required = visits cannot start before the loading proposal is approved. </div>
<div class="text-muted" colspan="2"> Disable Vehicle Closing in Route Workspace when end-of-day vehicle reconciliation is handled by warehouse or supervisor users instead of the salesperson. </div>
</group>
</group>
<group string="Route Product Settings">
<group>
<field name="route_enable_lot_serial_tracking"/>
<field name="route_enable_expiry_tracking" invisible="route_enable_lot_serial_tracking == False"/>
</group>
</group>
<group string="Return Settings">
<group>
<field name="return_damaged_location_id"/>
<field name="return_near_expiry_location_id"/>
</group>
</group>
</xpath>
</field>
</record>
<record id="action_route_return_settings" model="ir.actions.act_window">
<field name="name">Route Settings</field>
<field name="res_model">res.company</field>
<field name="view_mode">list,form</field>
<field name="domain">[]</field>
<field name="context">{}</field>
</record>
<menuitem id="menu_route_return_settings" name="Route Settings" parent="menu_route_configuration" action="action_route_return_settings" sequence="30"/>
</data>
</odoo>
