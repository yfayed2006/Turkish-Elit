<odoo>
<record id="view_res_company_form_route_return_settings" model="ir.ui.view">
<field name="name">res.company.form.route.sales.settings</field>
<field name="model">res.company</field>
<field name="inherit_id" ref="base.view_company_form"/>
<field name="arch" type="xml">
<xpath expr="//sheet" position="inside">
<group string="Route Sales Settings">
<group string="Workflow Controls">
<field name="route_enable_lot_serial_tracking"/>
<field name="route_enable_expiry_tracking" readonly="not route_enable_lot_serial_tracking"/>
<field name="route_require_related_contact_for_direct_sale"/>
</group>
<group string="Return Locations">
<field name="return_damaged_location_id"/>
<field name="return_near_expiry_location_id" readonly="not route_enable_expiry_tracking"/>
</group>
</group>
</xpath>
</field>
</record>
<record id="action_route_return_settings" model="ir.actions.act_window">
<field name="name">Route Sales Settings</field>
<field name="res_model">res.company</field>
<field name="view_mode">list,form</field>
<field name="domain">[]</field>
<field name="context">{}</field>
</record>
<menuitem id="menu_route_return_settings" name="Route Sales Settings" parent="menu_route_configuration" action="action_route_return_settings" sequence="30"/>
</odoo>
