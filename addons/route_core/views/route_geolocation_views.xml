<odoo>
<record id="view_route_outlet_location_setup_search" model="ir.ui.view">
<field name="name">route.outlet.location.setup.search</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<search string="Outlet Locations">
<field name="name" string="Outlet"/>
<field name="partner_id" string="Customer"/>
<field name="route_city_id" string="City"/>
<field name="area_id" string="Area"/>
<field name="geo_status" string="Location Status"/>
<separator/>
<filter name="filter_geo_missing" string="Missing Location" domain="[('geo_status', '=', 'missing')]"/>
<filter name="filter_geo_unverified" string="Unverified Location" domain="[('geo_status', '=', 'unverified')]"/>
<filter name="filter_geo_verified" string="Verified Location" domain="[('geo_status', '=', 'verified')]"/>
<separator/>
<filter name="group_by_geo_status" string="Location Status" context="{'group_by': 'geo_status'}"/>
<filter name="group_by_city" string="City" context="{'group_by': 'route_city_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
</search>
</field>
</record>
<record id="view_route_outlet_location_setup_list" model="ir.ui.view">
<field name="name">route.outlet.location.setup.list</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<list string="Outlet Location Setup" create="0" delete="0" default_order="geo_status, route_city_id, area_id, name">
<field name="name" string="Outlet"/>
<field name="partner_id" string="Customer" optional="show"/>
<field name="route_city_id" string="City" optional="show"/>
<field name="area_id" string="Area" optional="show"/>
<field name="geo_status" string="Location" widget="badge"/>
<field name="geo_display_coordinates" string="Coordinates" optional="show"/>
<field name="geo_address" string="Map Address" optional="hide"/>
<field name="geo_verified" string="Verified" optional="show"/>
<field name="geo_last_update" string="Last Update" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_outlet_location_setup_form" model="ir.ui.view">
<field name="name">route.outlet.location.setup.form</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<form string="Outlet Location">
<header>
<button name="action_search_outlet_address_on_map" type="object" string="Search Address on Map" class="btn-secondary"/>
<button name="action_open_outlet_map" type="object" string="Open Map" class="btn-primary" invisible="geo_status == 'missing'"/>
<button name="action_open_outlet_navigation" type="object" string="Navigate" class="btn-secondary" invisible="geo_status == 'missing'"/>
<button name="action_verify_outlet_location" type="object" string="Verify Location" class="btn-secondary" invisible="geo_status == 'verified'"/>
<button name="action_mark_outlet_location_unverified" type="object" string="Mark Unverified" class="btn-secondary" invisible="geo_status != 'verified'"/>
<button name="action_clear_outlet_location" type="object" string="Clear Location" class="btn-secondary" invisible="geo_status == 'missing'"/>
</header>
<sheet>
<div class="oe_title">
<label for="name"/>
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<group string="Outlet">
<group>
<field name="partner_id" readonly="1"/>
<field name="route_country_id" readonly="1"/>
<field name="route_city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
</group>
<group>
<field name="geo_status" widget="badge" readonly="1"/>
<field name="geo_verified"/>
<field name="geo_last_update" readonly="1"/>
</group>
</group>
<group string="Map Coordinates">
<group>
<field name="geo_latitude"/>
<field name="geo_longitude"/>
<field name="geo_display_coordinates" readonly="1"/>
<field name="geo_accuracy_m"/>
</group>
<group>
<field name="geo_address" placeholder="Optional map/search address..."/>
<field name="geo_source"/>
<field name="geo_place_id"/>
</group>
</group>
<group string="Usage Notes">
<div class="text-muted">Set Latitude and Longitude for the real outlet position, then verify the location. These coordinates will be used later for geo check-in, route maps, live monitoring, and route playback.</div>
</group>
</sheet>
</form>
</field>
</record>
<record id="action_route_outlet_location_setup" model="ir.actions.act_window">
<field name="name">Outlet Location Setup</field>
<field name="res_model">route.outlet</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_outlet_location_setup_search"/>
<field name="context">{'search_default_filter_geo_missing': 1}</field>
</record>
<record id="action_route_outlet_location_setup_list" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">list</field>
<field name="view_id" ref="view_route_outlet_location_setup_list"/>
<field name="act_window_id" ref="action_route_outlet_location_setup"/>
</record>
<record id="action_route_outlet_location_setup_form" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">form</field>
<field name="view_id" ref="view_route_outlet_location_setup_form"/>
<field name="act_window_id" ref="action_route_outlet_location_setup"/>
</record>
<menuitem id="menu_route_outlet_location_setup" name="Outlet Location Setup" parent="menu_route_configuration" action="action_route_outlet_location_setup" sequence="18" groups="route_core.group_route_management"/>
</odoo>
