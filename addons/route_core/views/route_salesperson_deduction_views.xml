<odoo>
<record id="view_route_salesperson_deduction_tree" model="ir.ui.view">
<field name="name">route.salesperson.deduction.tree</field>
<field name="model">route.salesperson.deduction</field>
<field name="arch" type="xml">
<list string="Monthly Deduction Execution" create="0" delete="0">
<field name="name"/>
<field name="month_date"/>
<field name="salesperson_id"/>
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'approved'" decoration-success="state == 'executed'" decoration-muted="state == 'cancelled'"/>
<field name="line_count"/>
<field name="total_shortage_qty"/>
<field name="total_shortage_amount"/>
<field name="approved_on" optional="show"/>
<field name="executed_on" optional="show"/>
</list>
</field>
</record>
<record id="view_route_salesperson_deduction_form" model="ir.ui.view">
<field name="name">route.salesperson.deduction.form</field>
<field name="model">route.salesperson.deduction</field>
<field name="arch" type="xml">
<form string="Monthly Deduction Execution" create="0" delete="0">
<header>
<button name="action_approve" type="object" string="Approve Deduction" class="btn-primary" invisible="state in ('approved','executed','cancelled')"/>
<button name="action_mark_executed" type="object" string="Mark Executed" class="btn-primary" invisible="state in ('executed','cancelled')"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state in ('draft','executed')"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state in ('cancelled','executed')"/>
<button name="action_open_monthly_ledger" type="object" string="Open Monthly Ledger" class="btn-secondary"/>
<field name="state" widget="statusbar" statusbar_visible="draft,approved,executed,cancelled" nolabel="1"/>
</header>
<sheet>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<group col="4" string="Execution Summary">
<group>
<field name="month_date" readonly="1"/>
<field name="salesperson_id" readonly="1"/>
<field name="company_id" readonly="1"/>
</group>
<group>
<field name="ledger_id" readonly="1"/>
<field name="approved_on" readonly="1" invisible="not approved_on"/>
<field name="approved_by_id" readonly="1" invisible="not approved_by_id"/>
<field name="executed_on" readonly="1" invisible="not executed_on"/>
<field name="executed_by_id" readonly="1" invisible="not executed_by_id"/>
</group>
<group>
<field name="line_count" readonly="1"/>
<field name="total_shortage_qty" readonly="1"/>
<field name="total_shortage_amount" readonly="1"/>
</group>
</group>
<notebook>
<page string="Deduction Lines">
<field name="line_ids" nolabel="1">
<list create="0" delete="0">
<field name="shortage_date" readonly="1"/>
<field name="vehicle_id" readonly="1" optional="show"/>
<field name="product_id" readonly="1"/>
<field name="lot_id" readonly="1" optional="show"/>
<field name="shortage_qty" readonly="1"/>
<field name="unit_price" readonly="1" optional="show"/>
<field name="shortage_amount" readonly="1"/>
<field name="settlement_note" readonly="1" optional="show"/>
<field name="execution_status" widget="badge" readonly="1" decoration-info="execution_status in ('pending','deduction_draft')" decoration-warning="execution_status == 'deduction_approved'" decoration-success="execution_status in ('deducted','admin_settled','waived')"/>
<field name="closing_id" readonly="1" optional="show"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" placeholder="Internal supervisor notes for the monthly deduction execution..." readonly="state == 'executed'"/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_salesperson_deduction_search" model="ir.ui.view">
<field name="name">route.salesperson.deduction.search</field>
<field name="model">route.salesperson.deduction</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="month_date"/>
<field name="salesperson_id"/>
<field name="state"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
<filter name="filter_executed" string="Executed" domain="[('state', '=', 'executed')]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_month" string="Month" context="{'group_by': 'month_date'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
</search>
</field>
</record>
<record id="action_route_salesperson_deduction" model="ir.actions.act_window">
<field name="name">Monthly Deduction Execution</field>
<field name="res_model">route.salesperson.deduction</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_salesperson_deduction_search"/>
</record>
<menuitem id="menu_route_salesperson_deduction" name="Monthly Deduction Execution" parent="menu_route_visit_root" action="action_route_salesperson_deduction" sequence="28"/>
</odoo>
