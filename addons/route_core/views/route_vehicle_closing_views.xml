<odoo>
<record id="view_route_vehicle_closing_tree" model="ir.ui.view">
<field name="name">route.vehicle.closing.tree</field>
<field name="model">route.vehicle.closing</field>
<field name="arch" type="xml">
<list string="Vehicle Closings" create="0">
<field name="name"/>
<field name="plan_id"/>
<field name="plan_date"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'closed'" decoration-danger="state == 'cancelled'"/>
<field name="variance_review_status" widget="badge" decoration-info="variance_review_status == 'pending'" decoration-warning="variance_review_status == 'in_progress'" decoration-success="variance_review_status in ('clean', 'done')"/>
<field name="count_started_datetime" optional="show"/>
<field name="count_done_datetime" optional="show"/>
<field name="variance_review_done_datetime" optional="show"/>
<field name="snapshot_datetime" optional="show"/>
<field name="close_datetime" optional="show"/>
<field name="total_system_qty"/>
<field name="total_counted_qty"/>
<field name="total_variance_qty"/>
<field name="variance_line_count"/>
<field name="pending_variance_line_count" optional="show"/>
</list>
</field>
</record>
<record id="view_route_vehicle_closing_form" model="ir.ui.view">
<field name="name">route.vehicle.closing.form</field>
<field name="model">route.vehicle.closing</field>
<field name="arch" type="xml">
<form string="Vehicle Closing" create="0" delete="0">
<header>
<button name="action_refresh_snapshot" type="object" string="Refresh Vehicle Snapshot" class="btn-secondary" invisible="state != 'draft' or count_done"/>
<button name="action_start_count" type="object" string="Start Count" class="btn-primary" invisible="state != 'draft' or count_started_datetime"/>
<button name="action_open_scan_wizard" type="object" string="Scan Vehicle Stock" class="btn-primary" invisible="state != 'draft' or not count_started_datetime or count_done"/>
<button name="action_close_day" type="object" string="Close Vehicle Day" class="btn-primary" invisible="state != 'draft' or not count_done"/>
<button name="action_start_variance_review" type="object" string="Review Variances" class="btn-primary" invisible="state != 'closed' or variance_line_count == 0 or variance_review_started_datetime"/>
<button name="action_complete_variance_review" type="object" string="Complete Variance Review" class="btn-primary" invisible="state != 'closed' or variance_line_count == 0 or not variance_review_started_datetime or variance_review_done or pending_variance_line_count != 0"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state != 'closed'"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state != 'draft' or count_done"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button type="object" name="action_open_route_plan" class="oe_stat_button" icon="fa-road">
<div class="o_stat_info">
<span class="o_stat_text">Route Plan</span>
</div>
</button>
<button type="object" name="action_open_vehicle_stock_snapshot" class="oe_stat_button" icon="fa-cubes">
<div class="o_stat_info">
<span class="o_stat_text">Vehicle Stock Snapshot</span>
</div>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<field name="state" widget="statusbar" statusbar_visible="draft,closed,cancelled" nolabel="1"/>
</div>
<group string="Closing Information" col="4">
<group>
<field name="plan_id" readonly="1"/>
<field name="plan_date" readonly="1"/>
<field name="vehicle_id" readonly="1"/>
<field name="user_id" readonly="1"/>
</group>
<group>
<field name="planning_finalized" readonly="1"/>
<field name="planning_finalized_datetime" readonly="1" invisible="not planning_finalized_datetime"/>
<field name="vehicle_location_id" readonly="1"/>
<field name="snapshot_datetime" readonly="1" invisible="not snapshot_datetime"/>
<field name="count_started_datetime" readonly="1" invisible="not count_started_datetime"/>
<field name="count_done_datetime" readonly="1" invisible="not count_done_datetime"/>
<field name="variance_review_started_datetime" readonly="1" invisible="not variance_review_started_datetime"/>
<field name="variance_review_done_datetime" readonly="1" invisible="not variance_review_done_datetime"/>
<field name="close_datetime" readonly="1" invisible="not close_datetime"/>
</group>
</group>
<group invisible="state != 'draft' or count_started_datetime" class="mt8 mb8">
<div class="alert alert-info" role="alert">
<strong>Next step:</strong>
Start Count to begin the physical vehicle count.
</div>
</group>
<group invisible="state != 'draft' or not count_started_datetime or count_done" class="mt8 mb8">
<div class="alert alert-warning" role="alert">
<strong>Count in progress:</strong>
use Scan Vehicle Stock, then press Done in the scan window before closing the vehicle day.
</div>
</group>
<group invisible="state != 'draft' or not count_done" class="mt8 mb8">
<div class="alert alert-success" role="alert">
<strong>Count completed:</strong>
Close Vehicle Day to finalize the vehicle closing.
</div>
</group>
<group invisible="state != 'closed' or variance_line_count == 0 or variance_review_started_datetime" class="mt8 mb8">
<div class="alert alert-warning" role="alert">
<strong>Variance review required:</strong>
review each variance line, choose a reason, and choose the next reconciliation action.
</div>
</group>
<group invisible="state != 'closed' or variance_line_count == 0 or not variance_review_started_datetime or variance_review_done" class="mt8 mb8">
<div class="alert alert-info" role="alert">
<strong>Variance review in progress:</strong>
fill in all variance lines, then complete the review.
</div>
</group>
<group invisible="state != 'closed' or variance_line_count == 0 or not variance_review_done" class="mt8 mb8">
<div class="alert alert-success" role="alert">
<strong>Variance review completed:</strong>
all variance lines now have a reason and reconciliation action.
</div>
</group>
<group invisible="state != 'closed' or variance_line_count != 0" class="mt8 mb8">
<div class="alert alert-success" role="alert">
<strong>No variances:</strong>
no reconciliation action is required for this vehicle closing.
</div>
</group>
<separator string="Closing Summary"/>
<group col="4">
<group string="Counts">
<field name="line_count" readonly="1"/>
<field name="variance_line_count" readonly="1"/>
<field name="reviewed_variance_line_count" readonly="1"/>
<field name="pending_variance_line_count" readonly="1"/>
</group>
<group string="Quantities">
<field name="total_system_qty" readonly="1"/>
<field name="total_counted_qty" readonly="1"/>
<field name="total_variance_qty" readonly="1"/>
<field name="total_abs_variance_qty" readonly="1"/>
<field name="variance_review_status" readonly="1" widget="badge" decoration-info="variance_review_status == 'pending'" decoration-warning="variance_review_status == 'in_progress'" decoration-success="variance_review_status in ('clean', 'done')"/>
</group>
</group>
<notebook>
<page string="Closing Lines">
<field name="line_ids" nolabel="1">
<list editable="bottom" create="0" delete="0">
<field name="product_id" readonly="1"/>
<field name="barcode" readonly="1" optional="show"/>
<field name="uom_id" readonly="1" optional="show"/>
<field name="location_id" readonly="1"/>
<field name="lot_id" readonly="1" optional="show"/>
<field name="expiry_date" readonly="1" optional="show"/>
<field name="alert_date" readonly="1" optional="hide"/>
<field name="in_date" readonly="1" optional="show"/>
<field name="system_qty" readonly="1"/>
<field name="reserved_qty" readonly="1" optional="show"/>
<field name="available_qty" readonly="1" optional="show"/>
<field name="counted_qty" readonly="parent.state != 'draft' or not parent.count_started_datetime"/>
<field name="variance_qty" readonly="1"/>
<field name="variance_status" readonly="1" widget="badge" decoration-success="variance_status == 'match'" decoration-warning="variance_status == 'over'" decoration-danger="variance_status == 'short'"/>
<field name="review_status" readonly="1" widget="badge" optional="show" decoration-info="review_status == 'pending'" decoration-success="review_status in ('clean', 'reviewed')"/>
<field name="variance_reason" readonly="parent.state != 'closed' or not parent.variance_review_started_datetime or parent.variance_review_done or variance_qty == 0" optional="show"/>
<field name="reconciliation_action" readonly="parent.state != 'closed' or not parent.variance_review_started_datetime or parent.variance_review_done or variance_qty == 0" optional="show"/>
<field name="review_note" readonly="parent.state != 'closed' or not parent.variance_review_started_datetime or parent.variance_review_done or variance_qty == 0" optional="show"/>
<field name="note" readonly="parent.state != 'draft'" optional="hide"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" readonly="state != 'draft'" placeholder="Internal notes..."/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_vehicle_closing_search" model="ir.ui.view">
<field name="name">route.vehicle.closing.search</field>
<field name="model">route.vehicle.closing</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="plan_id"/>
<field name="plan_date"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="state"/>
<field name="variance_review_status"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_closed" string="Closed" domain="[('state', '=', 'closed')]"/>
<filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
<filter name="filter_variance_pending" string="Variance Review Pending" domain="[('variance_review_status', 'in', ['pending', 'in_progress'])]"/>
<filter name="filter_variance_done" string="Variance Review Done" domain="[('variance_review_status', '=', 'done')]"/>
<separator/>
<filter name="group_by_plan_date" string="Plan Date" context="{'group_by': 'plan_date'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
</search>
</field>
</record>
<record id="action_route_vehicle_closing" model="ir.actions.act_window">
<field name="name">Vehicle Closings</field>
<field name="res_model">route.vehicle.closing</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_vehicle_closing_search"/>
</record>
<menuitem id="menu_route_vehicle_closing" name="Vehicle Closings" parent="menu_route_visit_root" action="action_route_vehicle_closing" sequence="26"/>
</odoo>
