<odoo>
<!-- 
        Bank/POS Payment Review
        Path in module:
        addons/route_core/views/route_bank_pos_payment_review_views.xml

        Purpose:
        - Adds a dedicated Accounting menu for Bank Transfer / POS payment confirmation.
        - Reuses the existing custody monitor card views so accountants see the action buttons.
        - Keeps one primary card per Bank/POS payment group using electronic_is_primary.
        - Also defines action_route_bank_pos_accounting_confirmation for compatibility with
          Accounting Work Queue methods that may call this XML id.
     -->
<record id="action_route_bank_pos_payment_review" model="ir.actions.act_window">
<field name="name">Bank/POS Payment Review</field>
<field name="res_model">route.visit.payment</field>
<field name="view_mode">kanban,list,form</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_kanban"/>
<field name="search_view_id" ref="route_core.view_route_custody_monitor_search"/>
<field name="domain">[('state', '=', 'confirmed'), ('payment_mode', 'in', ['bank', 'pos']), ('electronic_is_primary', '=', True)]</field>
<field name="context">{'search_default_filter_confirmed': 1, 'search_default_filter_electronic_pending': 1, 'create': 0, 'edit': 0, 'delete': 0, 'route_accounting_custody_monitor_mode': True, 'route_accounting_custody_actions_mode': True, 'group_by': False}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">No Bank/POS payments are waiting for Accounting confirmation.</p>
<p>Bank Transfer and POS payments reported by salespeople appear here for accounting confirmation, follow-up, and receipt voucher posting.</p>
</field>
</record>
<record id="action_route_bank_pos_payment_review_kanban_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">kanban</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_kanban"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_payment_review"/>
</record>
<record id="action_route_bank_pos_payment_review_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_list"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_payment_review"/>
</record>
<record id="action_route_bank_pos_payment_review_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="3"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_cheque_followup_form"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_payment_review"/>
</record>
<!--  Compatibility XML id used by some Accounting Work Queue versions.  -->
<record id="action_route_bank_pos_accounting_confirmation" model="ir.actions.act_window">
<field name="name">Bank/POS Payment Review</field>
<field name="res_model">route.visit.payment</field>
<field name="view_mode">kanban,list,form</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_kanban"/>
<field name="search_view_id" ref="route_core.view_route_custody_monitor_search"/>
<field name="domain">[('state', '=', 'confirmed'), ('payment_mode', 'in', ['bank', 'pos']), ('electronic_is_primary', '=', True)]</field>
<field name="context">{'search_default_filter_confirmed': 1, 'search_default_filter_electronic_pending': 1, 'create': 0, 'edit': 0, 'delete': 0, 'route_accounting_custody_monitor_mode': True, 'route_accounting_custody_actions_mode': True, 'group_by': False}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">No Bank/POS payments are waiting for Accounting confirmation.</p>
<p>Bank Transfer and POS payments reported by salespeople appear here for accounting confirmation, follow-up, and receipt voucher posting.</p>
</field>
</record>
<record id="action_route_bank_pos_accounting_confirmation_kanban_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">kanban</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_kanban"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_accounting_confirmation"/>
</record>
<record id="action_route_bank_pos_accounting_confirmation_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_custody_monitor_list"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_accounting_confirmation"/>
</record>
<record id="action_route_bank_pos_accounting_confirmation_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="3"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_cheque_followup_form"/>
<field name="act_window_id" ref="route_core.action_route_bank_pos_accounting_confirmation"/>
</record>
<menuitem id="menu_route_bank_pos_payment_review" name="Bank/POS Payment Review" parent="account.menu_finance_entries" action="route_core.action_route_bank_pos_payment_review" sequence="84" groups="route_core.group_route_cheque_accountant"/>
</odoo>
