<group string="Outlet Commission Trend" col="4">
<group>
<field name="sales_two_months_ago_label" readonly="1"/>
<field name="commission_two_months_ago_amount" readonly="1"/>
<field name="commission_two_months_ago_rate_display" readonly="1"/>
</group>
<group>
<field name="sales_previous_month_label" readonly="1"/>
<field name="commission_previous_month_amount" readonly="1"/>
<field name="commission_previous_month_rate_display" readonly="1"/>
</group>
<group>
<field name="sales_current_month_label" readonly="1"/>
<field name="commission_current_month_amount" readonly="1"/>
<field name="commission_current_month_rate_display" readonly="1"/>
</group>
<group>
<field name="commission_last_3_months_total" readonly="1"/>
<field name="commission_last_3_months_average" readonly="1"/>
<field name="commission_lifetime_total" readonly="1"/>
<field name="commission_trend_status" widget="badge" readonly="1" decoration-success="commission_trend_status == 'up'" decoration-warning="commission_trend_status == 'flat'" decoration-danger="commission_trend_status == 'down'"/>
</group>
</group>
<group string="Commission Growth" col="2">
<group>
