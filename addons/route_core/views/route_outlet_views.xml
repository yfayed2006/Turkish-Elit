<odoo>
<record id="view_route_outlet_list" model="ir.ui.view">
<field name="name">route.outlet.list</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<list string="Outlets">
<field name="code"/>
<field name="barcode"/>
<field name="name"/>
<field name="outlet_operation_mode" widget="badge" optional="show" decoration-info="outlet_operation_mode == 'consignment'" decoration-warning="outlet_operation_mode == 'direct_sale'"/>
<field name="area_id" optional="hide"/>
<field name="route_country_id" optional="show"/>
<field name="route_city_id" optional="show"/>
<field name="route_area_name"/>
<field name="partner_id"/>
<field name="summary_alert_level" widget="badge" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
<field name="current_due_amount" sum="Total Due"/>
<field name="open_shortage_count" string="Open Shortages" widget="badge" decoration-warning="open_shortage_count > 0"/>
<field name="near_expiry_product_count" string="Near Expiry" widget="badge" decoration-warning="near_expiry_product_count > 0"/>
<field name="last_visit_date"/>
<field name="last_sale_order_id"/>
<field name="visit_count"/>
<field name="phone"/>
<field name="mobile"/>
<field name="active"/>
</list>
</field>
</record>
<record id="view_route_outlet_pda_search" model="ir.ui.view">
<field name="name">route.outlet.pda.search</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<search string="Outlets">
<field name="name" string="Outlet"/>
<field name="code" string="Outlet Code"/>
<field name="partner_id" string="Customer"/>
<field name="route_city_id" string="City"/>
<field name="area_id" string="Area"/>
<field name="phone"/>
<field name="mobile"/>
<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
<filter name="filter_direct_sale" string="Direct Sale" domain="[('outlet_operation_mode', '=', 'direct_sale')]"/>
<filter name="filter_consignment" string="Consignment" domain="[('outlet_operation_mode', '=', 'consignment')]"/>
<filter name="group_by_customer" string="Customer" context="{'group_by': 'partner_id'}"/>
<filter name="group_by_city" string="City" context="{'group_by': 'route_city_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
</search>
</field>
</record>
<record id="view_route_outlet_pda_list" model="ir.ui.view">
<field name="name">route.outlet.pda.list</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<list string="Outlets" create="0" edit="0" delete="0">
<field name="code" string="Outlet Code" optional="show"/>
<field name="name" string="Outlet"/>
<field name="outlet_operation_mode" string="Mode" widget="badge" optional="show" decoration-info="outlet_operation_mode == 'consignment'" decoration-warning="outlet_operation_mode == 'direct_sale'"/>
<field name="summary_alert_level" string="Status" widget="badge" optional="show" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
<field name="current_due_amount" string="Current Due" sum="Total Due" optional="show"/>
<field name="last_visit_date" string="Last Visit Date" optional="show"/>
<field name="barcode" string="Barcode" optional="hide" column_invisible="context.get('route_show_barcode', False) == False"/>
<field name="route_city_id" string="City" optional="hide"/>
<field name="route_area_name" string="Area" optional="hide"/>
<field name="near_expiry_product_count" string="Near Expiry" widget="badge" optional="hide" decoration-warning="near_expiry_product_count > 0" column_invisible="context.get('route_hide_near_expiry', False)"/>
<field name="last_sale_order_id" string="Last Sale Order" optional="hide"/>
<field name="visit_count" string="Visits" optional="hide"/>
<field name="phone" optional="hide"/>
<field name="mobile" optional="hide"/>
<field name="active" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_outlet_pda_kanban" model="ir.ui.view">
<field name="name">route.outlet.pda.kanban</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<kanban class="route_pda_mobile_outlet_kanban" create="0" edit="0" delete="0">
<field name="name"/>
<field name="code"/>
<field name="partner_id"/>
<field name="outlet_operation_mode"/>
<field name="summary_alert_level"/>
<field name="current_due_amount"/>
<field name="last_visit_date"/>
<field name="visit_count"/>
<field name="return_order_count"/>
<field name="transfer_count"/>
<templates>
<t t-name="card">
<div t-attf-class="oe_kanban_global_click o_kanban_record route_pda_outlet_card route_pda_outlet_card_mode_#{record.outlet_operation_mode.raw_value or 'unknown'}">
<div class="route_pda_outlet_card_head">
<div t-attf-class="route_pda_outlet_title route_pda_outlet_title_mode_#{record.outlet_operation_mode.raw_value or 'unknown'}">
<field name="name"/>
</div>
<div class="route_pda_outlet_code">
<field name="code"/>
</div>
</div>
<div class="route_pda_outlet_customer">
<field name="partner_id"/>
</div>
<div class="route_pda_outlet_badges">
<span class="route_pda_outlet_badge route_pda_outlet_badge_mode">
<field name="outlet_operation_mode" widget="badge"/>
</span>
<span class="route_pda_outlet_badge route_pda_outlet_badge_status">
<field name="summary_alert_level" widget="badge"/>
</span>
</div>
<div class="route_pda_outlet_metrics">
<div class="route_pda_outlet_metric">
<span class="route_pda_outlet_metric_label">Current Due</span>
<span class="route_pda_outlet_metric_value">
<field name="current_due_amount"/>
</span>
</div>
<div class="route_pda_outlet_metric">
<span class="route_pda_outlet_metric_label">Last Visit</span>
<span class="route_pda_outlet_metric_value">
<field name="last_visit_date"/>
</span>
</div>
</div>
<div class="route_pda_outlet_footer">
<span class="route_pda_outlet_footer_label">Visits</span>
<span class="route_pda_outlet_footer_value">
<field name="visit_count"/>
</span>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_outlet_form" model="ir.ui.view">
<field name="name">route.outlet.form</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<form string="Outlet">
<sheet>
<div class="oe_button_box" name="button_box" invisible="not id">
<button name="action_view_visits" type="object" class="oe_stat_button" icon="fa-map-marker">
<field name="visit_count" string="Visits" widget="statinfo"/>
</button>
<button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
<field name="payment_count" string="Payments" widget="statinfo"/>
</button>
<button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
<field name="sale_order_count" string="Sale Orders" widget="statinfo"/>
</button>
<button name="action_view_stock_balances" type="object" class="oe_stat_button" icon="fa-cubes">
<field name="stock_balance_count" string="Stock Balances" widget="statinfo"/>
</button>
<button name="action_view_open_shortages" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
<field name="total_shortage_count" string="Shortages" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" placeholder="Outlet Name"/>
</h1>
</div>
<group>
<group>
<field name="code" readonly="1"/>
<field name="barcode"/>
<field name="route_country_id" required="1"/>
<field name="route_city_id" required="1" domain="[('country_id', '=', route_country_id)]" context="{'default_country_id': route_country_id}" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="area_id" string="Route Area" required="1" domain="[('city_id', '=', route_city_id)]" context="{'default_city_id': route_city_id}" options="{'no_quick_create': True, 'no_create_edit': False, 'no_open': False}"/>
<field name="route_area_name" invisible="1"/>
<field name="partner_id" domain="[('is_company', '=', True)]" context="{'default_is_company': True}" options="{'no_open': False}" required="outlet_operation_mode == 'direct_sale'"/>
<field name="outlet_operation_mode" widget="radio"/>
<field name="consignment_stock_location_mode" invisible="outlet_operation_mode != 'consignment'"/>
<field name="stock_location_id" invisible="outlet_operation_mode != 'consignment' or consignment_stock_location_mode != 'select_existing'" domain="[('usage', '=', 'internal'), ('company_id', 'in', [False, company_id])]" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="auto_stock_location_preview" readonly="1" invisible="outlet_operation_mode != 'consignment' or consignment_stock_location_mode != 'auto_create'"/>
<field name="direct_sale_pricelist_id" invisible="outlet_operation_mode != 'direct_sale'" options="{'no_open': False}"/>
<field name="active"/>
</group>
<group>
<field name="phone"/>
<field name="mobile"/>
<field name="default_commission_rate"/>
<field name="shelf_credit_limit_amount"/>
<field name="remaining_shelf_credit_amount" readonly="1"/>
<field name="active_stock_tracking"/>
</group>
</group>
<group string="Latest Activity" invisible="not id">
<group>
<field name="last_visit_id" readonly="1"/>
<field name="last_visit_date" readonly="1"/>
<field name="last_settlement_date" readonly="1"/>
</group>
<group>
<field name="last_sale_order_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
<field name="last_payment_id" readonly="1"/>
<field name="total_shortage_count" readonly="1"/>
</group>
</group>
<notebook invisible="not id">
<page string="Summary">
<group string="Summary KPIs" col="4">
<group>
<field name="summary_alert_level" widget="badge" readonly="1" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
<field name="current_due_amount" readonly="1"/>
<field name="open_shortage_count" readonly="1"/>
</group>
<group>
<field name="next_planned_visit_date" readonly="1"/>
<field name="stock_total_qty" readonly="1"/>
<field name="stock_total_value" readonly="1"/>
</group>
<group>
<field name="near_expiry_product_count" readonly="1"/>
<field name="expired_product_count" readonly="1"/>
<field name="deferred_payment_count" readonly="1"/>
<field name="refill_needed_count" readonly="1"/>
</group>
<group>
<field name="unpaid_visit_count" readonly="1"/>
<field name="open_plan_count" readonly="1"/>
<field name="stock_balance_count" readonly="1"/>
</group>
</group>
<group string="Basic Information" col="2">
<group>
<field name="partner_id" readonly="1"/>
<field name="route_country_id" readonly="1"/>
<field name="route_city_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
<field name="area_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
<field name="phone" readonly="1"/>
<field name="mobile" readonly="1"/>
<field name="commission_rate" readonly="1"/>
<field name="outlet_operation_mode" readonly="1" widget="badge" decoration-info="outlet_operation_mode == 'consignment'" decoration-warning="outlet_operation_mode == 'direct_sale'"/>
</group>
<group>
<field name="stock_location_id" readonly="1"/>
<field name="active_stock_tracking" readonly="1"/>
<field name="default_commission_rate" readonly="1"/>
<field name="shelf_credit_limit_amount" readonly="1"/>
<field name="remaining_shelf_credit_amount" readonly="1"/>
<field name="active" readonly="1"/>
</group>
</group>
<group string="Operational Summary" col="2">
<group>
<field name="last_visit_id" readonly="1"/>
<field name="last_visit_date" readonly="1"/>
<field name="in_progress_visit_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
</group>
<group>
<field name="next_route_plan_id" readonly="1"/>
<field name="next_planned_visit_date" readonly="1"/>
<field name="open_plan_count" readonly="1"/>
</group>
</group>
<group string="Financial Summary" col="2">
<group>
<field name="current_due_amount" readonly="1"/>
<field name="unpaid_visit_count" readonly="1"/>
<field name="payment_count" readonly="1"/>
</group>
<group>
<field name="last_payment_id" readonly="1"/>
<field name="last_payment_date" readonly="1"/>
<field name="last_payment_amount" readonly="1"/>
</group>
</group>
<group string="Monthly Sales Trend" col="4">
