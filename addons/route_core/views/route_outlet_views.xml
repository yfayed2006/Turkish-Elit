</group>
<group>
<field name="summary_alert_level" string="Status" readonly="1" widget="badge" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
</group>
<group>
<field name="current_due_amount" readonly="1"/>
</group>
<group>
<field name="last_visit_date" readonly="1"/>
</group>
</group>
<notebook class="route_pda_outlet_notebook">
