<group string="Outlet Summary" col="2">
<group>
<field name="code" readonly="1"/>
<field name="partner_id" string="Customer" readonly="1" options="{'no_open': True, 'no_create': True}"/>
<field name="route_city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
</group>
<group>
<field name="last_sale_order_id" readonly="1"/>
<field name="visit_count" readonly="1"/>
<field name="in_progress_visit_id" readonly="1"/>
<field name="last_payment_date" readonly="1"/>
<field name="last_return_ref" readonly="1" invisible="not last_return_ref"/>
<field name="last_transfer_ref" readonly="1" invisible="outlet_operation_mode != 'consignment' or not last_transfer_ref"/>
</group>
</group>
</page>
<page string="Details">
<group string="Outlet Details" col="2">
<group>
<field name="phone" readonly="1"/>
<field name="mobile" readonly="1"/>
</group>
<group/>
</group>
</page>
<page string="Finance">
<group string="Financial Snapshot" col="2">
<group>
<field name="payment_count" readonly="1"/>
<field name="unpaid_visit_count" readonly="1"/>
<field name="last_payment_amount" readonly="1"/>
</group>
<group>
<field name="sales_lifetime_total" readonly="1"/>
</group>
</group>
</page>
<page string="Stock" invisible="outlet_operation_mode != 'consignment'">
<group string="Consignment Stock Snapshot" col="2">
<group>
<field name="stock_balance_count" readonly="1"/>
<field name="stock_total_qty" readonly="1"/>
<field name="stock_total_value" readonly="1"/>
<field name="refill_needed_count" readonly="1"/>
</group>
<group>
<field name="zero_stock_product_count" readonly="1"/>
<field name="near_expiry_product_count" readonly="1" invisible="route_enable_lot_serial_tracking == False or route_enable_expiry_tracking == False"/>
<field name="expired_product_count" readonly="1" invisible="route_enable_lot_serial_tracking == False or route_enable_expiry_tracking == False"/>
<field name="last_stock_update_at" readonly="1"/>
</group>
</group>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_visit_payment_outlet_pda_kanban" model="ir.ui.view">
