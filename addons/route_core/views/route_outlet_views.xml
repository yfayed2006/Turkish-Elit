<odoo>
<record id="view_route_outlet_list" model="ir.ui.view">
<field name="name">route.outlet.list</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<list string="Outlets">
<field name="code"/>
<field name="barcode"/>
<field name="name"/>
<field name="area_id"/>
<field name="partner_id"/>
<field name="summary_alert_level" widget="badge" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
<field name="current_due_amount" sum="Total Due"/>
<field name="open_shortage_count" string="Open Shortages" widget="badge" decoration-warning="open_shortage_count > 0"/>
<field name="near_expiry_product_count" string="Near Expiry" widget="badge" decoration-warning="near_expiry_product_count > 0"/>
<field name="last_visit_date"/>
<field name="last_sale_order_id"/>
<field name="visit_count"/>
<field name="phone"/>
<field name="mobile"/>
<field name="active"/>
</list>
</field>
</record>
<record id="view_route_outlet_form" model="ir.ui.view">
<field name="name">route.outlet.form</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<form string="Outlet">
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_view_visits" type="object" class="oe_stat_button" icon="fa-map-marker">
<field name="visit_count" string="Visits" widget="statinfo"/>
</button>
<button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
<field name="payment_count" string="Payments" widget="statinfo"/>
</button>
<button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
<field name="sale_order_count" string="Sale Orders" widget="statinfo"/>
</button>
<button name="action_view_stock_balances" type="object" class="oe_stat_button" icon="fa-cubes">
<field name="stock_balance_count" string="Stock Balances" widget="statinfo"/>
</button>
<button name="action_view_open_shortages" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
<field name="total_shortage_count" string="Shortages" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" placeholder="Outlet Name"/>
</h1>
</div>
<group>
<group>
<field name="code" readonly="1"/>
<field name="barcode"/>
<field name="area_id"/>
<field name="partner_id" domain="[('is_company', '=', True)]" context="{'default_is_company': True}" options="{'no_open': False}"/>
<field name="active"/>
</group>
<group>
<field name="phone"/>
<field name="mobile"/>
<field name="default_commission_rate"/>
<field name="active_stock_tracking"/>
<field name="open_shortage_count" readonly="1"/>
</group>
</group>
<group string="Latest Activity">
<group>
<field name="last_visit_id" readonly="1"/>
<field name="last_visit_date" readonly="1"/>
<field name="last_settlement_date" readonly="1"/>
</group>
<group>
<field name="last_sale_order_id" readonly="1"/>
<field name="last_payment_id" readonly="1"/>
<field name="total_shortage_count" readonly="1"/>
</group>
</group>
<notebook>
<page string="Summary">
<group string="Summary KPIs" col="4">
<group>
<field name="summary_alert_level" widget="badge" readonly="1" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
<field name="current_due_amount" readonly="1"/>
<field name="open_shortage_count" readonly="1"/>
</group>
<group>
<field name="next_planned_visit_date" readonly="1"/>
<field name="stock_total_qty" readonly="1"/>
<field name="stock_total_value" readonly="1"/>
</group>
<group>
<field name="near_expiry_product_count" readonly="1"/>
<field name="expired_product_count" readonly="1"/>
<field name="deferred_payment_count" readonly="1"/>
<field name="refill_needed_count" readonly="1"/>
</group>
<group>
<field name="unpaid_visit_count" readonly="1"/>
<field name="open_plan_count" readonly="1"/>
<field name="stock_balance_count" readonly="1"/>
</group>
</group>
<group string="Basic Information" col="2">
<group>
<field name="partner_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="phone" readonly="1"/>
<field name="mobile" readonly="1"/>
<field name="commission_rate" readonly="1"/>
</group>
<group>
<field name="stock_location_id" readonly="1"/>
<field name="active_stock_tracking" readonly="1"/>
<field name="default_commission_rate" readonly="1"/>
<field name="active" readonly="1"/>
</group>
</group>
<group string="Operational Summary" col="2">
<group>
<field name="last_visit_id" readonly="1"/>
<field name="last_visit_date" readonly="1"/>
<field name="in_progress_visit_id" readonly="1"/>
</group>
<group>
<field name="next_route_plan_id" readonly="1"/>
<field name="next_planned_visit_date" readonly="1"/>
<field name="open_plan_count" readonly="1"/>
</group>
</group>
<group string="Financial Summary" col="2">
<group>
<field name="current_due_amount" readonly="1"/>
<field name="unpaid_visit_count" readonly="1"/>
<field name="payment_count" readonly="1"/>
</group>
<group>
<field name="last_payment_id" readonly="1"/>
<field name="last_payment_date" readonly="1"/>
<field name="last_payment_amount" readonly="1"/>
</group>
</group>
<group string="Monthly Sales Trend" col="4">
<group>
<field name="sales_two_months_ago_label" readonly="1"/>
<field name="sales_two_months_ago" readonly="1"/>
</group>
<group>
<field name="sales_previous_month_label" readonly="1"/>
<field name="sales_previous_month" readonly="1"/>
</group>
<group>
<field name="sales_current_month_label" readonly="1"/>
<field name="sales_current_month" readonly="1"/>
</group>
<group>
<field name="sales_last_3_months_total" readonly="1"/>
<field name="sales_last_3_months_average" readonly="1"/>
<field name="sales_trend_status" widget="badge" readonly="1" decoration-success="sales_trend_status == 'up'" decoration-warning="sales_trend_status == 'flat'" decoration-danger="sales_trend_status == 'down'"/>
</group>
</group>
<group string="Monthly Growth" col="2">
<group>
<field name="sales_previous_growth_display" readonly="1"/>
</group>
<group>
<field name="sales_growth_vs_previous_display" readonly="1"/>
</group>
</group>
<group string="Monthly Collections Trend" col="4">
<group>
<field name="sales_two_months_ago_label" readonly="1"/>
<field name="collections_two_months_ago" readonly="1"/>
<field name="collection_two_months_ago_rate_display" readonly="1"/>
</group>
<group>
<field name="sales_previous_month_label" readonly="1"/>
<field name="collections_previous_month" readonly="1"/>
<field name="collection_previous_rate_display" readonly="1"/>
</group>
<group>
<field name="sales_current_month_label" readonly="1"/>
<field name="collections_current_month" readonly="1"/>
<field name="collection_current_rate_display" readonly="1"/>
</group>
<group>
<field name="collections_last_3_months_total" readonly="1"/>
<field name="collections_last_3_months_average" readonly="1"/>
<field name="collection_status" widget="badge" readonly="1" decoration-success="collection_status == 'good'" decoration-warning="collection_status == 'warning'" decoration-danger="collection_status == 'weak'" decoration-info="collection_status == 'no_basis'"/>
</group>
</group>
<group string="Top Risk Products">
<field name="top_risk_products_html" nolabel="1" readonly="1" widget="html"/>
</group>
<group string="Stock Summary" col="2">
<group>
<field name="stock_balance_count" readonly="1"/>
<field name="stock_total_qty" readonly="1"/>
<field name="stock_total_value" readonly="1"/>
</group>
<group>
<field name="zero_stock_product_count" readonly="1"/>
<field name="near_expiry_product_count" readonly="1"/>
<field name="expired_product_count" readonly="1"/>
<field name="last_stock_update_at" readonly="1"/>
</group>
</group>
<group string="Shortages and Alerts" col="2">
<group>
<field name="open_shortage_count" readonly="1"/>
<field name="planned_shortage_count" readonly="1"/>
<field name="total_shortage_count" readonly="1"/>
</group>
<group>
<field name="last_shortage_id" readonly="1"/>
<field name="summary_alert_level" widget="badge" readonly="1" decoration-success="summary_alert_level == 'normal'" decoration-warning="summary_alert_level == 'warning'" decoration-danger="summary_alert_level == 'critical'"/>
</group>
</group>
<group string="Latest References" col="2">
<group>
<field name="last_sale_order_id" readonly="1"/>
<field name="last_payment_id" readonly="1"/>
<field name="last_shortage_id" readonly="1"/>
</group>
<group>
<field name="last_visit_id" readonly="1"/>
<field name="next_route_plan_id" readonly="1"/>
<field name="in_progress_visit_id" readonly="1"/>
</group>
</group>
<group string="Last No Sale Reason">
<field name="last_no_sale_reason" readonly="1" nolabel="1" placeholder="No no-sale reason recorded yet."/>
</group>
</page>
<page string="Address">
<group>
<group>
<field name="street"/>
<field name="street2"/>
<field name="city"/>
<field name="zip"/>
</group>
<group>
<field name="state_id"/>
<field name="country_id"/>
</group>
</group>
<group>
<field name="display_address" readonly="1"/>
</group>
</page>
<page string="Visits">
<field name="visit_ids" readonly="1">
<list>
<field name="name"/>
<field name="date"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="user_id"/>
<field name="state"/>
<field name="visit_process_state"/>
<field name="sale_order_id"/>
<field name="net_due_amount"/>
<field name="collected_amount"/>
<field name="remaining_due_amount"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" placeholder="Internal notes..."/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="action_route_outlet" model="ir.actions.act_window">
<field name="name">Outlets</field>
<field name="res_model">route.outlet</field>
<field name="view_mode">list,form</field>
</record>
<menuitem id="menu_route_outlet" name="Outlets" parent="menu_route_visit_root" action="action_route_outlet" sequence="30"/>
</odoo>
