<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_outlet_list" model="ir.ui.view">
        <field name="name">route.outlet.list</field>
        <field name="model">route.outlet</field>
        <field name="arch" type="xml">
            <list string="Outlets">
                <field name="code"/>
                <field name="name"/>
                <field name="area_id"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="mobile"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_outlet_form" model="ir.ui.view">
        <field name="name">route.outlet.form</field>
        <field name="model">route.outlet</field>
        <field name="arch" type="xml">
            <form string="Outlet">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Outlet Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="area_id"/>
                            <field name="partner_id"
                                   domain="[('is_company', '=', True)]"
                                   context="{'default_is_company': True}"
                                   options="{'no_open': False}"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="mobile"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Address">
                            <group>
                                <group>
                                    <field name="street"/>
                                    <field name="street2"/>
                                    <field name="city"/>
                                    <field name="zip"/>
                                </group>
                                <group>
                                    <field name="state_id"/>
                                    <field name="country_id"/>
                                </group>
                            </group>
                            <group>
                                <field name="display_address" readonly="1"/>
                            </group>
                        </page>

                        <page string="Notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_outlet" model="ir.actions.act_window">
        <field name="name">Outlets</field>
        <field name="res_model">route.outlet</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_route_outlet_root"
              name="Route Sales"
              sequence="60"/>

    <menuitem id="menu_route_outlet"
              name="Outlets"
              parent="menu_route_outlet_root"
              action="action_route_outlet"
              sequence="10"/>

</odoo>
