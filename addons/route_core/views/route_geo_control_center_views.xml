<odoo>
<record id="view_route_geo_control_card_search" model="ir.ui.view">
<field name="name">route.visit.geo.control.card.search</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<search string="Geo Visit Cards">
<field name="name" string="Visit"/>
<field name="outlet_id"/>
<field name="partner_id" string="Customer"/>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<separator/>
<filter name="geo_pending_checkin" string="Pending Check-in" domain="[('geo_review_state', '=', 'pending_checkin')]"/>
<filter name="geo_outlet_missing" string="Missing Outlet GPS" domain="[('geo_review_state', '=', 'outlet_missing')]"/>
<filter name="geo_inside_zone" string="Inside Zone" domain="[('geo_review_state', '=', 'inside_zone')]"/>
<filter name="geo_outside_zone" string="Outside Zone" domain="[('geo_review_state', 'in', ['outside_no_reason', 'outside_with_reason'])]"/>
<filter name="geo_needs_review" string="Needs Review" domain="[('geo_review_required', '=', True), ('geo_review_supervisor_decision', '=', False)]"/>
<filter name="geo_accepted" string="Accepted" domain="[('geo_review_supervisor_decision', '=', 'accepted')]"/>
<filter name="geo_needs_correction" string="Needs Correction" domain="[('geo_review_supervisor_decision', '=', 'needs_correction')]"/>
<separator/>
<filter name="group_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
<filter name="group_geo_state" string="Geo State" context="{'group_by': 'geo_review_state'}"/>
</search>
</field>
</record>
<record id="view_route_geo_control_visit_kanban" model="ir.ui.view">
<field name="name">route.visit.geo.control.kanban</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<kanban string="Geo Visit Cards" class="o_kanban_mobile route_geo_control_visit_kanban" create="0" delete="0" quick_create="0" default_order="date desc, geo_checkin_datetime desc, id desc">
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="visit_process_state"/>
<field name="state"/>
<field name="outlet_geo_status"/>
<field name="geo_review_state"/>
<field name="geo_review_required"/>
<field name="geo_review_supervisor_decision"/>
<field name="geo_checkin_distance_display"/>
<field name="geo_checkin_datetime"/>
<field name="geo_checkin_accuracy_m"/>
<field name="geo_checkin_outside_zone_reason"/>
<templates>
<t t-name="card">
<div class="o_kanban_record p-3">
<div class="d-flex justify-content-between align-items-start gap-2 mb-2">
<div class="min-w-0">
<strong class="d-block">
<field name="outlet_id"/>
</strong>
<span class="text-muted d-block text-nowrap">
<field name="name"/>
</span>
</div>
<div class="text-end">
<field name="geo_review_state" widget="badge"/>
<div class="mt-1">
<field name="visit_process_state" widget="badge"/>
</div>
</div>
</div>
<div class="row g-2 small mb-2">
<div class="col-6">
<span class="text-muted d-block">Salesperson</span>
<strong>
<field name="user_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Vehicle</span>
<strong>
<field name="vehicle_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Area</span>
<strong>
<field name="area_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Distance</span>
<strong>
<field name="geo_checkin_distance_display"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Check-in</span>
<strong>
<field name="geo_checkin_datetime"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Accuracy</span>
<strong>
<field name="geo_checkin_accuracy_m"/>
m
</strong>
</div>
</div>
<div class="small mb-2">
<span class="text-muted d-block">Reason</span>
<field name="geo_checkin_outside_zone_reason"/>
</div>
<div class="d-flex flex-wrap gap-1">
<button name="action_open_geo_review_visit" type="object" class="btn btn-primary btn-sm">Open Visit</button>
<button name="action_open_visit_outlet_map" type="object" class="btn btn-secondary btn-sm">Outlet Map</button>
<button name="action_open_visit_checkin_map" type="object" class="btn btn-secondary btn-sm">Check-in Map</button>
<button name="action_geo_review_accept" type="object" class="btn btn-success btn-sm">Accept</button>
<button name="action_geo_review_needs_correction" type="object" class="btn btn-warning btn-sm">Needs Correction</button>
<button name="action_geo_review_reset_decision" type="object" class="btn btn-light btn-sm">Reset</button>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_geo_control_center_form" model="ir.ui.view">
<field name="name">route.geo.control.center.form</field>
<field name="model">route.geo.control.center</field>
<field name="arch" type="xml">
<form string="Geo Control Center" create="0" delete="0">
<header>
<button name="action_refresh_dashboard" type="object" string="Refresh" icon="fa-refresh"/>
<button name="action_open_filtered_visits" type="object" string="Open Cards" class="btn-primary" icon="fa-th-large"/>
<button name="action_open_geo_review" type="object" string="Review Cards" icon="fa-list"/>
</header>
<sheet>
<field name="name" invisible="1"/>
<div class="oe_title">
<h2>Daily Geo Control</h2>
<p class="text-muted">Today's geo check-ins, supervisor review, and map actions.</p>
</div>
<div class="oe_button_box" name="button_box">
<button name="action_open_total_visits" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
<field name="total_visit_count" widget="statinfo" string="Today"/>
</button>
<button name="action_open_active_visits" type="object" class="oe_stat_button" icon="fa-play-circle">
<field name="active_visit_count" widget="statinfo" string="Active"/>
</button>
<button name="action_open_done_visits" type="object" class="oe_stat_button" icon="fa-check-circle">
<field name="done_visit_count" widget="statinfo" string="Done"/>
</button>
<button name="action_open_pending_checkin_visits" type="object" class="oe_stat_button" icon="fa-map-o">
<field name="pending_checkin_count" widget="statinfo" string="No Check-in"/>
</button>
<button name="action_open_outlet_missing_visits" type="object" class="oe_stat_button" icon="fa-map-marker">
<field name="outlet_missing_count" widget="statinfo" string="No Outlet GPS"/>
</button>
<button name="action_open_inside_zone_visits" type="object" class="oe_stat_button" icon="fa-bullseye">
<field name="inside_zone_count" widget="statinfo" string="Inside"/>
</button>
<button name="action_open_outside_zone_visits" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
<field name="outside_zone_count" widget="statinfo" string="Outside"/>
</button>
<button name="action_open_needs_review_visits" type="object" class="oe_stat_button" icon="fa-user-md">
<field name="needs_review_count" widget="statinfo" string="Review"/>
</button>
<button name="action_open_accepted_visits" type="object" class="oe_stat_button" icon="fa-thumbs-up">
<field name="accepted_count" widget="statinfo" string="Accepted"/>
</button>
<button name="action_open_needs_correction_visits" type="object" class="oe_stat_button" icon="fa-edit">
<field name="needs_correction_count" widget="statinfo" string="Correction"/>
</button>
</div>
<group string="Filters" col="4">
<group>
<field name="company_id" readonly="1"/>
<field name="visit_date"/>
<field name="visit_process_filter"/>
</group>
<group>
<field name="geo_review_filter"/>
<field name="salesperson_id"/>
<field name="vehicle_id"/>
</group>
<group>
<field name="area_id"/>
<field name="outlet_id"/>
<field name="filtered_visit_count" readonly="1"/>
</group>
</group>
<separator string="Today Geo Visit Cards"/>
<field name="geo_visit_ids" nolabel="1" readonly="1" mode="kanban" context="{'create': 0, 'edit': 0, 'delete': 0}">
<kanban string="Filtered Geo Visits" class="o_kanban_mobile route_geo_control_embedded_kanban" create="0" delete="0" quick_create="0" default_order="date desc, geo_checkin_datetime desc, id desc">
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="visit_process_state"/>
<field name="outlet_geo_status"/>
<field name="geo_review_state"/>
<field name="geo_review_required"/>
<field name="geo_review_supervisor_decision"/>
<field name="geo_checkin_distance_display"/>
<field name="geo_checkin_datetime"/>
<field name="geo_checkin_accuracy_m"/>
<field name="geo_checkin_outside_zone_reason"/>
<templates>
<t t-name="card">
<div class="o_kanban_record p-3">
<div class="d-flex justify-content-between align-items-start gap-2 mb-2">
<div class="min-w-0">
<strong class="d-block">
<field name="outlet_id"/>
</strong>
<span class="text-muted d-block text-nowrap">
<field name="name"/>
</span>
</div>
<div class="text-end">
<field name="geo_review_state" widget="badge"/>
<div class="mt-1">
<field name="visit_process_state" widget="badge"/>
</div>
</div>
</div>
<div class="row g-2 small mb-2">
<div class="col-6">
<span class="text-muted d-block">Salesperson</span>
<strong>
<field name="user_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Vehicle</span>
<strong>
<field name="vehicle_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Area</span>
<strong>
<field name="area_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Distance</span>
<strong>
<field name="geo_checkin_distance_display"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Check-in</span>
<strong>
<field name="geo_checkin_datetime"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Accuracy</span>
<strong>
<field name="geo_checkin_accuracy_m"/>
m
</strong>
</div>
</div>
<div class="small mb-2">
<span class="text-muted d-block">Reason</span>
<field name="geo_checkin_outside_zone_reason"/>
</div>
<div class="d-flex flex-wrap gap-1">
<button name="action_open_geo_review_visit" type="object" class="btn btn-primary btn-sm">Open Visit</button>
<button name="action_open_visit_outlet_map" type="object" class="btn btn-secondary btn-sm">Outlet Map</button>
<button name="action_open_visit_checkin_map" type="object" class="btn btn-secondary btn-sm">Check-in Map</button>
<button name="action_geo_review_accept" type="object" class="btn btn-success btn-sm">Accept</button>
<button name="action_geo_review_needs_correction" type="object" class="btn btn-warning btn-sm">Needs Correction</button>
<button name="action_geo_review_reset_decision" type="object" class="btn btn-light btn-sm">Reset</button>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</sheet>
</form>
</field>
</record>
<record id="server_action_open_route_geo_control_center" model="ir.actions.server">
<field name="name">Geo Control Center</field>
<field name="model_id" ref="route_core.model_route_geo_control_center"/>
<field name="state">code</field>
<field name="code">action = env["route.geo.control.center"].action_open_geo_control_center()</field>
</record>
<menuitem id="menu_route_geo_control_center" name="Geo Control Center" parent="route_core.menu_route_control_workspace" action="route_core.server_action_open_route_geo_control_center" sequence="11" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</odoo>
