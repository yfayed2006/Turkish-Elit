<odoo>
<record id="view_route_geo_control_card_search" model="ir.ui.view">
<field name="name">route.visit.geo.control.card.search</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<search string="Visit Location Cards">
<field name="name" string="Visit"/>
<field name="outlet_id"/>
<field name="partner_id" string="Customer"/>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<separator/>
<filter name="geo_pending_checkin" string="Pending Check-in" domain="[('geo_review_state', '=', 'pending_checkin')]"/>
<filter name="geo_outlet_missing" string="Missing Outlet Location" domain="[('geo_review_state', '=', 'outlet_missing')]"/>
<filter name="geo_inside_zone" string="Inside Zone" domain="[('geo_review_state', '=', 'inside_zone')]"/>
<filter name="geo_outside_zone" string="Outside Zone" domain="[('geo_review_state', 'in', ['outside_no_reason', 'outside_with_reason'])]"/>
<filter name="geo_needs_review" string="Needs Review" domain="[('geo_review_required', '=', True), ('geo_review_supervisor_decision', '=', False)]"/>
<filter name="geo_accepted" string="Accepted" domain="[('geo_review_supervisor_decision', '=', 'accepted')]"/>
<filter name="geo_needs_correction" string="Needs Correction" domain="[('geo_review_supervisor_decision', '=', 'needs_correction')]"/>
<separator/>
<filter name="group_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
<filter name="group_geo_state" string="Location Status" context="{'group_by': 'geo_review_state'}"/>
</search>
</field>
</record>
<record id="view_route_geo_control_visit_kanban" model="ir.ui.view">
<field name="name">route.visit.geo.control.kanban</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<kanban string="Visit Location Cards" class="o_kanban_mobile route_geo_control_visit_kanban" create="0" delete="0" quick_create="0" default_order="date desc, geo_checkin_datetime desc, id desc">
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="visit_process_state"/>
<field name="state"/>
<field name="outlet_geo_status"/>
<field name="geo_review_state"/>
<field name="geo_review_required"/>
<field name="geo_review_supervisor_decision"/>
<field name="geo_checkin_distance_display"/>
<field name="geo_checkin_datetime"/>
<field name="geo_checkin_accuracy_m"/>
<field name="geo_checkin_outside_zone_reason"/>
<templates>
<t t-name="card">
<div class="o_kanban_record p-3">
<div class="d-flex justify-content-between align-items-start gap-2 mb-2">
<div class="min-w-0">
<strong class="d-block">
<field name="outlet_id"/>
</strong>
<span class="text-muted d-block text-nowrap">
<field name="name"/>
</span>
</div>
<div class="text-end d-flex flex-column align-items-end gap-1">
<t t-if="record.visit_process_state.raw_value == 'done'">
<span class="badge rounded-pill bg-success text-white">Done</span>
</t>
<t t-elif="record.visit_process_state.raw_value and record.visit_process_state.raw_value != 'draft' and record.visit_process_state.raw_value != 'cancel'">
<span class="badge rounded-pill bg-warning text-dark">
<field name="visit_process_state"/>
</span>
</t>
<t t-elif="record.visit_process_state.raw_value == 'cancel'">
<span class="badge rounded-pill bg-secondary text-white">Cancelled</span>
</t>
<t t-else="">
<span class="badge rounded-pill bg-info text-dark">Draft</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'pending_checkin'">
<span class="badge rounded-pill bg-primary text-white">Pending Check-in</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outlet_missing'">
<span class="badge rounded-pill bg-light text-dark border">Outlet Location Missing</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'inside_zone'">
<span class="badge rounded-pill bg-success text-white">Inside Zone</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outside_no_reason'">
<span class="badge rounded-pill bg-danger text-white">Outside Zone</span>
<span class="badge rounded-pill bg-warning text-dark">Reason Missing</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outside_with_reason'">
<span class="badge rounded-pill bg-danger text-white">Outside Zone</span>
<span class="badge rounded-pill bg-light text-dark border">Reason Recorded</span>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value == 'accepted'">
<span class="badge rounded-pill bg-success text-white">Accepted</span>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value == 'needs_correction'">
<span class="badge rounded-pill bg-warning text-dark">Needs Correction</span>
</t>
</div>
</div>
<div class="row g-2 small mb-2">
<div class="col-6">
<span class="text-muted d-block">Salesperson</span>
<strong>
<field name="user_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Vehicle</span>
<strong>
<field name="vehicle_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Area</span>
<strong>
<field name="area_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Distance</span>
<strong>
<field name="geo_checkin_distance_display"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Check-in</span>
<strong>
<field name="geo_checkin_datetime"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted d-block">Accuracy</span>
<strong>
<field name="geo_checkin_accuracy_m"/>
m
</strong>
</div>
</div>
<div class="small mb-2">
<span class="text-muted d-block">Reason</span>
<field name="geo_checkin_outside_zone_reason"/>
</div>
<div class="d-flex flex-wrap gap-1">
<button name="action_open_geo_review_visit" type="object" class="btn btn-primary btn-sm px-2 py-1">Open Visit</button>
<button name="action_open_visit_outlet_map" type="object" class="btn btn-secondary btn-sm px-2 py-1">Outlet Map</button>
<button name="action_open_visit_checkin_map" type="object" class="btn btn-secondary btn-sm px-2 py-1">Check-in Map</button>
<t t-if="record.geo_review_supervisor_decision.raw_value != 'accepted'">
<button name="action_geo_review_accept" type="object" class="btn btn-success btn-sm px-2 py-1">Accept</button>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value != 'needs_correction'">
<button name="action_geo_review_needs_correction" type="object" class="btn btn-warning btn-sm px-2 py-1">Needs Correction</button>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value">
<button name="action_geo_review_reset_decision" type="object" class="btn btn-outline-secondary btn-sm px-2 py-1">Reset</button>
</t>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
