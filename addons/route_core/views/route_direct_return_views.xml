<odoo>
<record id="view_route_direct_return_pda_list" model="ir.ui.view">
<field name="name">route.direct.return.pda.list</field>
<field name="model">route.direct.return</field>
<field name="arch" type="xml">
<list string="Direct Returns" create="0" delete="0" edit="0">
<field name="name"/>
<field name="return_date"/>
<field name="outlet_id"/>
<field name="vehicle_id"/>
<field name="sale_order_id"/>
<field name="visit_id" optional="hide"/>
<field name="state"/>
<field name="picking_count"/>
</list>
</field>
</record>
<record id="view_route_direct_return_pda_kanban" model="ir.ui.view">
<field name="name">route.direct.return.pda.kanban</field>
<field name="model">route.direct.return</field>
<field name="arch" type="xml">
<kanban class="route_pda_payment_kanban" create="0" edit="0" delete="0">
<field name="name"/>
<field name="return_date"/>
<field name="amount_total"/>
<field name="state"/>
<field name="picking_count"/>
<field name="sale_order_id"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_payment_card">
<div class="route_pda_payment_head">
<div class="route_pda_payment_title">
<field name="name"/>
</div>
<div class="route_pda_payment_date">
<field name="return_date"/>
</div>
</div>
<div class="route_pda_payment_badges">
<span class="route_pda_payment_badge">
<t t-esc="record.state.value or ''"/>
</span>
<span class="route_pda_payment_badge" t-if="record.sale_order_id.value">
<t t-esc="record.sale_order_id.value"/>
</span>
</div>
<div class="route_pda_payment_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Estimated Value</span>
<span class="route_pda_payment_metric_value">
<field name="amount_total"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Pickings</span>
<span class="route_pda_payment_metric_value">
<field name="picking_count"/>
</span>
</div>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_direct_return_pda_search" model="ir.ui.view">
<field name="name">route.direct.return.pda.search</field>
<field name="model">route.direct.return</field>
<field name="arch" type="xml">
<search string="Direct Returns">
<field name="name" string="Reference"/>
<field name="return_date"/>
<field name="outlet_id"/>
<field name="sale_order_id"/>
<field name="state"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<separator/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
</search>
</field>
</record>
<record id="view_route_direct_return_line_form_mobile" model="ir.ui.view">
<field name="name">route.direct.return.line.form.mobile</field>
<field name="model">route.direct.return.line</field>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<form string="Add Return Product">
<sheet class="route_mobile_compact_sheet route_mobile_sale_order_line_sheet">
<field name="return_id" invisible="1"/>
<field name="company_id" invisible="1"/>
<field name="route_enable_lot_serial_tracking" invisible="1"/>
<field name="route_enable_expiry_tracking" invisible="1"/>
<field name="available_lot_ids" invisible="1"/>
<field name="route_product_image_128" invisible="1"/>
<div class="route_mobile_product_image_preview" invisible="not product_id">
<field name="route_product_image_128" widget="image" readonly="1" nolabel="1" class="route_mobile_product_popup_image"/>
</div>
<div class="route_mobile_summary_grid">
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Barcode / Scan</div>
<div class="route_mobile_info_value">
<field name="route_product_barcode" placeholder="Scan or type barcode"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Product</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="product_id" domain="[('sale_ok', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Quantity</div>
<div class="route_mobile_info_value">
<field name="quantity"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">UoM</div>
<div class="route_mobile_info_value">
<field name="uom_id" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Unit Price</div>
<div class="route_mobile_info_value">
<field name="estimated_unit_price" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Discount (%)</div>
<div class="route_mobile_info_value">
<field name="reference_discount" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Amount</div>
<div class="route_mobile_info_value">
<field name="estimated_amount" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Taxes</div>
<div class="route_mobile_info_value">
<field name="route_reference_tax_ids" widget="many2many_tags" readonly="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not product_id or product_id.tracking == 'none'">
<div class="route_mobile_detail_label">Lot / Serial</div>
<div class="route_mobile_detail_value">
<field name="lot_id" domain="[('id', 'in', available_lot_ids)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not product_id or product_id.tracking == 'none'">
<div class="route_mobile_detail_label">Manual Lot / Serial</div>
<div class="route_mobile_detail_value">
<field name="lot_name"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not route_enable_expiry_tracking">
<div class="route_mobile_detail_label">Expiry Date</div>
<div class="route_mobile_detail_value">
<field name="expiry_date"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Return Reason</div>
<div class="route_mobile_detail_value">
<field name="return_reason"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Destination</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="destination_location_id" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Line Note</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="note"/>
</div>
</div>
</sheet>
</form>
</field>
</record>
<record id="view_route_direct_return_form" model="ir.ui.view">
<field name="name">route.direct.return.form</field>
<field name="model">route.direct.return</field>
<field name="arch" type="xml">
<form string="Create Direct Return" create="0" delete="0" class="route_mobile_direct_return_form">
<header>
<button name="action_route_direct_return_back_to_visit" type="object" string="Back to Visit" class="btn-secondary" invisible="not visit_id"/>
<button name="action_back_to_outlet_form" type="object" string="Back to Outlet" class="btn-secondary" invisible="visit_id or (not outlet_id and not context.get('route_outlet_back_id'))"/>
<button name="action_create_pickings" type="object" string="Create Return Pickings" class="btn-primary" invisible="state != 'draft' or route_enable_direct_return == False"/>
<button name="action_view_pickings" type="object" string="View Pickings" class="btn-secondary" invisible="picking_count == 0"/>
<field name="state" widget="statusbar" statusbar_visible="draft,done,cancel"/>
</header>
<sheet class="route_mobile_compact_sheet route_mobile_direct_return_sheet">
<field name="route_enable_lot_serial_tracking" invisible="1"/>
<field name="route_enable_expiry_tracking" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="currency_id" invisible="1"/>
<field name="route_reference_product_ids" invisible="1"/>
<field name="visit_id" invisible="1"/>
<div class="route_mobile_header_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<div class="route_mobile_summary_grid route_mobile_sale_order_top_grid">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Return Date</div>
<div class="route_mobile_info_value">
<field name="return_date" readonly="state != 'draft'"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Outlet</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="outlet_id" domain="[('outlet_operation_mode', '=', 'direct_sale'), ('active', '=', True)]" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Pricelist</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="pricelist_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Customer</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="partner_id" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Salesperson</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="user_id" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Vehicle</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="vehicle_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Reference Sale Order</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="sale_order_id" readonly="state != 'draft'" domain="[('route_order_mode', '=', 'direct_sale'), ('route_outlet_id', '=', outlet_id)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Reference Delivery</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="reference_picking_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_return_total_card">
<div class="route_mobile_info_label">Estimated Return Value</div>
<div class="route_mobile_info_value">
<field name="amount_total" readonly="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box route_mobile_detail_box_subtle">
<div class="route_mobile_detail_label">Notes</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="note" placeholder="Return notes..." readonly="state != 'draft'"/>
</div>
</div>
<div class="route_mobile_section_header route_mobile_product_header">
<div class="route_mobile_section_title">Return Lines</div>
<div class="route_mobile_product_toolbar">
<button name="action_route_direct_return_add_product" type="object" string="Add / Scan Product" class="btn-primary route_mobile_product_action" invisible="state != 'draft' or route_enable_direct_return == False"/>
</div>
</div>
<field name="line_ids" nolabel="1" readonly="state != 'draft'" class="route_mobile_direct_return_lines_field">
<list editable="bottom" string="Return Lines" create="1" delete="1" class="route_mobile_return_line_list">
<field name="route_product_image_128" string="Image" widget="image" readonly="1" optional="show" class="route_mobile_product_image_cell"/>
<field name="product_id" string="Product" domain="[('sale_ok', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
<field name="route_product_barcode" string="Barcode" optional="show"/>
<field name="quantity" string="Qty"/>
<field name="uom_id" string="UoM" options="{'no_create': True, 'no_open': True}"/>
<field name="available_lot_ids" column_invisible="1"/>
<field name="lot_id" string="Lot/Serial" domain="[('id', 'in', available_lot_ids)]" options="{'no_create': True, 'no_open': True}" column_invisible="parent.route_enable_lot_serial_tracking == False" optional="show"/>
<field name="lot_name" string="Manual Lot/Serial" column_invisible="parent.route_enable_lot_serial_tracking == False" optional="hide"/>
<field name="expiry_date" string="Expiry" column_invisible="parent.route_enable_lot_serial_tracking == False or parent.route_enable_expiry_tracking == False" optional="show"/>
<field name="return_reason" string="Reason"/>
<field name="destination_location_id" string="Destination" optional="hide"/>
<field name="estimated_unit_price" string="Unit Price" readonly="1"/>
<field name="reference_discount" string="Disc. %" readonly="1" optional="show"/>
<field name="route_reference_tax_ids" string="Taxes" widget="many2many_tags" readonly="1" optional="hide"/>
<field name="estimated_amount" string="Amount" readonly="1"/>
</list>
<form string="Return Product">
<sheet class="route_mobile_compact_sheet route_mobile_sale_order_line_sheet">
<field name="return_id" invisible="1"/>
<field name="company_id" invisible="1"/>
<field name="route_enable_lot_serial_tracking" invisible="1"/>
<field name="route_enable_expiry_tracking" invisible="1"/>
<field name="available_lot_ids" invisible="1"/>
<field name="route_product_image_128" invisible="1"/>
<div class="route_mobile_product_image_preview" invisible="not product_id">
<field name="route_product_image_128" widget="image" readonly="1" nolabel="1" class="route_mobile_product_popup_image"/>
</div>
<div class="route_mobile_summary_grid">
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Barcode / Scan</div>
<div class="route_mobile_info_value">
<field name="route_product_barcode" placeholder="Scan or type barcode"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Product</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="product_id" domain="[('sale_ok', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Quantity</div>
<div class="route_mobile_info_value">
<field name="quantity"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">UoM</div>
<div class="route_mobile_info_value">
<field name="uom_id" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Unit Price</div>
<div class="route_mobile_info_value">
<field name="estimated_unit_price" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Discount (%)</div>
<div class="route_mobile_info_value">
<field name="reference_discount" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Amount</div>
<div class="route_mobile_info_value">
<field name="estimated_amount" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Taxes</div>
<div class="route_mobile_info_value">
<field name="route_reference_tax_ids" widget="many2many_tags" readonly="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not product_id or product_id.tracking == 'none'">
<div class="route_mobile_detail_label">Lot / Serial</div>
<div class="route_mobile_detail_value">
<field name="lot_id" domain="[('id', 'in', available_lot_ids)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not product_id or product_id.tracking == 'none'">
<div class="route_mobile_detail_label">Manual Lot / Serial</div>
<div class="route_mobile_detail_value">
<field name="lot_name"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not route_enable_lot_serial_tracking or not route_enable_expiry_tracking">
<div class="route_mobile_detail_label">Expiry Date</div>
<div class="route_mobile_detail_value">
<field name="expiry_date"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Return Reason</div>
<div class="route_mobile_detail_value">
<field name="return_reason"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Destination</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="destination_location_id" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Line Note</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="note"/>
</div>
</div>
</sheet>
</form>
</field>
</sheet>
</form>
</field>
</record>
<record id="action_route_direct_return" model="ir.actions.act_window">
<field name="name">Direct Returns</field>
<field name="res_model">route.direct.return</field>
<field name="view_mode">kanban,list,form</field>
<field name="search_view_id" ref="view_route_direct_return_pda_search"/>
<field name="views" eval="[(ref('route_core.view_route_direct_return_pda_kanban'), 'kanban'), (ref('route_core.view_route_direct_return_pda_list'), 'list'), (ref('route_core.view_route_direct_return_form'), 'form')]"/>
<field name="context">{}</field>
</record>
<record id="view_stock_picking_form_direct_return_price" model="ir.ui.view">
<field name="name">stock.picking.form.direct.return.price</field>
<field name="model">stock.picking</field>
<field name="inherit_id" ref="stock.view_picking_form"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='move_ids_without_package']//field[@name='product_id'] | //field[@name='move_ids']//field[@name='product_id']" position="after">
<field name="route_product_barcode" string="Barcode" optional="show"/>
<field name="route_direct_return_unit_price" string="Unit Price" optional="show" column_invisible="parent.picking_type_code == 'internal'"/>
<field name="route_direct_return_estimated_amount" string="Amount" optional="show" column_invisible="parent.picking_type_code == 'internal'"/>
</xpath>
</field>
</record>
</odoo>
