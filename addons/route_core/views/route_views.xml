<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_route_list" model="ir.ui.view">
        <field name="name">route.route.list</field>
        <field name="model">route.route</field>
        <field name="arch" type="xml">
            <list string="Routes">
                <field name="code"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="visit_day"/>
                <field name="store_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_route_form" model="ir.ui.view">
        <field name="name">route.route.form</field>
        <field name="model">route.route</field>
        <field name="arch" type="xml">
            <form string="Route">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code" readonly="1"/>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="visit_day"/>
                            <field name="store_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Stores">
                            <field name="line_ids" context="{'default_route_id': id}">
                                <list editable="bottom">
                                    <field name="route_id" column_invisible="1"/>
                                    <field name="sequence"/>
                                    <field name="store_id"/>
                                    <field name="store_code" readonly="1"/>
                                    <field name="customer_id" readonly="1"/>
                                    <field name="phone" readonly="1"/>
                                    <field name="city" readonly="1"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_route" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">route.route</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_route_route"
              name="Routes"
              parent="menu_route_core_root"
              action="action_route_route"
              sequence="10"/>

</odoo>
