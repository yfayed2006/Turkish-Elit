<odoo>
<record id="view_route_vehicle_closing_dashboard_kanban" model="ir.ui.view">
<field name="name">route.vehicle.closing.dashboard.kanban</field>
<field name="model">route.vehicle.closing</field>
<field name="arch" type="xml">
<kanban string="Vehicle Issue Cards" class="o_kanban_mobile route_dashboard_drill_kanban" create="0" delete="0" quick_create="0" default_order="plan_date desc, id desc">
<field name="name"/>
<field name="plan_id"/>
<field name="plan_date"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="state"/>
<field name="pending_variance_line_count"/>
<field name="pending_execution_line_count"/>
<field name="total_abs_variance_qty"/>
<field name="reconciliation_picking_count"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_dashboard_drill_card">
<div class="route_dashboard_drill_card_head">
<div>
<strong>
<field name="name"/>
</strong>
<span>
<field name="plan_id"/>
</span>
</div>
<span t-attf-class="route_dashboard_drill_badge route_dashboard_drill_state_#{record.state.raw_value or 'draft'}">
<t t-esc="record.state.value or ''"/>
</span>
</div>
<div class="route_dashboard_drill_card_body">
<div>
<span>Plan Date</span>
<b>
<field name="plan_date"/>
</b>
</div>
<div>
<span>Vehicle</span>
<b>
<field name="vehicle_id"/>
</b>
</div>
<div>
<span>Salesperson</span>
<b>
<field name="user_id"/>
</b>
</div>
<div>
<span>Variance Qty</span>
<b>
<field name="total_abs_variance_qty"/>
</b>
</div>
<div>
<span>Pending Variance</span>
<b>
<field name="pending_variance_line_count"/>
</b>
</div>
<div>
<span>Pending Execution</span>
<b>
<field name="pending_execution_line_count"/>
</b>
</div>
</div>
<div class="route_dashboard_drill_card_foot">
<span>Reconciliation Transfers</span>
<b>
<field name="reconciliation_picking_count"/>
</b>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
