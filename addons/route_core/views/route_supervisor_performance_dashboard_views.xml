<odoo>
<record id="view_route_supervisor_performance_dashboard_form" model="ir.ui.view">
<field name="name">route.supervisor.performance.dashboard.form</field>
<field name="model">route.supervisor.performance.dashboard</field>
<field name="arch" type="xml">
<form string="Supervisor Performance Dashboard" create="0" delete="0" class="route_supervisor_performance_dashboard_form">
<header>
<button name="action_refresh_dashboard" type="object" string="Refresh" icon="fa-refresh"/>
<button name="action_open_daily_closing" type="object" string="Daily Closing" icon="fa-lock" class="btn-primary"/>
<button name="action_open_visits" type="object" string="Visits" icon="fa-calendar-check-o"/>
<button name="action_open_unfinished_visits" type="object" string="Unfinished" icon="fa-exclamation-circle"/>
<button name="action_open_collections" type="object" string="Collections" icon="fa-money"/>
<button name="action_open_promises" type="object" string="Promises" icon="fa-calendar-o"/>
<button name="action_open_sales_orders" type="object" string="Sales Orders" icon="fa-shopping-cart" invisible="not show_direct_sale_sections"/>
<button name="action_open_returns" type="object" string="Returns" icon="fa-undo" invisible="not show_direct_return_sections"/>
<button name="action_open_location_review" type="object" string="Location Review" icon="fa-map-marker" invisible="not show_location_sections"/>
<button name="action_open_vehicle_issues" type="object" string="Vehicle Issues" icon="fa-truck" invisible="not show_vehicle_closing_sections"/>
<button name="action_open_closing_records" type="object" string="Closing Records" icon="fa-folder-open-o"/>
</header>
<sheet>
<div class="oe_title mb-2">
<span class="text-muted small">Supervisor Performance Dashboard</span>
<h1 class="mb-1">Performance Command Center</h1>
<p class="text-muted mb-0">Visual KPIs and charts for visits, collections, products, profit, promises, vehicles, and daily closing health.</p>
</div>
<h4 class="mt-2 mb-2">Dashboard Filters</h4>
<div class="row g-2 mb-3 route_dashboard_filter_cards">
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Period</span>
<field name="period_filter" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">From</span>
<field name="date_from" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">To</span>
<field name="date_to" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Salesperson</span>
<field name="salesperson_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Vehicle</span>
<field name="vehicle_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">City</span>
<field name="city_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Area</span>
<field name="area_id" nolabel="1" domain="[('city_id', '=', city_id)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Outlet</span>
<field name="outlet_id" nolabel="1" domain="[('active', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Company</span>
<field name="company_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
</div>
<field name="currency_id" invisible="1"/>
<field name="show_direct_sale_sections" invisible="1"/>
<field name="show_consignment_sections" invisible="1"/>
<field name="show_outlet_comparison_sections" invisible="1"/>
<field name="show_direct_return_sections" invisible="1"/>
<field name="show_location_sections" invisible="1"/>
<field name="show_vehicle_closing_sections" invisible="1"/>
<field name="show_loading_sections" invisible="1"/>
<field name="show_stock_transfer_sections" invisible="1"/>
<field name="show_lot_expiry_sections" invisible="1"/>
<field name="dashboard_operation_mode_label" invisible="1"/>
<field name="filtered_visit_count" invisible="1"/>
<field name="completed_visit_count" invisible="1"/>
<field name="collection_amount" invisible="1"/>
<field name="net_sales_amount" invisible="1"/>
<field name="open_promise_amount" invisible="1"/>
<field name="gross_profit_amount" invisible="1"/>
<field name="executive_html" nolabel="1" readonly="1" widget="html"/>
<field name="visit_chart_html" nolabel="1" readonly="1" widget="html"/>
<field name="collection_chart_html" nolabel="1" readonly="1" widget="html"/>
<field name="product_chart_html" nolabel="1" readonly="1" widget="html"/>
<field name="outlet_chart_html" nolabel="1" readonly="1" widget="html"/>
<field name="ranking_html" nolabel="1" readonly="1" widget="html"/>
</sheet>
</form>
</field>
</record>
<record id="server_action_open_route_supervisor_performance_dashboard" model="ir.actions.server">
<field name="name">Supervisor Performance Dashboard</field>
<field name="model_id" ref="route_core.model_route_supervisor_performance_dashboard"/>
<field name="state">code</field>
<field name="code">action = env["route.supervisor.performance.dashboard"].action_open_performance_dashboard()</field>
</record>
<menuitem id="menu_route_supervisor_performance_dashboard" name="Supervisor Performance Dashboard" parent="route_core.menu_route_control_workspace" action="route_core.server_action_open_route_supervisor_performance_dashboard" sequence="4" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</odoo>
