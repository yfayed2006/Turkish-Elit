<odoo>
<data>
<record id="view_route_schedule_template_list" model="ir.ui.view">
<field name="name">route.schedule.template.list</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<list>
<field name="name" string="Template Name"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="source_warehouse_id" optional="show"/>
<field name="city_summary" string="Cities" optional="show"/>
<field name="area_summary" string="Areas" optional="show"/>
<field name="outlet_summary" string="Outlets"/>
<field name="line_count" string="Stops"/>
<field name="schedule_count" string="Generated Weeks"/>
<field name="active" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_schedule_template_form" model="ir.ui.view">
<field name="name">route.schedule.template.form</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<form string="Weekly Visit Template">
<header>
<button name="action_create_current_week_schedule" type="object" string="Activate This Week" class="btn-primary" invisible="not id"/>
<button name="action_create_next_week_schedule" type="object" string="Activate Next Week" class="btn-secondary" invisible="not id"/>
<button name="action_view_weekly_schedules" type="object" string="Open Weekly Schedules" class="btn-secondary" invisible="not id"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_view_weekly_schedules" type="object" class="oe_stat_button" icon="fa-calendar" invisible="not id">
<field name="schedule_count" string="Generated Weeks" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" placeholder="Weekly Visit Template Name"/>
</h1>
<div class="mt8">
<field name="active" widget="boolean_toggle"/>
</div>
</div>
<div class="alert alert-info" role="alert"> This screen is for creating a reusable weekly visit template. After saving it, create a dated weekly schedule from it, then generate daily route plans. </div>
<div class="alert alert-warning" role="alert" invisible="off_day_stop_count == 0">
<strong>Weekly Off Day Review:</strong>
<field name="off_day_stop_count" class="oe_inline" readonly="1"/>
stop(s) are scheduled on
<field name="off_day" class="oe_inline" readonly="1"/>
and will need supervisor review before operational use.
</div>
<group string="Template Information" col="2">
<group>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="source_warehouse_id" options="{'no_create': True}"/>
</group>
<group>
<field name="company_id" readonly="1"/>
<field name="off_day" readonly="1"/>
<field name="off_day_stop_count" readonly="1"/>
<field name="city_summary" readonly="1"/>
<field name="area_summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<separator string="Weekly Visit Stops"/>
<div class="alert alert-info" role="alert"> Use this screen to build one reusable weekly template. Add outlets under each weekday tab. Select City first, then Area, then Outlet. </div>
<notebook>
<page string="Monday">
<field name="monday_line_ids" context="{'default_weekday': 'monday'}" domain="[('weekday', '=', 'monday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Tuesday">
<field name="tuesday_line_ids" context="{'default_weekday': 'tuesday'}" domain="[('weekday', '=', 'tuesday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Wednesday">
<field name="wednesday_line_ids" context="{'default_weekday': 'wednesday'}" domain="[('weekday', '=', 'wednesday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Thursday">
<field name="thursday_line_ids" context="{'default_weekday': 'thursday'}" domain="[('weekday', '=', 'thursday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Friday">
<field name="friday_line_ids" context="{'default_weekday': 'friday'}" domain="[('weekday', '=', 'friday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Saturday">
<field name="saturday_line_ids" context="{'default_weekday': 'saturday'}" domain="[('weekday', '=', 'saturday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Sunday">
<field name="sunday_line_ids" context="{'default_weekday': 'sunday'}" domain="[('weekday', '=', 'sunday')]">
<list editable="bottom" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="weekday" column_invisible="1" force_save="1"/>
<field name="city_id"/>
<field name="same_day_used_outlet_ids" column_invisible="1"/>
<field name="available_outlet_ids" column_invisible="1"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id), ('id', 'not in', same_day_used_outlet_ids)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
</notebook>
<group string="Notes">
<field name="notes" placeholder="Supervisor planning notes..."/>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_schedule_template_search" model="ir.ui.view">
<field name="name">route.schedule.template.search</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<search>
<field name="name" string="Template Name"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="city_summary" string="Cities"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_schedule_template" model="ir.actions.act_window">
<field name="name">Weekly Visit Templates</field>
<field name="res_model">route.schedule.template</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_schedule_template_search"/>
<field name="context">{'search_default_filter_active': 1}</field>
</record>
</data>
</
