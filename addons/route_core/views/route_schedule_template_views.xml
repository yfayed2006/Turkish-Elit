<odoo>
<data>
<record id="view_route_schedule_template_list" model="ir.ui.view">
<field name="name">route.schedule.template.list</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<list string="Weekly Visit Templates">
<field name="name" string="Template"/>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="source_warehouse_id" string="Source Warehouse" optional="hide"/>
<field name="line_count" string="Stops"/>
<field name="schedule_count" string="Schedules"/>
<field name="city_summary" string="Cities" optional="hide"/>
<field name="area_summary" string="Areas" optional="hide"/>
<field name="outlet_summary" string="Planned Outlets" optional="hide"/>
<field name="active" string="Active" optional="show"/>
</list>
</field>
</record>
<record id="view_route_schedule_template_form" model="ir.ui.view">
<field name="name">route.schedule.template.form</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<form string="Weekly Visit Template">
<header>
<button name="action_create_current_week_schedule" type="object" string="Create This Week Schedule" class="btn-primary" invisible="not id" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_create_next_week_schedule" type="object" string="Create Next Week Schedule" class="btn-secondary" invisible="not id" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_view_weekly_schedules" type="object" string="Open Weekly Schedules" class="btn-secondary" invisible="not id" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box" invisible="not id">
<button name="action_view_weekly_schedules" type="object" class="oe_stat_button" icon="fa-calendar" groups="route_core.group_route_supervisor,route_core.group_route_management">
<field name="schedule_count" string="Schedules" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" placeholder="Weekly Template Name"/>
</h1>
<div class="mt8">
<field name="active" widget="boolean_toggle"/>
</div>
</div>
<div class="alert alert-info" role="alert" invisible="id">Complete the template name, salesperson, vehicle, and source warehouse, then save to add weekly stops.</div>
<div class="alert alert-info" role="alert" invisible="not id">Build reusable weekly stops here, then create this week or next week schedule when ready.</div>
<div class="alert alert-warning" role="alert" invisible="not id or off_day_stop_count == 0">
<strong>Weekly Off Day Review:</strong>
<field name="off_day_stop_count" class="oe_inline" readonly="1"/>
stop(s) are scheduled on
<field name="off_day" class="oe_inline" readonly="1"/>
and will need supervisor review before operational use.
</div>
<group string="Template Information" col="2">
<group>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="source_warehouse_id" options="{'no_create': True}"/>
</group>
<group>
<field name="company_id" readonly="1"/>
<field name="off_day" readonly="1"/>
<field name="off_day_stop_count" readonly="1" invisible="not id"/>
<field name="city_summary" readonly="1" invisible="not id"/>
<field name="area_summary" readonly="1" invisible="not id"/>
<field name="outlet_summary" readonly="1" invisible="not id"/>
</group>
</group>
<div class="route_mobile_summary_grid" invisible="not id">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Template Stops</div>
<div class="route_mobile_info_value">
<field name="line_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Generated Weeks</div>
<div class="route_mobile_info_value">
<field name="schedule_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Off-Day Stops</div>
<div class="route_mobile_info_value">
<field name="off_day_stop_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not city_summary">
<div class="route_mobile_detail_label">Cities</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="city_summary" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not area_summary">
<div class="route_mobile_detail_label">Areas</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="area_summary" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not outlet_summary">
<div class="route_mobile_detail_label">Planned Outlets</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="outlet_summary" readonly="1" nolabel="1"/>
</div>
</div>
<separator string="Weekly Stops" invisible="not id"/>
<div class="alert alert-info" role="alert" invisible="not id">Use Add Stop under each weekday to open the stop popup. Select City, Area, then Outlets.</div>
<notebook invisible="not id">
<page string="Monday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'monday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="monday_line_ids" context="{'default_weekday': 'monday'}" domain="[('weekday', '=', 'monday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Tuesday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'tuesday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="tuesday_line_ids" context="{'default_weekday': 'tuesday'}" domain="[('weekday', '=', 'tuesday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Wednesday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'wednesday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="wednesday_line_ids" context="{'default_weekday': 'wednesday'}" domain="[('weekday', '=', 'wednesday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Thursday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'thursday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="thursday_line_ids" context="{'default_weekday': 'thursday'}" domain="[('weekday', '=', 'thursday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Friday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'friday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="friday_line_ids" context="{'default_weekday': 'friday'}" domain="[('weekday', '=', 'friday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Saturday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'saturday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="saturday_line_ids" context="{'default_weekday': 'saturday'}" domain="[('weekday', '=', 'saturday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Sunday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add Stop" class="btn-primary" context="{'default_weekday': 'sunday'}" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="sunday_line_ids" context="{'default_weekday': 'sunday'}" domain="[('weekday', '=', 'sunday')]" invisible="not id">
<list create="0" delete="1" decoration-warning="is_off_day">
<field name="is_off_day" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
</notebook>
<group string="Notes">
<field name="notes" placeholder="Supervisor planning notes..."/>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_schedule_template_search" model="ir.ui.view">
<field name="name">route.schedule.template.search</field>
<field name="model">route.schedule.template</field>
<field name="arch" type="xml">
<search>
<field name="name" string="Template Name"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="city_summary" string="Cities"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_schedule_template" model="ir.actions.act_window">
<field name="name">Weekly Visit Templates</field>
<field name="res_model">route.schedule.template</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_schedule_template_search"/>
<field name="context">{'search_default_filter_active': 1}</field>
</record>
</data>
</odoo>
