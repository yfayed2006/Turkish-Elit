<odoo>
<record id="view_route_plan_form_role_security" model="ir.ui.view">
<field name="name">route.plan.form.role.security</field>
<field name="model">route.plan</field>
<field name="inherit_id" ref="route_core.view_route_plan_form"/>
<field name="arch" type="xml">
<xpath expr="//button[@name='action_open_pending_visit_review_wizard']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_finalize_daily_plan']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_reopen_daily_plan']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_generate_loading_proposal']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_view_loading_proposal']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_open_vehicle_stock_snapshot']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//field[@name='loading_proposal_state']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//field[@name='loading_proposal_count']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_view_loading_proposal' and hasclass('oe_stat_button')]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_open_pending_visit_review_wizard' and hasclass('oe_stat_button')]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_open_add_area_outlets_wizard']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_load_previous_pending_visits']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_reopen_line']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_shortage_form_role_security" model="ir.ui.view">
<field name="name">route.shortage.form.role.security</field>
<field name="model">route.shortage</field>
<field name="inherit_id" ref="route_core.view_route_shortage_form"/>
<field name="arch" type="xml">
<xpath expr="//button[@name='action_mark_planned']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_mark_done']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_reopen']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_cancel']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_salesperson_shortage_form_role_security" model="ir.ui.view">
<field name="name">route.salesperson.shortage.form.role.security</field>
<field name="model">route.salesperson.shortage</field>
<field name="inherit_id" ref="route_core.view_route_salesperson_shortage_form"/>
<field name="arch" type="xml">
<xpath expr="//button[@name='action_start_review']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_finalize_settlement']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_sync_deduction_record']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_open_deduction_record']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_reopen']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_outlet_form_role_security" model="ir.ui.view">
<field name="name">route.outlet.form.role.security</field>
<field name="model">route.outlet</field>
<field name="inherit_id" ref="route_core.view_route_outlet_form"/>
<field name="arch" type="xml">
<xpath expr="//button[@name='action_recompute_summary']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_outlet_diagnostics']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_visit_form_role_security" model="ir.ui.view">
<field name="name">route.visit.form.role.security</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//button[@name='action_recompute_visit_health']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//button[@name='action_visit_diagnostics']" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_visit_form_supervisor_review_polish" model="ir.ui.view">
<field name="name">route.visit.form.supervisor.review.polish</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//page[field[@name='notes']]" position="before">
<page string="Supervisor Review" groups="route_core.group_route_supervisor,route_core.group_route_management">
<div class="alert alert-info" role="alert"> Use this tab for fast supervision follow-up. Open the operational tabs only when you need line-level investigation. </div>
<div class="route_mobile_summary_grid" invisible="visit_execution_mode == 'direct_sales'">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Previous Due</div>
<div class="route_mobile_info_value">
<field name="consignment_previous_due_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Current Visit Sale</div>
<div class="route_mobile_info_value">
<field name="consignment_current_visit_sale_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Current Visit Returns</div>
<div class="route_mobile_info_value">
<field name="consignment_current_visit_return_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Amount Due Now</div>
<div class="route_mobile_info_value">
<field name="consignment_amount_due_now" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Collected</div>
<div class="route_mobile_info_value">
<field name="collected_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Immediate Remaining</div>
<div class="route_mobile_info_value">
<field name="consignment_immediate_remaining_amount" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_mobile_summary_grid" invisible="visit_execution_mode != 'direct_sales'">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Previous Due</div>
<div class="route_mobile_info_value">
<field name="direct_stop_previous_due_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Current Visit Sale</div>
<div class="route_mobile_info_value">
<field name="direct_stop_sales_total" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Current Visit Returns</div>
<div class="route_mobile_info_value">
<field name="direct_stop_returns_total" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Amount Due Now</div>
<div class="route_mobile_info_value">
<field name="direct_stop_grand_due_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Collected</div>
<div class="route_mobile_info_value">
<field name="direct_stop_settlement_paid_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Immediate Remaining</div>
<div class="route_mobile_info_value">
<field name="direct_stop_immediate_remaining_amount" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_grid">
<div class="route_mobile_detail_box" invisible="visit_execution_mode == 'direct_sales' or not summary_sale_order_ref">
<div class="route_mobile_detail_label">Sale Order</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="summary_sale_order_ref" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="visit_execution_mode == 'direct_sales' or not summary_refill_transfer_ref">
<div class="route_mobile_detail_label">Refill Transfer</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="summary_refill_transfer_ref" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="visit_execution_mode == 'direct_sales' or not summary_return_transfer_refs or summary_return_transfer_refs == '-'">
<div class="route_mobile_detail_label">Return Transfers</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="summary_return_transfer_refs" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="visit_execution_mode != 'direct_sales' or not direct_stop_order_refs or direct_stop_order_refs == '-'">
<div class="route_mobile_detail_label">Sale Order</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="direct_stop_order_refs" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="visit_execution_mode != 'direct_sales' or not direct_stop_return_refs or direct_stop_return_refs == '-'">
<div class="route_mobile_detail_label">Return</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="direct_stop_return_refs" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Visit Process State</div>
<div class="route_mobile_detail_value">
<field name="visit_process_state" readonly="1" nolabel="1" widget="badge" decoration-info="visit_process_state in ('checked_in', 'counting', 'reconciled')" decoration-warning="visit_process_state == 'collection_done'" decoration-success="visit_process_state in ('ready_to_close', 'done')"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Current Step</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="ux_stage_title" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not notes">
<div class="route_mobile_detail_label">Internal Notes</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="notes" readonly="1" nolabel="1"/>
</div>
</div>
</page>
</xpath>
</field>
</record>
</odoo>
