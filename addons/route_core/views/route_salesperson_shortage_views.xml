<odoo>
<record id="view_route_salesperson_shortage_tree" model="ir.ui.view">
<field name="name">route.salesperson.shortage.tree</field>
<field name="model">route.salesperson.shortage</field>
<field name="arch" type="xml">
<list string="Salesperson Shortage Ledgers">
<field name="name"/>
<field name="month_date"/>
<field name="salesperson_id"/>
<field name="state" widget="badge" decoration-info="state == 'open'" decoration-warning="state == 'under_review'" decoration-success="state == 'settled'"/>
<field name="line_count"/>
<field name="pending_line_count"/>
<field name="finalized_line_count"/>
<field name="total_shortage_qty"/>
<field name="total_shortage_amount"/>
<field name="pending_amount" optional="show"/>
<field name="finalized_amount" optional="show"/>
</list>
</field>
</record>
<record id="view_route_salesperson_shortage_form" model="ir.ui.view">
<field name="name">route.salesperson.shortage.form</field>
<field name="model">route.salesperson.shortage</field>
<field name="arch" type="xml">
<form string="Salesperson Shortage Ledger" create="0" delete="0">
<header>
<button name="action_start_review" type="object" string="Start Review" class="btn-primary" invisible="state != 'open'"/>
<button name="action_finalize_settlement" type="object" string="Finalize Month" class="btn-primary" invisible="state != 'under_review'"/>
<button name="action_sync_deduction_record" type="object" string="Sync Deduction Record" class="btn-secondary" invisible="state != 'settled'"/>
<button name="action_open_deduction_record" type="object" string="Open Deduction Record" class="btn-secondary" invisible="state != 'settled' or deduction_line_count == 0"/>
<button name="%(action_report_route_salesperson_monthly_statement)d" type="action" string="Print Monthly Statement" class="btn-secondary" invisible="state == 'open'"/>
<button name="action_reopen" type="object" string="Reopen" class="btn-secondary" invisible="state != 'settled'"/>
<field name="state" widget="statusbar" statusbar_visible="open,under_review,settled" nolabel="1"/>
</header>
<sheet>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<group string="Ledger Information" col="4">
<group>
<field name="month_date" readonly="1"/>
<field name="salesperson_id" readonly="1"/>
<field name="company_id" readonly="1"/>
</group>
<group>
<field name="settled_on" readonly="1" invisible="not settled_on"/>
<field name="settled_by_id" readonly="1" invisible="not settled_by_id"/>
</group>
</group>
<separator string="Monthly Summary"/>
<group col="4">
<group string="Lines">
<field name="line_count" readonly="1"/>
<field name="pending_line_count" readonly="1"/>
<field name="finalized_line_count" readonly="1"/>
</group>
<group string="Settlement">
<field name="deduction_line_count" readonly="1"/>
<field name="settled_line_count" readonly="1"/>
<field name="waived_line_count" readonly="1"/>
</group>
<group string="Amounts">
<field name="total_shortage_qty" readonly="1"/>
<field name="total_shortage_amount" readonly="1"/>
<field name="pending_amount" readonly="1"/>
<field name="finalized_amount" readonly="1"/>
<field name="deduction_amount" readonly="1"/>
<field name="admin_settled_amount" readonly="1"/>
<field name="waived_amount" readonly="1"/>
</group>
</group>
<notebook>
<page string="Shortage Lines">
<field name="line_ids" nolabel="1">
<list create="0" delete="0" editable="bottom">
<field name="shortage_date" readonly="1"/>
<field name="vehicle_id" readonly="1" optional="show"/>
<field name="product_id" readonly="1"/>
<field name="lot_id" readonly="1" optional="show"/>
<field name="shortage_qty" readonly="1"/>
<field name="unit_price" readonly="1" optional="show"/>
<field name="shortage_amount" readonly="1"/>
<field name="variance_reason" readonly="1" optional="show"/>
<field name="reconciliation_action" readonly="1" optional="show"/>
<field name="settlement_decision" readonly="parent.state == 'settled' or is_finalized"/>
<field name="settlement_status" readonly="1" widget="badge" decoration-info="settlement_status == 'pending'" decoration-success="settlement_status in ('deduct','settled','waived')"/>
<field name="execution_status" readonly="1" widget="badge" decoration-info="execution_status in ('pending','deduction_draft')" decoration-warning="execution_status == 'deduction_approved'" decoration-success="execution_status in ('deducted','admin_settled','waived')"/>
<field name="settlement_note" readonly="parent.state == 'settled' or is_finalized" optional="show"/>
<field name="closing_id" readonly="1" optional="show"/>
<field name="deduction_record_id" readonly="1" optional="show"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" placeholder="Internal notes for the monthly shortage settlement..." readonly="state == 'settled'"/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_salesperson_shortage_search" model="ir.ui.view">
<field name="name">route.salesperson.shortage.search</field>
<field name="model">route.salesperson.shortage</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="month_date"/>
<field name="salesperson_id"/>
<field name="state"/>
<filter name="filter_open" string="Open" domain="[('state', '=', 'open')]"/>
<filter name="filter_under_review" string="Under Review" domain="[('state', '=', 'under_review')]"/>
<filter name="filter_settled" string="Settled" domain="[('state', '=', 'settled')]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_month" string="Month" context="{'group_by': 'month_date'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
</search>
</field>
</record>
<record id="view_route_salesperson_shortage_line_tree" model="ir.ui.view">
<field name="name">route.salesperson.shortage.line.tree</field>
<field name="model">route.salesperson.shortage.line</field>
<field name="arch" type="xml">
<list string="Salesperson Shortage Lines" create="0" delete="0">
<field name="ledger_id"/>
<field name="shortage_date"/>
<field name="salesperson_id"/>
<field name="vehicle_id" optional="show"/>
<field name="product_id"/>
<field name="lot_id" optional="show"/>
<field name="shortage_qty"/>
<field name="shortage_amount"/>
<field name="settlement_decision" optional="show"/>
<field name="settlement_status" widget="badge" decoration-info="settlement_status == 'pending'" decoration-success="settlement_status in ('deduct','settled','waived')"/>
<field name="execution_status" widget="badge" decoration-info="execution_status in ('pending','deduction_draft')" decoration-warning="execution_status == 'deduction_approved'" decoration-success="execution_status in ('deducted','admin_settled','waived')"/>
<field name="closing_id" optional="show"/>
</list>
</field>
</record>
<record id="action_route_salesperson_shortage" model="ir.actions.act_window">
<field name="name">Salesperson Shortages</field>
<field name="res_model">route.salesperson.shortage</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_salesperson_shortage_search"/>
</record>
<record id="action_route_salesperson_shortage_line" model="ir.actions.act_window">
<field name="name">Salesperson Shortage Lines</field>
<field name="res_model">route.salesperson.shortage.line</field>
<field name="view_mode">list,form</field>
</record>
<menuitem id="menu_route_salesperson_shortage" name="Salesperson Shortages" parent="menu_route_visit_root" action="action_route_salesperson_shortage" sequence="27"/>
</odoo>
