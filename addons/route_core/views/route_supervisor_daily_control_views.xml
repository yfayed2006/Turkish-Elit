<span class="text-muted small d-block">Due</span>
<strong>
<field name="net_due_amount" widget="monetary"/>
</strong>
</div>
<div class="col-4">
<span class="text-muted small d-block">Collected</span>
<strong>
<field name="collected_amount" widget="monetary"/>
</strong>
</div>
<div class="col-4">
<span class="text-muted small d-block">Open</span>
<strong>
<field name="remaining_due_amount" widget="monetary"/>
</strong>
</div>
</div>
<t t-if="record.promise_to_pay_count.raw_value">
<div class="mb-2">
<span class="badge rounded-pill text-bg-light border">
Open Promise:
<field name="promise_to_pay_count"/>
</span>
<t t-if="record.latest_promise_status.raw_value">
<span class="badge rounded-pill text-bg-light border">
<field name="latest_promise_status"/>
</span>
</t>
</div>
</t>
<div class="d-flex flex-wrap gap-1 mt-2 route-supervisor-daily-card-actions">
<button name="action_open_geo_review_visit" type="object" class="btn btn-primary btn-sm px-2 py-1">Open Visit</button>
<button name="action_open_visit_outlet_map" type="object" class="btn btn-light btn-sm px-2 py-1">Outlet Map</button>
<button name="action_open_visit_checkin_map" type="object" class="btn btn-light btn-sm px-2 py-1">Check-in Map</button>
<button name="action_open_statement_of_account" type="object" class="btn btn-light btn-sm px-2 py-1">Statement</button>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
