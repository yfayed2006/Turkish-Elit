<odoo>
<record id="view_route_supervisor_daily_visit_search" model="ir.ui.view">
<field name="name">route.visit.supervisor.daily.search</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<search string="Daily Visits">
<field name="name"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<filter name="filter_not_started" string="Not Started" domain="[('visit_process_state', '=', 'draft')]"/>
<filter name="filter_active" string="Active" domain="[('visit_process_state', 'not in', ['draft', 'done', 'cancel'])]"/>
<filter name="filter_done" string="Done" domain="[('visit_process_state', '=', 'done')]"/>
<separator/>
<filter name="filter_location_attention" string="Location Attention" domain="['|','|',('geo_review_state', 'in', ['pending_checkin', 'outlet_missing', 'outside_no_reason', 'outside_with_reason']),('geo_review_required', '=', True),('geo_review_supervisor_decision', '=', 'needs_correction')]"/>
<filter name="filter_open_due" string="Open Due" domain="[]"/>
<separator/>
<filter name="group_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_status" string="Visit Status" context="{'group_by': 'visit_process_state'}"/>
</search>
</field>
</record>
<record id="view_route_supervisor_daily_visit_kanban" model="ir.ui.view">
<field name="name">route.visit.supervisor.daily.kanban</field>
<field name="model">route.visit</field>
<field name="arch" type="xml">
<kanban string="Daily Visit Cards" class="o_kanban_mobile route_supervisor_daily_visit_kanban" create="0" delete="0" quick_create="0" default_order="date desc, start_datetime desc, id desc">
<field name="name"/>
<field name="date"/>
<field name="currency_id"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<field name="visit_process_state"/>
<field name="geo_review_state"/>
<field name="geo_review_required"/>
<field name="geo_review_supervisor_decision"/>
<field name="geo_checkin_distance_display"/>
<field name="collected_amount"/>
<field name="remaining_due_amount"/>
<field name="net_due_amount"/>
<field name="promise_to_pay_count"/>
<field name="latest_promise_status"/>
<templates>
<t t-name="card">
<div class="kanban-box p-3 border rounded bg-white shadow-sm route-supervisor-daily-card">
<div class="d-flex justify-content-between gap-2 align-items-start mb-2">
<div class="min-w-0">
<strong class="d-block fs-5 text-truncate">
<field name="outlet_id"/>
</strong>
<span class="text-muted d-block">
<field name="name"/>
</span>
</div>
<div class="text-end d-flex flex-column gap-1 align-items-end">
<t t-if="record.visit_process_state.raw_value == 'draft'">
<span class="badge rounded-pill text-bg-secondary">Not Started</span>
</t>
<t t-if="record.visit_process_state.raw_value != 'draft' and record.visit_process_state.raw_value != 'done' and record.visit_process_state.raw_value != 'cancel'">
<span class="badge rounded-pill text-bg-primary">Active</span>
</t>
<t t-if="record.visit_process_state.raw_value == 'done'">
<span class="badge rounded-pill text-bg-success">Done</span>
</t>
<t t-if="record.visit_process_state.raw_value == 'cancel'">
<span class="badge rounded-pill text-bg-danger">Cancelled</span>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value == 'accepted'">
<span class="badge rounded-pill text-bg-success">Location Accepted</span>
</t>
<t t-if="record.geo_review_supervisor_decision.raw_value == 'needs_correction'">
<span class="badge rounded-pill text-bg-warning">Location Correction</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'pending_checkin'">
<span class="badge rounded-pill text-bg-info">No Check-in</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outlet_missing'">
<span class="badge rounded-pill text-bg-secondary">No Outlet Location</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outside_no_reason'">
<span class="badge rounded-pill text-bg-warning">Outside - No Reason</span>
</t>
<t t-if="record.geo_review_state.raw_value == 'outside_with_reason'">
<span class="badge rounded-pill text-bg-warning">Outside - Reason</span>
</t>
</div>
</div>
<div class="row g-2 mb-2">
<div class="col-6">
<span class="text-muted small d-block">Salesperson</span>
<strong>
<field name="user_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted small d-block">Vehicle</span>
<strong>
<field name="vehicle_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted small d-block">Area</span>
<strong>
<field name="area_id"/>
</strong>
</div>
<div class="col-6">
<span class="text-muted small d-block">Distance</span>
<strong>
<field name="geo_checkin_distance_display"/>
</strong>
</div>
</div>
<div class="row g-2 mb-2">
