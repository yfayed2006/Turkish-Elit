<odoo>
<record id="view_route_supervisor_assignment_tree" model="ir.ui.view">
<field name="name">route.supervisor.assignment.tree</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<list string="Supervisor Assignments">
<field name="sequence" widget="handle"/>
<field name="name"/>
<field name="supervisor_user_id"/>
<field name="salesperson_ids" widget="many2many_tags" optional="show"/>
<field name="vehicle_ids" widget="many2many_tags" optional="show"/>
<field name="area_ids" widget="many2many_tags" optional="show"/>
<field name="city_ids" widget="many2many_tags" optional="show"/>
<field name="country_ids" widget="many2many_tags" optional="show"/>
<field name="scope_label" string="Scope" optional="show"/>
<field name="active"/>
</list>
</field>
</record>
<record id="view_route_supervisor_assignment_search" model="ir.ui.view">
<field name="name">route.supervisor.assignment.search</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<search string="Supervisor Assignments">
<field name="name"/>
<field name="supervisor_user_id"/>
<field name="salesperson_ids"/>
<field name="vehicle_ids"/>
<field name="area_ids"/>
<field name="city_ids"/>
<field name="country_ids"/>
<filter name="active" string="Active" domain="[('active','=',True)]"/>
<group expand="0" string="Group By">
<filter string="Supervisor" context="{'group_by': 'supervisor_user_id'}"/>
<filter string="Company" context="{'group_by': 'company_id'}"/>
</group>
</search>
</field>
</record>
<record id="view_route_supervisor_assignment_form" model="ir.ui.view">
<field name="name">route.supervisor.assignment.form</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<form string="Supervisor Assignment">
<sheet>
<group col="2">
<group>
<field name="name"/>
<field name="active"/>
<field name="sequence"/>
<field name="company_id"/>
<field name="supervisor_user_id" options="{'no_open': False}"/>
<field name="supervisor_mobile" readonly="1"/>
<field name="supervisor_phone" readonly="1"/>
</group>
<group string="Assignment Scope">
<field name="salesperson_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
<field name="vehicle_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
<field name="area_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
<field name="city_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
<field name="country_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
<field name="scope_label" readonly="1" string="Scope"/>
</group>
</group>
<group>
<field name="note" placeholder="Example: Seeb and Muscat teams report to this supervisor on WhatsApp."/>
</group>
<group string="Matching Priority" col="1">
<div>
<p>Salespersons → Vehicles → Areas → Cities → Countries → Default fallback.</p>
<p class="text-muted">Leave fields empty when the rule should apply more broadly. Selecting an area automatically covers all outlets inside that area.</p>
</div>
</group>
</sheet>
</form>
</field>
</record>
<record id="action_route_supervisor_assignment" model="ir.actions.act_window">
<field name="name">Supervisor Assignments</field>
<field name="res_model">route.supervisor.assignment</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_supervisor_assignment_search"/>
<field name="context">{'search_default_active': 1}</field>
</record>
<menuitem id="menu_route_supervisor_assignment" name="Supervisor Assignments" parent="route_core.menu_route_configuration" action="route_core.action_route_supervisor_assignment" sequence="35" groups="route_core.group_route_management,route_core.group_route_supervisor"/>
</odoo>
