<odoo>
<record id="view_route_supervisor_assignment_tree" model="ir.ui.view">
<field name="name">route.supervisor.assignment.tree</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<list string="Supervisor Assignments" default_order="sequence asc, id asc">
<field name="sequence" widget="handle"/>
<field name="name"/>
<field name="supervisor_user_id"/>
<field name="salesperson_id" optional="show"/>
<field name="vehicle_id" optional="show"/>
<field name="area_id" optional="show"/>
<field name="city_id" optional="show"/>
<field name="country_id" optional="show"/>
<field name="scope_label" optional="show"/>
<field name="active"/>
</list>
</field>
</record>
<record id="view_route_supervisor_assignment_form" model="ir.ui.view">
<field name="name">route.supervisor.assignment.form</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<form string="Supervisor Assignment">
<sheet>
<group>
<group>
<field name="active"/>
<field name="sequence"/>
<field name="company_id"/>
<field name="supervisor_user_id"/>
<field name="supervisor_mobile" readonly="1"/>
<field name="supervisor_phone" readonly="1"/>
</group>
<group>
<field name="salesperson_id"/>
<field name="vehicle_id"/>
<field name="country_id"/>
<field name="city_id" options="{'no_create_edit': False}"/>
<field name="area_id" options="{'no_create_edit': False}"/>
<field name="scope_label" readonly="1"/>
</group>
</group>
<group>
<field name="notes" placeholder="Optional notes about this assignment rule..."/>
</group>
<group>
<label string="Matching priority:"/>
<div>
<p>Salesperson → Vehicle → Area → City → Country → Default fallback.</p>
<p>Leave fields empty when the rule should apply more broadly.</p>
</div>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_supervisor_assignment_search" model="ir.ui.view">
<field name="name">route.supervisor.assignment.search</field>
<field name="model">route.supervisor.assignment</field>
<field name="arch" type="xml">
<search string="Search Supervisor Assignments">
<field name="name"/>
<field name="supervisor_user_id"/>
<field name="salesperson_id"/>
<field name="vehicle_id"/>
<field name="country_id"/>
<field name="city_id"/>
<field name="area_id"/>
<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
<filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
<separator/>
<filter name="group_by_supervisor" string="Supervisor" context="{'group_by': 'supervisor_user_id'}"/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_country" string="Country" context="{'group_by': 'country_id'}"/>
<filter name="group_by_city" string="City" context="{'group_by': 'city_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
</search>
</field>
</record>
<record id="action_route_supervisor_assignment" model="ir.actions.act_window">
<field name="name">Supervisor Assignments</field>
<field name="res_model">route.supervisor.assignment</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_supervisor_assignment_search"/>
<field name="context">{'search_default_filter_active': 1}</field>
</record>
<menuitem id="menu_route_supervisor_assignment" name="Supervisor Assignments" parent="route_core.menu_route_configuration" action="action_route_supervisor_assignment" sequence="35" groups="route_core.group_route_management"/>
</odoo>
