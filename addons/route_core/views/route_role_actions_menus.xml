<odoo>
<!--  Root visibility by role  -->
<record id="menu_route_visit_root" model="ir.ui.menu">
<field name="group_ids" eval="[(6, 0, [ref('route_core.group_route_salesperson'), ref('route_core.group_route_supervisor'), ref('route_core.group_route_management')])]"/>
</record>
<!--  Supervisor / Management workspace grouping  -->
<menuitem id="menu_route_operations_workspace" name="Operations" parent="route_core.menu_route_visit_root" sequence="20" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<menuitem id="menu_route_control_workspace" name="Review & Control" parent="route_core.menu_route_visit_root" sequence="30" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<menuitem id="menu_route_management_workspace" name="Management Setup" parent="route_core.menu_route_visit_root" sequence="80" groups="route_core.group_route_management"/>
