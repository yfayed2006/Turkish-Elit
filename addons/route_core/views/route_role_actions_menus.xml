<!--         Salesperson-safe menu actions         -->
<record id="action_route_plan_salesperson" model="ir.actions.act_window">
<field name="name">My Daily Plans</field>
<field name="res_model">route.plan</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_plan_search"/>
<field name="domain">[("user_id", "=", uid)]</field>
<field name="context">{'search_default_filter_my_plans': 1, 'search_default_filter_today': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
<record id="action_route_visit_pda_salesperson" model="ir.actions.act_window">
<field name="name">Today's Visits</field>
<field name="res_model">route.visit</field>
<field name="view_mode">kanban,form,list</field>
<field name="search_view_id" ref="route_core.view_route_visit_search"/>
<field name="domain">[("user_id", "=", uid), ("date", "=", context_today()), ("state", "not in", ["done", "cancel", "cancelled"])]</field>
<field name="context">{'search_default_filter_my_visits': 1, 'search_default_filter_today': 1, 'search_default_filter_active': 1, 'create': 0, 'edit': 1, 'delete': 0}</field>
</record>
<record id="action_route_visit_history_salesperson" model="ir.actions.act_window">
<field name="name">My Visit History</field>
<field name="res_model">route.visit</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_visit_search"/>
<field name="domain">[("user_id", "=", uid), ("state", "in", ["done", "cancel", "cancelled"])]</field>
<field name="context">{'search_default_filter_my_visits': 1, 'search_default_filter_done': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">Review your completed and closed visits here.</p>
</field>
</record>
<record id="action_route_vehicle_closing_salesperson" model="ir.actions.act_window">
<field name="name">My Vehicle Closings</field>
<field name="res_model">route.vehicle.closing</field>
<field name="view_mode">list,form</field>
<field name="view_id" ref="route_core.view_route_vehicle_closing_salesperson_list"/>
<field name="search_view_id" ref="route_core.view_route_vehicle_closing_search"/>
<field name="domain">[("user_id", "=", uid), ("state", "=", "closed")]</field>
<field name="context">{'search_default_filter_closed': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
<record id="action_route_visit_collection_salesperson" model="ir.actions.act_window">
<field name="name">My Visit Collections</field>
<field name="res_model">route.visit.payment</field>
<field name="view_mode">kanban,list,form</field>
<field name="view_id" ref="route_core.view_route_visit_collection_kanban"/>
<field name="search_view_id" ref="route_core.view_route_visit_collection_search"/>
<field name="domain">[("salesperson_id", "=", uid), ("state", "=", "confirmed")]</field>
<field name="context">{'search_default_filter_my_payments': 1, 'search_default_filter_confirmed': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
<menuitem id="menu_route_salesperson_home" name="Route Workspace" parent="route_core.menu_route_visit_root" action="route_core.server_action_open_route_pda_home" sequence="190" groups="route_core.group_route_salesperson"/>
