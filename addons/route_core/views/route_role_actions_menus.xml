<!--  Salesperson actions  -->
<record id="action_route_plan_salesperson" model="ir.actions.act_window">
<field name="name">My Route Plans</field>
<field name="res_model">route.plan</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_plan_search"/>
<field name="domain">[('user_id', '=', uid)]</field>
<field name="context">{'search_default_filter_my_plans': 1, 'search_default_filter_today': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
<record id="action_route_visit_pda_salesperson" model="ir.actions.act_window">
<field name="name">My PDA Visits</field>
<field name="res_model">route.visit</field>
<field name="view_mode">kanban,form,list</field>
<field name="search_view_id" ref="route_core.view_route_visit_search"/>
<field name="domain">[('user_id', '=', uid)]</field>
<field name="context">{'search_default_filter_my_visits': 1, 'search_default_filter_today': 1, 'create': 0, 'edit': 1, 'delete': 0, 'pda_mode': True}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">Open your route visits in PDA mode.</p>
</field>
</record>
<record id="action_route_visit_pda_salesperson_kanban_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">kanban</field>
<field name="view_id" ref="route_core.view_route_visit_pda_kanban"/>
<field name="act_window_id" ref="route_core.action_route_visit_pda_salesperson"/>
</record>
<record id="action_route_visit_pda_salesperson_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_visit_pda_form"/>
<field name="act_window_id" ref="route_core.action_route_visit_pda_salesperson"/>
</record>
<record id="action_route_visit_pda_salesperson_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="3"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_visit_tree"/>
<field name="act_window_id" ref="route_core.action_route_visit_pda_salesperson"/>
</record>
