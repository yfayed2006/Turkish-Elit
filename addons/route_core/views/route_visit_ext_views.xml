<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_route_visit_form_ext_route_sales" model="ir.ui.view">
        <field name="name">route.visit.form.ext.route.sales</field>
        <field name="model">route.visit</field>
        <field name="inherit_id" ref="route_core.view_route_visit_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Visit Process">
                    <group>
                        <field name="visit_process_state"/>
                        <field name="commission_rate"/>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="check_in_datetime"/>
                        <field name="count_start_datetime"/>
                        <field name="count_end_datetime"/>
                        <field name="reconciliation_datetime"/>
                        <field name="collection_datetime"/>
                        <field name="refill_datetime"/>
                        <field name="check_out_datetime"/>
                    </group>
                </group>

                <notebook>
                    <page string="Visit Lines">
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="product_id"/>
                                <field name="barcode" readonly="1"/>
                                <field name="previous_qty"/>
                                <field name="counted_qty"/>
                                <field name="return_qty"/>
                                <field name="sold_qty" readonly="1"/>
                                <field name="supplied_qty"/>
                                <field name="new_balance_qty" readonly="1"/>
                                <field name="unit_price"/>
                                <field name="sold_amount" readonly="1"/>
                                <field name="note"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Payments">
                        <field name="payment_ids">
                            <tree editable="bottom">
                                <field name="payment_date"/>
                                <field name="payment_mode"/>
                                <field name="amount"/>
                                <field name="reference"/>
                                <field name="bank_name"/>
                                <field name="pos_terminal"/>
                                <field name="state"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Summary">
                        <group string="Quantity Summary">
                            <group>
                                <field name="previous_total_qty" readonly="1"/>
                                <field name="counted_total_qty" readonly="1"/>
                                <field name="returned_total_qty" readonly="1"/>
                            </group>
                            <group>
                                <field name="sold_total_qty" readonly="1"/>
                                <field name="supplied_total_qty" readonly="1"/>
                                <field name="new_balance_total_qty" readonly="1"/>
                            </group>
                        </group>

                        <group string="Financial Summary">
                            <group>
                                <field name="previous_stock_value" readonly="1"/>
                                <field name="counted_stock_value" readonly="1"/>
                                <field name="gross_sales_amount" readonly="1"/>
                                <field name="return_amount" readonly="1"/>
                            </group>
                            <group>
                                <field name="commission_amount" readonly="1"/>
                                <field name="net_due_amount" readonly="1"/>
                                <field name="collected_amount" readonly="1"/>
                                <field name="remaining_due_amount" readonly="1"/>
                                <field name="supplied_value" readonly="1"/>
                                <field name="new_balance_value" readonly="1"/>
                            </group>
                        </group>

                        <group string="Flags">
                            <group>
                                <field name="has_collection" readonly="1"/>
                                <field name="has_returns" readonly="1"/>
                            </group>
                            <group>
                                <field name="has_refill" readonly="1"/>
                                <field name="is_ready_to_close" readonly="1"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_set_checked_in" string="Check In" type="object" class="btn-primary"/>
                <button name="action_set_counting" string="Start Count" type="object"/>
                <button name="action_set_reconciled" string="Reconcile" type="object"/>
                <button name="action_set_collection_done" string="Collection Done" type="object"/>
                <button name="action_set_refill_done" string="Refill Done" type="object"/>
                <button name="action_set_ready_to_close" string="Ready To Close" type="object"/>
                <button name="action_set_done_process" string="Finish Process" type="object" class="btn-success"/>
                <button name="action_set_cancelled_process" string="Cancel Process" type="object" class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
