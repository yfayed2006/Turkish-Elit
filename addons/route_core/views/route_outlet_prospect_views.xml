<odoo>
<record id="view_route_outlet_prospect_kanban" model="ir.ui.view">
<field name="name">route.outlet.prospect.kanban</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<kanban class="route_pda_payment_kanban" create="1" edit="1" delete="0">
<field name="name"/>
<field name="reference"/>
<field name="state"/>
<field name="salesperson_id"/>
<field name="outlet_operation_mode"/>
<field name="phone"/>
<field name="mobile"/>
<field name="area_id"/>
<field name="route_city_id"/>
<field name="submitted_at"/>
<field name="location_captured"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_payment_card">
<div class="route_pda_payment_head">
<div class="route_pda_payment_title">
<field name="name"/>
</div>
<div class="route_pda_payment_date">
<field name="submitted_at"/>
</div>
</div>
<div class="route_pda_payment_badges">
<span t-attf-class="route_pda_payment_badge route_pda_payment_badge_status route_pda_payment_status_#{record.state.raw_value or 'draft'}">
<t t-esc="record.state.value or 'Draft'"/>
</span>
<span class="route_pda_payment_badge route_pda_payment_badge_collection">
<t t-esc="record.outlet_operation_mode.value or ''"/>
</span>
<span t-if="record.location_captured.raw_value" class="route_pda_payment_badge route_pda_payment_badge_mode route_pda_payment_mode_cash">GPS Captured</span>
</div>
<div class="route_pda_payment_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Salesperson</span>
<span class="route_pda_payment_metric_value">
<field name="salesperson_id"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Area</span>
<span class="route_pda_payment_metric_value">
<field name="area_id"/>
</span>
</div>
</div>
<div class="route_pda_payment_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Phone</span>
<span class="route_pda_payment_metric_value">
<t t-esc="record.phone.value or record.mobile.value or '-'"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Reference</span>
<span class="route_pda_payment_metric_value">
<field name="reference"/>
</span>
</div>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_outlet_prospect_list" model="ir.ui.view">
<field name="name">route.outlet.prospect.list</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<list string="Potential Customers" create="1" edit="1" delete="0">
<field name="reference"/>
<field name="name"/>
<field name="state" widget="badge" decoration-info="state == 'submitted'" decoration-warning="state == 'needs_correction'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
<field name="salesperson_id"/>
<field name="outlet_operation_mode"/>
<field name="phone" optional="show"/>
<field name="mobile" optional="show"/>
<field name="area_id" optional="show"/>
<field name="location_captured" widget="boolean_toggle" optional="show"/>
<field name="submitted_at" optional="show"/>
<field name="reviewed_at" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_outlet_prospect_search" model="ir.ui.view">
<field name="name">route.outlet.prospect.search</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<search string="Potential Customers">
<field name="name" string="Outlet"/>
<field name="reference"/>
<field name="salesperson_id"/>
<field name="phone"/>
<field name="mobile"/>
<field name="area_id"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
<filter name="filter_needs_correction" string="Needs Correction" domain="[('state', '=', 'needs_correction')]"/>
<filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
<filter name="filter_rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
<separator/>
<filter name="filter_my_leads" string="My Leads" domain="[('salesperson_id', '=', uid)]"/>
<filter name="filter_gps" string="GPS Captured" domain="['|', ('latitude', '!=', 0.0), ('longitude', '!=', 0.0)]"/>
<separator/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
</search>
</field>
</record>
<record id="view_route_outlet_prospect_form" model="ir.ui.view">
<field name="name">route.outlet.prospect.form</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<form string="Potential Customer" create="1" edit="1" delete="0">
<header>
<button name="action_submit" type="object" string="Submit for Approval" class="btn-primary" invisible="state not in ('draft', 'needs_correction')"/>
<button name="action_capture_location" type="object" string="Capture Location" class="btn-secondary" invisible="state not in ('draft', 'needs_correction')"/>
<button name="action_open_captured_location_map" type="object" string="Open Location" class="btn-secondary" invisible="not location_captured"/>
<button name="action_approve" type="object" string="Approve and Create Outlet" class="btn-primary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'submitted'"/>
<button name="action_request_correction" type="object" string="Request Correction" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'submitted'"/>
<button name="action_reject" type="object" string="Reject" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state not in ('submitted', 'needs_correction')"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state not in ('needs_correction', 'rejected', 'cancelled')"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state not in ('draft', 'needs_correction')"/>
<field name="state" widget="statusbar" statusbar_visible="draft,submitted,needs_correction,approved"/>
</header>
<sheet class="route_pda_home_sheet route_pda_detail_sheet route_pda_outlet_sheet">
<div class="route_pda_detail_header">
<button name="action_back_to_customer_profiles" type="object" class="btn route_pda_back_btn">
<i class="fa fa-arrow-left" title="Arrow Left"/>
<span>Back to Customer Profiles</span>
</button>
<h2 class="route_pda_detail_title">Potential Customer</h2>
</div>
<div class="oe_title">
<label for="name"/>
<h1>
<field name="name" placeholder="Outlet / shop name" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</h1>
</div>
<div class="route_pda_payment_badges route_pda_payment_badges_primary">
<field name="reference" readonly="1" nolabel="1"/>
<field name="state" readonly="1" widget="badge" nolabel="1" decoration-success="state == 'approved'" decoration-warning="state in ('submitted', 'needs_correction')" decoration-danger="state == 'rejected'"/>
<field name="outlet_operation_mode" readonly="state in ('approved', 'rejected', 'cancelled')" widget="badge" nolabel="1"/>
</div>
<group string="Sales Context" col="4">
<field name="salesperson_id" readonly="state != 'draft'"/>
<field name="company_id" readonly="1"/>
<field name="submitted_at" readonly="1"/>
<field name="reviewed_by_id" readonly="1"/>
</group>
<group string="Contact and Location" col="2">
<group>
<field name="contact_name" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="phone" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="mobile" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="email" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
<group>
<field name="route_country_id" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="route_city_id" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="area_id" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="route_area_name" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
</group>
<group string="Address" col="2">
<group>
<field name="street" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="street2" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
<group>
<field name="city" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="display_address" readonly="1"/>
</group>
</group>
<group string="Store Specification" col="4">
<field name="shop_area_sqm" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="frontage_width_m" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="street_width_m" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="entrance_width_m" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="visibility_level" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="traffic_level" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="refrigeration_available" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="parking_available" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="shelf_capacity_note" colspan="4" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
<group string="GPS Location" col="4">
<field name="location_captured" readonly="1" widget="boolean_toggle"/>
<field name="latitude" readonly="1"/>
<field name="longitude" readonly="1"/>
<field name="location_accuracy_m" readonly="1"/>
<field name="location_captured_at" readonly="1"/>
</group>
<group string="Photos" col="2">
<field name="exterior_image" widget="image" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="interior_image" widget="image" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
<group string="Business Notes" col="2">
<field name="expected_monthly_sales" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="product_interest_text" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="competitor_notes" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="salesperson_note" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</group>
<group string="Supervisor Review" col="2">
<field name="supervisor_note" groups="route_core.group_route_supervisor,route_core.group_route_management" readonly="state in ('approved', 'rejected', 'cancelled')"/>
<field name="reviewed_at" readonly="1"/>
<field name="approved_partner_id" readonly="1"/>
<field name="approved_outlet_id" readonly="1"/>
</group>
</sheet>
<chatter/>
</form>
</field>
</record>
<record id="action_route_outlet_prospect_salesperson" model="ir.actions.act_window">
<field name="name">Potential Customers</field>
<field name="res_model">route.outlet.prospect</field>
<field name="view_mode">kanban,list,form</field>
<field name="search_view_id" ref="route_core.view_route_outlet_prospect_search"/>
<field name="domain">[('salesperson_id', '=', uid), ('state', 'in', ['draft', 'submitted', 'needs_correction'])]</field>
<field name="context">{'default_salesperson_id': uid, 'search_default_filter_my_leads': 1, 'create': 1, 'edit': 1, 'delete': 0}</field>
</record>
<record id="action_route_outlet_prospect_salesperson_kanban_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">kanban</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_kanban"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_salesperson"/>
</record>
<record id="action_route_outlet_prospect_salesperson_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_list"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_salesperson"/>
</record>
<record id="action_route_outlet_prospect_salesperson_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="3"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_form"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_salesperson"/>
</record>
<record id="action_route_outlet_prospect_review" model="ir.actions.act_window">
<field name="name">Potential Customer Approval</field>
<field name="res_model">route.outlet.prospect</field>
<field name="view_mode">kanban,list,form</field>
<field name="search_view_id" ref="route_core.view_route_outlet_prospect_search"/>
<field name="domain">[]</field>
<field name="context">{'search_default_filter_submitted': 1, 'create': 0, 'edit': 1, 'delete': 0}</field>
</record>
<record id="action_route_outlet_prospect_review_kanban_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">kanban</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_kanban"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_review"/>
</record>
<record id="action_route_outlet_prospect_review_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_list"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_review"/>
</record>
<record id="action_route_outlet_prospect_review_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="3"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_outlet_prospect_form"/>
<field name="act_window_id" ref="route_core.action_route_outlet_prospect_review"/>
</record>
<menuitem id="menu_route_outlet_prospect_review" name="Potential Customers" parent="route_core.menu_route_control_workspace" action="route_core.action_route_outlet_prospect_review" sequence="18" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</odoo>
