<odoo>
<record id="view_route_outlet_prospect_kanban" model="ir.ui.view">
<field name="name">route.outlet.prospect.kanban</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<kanban class="route_pda_payment_kanban" create="1" edit="1" delete="0">
<field name="name"/>
<field name="reference"/>
<field name="state"/>
<field name="salesperson_id"/>
<field name="outlet_operation_mode"/>
<field name="phone"/>
<field name="mobile"/>
<field name="area_id"/>
<field name="route_city_id"/>
<field name="submitted_at"/>
<field name="location_captured"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_payment_card">
<div class="route_pda_payment_head">
<div class="route_pda_payment_title">
<field name="name"/>
</div>
<div class="route_pda_payment_date">
<field name="submitted_at"/>
</div>
</div>
<div class="route_pda_payment_badges">
<span t-attf-class="route_pda_payment_badge route_pda_payment_badge_status route_pda_payment_status_#{record.state.raw_value or 'draft'}">
<t t-esc="record.state.value or 'Draft'"/>
</span>
<span t-if="record.location_captured.raw_value" class="route_pda_payment_badge route_pda_payment_badge_mode route_pda_payment_mode_cash">GPS Captured</span>
</div>
<div class="route_pda_payment_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Salesperson</span>
<span class="route_pda_payment_metric_value">
<field name="salesperson_id"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Area</span>
<span class="route_pda_payment_metric_value">
<field name="area_id"/>
</span>
</div>
</div>
<div class="route_pda_payment_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Phone</span>
<span class="route_pda_payment_metric_value">
<t t-esc="record.phone.value or record.mobile.value or '-'"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Reference</span>
<span class="route_pda_payment_metric_value">
<field name="reference"/>
</span>
</div>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_outlet_prospect_list" model="ir.ui.view">
<field name="name">route.outlet.prospect.list</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<list string="Potential Customers" create="1" edit="1" delete="0">
<field name="reference"/>
<field name="name"/>
<field name="state" widget="badge" decoration-info="state == 'submitted'" decoration-warning="state == 'needs_correction'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
<field name="salesperson_id"/>
<field name="outlet_operation_mode" string="Final Operation Mode" optional="hide"/>
<field name="phone" optional="show"/>
<field name="mobile" optional="show"/>
<field name="area_id" optional="show"/>
<field name="location_captured" widget="boolean_toggle" optional="show"/>
<field name="submitted_at" optional="show"/>
<field name="reviewed_at" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_outlet_prospect_search" model="ir.ui.view">
<field name="name">route.outlet.prospect.search</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<search string="Potential Customers">
<field name="name" string="Outlet"/>
<field name="reference"/>
<field name="salesperson_id"/>
<field name="phone"/>
<field name="mobile"/>
<field name="area_id"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
<filter name="filter_needs_correction" string="Needs Correction" domain="[('state', '=', 'needs_correction')]"/>
<filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
<filter name="filter_rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
<separator/>
<filter name="filter_my_leads" string="My Leads" domain="[('salesperson_id', '=', uid)]"/>
<filter name="filter_gps" string="GPS Captured" domain="['|', ('latitude', '!=', 0.0), ('longitude', '!=', 0.0)]"/>
<separator/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
</search>
</field>
</record>
<record id="view_route_outlet_prospect_form" model="ir.ui.view">
<field name="name">route.outlet.prospect.form</field>
<field name="model">route.outlet.prospect</field>
<field name="arch" type="xml">
<form string="Potential Customer" create="1" edit="1" delete="0">
<header>
<button name="action_submit" type="object" string="Submit for Approval" class="btn-primary" invisible="state not in ('draft', 'needs_correction')"/>
<button name="action_noop_pending_review" type="object" string="Pending Review" class="btn-secondary" invisible="state != 'submitted'"/>
<button name="action_capture_location" type="object" string="Capture Current Location" class="btn-secondary" invisible="state not in ('draft', 'needs_correction')"/>
<button name="action_open_captured_location_map" type="object" string="Open Location" class="btn-secondary" invisible="not location_captured"/>
<button name="action_approve" type="object" string="Approve and Create Outlet" class="btn-primary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'submitted'"/>
<button name="action_request_correction" type="object" string="Request Correction" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'submitted'"/>
<button name="action_reject" type="object" string="Reject" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state not in ('submitted', 'needs_correction')"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state not in ('needs_correction', 'rejected', 'cancelled')"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state not in ('draft', 'needs_correction')"/>
<field name="state" widget="statusbar" statusbar_visible="draft,submitted,needs_correction,approved"/>
</header>
<sheet class="route_pda_home_sheet route_pda_detail_sheet route_pda_outlet_sheet">
<div class="route_pda_detail_header">
<button name="action_back_to_customer_profiles" type="object" class="btn route_pda_back_btn">
<i class="fa fa-arrow-left" title="Arrow Left"/>
<span>Back to Customer Profiles</span>
</button>
<h2 class="route_pda_detail_title">Potential Customer</h2>
</div>
<field name="salesperson_id" invisible="1"/>
<field name="company_id" invisible="1"/>
<field name="currency_id" invisible="1"/>
<div class="oe_title">
<label for="name"/>
<h1>
<field name="name" placeholder="Outlet / shop name" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</h1>
</div>
<div class="route_pda_payment_badges route_pda_payment_badges_primary">
<field name="reference" readonly="1" nolabel="1"/>
<field name="state" readonly="1" widget="badge" nolabel="1" decoration-success="state == 'approved'" decoration-warning="state in ('submitted', 'needs_correction')" decoration-danger="state == 'rejected'"/>
<field name="outlet_operation_mode" readonly="1" widget="badge" nolabel="1" invisible="state != 'approved'"/>
</div>
<div class="route_pda_info_hint_inline route_pda_product_center_note" invisible="state not in ('draft', 'needs_correction')"> Capture the shop identity, contact, location, photos, and business notes, then submit it for supervisor approval. </div>
<div class="route_pda_info_hint_inline route_pda_product_center_note" invisible="state in ('draft', 'needs_correction')"> This potential customer has been submitted or reviewed. Supervisor approval will create the official customer and outlet. </div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">Contact and Location</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Contact Person</div>
<div class="route_pda_info_value">
<field name="contact_name" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Phone</div>
<div class="route_pda_info_value">
<field name="phone" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Mobile</div>
<div class="route_pda_info_value">
<field name="mobile" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Email</div>
<div class="route_pda_info_value">
<field name="email" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Route Country</div>
<div class="route_pda_info_value">
<field name="route_country_id" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')" options="{'no_create': True, 'no_create_edit': True}"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Route City</div>
<div class="route_pda_info_value">
<field name="route_city_id" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')" domain="[]" context="{'default_country_id': route_country_id}"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Area</div>
<div class="route_pda_info_value">
<field name="area_id" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')" domain="[]" context="{'default_city_id': route_city_id}"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Area Name</div>
<div class="route_pda_info_value">
<field name="route_area_name" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">Address</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Street / Address Line 1</div>
<div class="route_pda_info_value">
<field name="street" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Address Line 2</div>
<div class="route_pda_info_value">
<field name="street2" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">City Text</div>
<div class="route_pda_info_value">
<field name="city" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Display Address</div>
<div class="route_pda_info_value">
<field name="display_address" nolabel="1" readonly="1"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">Store Specification</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Approx. Shop Area (m²)</div>
<div class="route_pda_info_value">
<field name="shop_area_sqm" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Frontage Width (m)</div>
<div class="route_pda_info_value">
<field name="frontage_width_m" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Street Width (m)</div>
<div class="route_pda_info_value">
<field name="street_width_m" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Entrance Width (m)</div>
<div class="route_pda_info_value">
<field name="entrance_width_m" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Street Visibility</div>
<div class="route_pda_info_value">
<field name="visibility_level" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Street Traffic</div>
<div class="route_pda_info_value">
<field name="traffic_level" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Refrigeration Available</div>
<div class="route_pda_info_value">
<field name="refrigeration_available" nolabel="1" widget="boolean_toggle" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Parking Available</div>
<div class="route_pda_info_value">
<field name="parking_available" nolabel="1" widget="boolean_toggle" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full" style="grid-column: 1 / -1;">
<div class="route_pda_info_label">Shelf / Display Capacity</div>
<div class="route_pda_info_value">
<field name="shelf_capacity_note" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">GPS Location</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Location Status</div>
<div class="route_pda_info_value">
<field name="location_captured" nolabel="1" readonly="1" widget="boolean_toggle"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">GPS Accuracy (m)</div>
<div class="route_pda_info_value">
<field name="location_accuracy_m" nolabel="1" readonly="1"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Captured At</div>
<div class="route_pda_info_value">
<field name="location_captured_at" nolabel="1" readonly="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_action">
<div class="route_pda_info_label">Location Actions</div>
<button name="action_capture_location" type="object" string="Capture Current Location" class="btn btn-primary" invisible="state not in ('draft', 'needs_correction')"/>
<button name="action_open_captured_location_map" type="object" string="Open Map" class="btn btn-secondary" invisible="not location_captured"/>
</div>
</div>
</div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">Photos</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Exterior Photo</div>
<div class="route_pda_info_value">
<field name="exterior_image" widget="image" nolabel="1" options="{'size': [160, 160]}" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card">
<div class="route_pda_info_label">Interior Photo</div>
<div class="route_pda_info_value">
<field name="interior_image" widget="image" nolabel="1" options="{'size': [160, 160]}" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_pda_group_operations">
<div class="route_pda_group_title">Business Notes</div>
<div class="route_pda_card_grid route_pda_card_grid_2">
<div class="route_pda_info_card">
<div class="route_pda_info_label">Expected Monthly Sales</div>
<div class="route_pda_info_value">
<field name="expected_monthly_sales" nolabel="1" readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_text_card" style="grid-column: 1 / -1;">
<div class="route_pda_info_label">Suggested Products / Demand</div>
<div class="route_pda_info_value route_pda_text_value">
<field name="product_interest_text" nolabel="1" placeholder="Suggested products, demand notes, product categories..." readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_text_card" style="grid-column: 1 / -1;">
<div class="route_pda_info_label">Nearby Competitors</div>
<div class="route_pda_info_value route_pda_text_value">
<field name="competitor_notes" nolabel="1" placeholder="Nearby competitors, price level, shelf position..." readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_text_card" style="grid-column: 1 / -1;">
<div class="route_pda_info_label">Salesperson Notes</div>
<div class="route_pda_info_value route_pda_text_value">
<field name="salesperson_note" nolabel="1" placeholder="Salesperson observations and follow-up notes..." readonly="state in ('approved', 'rejected', 'cancelled')"/>
</div>
</div>
</div>
</div>
</sheet>
</form>
</field>
</record>
