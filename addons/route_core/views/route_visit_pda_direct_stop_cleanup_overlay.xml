<odoo>
<record id="view_route_visit_pda_direct_stop_cleanup_overlay_workflow" model="ir.ui.view">
<field name="name">route.visit.pda.direct.stop.cleanup.overlay.workflow</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form_workflow_ux"/>
<field name="priority">999</field>
<field name="arch" type="xml">
<xpath expr="//field[@name='outlet_open_shortage_count']/ancestor::group[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='collection_priority']/ancestor::group[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='direct_stop_previous_due_amount']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='partner_id']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='partner_id']/ancestor::group[2]/preceding-sibling::separator[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='resolved_supervisor_partner_id']/ancestor::group[2]" position="attributes">
<attribute name="invisible">1</attribute>
</xpath>
<xpath expr="//field[@name='resolved_supervisor_partner_id']/ancestor::group[2]/preceding-sibling::separator[1]" position="attributes">
<attribute name="invisible">1</attribute>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_direct_stop_cleanup_overlay_payment" model="ir.ui.view">
<field name="name">route.visit.pda.direct.stop.cleanup.overlay.payment</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form_payment_ux"/>
<field name="priority">1000</field>
<field name="arch" type="xml">
<xpath expr="//field[@name='net_due_amount']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
</field>
</record>
</odoo>
