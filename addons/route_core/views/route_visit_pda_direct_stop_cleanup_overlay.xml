<odoo>
<record id="view_route_visit_pda_form_direct_stop_cleanup_overlay" model="ir.ui.view">
<field name="name">route.visit.pda.form.direct.stop.cleanup.overlay</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form_workflow_ux"/>
<field name="priority">999</field>
<field name="arch" type="xml">
<xpath expr="//group[.//field[@name='outlet_open_shortage_count'] and .//field[@name='pending_near_expiry_line_count']]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//group[.//field[@name='collection_priority'] and .//field[@name='outlet_health_status']]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<xpath expr="//group[.//field[@name='direct_stop_previous_due_amount'] and .//field[@name='direct_stop_settlement_paid_amount'] and .//field[@name='direct_stop_grand_due_amount']]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
</odoo>
