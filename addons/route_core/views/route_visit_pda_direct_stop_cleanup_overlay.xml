<odoo>
<record id="view_route_visit_pda_direct_stop_cleanup_overlay_workflow" model="ir.ui.view">
<field name="name">route.visit.pda.direct.stop.cleanup.overlay.workflow</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form_workflow_ux"/>
<field name="active" eval="True"/>
<field name="priority">1200</field>
<field name="arch" type="xml">
<!--  Hide PDA-only analytics blocks by replacing the exact visible groups.  -->
<xpath expr="//separator[@string='Visit Command Header']/following-sibling::group[1]/group[3]" position="replace">
<group invisible="1"/>
</xpath>
<xpath expr="//separator[@string='Visit Command Header']/following-sibling::group[1]/group[4]" position="replace">
<group invisible="1"/>
</xpath>
<!--  Hide the direct-stop operational summary block that remains visible on PDA direct-sale visits.  -->
<xpath expr="//group[@string='Visit Details']/preceding-sibling::group[1][.//field[@name='direct_stop_previous_due_amount'] and .//field[@name='direct_stop_settlement_paid_amount']]" position="replace">
<group invisible="1"/>
</xpath>
<!--  Remove supervisor routing details from the PDA visit page; WhatsApp still resolves in backend logic.  -->
<xpath expr="//page[@string='Payments']/group[@string='Supervisor WhatsApp Routing']" position="replace">
<group invisible="1"/>
</xpath>
</field>
</record>
</odoo
