<odoo>
<!--  Clean salesperson PDA visit screen: keep only operational essentials  -->
<record id="view_route_visit_pda_direct_stop_cleanup_overlay_base" model="ir.ui.view">
<field name="name">route.visit.pda.direct.stop.cleanup.overlay.base</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="priority">999</field>
<field name="arch" type="xml">
<!--  hide shortage / near-expiry analytics block for salesperson  -->
<xpath expr="//field[@name='outlet_open_shortage_count']/ancestor::group[1]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide the exact right-side analytics block shown in the screenshot  -->
<xpath expr="//field[@name='collection_priority']/ancestor::group[1]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide direct-stop operational summary  -->
<xpath expr="//field[@name='direct_stop_previous_due_amount']/ancestor::group[2]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide supervisor routing block from visit screen  -->
<xpath expr="//field[@name='resolved_supervisor_partner_id']/ancestor::group[2]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_direct_stop_cleanup_overlay_workflow" model="ir.ui.view">
<field name="name">route.visit.pda.direct.stop.cleanup.overlay.workflow</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form_workflow_ux"/>
<field name="priority">1000</field>
<field name="arch" type="xml">
<!--  hide shortage / near-expiry analytics block for salesperson  -->
<xpath expr="//field[@name='outlet_open_shortage_count']/ancestor::group[1]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide the exact right-side analytics block shown in the screenshot  -->
<xpath expr="//field[@name='collection_priority']/ancestor::group[1]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide direct-stop operational summary  -->
<xpath expr="//field[@name='direct_stop_previous_due_amount']/ancestor::group[2]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
<!--  hide supervisor routing block from visit screen  -->
<xpath expr="//field[@name='resolved_supervisor_partner_id']/ancestor::group[2]" position="attributes">
<attribute name="groups">route_core.group_route_supervisor,route_core.group_route_management</attribute>
</xpath>
</field>
</record>
</odoo>
