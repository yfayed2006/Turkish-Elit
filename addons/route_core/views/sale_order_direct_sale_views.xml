<odoo>
<record id="view_sale_order_form_route_direct_sale" model="ir.ui.view">
<field name="name">sale.order.form.route.direct.sale</field>
<field name="model">sale.order</field>
<field name="inherit_id" ref="sale.view_order_form"/>
<field name="arch" type="xml">
<xpath expr="//header" position="inside">
<button name="action_back_to_outlet_form" type="object" string="Back to Outlet" class="btn-secondary" invisible="not route_outlet_id"/>
<button name="action_open_direct_sale_deliveries" type="object" string="Deliveries" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_sale == False or route_operation_mode == 'consignment'"/>
<button name="action_open_direct_sale_returns" type="object" string="Returns" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_return == False"/>
<button name="action_open_direct_sale_payments" type="object" string="Payments" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_sale == False or route_operation_mode == 'consignment'"/>
<button name="action_create_direct_return" type="object" string="Create Return" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_return == False"/>
<button name="action_no_direct_return" type="object" string="No Return" class="btn-secondary" invisible="not route_show_no_direct_return"/>
</xpath>
<xpath expr="//field[@name='partner_id']" position="attributes">
<attribute name="readonly">route_order_mode == 'direct_sale' and route_outlet_id</attribute>
</xpath>
<xpath expr="//field[@name='pricelist_id']" position="attributes">
<attribute name="readonly">route_order_mode == 'direct_sale'</attribute>
<attribute name="options">{'no_create': True, 'no_open': True}</attribute>
</xpath>
<xpath expr="//field[@name='order_line']/tree/field[@name='product_id'] | //field[@name='order_line']/list/field[@name='product_id']" position="after">
<field name="route_product_barcode" string="Barcode" optional="show"/>
<field name="route_source_available_qty" string="Available in Vehicle" optional="show" readonly="1" column_invisible="parent.route_order_mode != 'direct_sale'"/>
</xpath>
<xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id'] | //field[@name='order_line']/list/field[@name='product_template_id']" position="attributes">
<attribute name="domain">parent.route_order_mode != 'direct_sale' and [] or [('id', 'in', parent.route_available_product_tmpl_ids)]</attribute>
<attribute name="context">{'route_only_source_available_products': parent.route_order_mode == 'direct_sale', 'route_source_location_id': parent.route_source_location_id}</attribute>
</xpath>
<xpath expr="//field[@name='order_line']/tree/field[@name='product_id'] | //field[@name='order_line']/list/field[@name='product_id']" position="attributes">
<attribute name="domain">parent.route_order_mode != 'direct_sale' and [] or [('id', 'in', parent.route_available_product_ids)]</attribute>
<attribute name="context">{'route_only_source_available_products': parent.route_order_mode == 'direct_sale', 'route_source_location_id': parent.route_source_location_id}</attribute>
</xpath>
<xpath expr="//field[@name='partner_id']" position="after">
<field name="route_order_mode"/>
<field name="route_outlet_id" domain="[('outlet_operation_mode', '=', 'direct_sale'), ('active', '=', True)]" invisible="route_order_mode != 'direct_sale'" required="route_order_mode == 'direct_sale'" readonly="route_order_mode == 'direct_sale'" options="{'no_create': True, 'no_open': True}"/>
<field name="route_source_location_id" invisible="route_order_mode != 'direct_sale'" readonly="1"/>
<field name="route_available_product_ids" invisible="1"/>
<field name="route_available_product_tmpl_ids" invisible="1"/>
<field name="route_payment_mode" invisible="route_order_mode != 'direct_sale'"/>
<field name="route_payment_due_date" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'deferred'" required="route_order_mode == 'direct_sale' and route_payment_mode == 'deferred'"/>
<field name="route_cheque_number" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'cheque'" required="route_order_mode == 'direct_sale' and route_payment_mode == 'cheque'"/>
<field name="route_cheque_bank_name" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'cheque'" required="route_order_mode == 'direct_sale' and route_payment_mode == 'cheque'"/>
<field name="route_cheque_date" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'cheque'" required="route_order_mode == 'direct_sale' and route_payment_mode == 'cheque'"/>
<field name="route_cheque_holder_name" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'cheque'"/>
<field name="route_cheque_note" invisible="route_order_mode != 'direct_sale' or route_payment_mode != 'cheque'"/>
<field name="direct_sale_collected_amount" invisible="route_order_mode != 'direct_sale'" readonly="1"/>
<field name="direct_sale_remaining_due" invisible="route_order_mode != 'direct_sale'" readonly="1"/>
<field name="direct_sale_payment_count" invisible="1" readonly="1"/>
<field name="route_enable_lot_serial_tracking" invisible="1"/>
<field name="route_enable_expiry_tracking" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_operation_mode" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="route_show_no_direct_return" invisible="1"/>
</xpath>
<!--      Keep lot/expiry fields inside the Route mobile/PDA direct-sale view only.
     Showing route_lot_id inside the inherited standard Sales form can make
     sale.order web_read fail after confirmation for users that do not have the
     exact stock.lot lookup context/access used by the PDA flow. The actual lot
     restriction is still applied during confirmation and delivery creation.      -->
</field>
</record>
<record id="view_sale_order_line_form_route_direct_sale" model="ir.ui.view">
<field name="name">sale.order.line.form.route.direct.sale</field>
<field name="model">sale.order.line</field>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<form string="Create Order Lines">
<sheet class="route_mobile_compact_sheet route_mobile_sale_order_line_sheet">
<field name="order_id" invisible="1"/>
<field name="route_available_product_ids" invisible="1"/>
<field name="route_available_product_tmpl_ids" invisible="1"/>
<field name="route_source_available_qty" invisible="1"/>
<field name="route_product_image_128" invisible="1"/>
<field name="display_type" invisible="1"/>
<div class="route_mobile_product_image_preview" invisible="display_type or not product_id">
<field name="route_product_image_128" widget="image" readonly="1" nolabel="1" class="route_mobile_product_popup_image"/>
</div>
<div class="route_mobile_summary_grid" invisible="display_type">
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Barcode / Scan</div>
<div class="route_mobile_info_value">
<field name="route_product_barcode" placeholder="Scan or type barcode"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_full">
<div class="route_mobile_info_label">Product</div>
<div class="route_mobile_info_value">
<field name="product_id" domain="order_id.route_order_mode != 'direct_sale' and [] or [('id', 'in', route_available_product_ids)]" context="{'route_only_source_available_products': order_id.route_order_mode == 'direct_sale', 'route_source_location_id': order_id.route_source_location_id}" options="{'no_create': True, 'no_open': True}" required="not display_type"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Quantity</div>
<div class="route_mobile_info_value">
<field name="product_uom_qty" string="Quantity" invisible="display_type"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="display_type">
<div class="route_mobile_info_label">UoM</div>
<div class="route_mobile_info_value">
<field name="product_uom_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="order_id.route_order_mode != 'direct_sale' or display_type">
<div class="route_mobile_info_label">Available in Vehicle</div>
<div class="route_mobile_info_value">
<field name="route_source_available_qty" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="display_type">
<div class="route_mobile_info_label">Unit Price</div>
<div class="route_mobile_info_value">
<field name="price_unit" string="Unit Price" readonly="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box" invisible="order_id.route_order_mode != 'direct_sale' or not order_id.route_enable_lot_serial_tracking or not product_id or product_id.tracking == 'none'">
<div class="route_mobile_detail_label">Lot / Serial</div>
<div class="route_mobile_detail_value">
<field name="route_lot_id" string="Lot/Serial" options="{'no_create': True, 'no_open': True}" readonly="id"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="order_id.route_order_mode != 'direct_sale' or not order_id.route_enable_lot_serial_tracking or not order_id.route_enable_expiry_tracking or not route_lot_id">
<div class="route_mobile_detail_label">Expiry Date</div>
<div class="route_mobile_detail_value">
<field name="route_expiry_month_label" string="Expiry" readonly="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="display_type">
<div class="route_mobile_detail_label">Taxes</div>
<div class="route_mobile_detail_value">
<field name="tax_ids" widget="many2many_tags" readonly="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="display_type">
<div class="route_mobile_detail_label">Discount (%)</div>
<div class="route_mobile_detail_value">
<field name="discount" readonly="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="display_type">
<div class="route_mobile_detail_label">Untaxed Amount</div>
<div class="route_mobile_detail_value">
<field name="price_subtotal" readonly="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="display_type">
<div class="route_mobile_detail_label">Tax Amount</div>
<div class="route_mobile_detail_value">
<field name="price_tax" readonly="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="display_type">
<div class="route_mobile_detail_label">Total Incl. Tax</div>
<div class="route_mobile_detail_value">
<field name="price_total" readonly="1"/>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Description</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="name" readonly="1"/>
</div>
</div>
</sheet>
</form>
</field>
</record>
<record id="view_sale_order_form_route_direct_sale_mobile" model="ir.ui.view">
<field name="name">sale.order.form.route.direct.sale.mobile</field>
<field name="model">sale.order</field>
<field name="priority" eval="210"/>
<field name="arch" type="xml">
<form string="Route Direct Sale" class="route_mobile_sale_order_form">
<header>
<button name="action_route_direct_sale_back_to_visit" type="object" string="Back to Visit" class="btn-secondary" invisible="route_order_mode != 'direct_sale'"/>
<button name="action_route_direct_sale_confirm_and_return" type="object" string="Confirm Sale" class="btn-primary" invisible="state not in ('draft', 'sent')" context="{'route_return_to_visit_after_confirm': True}"/>
<button name="action_open_direct_sale_deliveries" type="object" string="Deliveries" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_sale == False or route_operation_mode == 'consignment'"/>
<button name="action_open_direct_sale_payments" type="object" string="Payments" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_sale == False or route_operation_mode == 'consignment'"/>
<button name="action_create_direct_return" type="object" string="Create Return" class="btn-secondary" invisible="route_order_mode != 'direct_sale' or state not in ('sale', 'done') or route_enable_direct_return == False"/>
<field name="state" widget="statusbar" statusbar_visible="draft,sale,done,cancel"/>
</header>
<sheet class="route_mobile_compact_sheet route_mobile_sale_order_sheet">
<field name="route_order_mode" invisible="1"/>
<field name="route_visit_id" invisible="1"/>
<field name="route_available_product_ids" invisible="1"/>
<field name="route_available_product_tmpl_ids" invisible="1"/>
<field name="route_enable_lot_serial_tracking" invisible="1"/>
<field name="route_enable_expiry_tracking" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_operation_mode" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="route_show_no_direct_return" invisible="1"/>
<field name="currency_id" invisible="1"/>
<div class="route_mobile_header_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<div class="route_mobile_summary_grid route_mobile_sale_order_top_grid">
<div class="route_mobile_info_card route_mobile_info_card_priority">
<div class="route_mobile_info_label">Customer</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="partner_id" readonly="route_order_mode == 'direct_sale' and route_outlet_id" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Outlet</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="route_outlet_id" domain="[('outlet_operation_mode', '=', 'direct_sale'), ('active', '=', True)]" required="route_order_mode == 'direct_sale'" readonly="route_order_mode == 'direct_sale'" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Pricelist</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="pricelist_id" readonly="route_order_mode == 'direct_sale'" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Source Location</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="route_source_location_id" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Payment Mode</div>
<div class="route_mobile_info_value">
<field name="route_payment_mode"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="route_payment_mode != 'deferred'">
<div class="route_mobile_info_label">Deferred Due Date</div>
<div class="route_mobile_info_value">
<field name="route_payment_due_date" required="route_payment_mode == 'deferred'"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="route_payment_mode != 'cheque'">
<div class="route_mobile_info_label">Cheque Number</div>
<div class="route_mobile_info_value">
<field name="route_cheque_number" required="route_payment_mode == 'cheque'"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="route_payment_mode != 'cheque'">
<div class="route_mobile_info_label">Cheque Bank</div>
<div class="route_mobile_info_value">
<field name="route_cheque_bank_name" required="route_payment_mode == 'cheque'"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="route_payment_mode != 'cheque'">
<div class="route_mobile_info_label">Cheque Date</div>
<div class="route_mobile_info_value">
<field name="route_cheque_date" required="route_payment_mode == 'cheque'"/>
</div>
</div>
<div class="route_mobile_info_card" invisible="route_payment_mode != 'cheque'">
<div class="route_mobile_info_label">Cheque Holder</div>
<div class="route_mobile_info_value">
<field name="route_cheque_holder_name"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_info_card_wide" invisible="route_payment_mode != 'cheque'">
<div class="route_mobile_info_label">Cheque Details</div>
<div class="route_mobile_info_value route_mobile_wrap_value">
<field name="route_cheque_note" widget="text"/>
</div>
</div>
</div>
<div class="route_mobile_summary_grid route_mobile_sale_totals_grid">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Untaxed</div>
<div class="route_mobile_info_value">
<field name="amount_untaxed" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Tax</div>
<div class="route_mobile_info_value">
<field name="amount_tax" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card route_mobile_sale_total_card">
<div class="route_mobile_info_label">Total</div>
<div class="route_mobile_info_value">
<field name="amount_total" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Remaining</div>
<div class="route_mobile_info_value">
<field name="direct_sale_remaining_due" readonly="1"/>
</div>
</div>
</div>
<div class="route_mobile_section_header route_mobile_product_header">
<div class="route_mobile_section_title">Sale Products</div>
<div class="route_mobile_product_toolbar">
<button name="action_route_direct_sale_add_product" type="object" string="Add / Scan Product" class="btn-primary route_mobile_product_action" invisible="state not in ('draft', 'sent')"/>
</div>
</div>
<field name="order_line" class="route_mobile_direct_products_field" context="{'default_display_type': False, 'route_only_source_available_products': route_order_mode == 'direct_sale', 'route_source_location_id': route_source_location_id}">
<list string="Products" editable="bottom" create="1" delete="1" class="route_mobile_sale_line_list">
<field name="display_type" column_invisible="1"/>
<field name="route_product_image_128" string="Image" widget="image" readonly="1" optional="show" class="route_mobile_product_image_cell"/>
<field name="product_id" string="Product" domain="parent.route_order_mode != 'direct_sale' and [] or [('id', 'in', parent.route_available_product_ids)]" context="{'route_only_source_available_products': parent.route_order_mode == 'direct_sale', 'route_source_location_id': parent.route_source_location_id}" options="{'no_create': True, 'no_open': True}" required="not display_type" readonly="parent.state not in ('draft', 'sent')"/>
<field name="route_product_barcode" string="Barcode" optional="show" readonly="1"/>
<field name="product_uom_qty" string="Qty" readonly="parent.state not in ('draft', 'sent')"/>
<field name="product_uom_id" string="UoM" options="{'no_create': True, 'no_open': True}" readonly="1"/>
<field name="route_source_available_qty" string="Vehicle" readonly="1" column_invisible="parent.route_order_mode != 'direct_sale'"/>
<field name="route_lot_id" string="Lot/Serial" column_invisible="parent.route_order_mode != 'direct_sale' or parent.route_enable_lot_serial_tracking == False" optional="show" readonly="parent.state not in ('draft', 'sent')"/>
<field name="route_expiry_month_label" string="Expiry" readonly="1" column_invisible="parent.route_order_mode != 'direct_sale' or parent.route_enable_lot_serial_tracking == False or parent.route_enable_expiry_tracking == False" optional="show"/>
<field name="price_unit" string="Unit" readonly="1"/>
<field name="discount" string="Disc. %" optional="show" readonly="1"/>
<field name="price_subtotal" string="Untaxed" readonly="1"/>
<field name="price_tax" string="Tax" readonly="1" optional="show"/>
<field name="price_total" string="Total Incl. Tax" readonly="1" optional="show"/>
