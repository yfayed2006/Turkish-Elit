<odoo>
<record id="view_route_direct_return_form_tax_policy" model="ir.ui.view">
<field name="name">route.direct.return.form.tax.policy</field>
<field name="model">route.direct.return</field>
<field name="inherit_id" ref="route_core.view_route_direct_return_form"/>
<field name="priority" eval="260"/>
<field name="arch" type="xml">
<xpath expr="//div[contains(@class, 'route_mobile_direct_return_notice_text')]" position="replace">
<div class="route_mobile_direct_return_notice_text">Return prices, discounts, and taxes are calculated from this outlet's direct-sale pricelist. Reference sale order or delivery is optional and used for tracking only. The confirmed return value will reduce the current stop settlement.</div>
</xpath>
<xpath expr="//field[@name='amount_total']/ancestor::div[contains(@class, 'route_mobile_return_total_card')][1]" position="before">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Return Untaxed</div>
<div class="route_mobile_info_value">
<field name="amount_untaxed" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Return Tax</div>
<div class="route_mobile_info_value">
<field name="amount_tax" readonly="1"/>
</div>
</div>
</xpath>
<xpath expr="//field[@name='amount_total']/ancestor::div[contains(@class, 'route_mobile_return_total_card')][1]/div[contains(@class, 'route_mobile_info_label')]" position="replace">
<div class="route_mobile_info_label">Return Total Incl. Tax</div>
</xpath>
<xpath expr="//field[@name='line_ids']//*[self::list or self::tree]/field[@name='estimated_amount']" position="attributes">
<attribute name="string">Return Total</attribute>
</xpath>
<xpath expr="//field[@name='line_ids']//*[self::list or self::tree]/field[@name='estimated_amount']" position="before">
<field name="estimated_untaxed_amount" string="Untaxed" readonly="1" optional="show"/>
<field name="estimated_tax_amount" string="Tax" readonly="1" optional="show"/>
</xpath>
</field>
</record>
<record id="view_route_direct_return_line_form_mobile_tax_policy" model="ir.ui.view">
<field name="name">route.direct.return.line.form.mobile.tax.policy</field>
<field name="model">route.direct.return.line</field>
<field name="inherit_id" ref="route_core.view_route_direct_return_line_form_mobile"/>
<field name="priority" eval="260"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='estimated_amount']/ancestor::div[contains(@class, 'route_mobile_info_card')][1]/div[contains(@class, 'route_mobile_info_label')]" position="replace">
<div class="route_mobile_info_label">Return Total</div>
</xpath>
<xpath expr="//field[@name='estimated_amount']/ancestor::div[contains(@class, 'route_mobile_info_card')][1]" position="before">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Untaxed Amount</div>
<div class="route_mobile_info_value">
<field name="estimated_untaxed_amount" readonly="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Tax Amount</div>
<div class="route_mobile_info_value">
<field name="estimated_tax_amount" readonly="1"/>
</div>
</div>
</xpath>
<xpath expr="//field[@name='route_reference_tax_ids']/ancestor::div[contains(@class, 'route_mobile_info_card')][1]/div[contains(@class, 'route_mobile_info_label')]" position="replace">
<div class="route_mobile_info_label">Taxes</div>
</xpath>
</field>
</record>
</odoo>
