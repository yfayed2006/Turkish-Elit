<odoo>
<record id="view_route_visit_form_workflow_ux" model="ir.ui.view">
<field name="name">route.visit.form.workflow.ux</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//header/field[@name='visit_process_state']" position="before">
<button name="action_ux_open_direct_sale_orders" string="Direct Sale Orders" type="object" class="btn-secondary" invisible="outlet_operation_mode != 'direct_sale' or not ux_can_open_direct_sale_orders"/>
<button name="action_ux_open_direct_sale_payments" string="Direct Sale Payments" type="object" class="btn-secondary" invisible="outlet_operation_mode != 'direct_sale' or not ux_can_open_direct_sale_payments"/>
<button name="action_ux_open_direct_returns" string="Direct Returns" type="object" class="btn-secondary" invisible="outlet_operation_mode != 'direct_sale' or not ux_can_open_direct_returns"/>
<button name="action_ux_collect_payment" string="Collect Payment" type="object" class="btn-secondary" invisible="outlet_operation_mode != 'direct_sale' or not ux_can_review_settlement or ux_primary_action == 'collect_payment' or ux_primary_action == 'confirm_payments'"/>
</xpath>
<xpath expr="//sheet" position="inside">
<field name="route_operation_mode" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="outlet_operation_mode" invisible="1"/>
<field name="visit_execution_mode" invisible="1"/>
<field name="visit_execution_mode_label" invisible="1"/>
<field name="ux_stage" invisible="1"/>
<field name="ux_primary_action" invisible="1"/>
<field name="ux_stage_title" invisible="1"/>
<field name="ux_stage_help" invisible="1"/>
<field name="ux_can_create_direct_sale" invisible="1"/>
<field name="ux_can_open_direct_sale_orders" invisible="1"/>
<field name="ux_can_open_direct_sale_payments" invisible="1"/>
<field name="ux_can_create_direct_return" invisible="1"/>
<field name="ux_can_open_direct_returns" invisible="1"/>
<field name="ux_can_no_sale" invisible="1"/>
<field name="ux_can_no_return" invisible="1"/>
<field name="ux_can_finish_visit" invisible="1"/>
<field name="ux_can_review_settlement" invisible="1"/>
<field name="ux_can_receipt_actions" invisible="1"/>
</xpath>
<xpath expr="//group[.//field[@name='visit_mode']]" position="inside">
<field name="visit_execution_mode_label" string="Execution Mode" readonly="1" widget="badge" decoration-info="visit_execution_mode == 'direct_sales'" decoration-success="visit_execution_mode == 'consignment'"/>
</xpath>
<xpath expr="//page[field[@name='line_ids']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//page[field[@name='payment_ids']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//div[contains(@class, 'alert') and .//field[@name='ux_stage_help']]" position="after">
<group string="Direct Stop Actions" col="3" invisible="outlet_operation_mode != 'direct_sale' or not ux_can_receipt_actions">
<button name="action_print_direct_stop_settlement_receipt" string="Print Settlement Receipt" type="object" class="btn-primary"/>
<button name="action_send_direct_stop_whatsapp_outlet" string="WhatsApp Outlet" type="object" class="btn-secondary"/>
<button name="action_send_direct_stop_whatsapp_supervisor" string="WhatsApp Supervisor" type="object" class="btn-secondary"/>
</group>
<group string="Direct Stop Operational Summary" col="3" invisible="outlet_operation_mode != 'direct_sale'">
<group>
<field name="direct_stop_previous_due_amount" readonly="1"/>
<field name="direct_stop_previous_due_since_date" readonly="1"/>
<field name="direct_stop_sales_total" readonly="1"/>
</group>
<group>
<field name="direct_stop_returns_total" readonly="1"/>
<field name="direct_stop_current_net_amount" readonly="1"/>
<field name="direct_stop_grand_due_amount" readonly="1"/>
</group>
<group>
<field name="direct_stop_settlement_paid_amount" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" readonly="1"/>
<field name="direct_stop_credit_amount" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
</group>
</xpath>
<xpath expr="//div[field[@name='outlet_decision_flags_html']]/preceding-sibling::separator[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or not outlet_decision_flags_html</attribute>
</xpath>
<xpath expr="//div[field[@name='outlet_decision_flags_html']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or not outlet_decision_flags_html</attribute>
</xpath>
<xpath expr="//group[.//field[@name='debt_policy_reason']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='slow_moving_line_count']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='visit_planning_reason']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='outlet_open_promise_count'] and .//field[@name='collection_priority_reason']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='outlet_aging_0_30_amount'] and .//field[@name='debt_policy_reason']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='slow_moving_line_count'] and .//field[@name='oldest_days_on_shelf']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[.//field[@name='recommended_visit_frequency'] and .//field[@name='visit_planning_reason']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
</field>
</record>
