<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_pda_form_stepflow_inherit" model="ir.ui.view">
        <field name="name">route.visit.pda.form.stepflow.inherit</field>
        <field name="model">route.visit</field>
        <field name="priority" eval="1000"/>
        <field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form/header/button[@name='action_load_previous_balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_start_visit']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_cancel_process']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_open_scan_wizard']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_set_reconciled']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_generate_refill_proposal']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_confirm_all_payments']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_skip_collection']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_create_sale_order']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_open_end_visit_wizard']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_update_outlet_balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_set_done_process']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_prepare_internal_transfer']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='action_view_pending_refill']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form/header" position="inside">
                <field name="ux_primary_action" invisible="1"/>

                <button name="action_ux_start_visit"
                        type="object"
                        string="Start Visit"
                        class="btn btn-primary"
                        invisible="ux_primary_action != 'start_visit'"/>

                <button name="action_ux_load_previous_balance"
                        type="object"
                        string="Load Previous Balance"
                        class="btn btn-primary"
                        invisible="ux_primary_action != 'load_previous_balance'"/>

                <button name="action_ux_scan_shelf"
                        type="object"
                        string="Scan Shelf"
                        class="btn btn-primary"
                        invisible="ux_primary_action != 'scan_shelf'"/>

                <button name="action_ux_reconcile_count"
                        type="object"
                        string="Reconcile Count"
                        class="btn btn-primary"
                        invisible="ux_primary_action != 'reconcile_count'"/>

                <button name="action_ux_finalize_visit"
                        type="object"
                        string="Finalize Visit"
                        class="btn btn-primary"
                        invisible="ux_primary_action != 'finalize_visit'"/>
            </xpath>

            <xpath expr="//form/sheet" position="inside">
                <div class="alert alert-info mb-3" role="alert">
                    <div class="fw-bold">
                        <field name="ux_stage_title" nolabel="1" readonly="1"/>
                    </div>
                    <div>
                        <field name="ux_stage_help" nolabel="1" readonly="1"/>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
