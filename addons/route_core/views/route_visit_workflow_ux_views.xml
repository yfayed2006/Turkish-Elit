<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_pda_form_stepflow_inherit" model="ir.ui.view">
        <field name="name">route.visit.pda.form.stepflow.inherit</field>
        <field name="model">route.visit</field>
        <field name="priority" eval="1000"/>
        <field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form/header" position="replace">
                <header>
                    <field name="ux_primary_action" invisible="1"/>

                    <button name="action_ux_start_visit"
                            type="object"
                            string="Start Visit"
                            class="btn btn-primary"
                            invisible="ux_primary_action != 'start_visit'"/>

                    <button name="action_ux_load_previous_balance"
                            type="object"
                            string="Load Previous Balance"
                            class="btn btn-primary"
                            invisible="ux_primary_action != 'load_previous_balance'"/>

                    <button name="action_ux_scan_shelf"
                            type="object"
                            string="Scan Shelf"
                            class="btn btn-primary"
                            invisible="ux_primary_action != 'scan_shelf'"/>

                    <button name="action_ux_reconcile_count"
                            type="object"
                            string="Reconcile Count"
                            class="btn btn-primary"
                            invisible="ux_primary_action != 'reconcile_count'"/>

                    <button name="action_ux_finalize_visit"
                            type="object"
                            string="Finalize Visit"
                            class="btn btn-primary"
                            invisible="ux_primary_action != 'finalize_visit'"/>

                    <field name="visit_process_state"
                           widget="statusbar"
                           statusbar_visible="pending,checked_in,counting,reconciled,collection_done,ready_to_close,done"/>

                    <field name="state" invisible="1"/>
                </header>
            </xpath>

            <xpath expr="//form/sheet" position="inside">
                <div class="alert alert-info mb-3" role="alert">
                    <div class="fw-bold">
                        <field name="ux_stage_title" nolabel="1" readonly="1"/>
                    </div>
                    <div>
                        <field name="ux_stage_help" nolabel="1" readonly="1"/>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
