<odoo>
<record id="view_route_visit_form_workflow_ux" model="ir.ui.view">
<field name="name">route.visit.form.workflow.ux</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//header/field[@name='visit_process_state']" position="before">
<button name="action_ux_create_direct_sale" string="Yes, Create Sale" type="object" class="btn-primary" invisible="ux_primary_action != 'direct_sale_decision'"/>
<button name="action_ux_no_sale" string="No Sale" type="object" class="btn-secondary" invisible="ux_primary_action != 'direct_sale_decision'"/>
<button name="action_ux_create_direct_return" string="Yes, Create Return" type="object" class="btn-primary" invisible="ux_primary_action != 'direct_return_decision' or not route_enable_direct_return"/>
<button name="action_ux_no_return" string="No Return" type="object" class="btn-secondary" invisible="ux_primary_action != 'direct_return_decision'"/>
<button name="action_ux_open_direct_sale_orders" string="Direct Sale Orders" type="object" class="btn-secondary" invisible="visit_execution_mode != 'direct_sales' or not ux_can_open_direct_sale_orders"/>
<button name="action_ux_open_direct_sale_payments" string="Direct Sale Payments" type="object" class="btn-secondary" invisible="visit_execution_mode != 'direct_sales' or not ux_can_open_direct_sale_payments"/>
<button name="action_ux_open_direct_returns" string="Direct Returns" type="object" class="btn-secondary" invisible="visit_execution_mode != 'direct_sales' or not ux_can_open_direct_returns"/>
</xpath>
<xpath expr="//sheet" position="inside">
<field name="route_operation_mode" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="outlet_operation_mode" invisible="1"/>
<field name="visit_execution_mode" invisible="1"/>
<field name="visit_execution_mode_label" invisible="1"/>
<field name="ux_stage" invisible="1"/>
<field name="ux_primary_action" invisible="1"/>
<field name="ux_stage_title" invisible="1"/>
<field name="ux_stage_help" invisible="1"/>
<field name="ux_can_create_direct_sale" invisible="1"/>
<field name="ux_can_open_direct_sale_orders" invisible="1"/>
<field name="ux_can_open_direct_sale_payments" invisible="1"/>
<field name="ux_can_create_direct_return" invisible="1"/>
<field name="ux_can_open_direct_returns" invisible="1"/>
<field name="ux_can_no_sale" invisible="1"/>
<field name="ux_can_no_return" invisible="1"/>
<field name="ux_can_finish_visit" invisible="1"/>
<field name="direct_stop_order_count" invisible="1"/>
<field name="direct_stop_return_count" invisible="1"/>
<field name="direct_stop_sales_total" invisible="1"/>
<field name="direct_stop_returns_total" invisible="1"/>
<field name="direct_stop_credit_amount" invisible="1"/>
<field name="direct_stop_credit_policy" invisible="1"/>
<field name="net_due_amount" invisible="1"/>
<field name="collected_amount" invisible="1"/>
<field name="remaining_due_amount" invisible="1"/>
</xpath>
<xpath expr="//group[.//field[@name='visit_mode']]" position="inside">
<field name="visit_execution_mode_label" string="Execution Mode" readonly="1" widget="badge" decoration-info="visit_execution_mode == 'direct_sales'" decoration-success="visit_execution_mode == 'consignment'"/>
</xpath>
<xpath expr="//page[field[@name='line_ids']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//page[field[@name='payment_ids']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//div[field[@name='outlet_decision_flags_html']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or not outlet_decision_flags_html</attribute>
</xpath>
<xpath expr="//group[field[@name='outlet_aging_0_30_amount']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[field[@name='slow_moving_line_count']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//group[field[@name='outlet_health_score']]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales'</attribute>
</xpath>
</field>
</record>
