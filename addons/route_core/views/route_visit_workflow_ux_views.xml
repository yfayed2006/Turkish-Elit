<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_form_workflow_ux" model="ir.ui.view">
        <field name="name">route.visit.form.workflow.ux</field>
        <field name="model">route.visit</field>
        <field name="inherit_id" ref="route_core.view_route_visit_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="replace">
                <header>
                    <button
                        name="action_ux_start_visit"
                        string="Start Visit"
                        type="object"
                        class="btn-primary"
                        invisible="ux_primary_action != 'start_visit'"
                    />
                    <button
                        name="action_ux_load_previous_balance"
                        string="Load Previous Balance"
                        type="object"
                        class="btn-primary"
                        invisible="ux_primary_action != 'load_previous_balance'"
                    />
                    <button
                        name="action_ux_scan_shelf"
                        string="Scan Shelf"
                        type="object"
                        class="btn-primary"
                        invisible="ux_primary_action != 'scan_shelf'"
                    />
                    <button
                        name="action_ux_reconcile_count"
                        string="Reconcile"
                        type="object"
                        class="btn-primary"
                        invisible="ux_primary_action != 'reconcile_count'"
                    />
                    <button
                        name="action_ux_finalize_visit"
                        string="Finish Process"
                        type="object"
                        class="btn-success"
                        invisible="ux_primary_action != 'finalize_visit'"
                    />
                    <button
                        name="action_set_cancelled_process"
                        string="Cancel Process"
                        type="object"
                        class="btn-secondary"
                        invisible="visit_process_state in ('done', 'cancelled')"
                    />

                    <field
                        name="visit_process_state"
                        widget="statusbar"
                        statusbar_visible="pending,checked_in,counting,reconciled,collection_done,ready_to_close,done,cancelled"
                    />
                </header>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <field name="ux_primary_action" invisible="1"/>
                <field name="ux_stage" invisible="1"/>
                <field name="ux_stage_title" invisible="1"/>
                <field name="ux_stage_help" invisible="1"/>
                <field name="ux_can_scan_barcode" invisible="1"/>
                <field name="ux_can_create_sale_order" invisible="1"/>
                <field name="ux_can_view_sale_order" invisible="1"/>
                <field name="ux_can_open_pending_refill" invisible="1"/>

                <div class="alert alert-info mb-3" role="alert">
                    <strong>
                        <field name="ux_stage_title" readonly="1" nolabel="1"/>
                    </strong>
                    <div class="mt-1">
                        <field name="ux_stage_help" readonly="1" nolabel="1"/>
                    </div>
                </div>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="replace">
                <div class="oe_button_box" name="button_box">
                    <button
                        name="action_ux_scan_shelf"
                        string="Scan Barcode"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-barcode"
                        invisible="not ux_can_scan_barcode"
                    />

                    <button
                        name="action_ux_create_sale_order"
                        string="Create Sale Order"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shopping-cart"
                        invisible="not ux_can_create_sale_order"
                    />

                    <button
                        name="action_ux_view_sale_order"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-external-link"
                        invisible="not ux_can_view_sale_order"
                    >
                        <field name="sale_order_count" string="View Sale Order" widget="statinfo"/>
                    </button>

                    <button
                        name="action_view_pending_refill"
                        string="Pending Refill"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-refresh"
                        invisible="not ux_can_open_pending_refill"
                    />
                </div>
            </xpath>
        </field>
    </record>

