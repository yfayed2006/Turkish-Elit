<odoo>
<record id="view_route_visit_form_workflow_ux" model="ir.ui.view">
<field name="name">route.visit.form.workflow.ux</field>
<field name="model">route.visit</field>
<field name="priority">90</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//header/field[@name='visit_process_state']" position="before">
<button name="action_ux_open_direct_sale_orders" string="Direct Sale Orders" type="object" class="btn-secondary" invisible="(visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales') or not ux_can_open_direct_sale_orders"/>
<button name="action_ux_open_direct_sale_payments" string="Direct Sale Payments" type="object" class="btn-secondary" invisible="(visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales') or not ux_can_open_direct_sale_payments"/>
<button name="action_ux_open_direct_returns" string="Direct Returns" type="object" class="btn-secondary" invisible="(visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales') or not ux_can_open_direct_returns"/>
<button name="action_ux_collect_payment" string="Collect Payment" type="object" class="btn-secondary" invisible="(visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales') or not ux_can_review_settlement or ux_primary_action == 'collect_payment' or ux_primary_action == 'confirm_payments'"/>
<button name="action_print_direct_stop_settlement_receipt" string="Print Settlement Receipt" type="object" class="btn-secondary" invisible="not ux_can_receipt_actions"/>
<button name="action_send_direct_stop_whatsapp_outlet" string="WhatsApp Outlet" type="object" class="btn-secondary" invisible="not ux_can_receipt_actions"/>
<button name="action_send_direct_stop_whatsapp_supervisor" string="WhatsApp Supervisor" type="object" class="btn-secondary" invisible="not ux_can_receipt_actions"/>
</xpath>
<xpath expr="//sheet" position="inside">
<field name="route_operation_mode" invisible="1"/>
<field name="route_enable_direct_sale" invisible="1"/>
<field name="route_enable_direct_return" invisible="1"/>
<field name="outlet_operation_mode" invisible="1"/>
<field name="visit_execution_mode" invisible="1"/>
<field name="visit_execution_mode_label" invisible="1"/>
<field name="ux_stage" invisible="1"/>
<field name="ux_primary_action" invisible="1"/>
<field name="ux_stage_title" invisible="1"/>
<field name="ux_stage_help" invisible="1"/>
<field name="ux_can_create_direct_sale" invisible="1"/>
<field name="ux_can_open_direct_sale_orders" invisible="1"/>
<field name="ux_can_open_direct_sale_payments" invisible="1"/>
<field name="ux_can_create_direct_return" invisible="1"/>
<field name="ux_can_open_direct_returns" invisible="1"/>
<field name="ux_can_no_sale" invisible="1"/>
<field name="ux_can_no_return" invisible="1"/>
<field name="ux_can_finish_visit" invisible="1"/>
<field name="ux_can_review_settlement" invisible="1"/>
<field name="ux_can_receipt_actions" invisible="1"/>
</xpath>
<xpath expr="//field[@name='visit_mode']/ancestor::group[1]" position="inside">
<field name="visit_execution_mode_label" string="Execution Mode" readonly="1" widget="badge" decoration-info="visit_execution_mode == 'direct_sales'" decoration-success="visit_execution_mode == 'consignment'"/>
</xpath>
<xpath expr="//field[@name='line_ids']/ancestor::page[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='payment_ids']/ancestor::page[1]" position="attributes">
<attribute name="invisible">False</attribute>
</xpath>
<xpath expr="//field[@name='outlet_decision_flags_html']/ancestor::div[1]" position="before">
<group string="Direct Stop Summary" col="3" invisible="visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales'">
<group>
<field name="direct_stop_previous_due_amount" readonly="1"/>
<field name="direct_stop_previous_due_since_date" readonly="1"/>
<field name="direct_stop_sales_total" readonly="1"/>
</group>
<group>
<field name="direct_stop_returns_total" readonly="1"/>
<field name="direct_stop_current_net_amount" readonly="1"/>
<field name="direct_stop_grand_due_amount" readonly="1"/>
</group>
<group>
<field name="direct_stop_settlement_paid_amount" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" readonly="1"/>
<field name="direct_stop_credit_amount" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
</group>
</xpath>
<xpath expr="//field[@name='outlet_decision_flags_html']/ancestor::div[1]/preceding-sibling::separator[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales' or not outlet_decision_flags_html</attribute>
</xpath>
<xpath expr="//field[@name='outlet_decision_flags_html']/ancestor::div[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales' or not outlet_decision_flags_html</attribute>
</xpath>
<xpath expr="//field[@name='debt_policy_reason']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='slow_moving_line_count']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='visit_planning_reason']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='collection_priority_reason']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='outlet_aging_0_30_amount']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='oldest_days_on_shelf']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='recommended_visit_frequency']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='remaining_due_amount']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='pending_near_expiry_line_count']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='outlet_health_status']/ancestor::group[2]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
<xpath expr="//field[@name='start_datetime']/ancestor::group[1]" position="after">
<group invisible="visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales'">
<field name="direct_stop_sale_status" readonly="1" widget="badge" decoration-success="direct_stop_sale_status == 'yes'" decoration-warning="direct_stop_sale_status == 'pending'" decoration-info="direct_stop_sale_status == 'no'"/>
<field name="direct_stop_return_status" readonly="1" widget="badge" decoration-success="direct_stop_return_status == 'yes'" decoration-warning="direct_stop_return_status == 'pending'" decoration-info="direct_stop_return_status == 'no'"/>
<field name="direct_stop_order_count" readonly="1"/>
</group>
<group invisible="visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales'">
<field name="direct_stop_return_count" readonly="1"/>
<field name="direct_stop_settlement_ready" readonly="1"/>
<field name="direct_stop_credit_policy" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
</xpath>
<xpath expr="//field[@name='payment_ids']/ancestor::page[1]" position="before">
<page string="Direct Stop" invisible="visit_execution_mode != 'direct_sales' and outlet_operation_mode != 'direct_sale' and outlet_operation_mode != 'direct_sales'">
<group col="2">
<group>
<field name="direct_stop_sale_status" readonly="1" widget="badge" decoration-success="direct_stop_sale_status == 'yes'" decoration-warning="direct_stop_sale_status == 'pending'" decoration-info="direct_stop_sale_status == 'no'"/>
<field name="direct_stop_return_status" readonly="1" widget="badge" decoration-success="direct_stop_return_status == 'yes'" decoration-warning="direct_stop_return_status == 'pending'" decoration-info="direct_stop_return_status == 'no'"/>
<field name="direct_stop_order_count" readonly="1"/>
<field name="direct_stop_return_count" readonly="1"/>
</group>
<group>
<field name="direct_stop_previous_due_amount" readonly="1"/>
<field name="direct_stop_sales_total" readonly="1"/>
<field name="direct_stop_returns_total" readonly="1"/>
<field name="direct_stop_grand_due_amount" readonly="1"/>
</group>
</group>
<separator string="Direct Sale Orders" invisible="not direct_stop_order_ids"/>
<field name="direct_stop_order_ids" readonly="1" invisible="not direct_stop_order_ids">
<list create="0" delete="0">
<field name="name"/>
<field name="date_order"/>
<field name="state"/>
<field name="amount_total"/>
</list>
</field>
<separator string="Direct Returns" invisible="not direct_stop_return_ids"/>
<field name="direct_stop_return_ids" readonly="1" invisible="not direct_stop_return_ids">
<list create="0" delete="0">
<field name="name"/>
<field name="return_date"/>
<field name="state"/>
<field name="amount_total"/>
</list>
</field>
</page>
</xpath>
<xpath expr="//button[@name='action_visit_diagnostics']/ancestor::page[1]" position="attributes">
<attribute name="invisible">visit_execution_mode == 'direct_sales' or outlet_operation_mode == 'direct_sale' or outlet_operation_mode == 'direct_sales'</attribute>
</xpath>
</field>
</record>
