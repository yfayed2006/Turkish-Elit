<odoo>
<record id="view_route_shortage_tree" model="ir.ui.view">
<field name="name">route.shortage.tree</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<list string="Route Shortages">
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="user_id" optional="show"/>
<field name="vehicle_id" optional="show"/>
<field name="planned_date" optional="show"/>
<field name="planned_route_plan_id" optional="show"/>
<field name="line_count"/>
<field name="total_missing_qty"/>
<field name="total_remaining_qty"/>
<field name="state" widget="badge" decoration-info="state == 'open'" decoration-warning="state == 'planned'" decoration-success="state == 'done'" decoration-muted="state == 'cancel'"/>
</list>
</field>
</record>
<record id="view_route_shortage_form" model="ir.ui.view">
<field name="name">route.shortage.form</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<form string="Route Shortage">
<header>
<button name="action_mark_planned" type="object" string="Mark Planned" class="btn-primary" invisible="state in ('planned', 'done', 'cancel')"/>
<button name="action_mark_done" type="object" string="Mark Done" class="btn-primary" invisible="state in ('done', 'cancel')"/>
<button name="action_reopen" type="object" string="Reopen" class="btn-secondary" invisible="state == 'open'"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state == 'cancel'"/>
<button name="action_view_source_visit" type="object" string="Open Source Visit" class="btn-secondary" invisible="not source_visit_id"/>
<button name="action_view_planned_route_plan" type="object" string="Open Planned Route" class="btn-secondary" invisible="not planned_route_plan_id"/>
<field name="state" widget="statusbar" statusbar_visible="open,planned,done,cancel" nolabel="1"/>
</header>
<sheet>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<group string="Shortage Information" col="4">
<group>
<field name="date"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
</group>
<group>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="source_visit_id" readonly="1"/>
<field name="company_id" groups="base.group_multi_company"/>
</group>
<group string="Planning">
<field name="planned_date"/>
<field name="planned_route_plan_id"/>
</group>
<group string="Summary">
<field name="line_count" readonly="1"/>
<field name="product_count" readonly="1"/>
<field name="total_missing_qty" readonly="1"/>
<field name="total_remaining_qty" readonly="1"/>
</group>
</group>
<notebook>
<page string="Shortage Lines">
<field name="line_ids" nolabel="1">
<list editable="bottom">
<field name="product_id"/>
<field name="uom_id" readonly="1" optional="show"/>
<field name="qty_sold" readonly="1" optional="show"/>
<field name="qty_supplied" readonly="1" optional="show"/>
<field name="qty_missing"/>
<field name="qty_done"/>
<field name="qty_remaining" readonly="1"/>
<field name="unit_price" optional="show"/>
<field name="missing_value" readonly="1" optional="show"/>
<field name="remaining_value" readonly="1" optional="show"/>
<field name="state" widget="badge" decoration-info="state == 'open'" decoration-success="state == 'done'" decoration-muted="state == 'cancel'"/>
<field name="note" optional="show"/>
<field name="source_visit_line_id" readonly="1" optional="hide"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" placeholder="Internal notes for this shortage..."/>
</page>
</notebook>
</sheet>
<chatter/>
</form>
</field>
</record>
<record id="view_route_shortage_search" model="ir.ui.view">
<field name="name">route.shortage.search</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="state"/>
<filter name="filter_open" string="Open" domain="[('state', '=', 'open')]"/>
<filter name="filter_planned" string="Planned" domain="[('state', '=', 'planned')]"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
<separator/>
<filter name="group_by_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
</search>
</field>
</record>
<record id="view_route_shortage_line_tree" model="ir.ui.view">
<field name="name">route.shortage.line.tree</field>
<field name="model">route.shortage.line</field>
<field name="arch" type="xml">
<list string="Route Shortage Lines" create="0" delete="0">
<field name="shortage_id"/>
<field name="outlet_id"/>
<field name="product_id"/>
<field name="qty_missing"/>
<field name="qty_done"/>
<field name="qty_remaining"/>
<field name="missing_value" optional="show"/>
<field name="remaining_value" optional="show"/>
<field name="state" widget="badge" decoration-info="state == 'open'" decoration-success="state == 'done'" decoration-muted="state == 'cancel'"/>
</list>
</field>
</record>
<record id="action_route_shortage" model="ir.actions.act_window">
<field name="name">Route Shortages</field>
<field name="res_model">route.shortage</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_shortage_search"/>
<field name="context">{'default_user_id': uid}</field>
</record>
<record id="action_route_shortage_line" model="ir.actions.act_window">
<field name="name">Route Shortage Lines</field>
<field name="res_model">route.shortage.line</field>
<field name="view_mode">list,form</field>
</record>
<menuitem id="menu_route_shortage" name="Shortages" parent="menu_route_visit_root" action="action_route_shortage" sequence="26"/>
</odoo>
