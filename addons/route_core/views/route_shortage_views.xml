<odoo>
<record id="view_route_shortage_list" model="ir.ui.view">
<field name="name">route.shortage.list</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<list string="Shortages" create="0">
<field name="name"/>
<field name="date"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="user_id"/>
<field name="source_visit_id" string="Generated From Visit"/>
<field name="planned_route_plan_id"/>
<field name="line_count"/>
<field name="total_remaining_qty"/>
<field name="planned_date"/>
<field name="state" widget="badge" decoration-warning="state == 'open'" decoration-info="state == 'planned'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</list>
</field>
</record>
<record id="view_route_shortage_form" model="ir.ui.view">
<field name="name">route.shortage.form</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<form string="Shortage" create="0">
<header>
<button name="action_mark_planned" type="object" string="Mark Planned" class="btn-primary" invisible="state != 'open'"/>
<button name="action_mark_done" type="object" string="Mark Done" class="btn-success" invisible="state in ('done', 'cancel')"/>
<button name="action_reopen" type="object" string="Reopen" class="btn-secondary" invisible="state not in ('planned', 'done', 'cancel')"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state == 'cancel'"/>
<button name="action_view_source_visit" type="object" string="Open Generated Visit" class="btn-secondary" invisible="not source_visit_id"/>
<button name="action_view_planned_route_plan" type="object" string="Open Planned Route Plan" class="btn-secondary" invisible="not planned_route_plan_id"/>
<field name="state" widget="statusbar" statusbar_visible="open,planned,done,cancel"/>
</header>
<sheet>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
</div>
<group col="2">
<group>
<field name="date"/>
<field name="planned_date"/>
<field name="planned_route_plan_id" readonly="1"/>
<field name="source_visit_id" string="Generated From Visit" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1"/>
</group>
<group>
<field name="area_id" readonly="1"/>
<field name="vehicle_id" readonly="1"/>
<field name="user_id" readonly="1"/>
<field name="line_count" readonly="1"/>
<field name="total_remaining_qty" readonly="1"/>
</group>
</group>
<group>
<field name="note" placeholder="Supervisor notes..."/>
</group>
<notebook>
<page string="Shortage Lines">
<field name="line_ids">
<list editable="bottom">
<field name="product_id" readonly="1"/>
<field name="qty_sold" readonly="1"/>
<field name="qty_supplied" readonly="1"/>
<field name="qty_missing"/>
<field name="qty_done"/>
<field name="qty_remaining" readonly="1"/>
<field name="unit_price" readonly="1"/>
<field name="remaining_value" readonly="1"/>
<field name="state"/>
<field name="note"/>
</list>
</field>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_shortage_search" model="ir.ui.view">
<field name="name">route.shortage.search</field>
<field name="model">route.shortage</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="user_id"/>
<field name="source_visit_id" string="Generated From Visit"/>
<field name="planned_route_plan_id"/>
<filter name="filter_open" string="Open" domain="[('state', '=', 'open')]"/>
<filter name="filter_planned" string="Planned" domain="[('state', '=', 'planned')]"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
<separator/>
<filter name="group_by_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_plan" string="Route Plan" context="{'group_by': 'planned_route_plan_id'}"/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
</search>
</field>
</record>
<record id="action_route_shortage" model="ir.actions.act_window">
<field name="name">Shortages</field>
<field name="res_model">route.shortage</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_shortage_search"/>
<field name="context">{'search_default_filter_open': 1}</field>
<field name="help" type="html">
<p class="o_view_nocontent_smiling_face">Shortages generated from visits appear here for supervisor follow-up.</p>
</field>
</record>
<menuitem id="menu_route_shortage" name="Shortages" parent="menu_route_visit_root" action="action_route_shortage" sequence="30"/>
</odoo>
