<odoo>
<record id="view_route_outlet_form_ext_route_sales" model="ir.ui.view">
<field name="name">route.outlet.form.ext.route.sales</field>
<field name="model">route.outlet</field>
<field name="inherit_id" ref="route_core.view_route_outlet_form"/>
<field name="arch" type="xml">
<xpath expr="//page[@string='Summary']/group[@string='Financial Summary']" position="after">
<group string="Monthly Sales Trend" col="4">
<group>
<field name="sales_current_month" readonly="1"/>
</group>
<group>
<field name="sales_previous_month" readonly="1"/>
</group>
<group>
<field name="sales_two_months_ago" readonly="1"/>
</group>
<group>
<field name="sales_last_3_months_total" readonly="1"/>
</group>
</group>
</xpath>
</field>
</record>
</odoo>
