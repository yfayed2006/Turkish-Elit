<odoo>
<record id="view_route_outlet_form_setup_cleanup" model="ir.ui.view">
<field name="name">route.outlet.form.setup.cleanup</field>
<field name="model">route.outlet</field>
<field name="inherit_id" ref="route_core.view_route_outlet_form"/>
<field name="priority" eval="95"/>
<field name="arch" type="xml">
<xpath expr="//form/sheet/group/group[1]" position="replace">
<group>
<field name="code" readonly="1"/>
<field name="barcode"/>
<field name="route_country_id" required="1"/>
<field name="route_city_id" required="1" domain="[('country_id', '=', route_country_id)]" context="{'default_country_id': route_country_id}" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="area_id" string="Route Area" required="1" domain="[('city_id', '=', route_city_id)]" context="{'default_city_id': route_city_id}" options="{'no_quick_create': True, 'no_create_edit': False, 'no_open': False}"/>
<field name="route_area_name" invisible="1"/>
<field name="partner_id" domain="[('is_company', '=', True)]" context="{'default_is_company': True}" options="{'no_open': False}" required="outlet_operation_mode == 'direct_sale'"/>
<field name="outlet_operation_mode" widget="radio"/>
<field name="stock_location_id" invisible="outlet_operation_mode != 'consignment'"/>
<field name="direct_sale_pricelist_id" invisible="outlet_operation_mode != 'direct_sale'"/>
<field name="active"/>
</group>
</xpath>
</field>
</record>
</odoo>
