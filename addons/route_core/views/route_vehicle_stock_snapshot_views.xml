<odoo>
<record id="view_route_vehicle_stock_snapshot_kanban" model="ir.ui.view">
<field name="name">stock.quant.route.vehicle.snapshot.kanban</field>
<field name="model">stock.quant</field>
<field name="arch" type="xml">
<kanban class="route_pda_mobile_stock_kanban route_pda_mobile_stock_kanban_vehicle" create="0" edit="0" delete="0">
<field name="product_id"/>
<field name="route_barcode"/>
<field name="location_id"/>
<field name="lot_id"/>
<field name="route_expiry_date"/>
<field name="quantity"/>
<field name="available_quantity"/>
<field name="route_product_image_128"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_stock_card">
<div class="route_pda_stock_card_top">
<div class="route_pda_stock_thumb_wrap">
<field name="route_product_image_128" widget="image" class="route_pda_stock_thumb" options="{'size': [128, 128], 'preview_image': 'route_product_image_128'}"/>
</div>
<div class="route_pda_stock_qty_wrap">
<div class="route_pda_stock_qty">
<field name="quantity"/>
</div>
<div class="route_pda_stock_qty_label">Qty</div>
</div>
</div>
<div class="route_pda_stock_name">
<field name="product_id"/>
</div>
<div class="route_pda_stock_meta" t-if="record.route_barcode.raw_value">
Barcode:
<field name="route_barcode"/>
</div>
<div class="route_pda_stock_meta">
Available:
<field name="available_quantity"/>
</div>
<div class="route_pda_stock_meta" t-if="record.location_id.raw_value">
Location:
<field name="location_id"/>
</div>
<div class="route_pda_stock_meta" t-if="record.lot_id.raw_value">
Lot:
<field name="lot_id"/>
</div>
<div class="route_pda_stock_meta" t-if="record.route_expiry_date.raw_value">
Expiry:
<field name="route_expiry_date"/>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_vehicle_stock_snapshot_list" model="ir.ui.view">
<field name="name">stock.quant.route.vehicle.snapshot.list</field>
<field name="model">stock.quant</field>
<field name="arch" type="xml">
<list string="Stock Snapshot" create="0" edit="0" delete="0" default_order="product_id, location_id, lot_id">
<field name="product_id"/>
<field name="quantity"/>
<field name="available_quantity" optional="show"/>
<field name="route_barcode" optional="hide"/>
<field name="lot_id" optional="hide"/>
<field name="route_expiry_date" optional="hide"/>
<field name="location_id" optional="hide"/>
<field name="reserved_quantity" optional="hide"/>
<field name="in_date" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_vehicle_stock_snapshot_search" model="ir.ui.view">
<field name="name">stock.quant.route.vehicle.snapshot.search</field>
<field name="model">stock.quant</field>
<field name="arch" type="xml">
<search string="Vehicle Products Stock">
<field name="product_id"/>
<field name="route_barcode"/>
<field name="lot_id"/>
<field name="location_id"/>
<filter name="filter_vehicle_has_qty" string="Has Quantity" domain="[('quantity', '>', 0)]"/>
<filter name="filter_vehicle_negative_available" string="Negative Available" domain="[('available_quantity', '<', 0)]"/>
<filter name="filter_vehicle_zero_available" string="Zero Available" domain="[('available_quantity', '=', 0)]"/>
<filter name="filter_vehicle_with_lot" string="With Lot / Serial" domain="[('lot_id', '!=', False)]"/>
<filter name="filter_vehicle_with_expiry" string="With Expiry Date" domain="[('route_expiry_date', '!=', False)]"/>
<separator/>
<filter name="group_by_vehicle_product" string="Product" context="{'group_by': 'product_id'}"/>
<filter name="group_by_vehicle_location" string="Location" context="{'group_by': 'location_id'}"/>
<filter name="group_by_vehicle_lot" string="Lot" context="{'group_by': 'lot_id'}"/>
<searchpanel>
<field name="product_id" string="Product"/>
<field name="location_id" string="Location"/>
</searchpanel>
</search>
</field>
</record>
<record id="view_route_main_warehouse_stock_snapshot_search" model="ir.ui.view">
<field name="name">stock.quant.route.main.warehouse.snapshot.search</field>
<field name="model">stock.quant</field>
<field name="arch" type="xml">
<search string="Main Warehouse Products Stock">
<field name="product_id"/>
<field name="route_barcode"/>
<field name="lot_id"/>
<field name="location_id"/>
<filter name="filter_main_has_qty" string="Has Quantity" domain="[('quantity', '>', 0)]"/>
<filter name="filter_main_reserved_qty" string="Reserved Qty" domain="[('reserved_quantity', '>', 0)]"/>
<filter name="filter_main_available_less_than_qty" string="Available Less Than Qty" domain="[('available_quantity', '<', 0)]"/>
<filter name="filter_main_zero_available" string="Zero Available" domain="[('available_quantity', '=', 0)]"/>
<filter name="filter_main_with_lot" string="With Lot / Serial" domain="[('lot_id', '!=', False)]"/>
<filter name="filter_main_with_expiry" string="With Expiry Date" domain="[('route_expiry_date', '!=', False)]"/>
<separator/>
<filter name="group_by_main_product" string="Product" context="{'group_by': 'product_id'}"/>
<filter name="group_by_main_location" string="Location" context="{'group_by': 'location_id'}"/>
<filter name="group_by_main_lot" string="Lot" context="{'group_by': 'lot_id'}"/>
<searchpanel>
<field name="product_id" string="Product"/>
<field name="location_id" string="Location"/>
</searchpanel>
</search>
</field>
</record>
</odoo>
