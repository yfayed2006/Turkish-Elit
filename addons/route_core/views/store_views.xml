<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_store_tree" model="ir.ui.view">
        <field name="name">route.store.tree</field>
        <field name="model">route.store</field>
        <field name="arch" type="xml">
            <list string="Stores">
                <field name="sequence"/>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="visit_day"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_store_form" model="ir.ui.view">
        <field name="name">route.store.form</field>
        <field name="model">route.store</field>
        <field name="arch" type="xml">
            <form string="Store">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="visit_day"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Address">
                            <group>
                                <field name="street"/>
                                <field name="street2"/>
                                <field name="city"/>
                                <field name="zip"/>
                                <field name="country_id"/>
                            </group>
                        </page>

                        <page string="Location">
                            <group>
                                <field name="latitude"/>
                                <field name="longitude"/>
                            </group>
                        </page>

                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_store" model="ir.actions.act_window">
        <field name="name">Stores</field>
        <field name="res_model">route.store</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_route_core_root"
              name="Route Management"
              sequence="10"/>

    <menuitem id="menu_route_store"
              name="Stores"
              parent="menu_route_core_root"
              action="action_route_store"
              sequence="20"/>

</odoo>
