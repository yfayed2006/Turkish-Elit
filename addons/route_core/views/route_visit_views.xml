<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_list" model="ir.ui.view">
    <field name="name">route.visit.list</field>
    <field name="model">route.visit</field>
    <field name="arch" type="xml">
        <list string="Visits">
            <field name="visit_date"/>
            <field name="state" widget="badge"/>
            <field name="route_id"/>
            <field name="store_id"/>
            <field name="user_id"/>
            <field name="check_in"/>
            <field name="check_out"/>
            <field name="duration_minutes"/>
            <field name="active" optional="hide"/>
        </list>
    </field>
</record>
 <record id="view_route_visit_search" model="ir.ui.view">
    <field name="name">route.visit.search</field>
    <field name="model">route.visit</field>
    <field name="arch" type="xml">
        <search>
            <field name="route_id"/>
            <field name="store_id"/>
            <field name="user_id"/>
            <field name="visit_date"/>

            <filter name="my_visits_filter"
                    string="My Visits"
                    domain="[('user_id', '=', uid)]"/>

            <filter name="planned_filter"
                    string="Planned"
                    domain="[('state', '=', 'planned')]"/>

            <filter name="in_progress_filter"
                    string="In Progress"
                    domain="[('state', '=', 'in_progress')]"/>

            <filter name="done_filter"
                    string="Done"
                    domain="[('state', '=', 'done')]"/>

            <filter name="missed_filter"
                    string="Missed"
                    domain="[('state', '=', 'missed')]"/>

            <filter name="active_filter"
                    string="Active"
                    domain="[('active', '=', True)]"/>

            <filter name="group_by_route"
                    string="Group by Route"
                    context="{'group_by': 'route_id'}"/>

            <filter name="group_by_store"
                    string="Group by Store"
                    context="{'group_by': 'store_id'}"/>

            <filter name="group_by_user"
                    string="Group by Salesperson"
                    context="{'group_by': 'user_id'}"/>

            <filter name="group_by_state"
                    string="Group by Status"
                    context="{'group_by': 'state'}"/>

            <filter name="group_by_visit_date"
                    string="Group by Visit Date"
                    context="{'group_by': 'visit_date'}"/>
        </search>
    </field>
</record>

   <record id="view_route_visit_form" model="ir.ui.view">
    <field name="name">route.visit.form</field>
    <field name="model">route.visit</field>
    <field name="arch" type="xml">
        <form string="Visit">
            <header>
                <button name="action_start_visit"
                        string="Start Visit"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'planned'"/>

                <button name="action_finish_visit"
                        string="Finish Visit"
                        type="object"
                        class="btn-success"
                        invisible="state != 'in_progress'"/>

                <button name="action_mark_missed"
                        string="Mark Missed"
                        type="object"
                        invisible="state in ('done', 'missed')"/>

                <button name="action_create_sale_order"
                        string="Create Sale Order"
                        type="object"
                        class="btn-secondary"
                        invisible="sale_order_id != False"/>

                <button name="action_open_sale_order"
                        string="Open Sale Order"
                        type="object"
                        class="btn-secondary"
                        invisible="sale_order_id == False"/>

                <field name="state" widget="statusbar" statusbar_visible="planned,in_progress,done,missed"/>
            </header>

            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_sale_order"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                            invisible="sale_order_id == False">
                        <field name="sale_order_count" widget="statinfo" string="Sales Order"/>
                    </button>
                </div>

                <group>
                    <group>
                        <field name="route_id"/>
                        <field name="route_line_id"/>
                        <field name="store_id"/>
                        <field name="user_id"/>
                        <field name="visit_date"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="customer_id" readonly="1"/>
                        <field name="phone" readonly="1"/>
                        <field name="city" readonly="1"/>
                        <field name="check_in" readonly="1"/>
                        <field name="check_out" readonly="1"/>
                        <field name="duration_minutes" readonly="1"/>
                        <field name="sale_order_id" readonly="1"/>
                    </group>
                </group>

                <notebook>
                    <page string="Notes">
                        <field name="notes"/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

    <record id="action_route_visit" model="ir.actions.act_window">
        <field name="name">Visits</field>
        <field name="res_model">route.visit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_route_visit_search"/>
    </record>

    <menuitem id="menu_route_visit"
              name="Visits"
              parent="menu_route_core_root"
              action="action_route_visit"
              sequence="40"/>

</odoo>
