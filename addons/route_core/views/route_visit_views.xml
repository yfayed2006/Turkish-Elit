<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_tree" model="ir.ui.view">
        <field name="name">route.visit.tree</field>
        <field name="model">route.visit</field>
        <field name="arch" type="xml">
            <list string="Route Visits">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="area_id"/>
                <field name="user_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
                <field name="sale_order_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
            </list>
        </field>
    </record>

    <record id="view_route_visit_form" model="ir.ui.view">
        <field name="name">route.visit.form</field>
        <field name="model">route.visit</field>
        <field name="arch" type="xml">
            <form string="Route Visit">
                <header>
                    <button
                        name="action_start_visit"
                        string="Start Visit"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_create_sale_order"
                        string="Create Sale Order"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'in_progress'"
                    />
                    <button
                        name="action_end_visit"
                        string="End Visit"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'in_progress'"
                    />
                    <button
                        name="action_cancel"
                        string="Cancel"
                        type="object"
                        invisible="state in ('done', 'cancel')"
                    />
                    <button
                        name="action_reset_to_draft"
                        string="Reset to Draft"
                        type="object"
                        invisible="state != 'cancel'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancel"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_sale_order"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                            invisible="sale_order_count == 0"
                        >
                            <field name="sale_order_count" string="Sale Order" widget="statinfo"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date" readonly="state in ('done', 'cancel')"/>
                            <field name="partner_id" readonly="state != 'draft' or state in ('done', 'cancel')"/>
                            <field name="area_id" readonly="1"/>
                            <field name="user_id" readonly="state != 'draft' or state in ('done', 'cancel')"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="start_datetime" readonly="1"/>
                            <field name="end_datetime" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field
                                name="notes"
                                placeholder="Internal notes..."
                                readonly="state in ('done', 'cancel')"
                            />
                        </page>
                        <page string="No Sale Reason" invisible="not no_sale_reason">
                            <field name="no_sale_reason" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_route_visit_search" model="ir.ui.view">
        <field name="name">route.visit.search</field>
        <field name="model">route.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="area_id"/>
                <field name="user_id"/>
                <field name="date"/>

                <filter
                    name="filter_my_visits"
                    string="My Visits"
                    domain="[('user_id', '=', uid)]"
                />
                <filter
                    name="filter_today"
                    string="Today"
                    domain="[('date', '=', context_today())]"
                />
                <filter
                    name="filter_draft"
                    string="Draft"
                    domain="[('state', '=', 'draft')]"
                />
                <filter
                    name="filter_in_progress"
                    string="In Progress"
                    domain="[('state', '=', 'in_progress')]"
                />
                <filter
                    name="filter_done"
                    string="Done"
                    domain="[('state', '=', 'done')]"
                />
                <filter
                    name="filter_cancel"
                    string="Cancelled"
                    domain="[('state', '=', 'cancel')]"
                />
                <group expand="0" string="Group By">
                    <filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
                    <filter name="group_by_customer" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_date" string="Visit Date" context="{'group_by': 'date'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_route_visit" model="ir.actions.act_window">
        <field name="name">Route Visits</field>
        <field name="res_model">route.visit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_route_visit_search"/>
        <field name="context">
            {
                'search_default_filter_my_visits': 1,
                'search_default_filter_today': 1
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first route visit
            </p>
        </field>
    </record>

    <menuitem
        id="menu_route_visit_root"
        name="Route Visits"
        sequence="10"
    />

    <menuitem
        id="menu_route_visit"
        name="Visits"
        parent="menu_route_visit_root"
        action="action_route_visit"
        sequence="10"
    />

</odoo>
