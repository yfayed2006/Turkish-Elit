<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_tree" model="ir.ui.view">
        <field name="name">route.visit.tree</field>
        <field name="model">route.visit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <record id="view_route_visit_form" model="ir.ui.view">
        <field name="name">route.visit.form</field>
        <field name="model">route.visit</field>
        <field name="arch" type="xml">
            <form string="Route Visit">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="user_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_visit" model="ir.actions.act_window">
        <field name="name">Route Visits</field>
        <field name="res_model">route.visit</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_route_root" name="Route Management" sequence="10"/>
    <menuitem id="menu_route_visit" name="Visits" parent="menu_route_root" action="action_route_visit" sequence="20"/>

</odoo>
