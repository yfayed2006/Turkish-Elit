<field name="outlet_id"/>
<field name="partner_id"/>
<field name="area_id"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="shortage_count" string="Shortages" widget="badge" decoration-warning="shortage_count > 0"/>
<field name="visit_process_state"/>
<field name="state"/>
