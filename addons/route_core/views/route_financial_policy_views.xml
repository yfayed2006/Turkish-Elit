<odoo>
<!--   Dedicated management setup views for outlets.
      This action is the unified setup screen for creating and maintaining outlets:
      identity, customer, operation mode, pricing/commission, consignment stock, and location.  -->
<record id="view_route_outlet_management_config_search" model="ir.ui.view">
<field name="name">route.outlet.management.config.search</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<search string="Outlet Configuration">
<field name="name" string="Outlet"/>
<field name="code" string="Outlet Code"/>
<field name="barcode" string="Outlet Barcode"/>
<field name="partner_id" string="Customer"/>
<field name="route_country_id" string="Country"/>
<field name="route_city_id" string="City"/>
<field name="area_id" string="Area"/>
<field name="outlet_operation_mode" string="Operation Mode"/>
<field name="geo_status" string="Location Status"/>
<separator/>
<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
<filter name="filter_direct_sale" string="Direct Sale" domain="[('outlet_operation_mode', '=', 'direct_sale')]"/>
<filter name="filter_consignment" string="Consignment" domain="[('outlet_operation_mode', '=', 'consignment')]"/>
<filter name="filter_category_commission" string="Category Commission" domain="[('outlet_operation_mode', '=', 'consignment'), ('consignment_commission_mode', '=', 'category_rate')]"/>
<filter name="filter_fixed_commission" string="Fixed Commission" domain="[('outlet_operation_mode', '=', 'consignment'), ('consignment_commission_mode', '=', 'fixed_rate')]"/>
<filter name="filter_missing_location" string="Missing Location" domain="[('geo_status', '=', 'missing')]"/>
<filter name="filter_unverified_location" string="Unverified Location" domain="[('geo_status', '=', 'unverified')]"/>
<separator/>
<filter name="group_by_operation_mode" string="Operation Mode" context="{'group_by': 'outlet_operation_mode'}"/>
<filter name="group_by_commission_type" string="Commission Type" context="{'group_by': 'consignment_commission_mode'}"/>
<filter name="group_by_customer" string="Customer" context="{'group_by': 'partner_id'}"/>
<filter name="group_by_city" string="City" context="{'group_by': 'route_city_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_by_location_status" string="Location Status" context="{'group_by': 'geo_status'}"/>
</search>
</field>
</record>
<record id="view_route_outlet_management_config_list" model="ir.ui.view">
<field name="name">route.outlet.management.config.list</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<list string="Outlet Configuration" create="1" edit="1" delete="0">
<field name="code" string="Outlet Code" readonly="1" optional="show"/>
<field name="barcode" string="Outlet Barcode" optional="show"/>
<field name="name" string="Outlet"/>
<field name="outlet_operation_mode" string="Operation Mode" widget="badge" optional="show" decoration-info="outlet_operation_mode == 'consignment'" decoration-warning="outlet_operation_mode == 'direct_sale'"/>
<field name="partner_id" string="Customer" optional="show"/>
<field name="route_country_id" string="Country" optional="show"/>
<field name="route_city_id" string="City" optional="show"/>
<field name="area_id" string="Area" optional="show"/>
<field name="direct_sale_pricelist_id" string="Direct Sale Pricelist" optional="show"/>
<field name="consignment_commission_mode" string="Consignment Commission Type" optional="show"/>
<field name="default_commission_rate" string="Fixed Commission %" optional="show"/>
<field name="commission_line_count" string="Category Rules" optional="show"/>
<field name="geo_status" string="Location Status" widget="badge" optional="show" decoration-danger="geo_status == 'missing'" decoration-warning="geo_status == 'unverified'" decoration-success="geo_status == 'verified'"/>
<field name="geo_verified" string="Verified" optional="hide"/>
<field name="active" optional="show"/>
</list>
</field>
</record>
<record id="view_route_outlet_management_config_form" model="ir.ui.view">
<field name="name">route.outlet.management.config.form</field>
<field name="model">route.outlet</field>
<field name="arch" type="xml">
<form string="Outlet Configuration" create="1" edit="1" delete="0">
<header>
<button name="action_search_outlet_address_on_map" type="object" string="Search Address on Map" class="btn-secondary" invisible="not id"/>
<button name="action_open_outlet_map" type="object" string="Open Map" class="btn-primary" invisible="not id or geo_status == 'missing'"/>
<button name="action_open_outlet_navigation" type="object" string="Navigate" class="btn-secondary" invisible="not id or geo_status == 'missing'"/>
<button name="action_verify_outlet_location" type="object" string="Verify Location" class="btn-secondary" invisible="not id or geo_status == 'verified'"/>
<button name="action_mark_outlet_location_unverified" type="object" string="Mark Location Unverified" class="btn-secondary" invisible="not id or geo_status != 'verified'"/>
</header>
<sheet>
<div class="oe_title">
<h1>
<field name="name" placeholder="Outlet Name"/>
</h1>
</div>
<field name="company_id" invisible="1"/>
<field name="financial_policy" invisible="1"/>
<field name="consignment_settlement_policy" invisible="1"/>
<group string="Outlet Configuration" col="2">
<group string="Identity and Location">
<field name="code" readonly="1"/>
<field name="barcode"/>
<field name="route_country_id" required="1"/>
<field name="route_city_id" required="1" domain="[('country_id', '=', route_country_id)]" context="{'default_country_id': route_country_id}" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="area_id" string="Route Area" required="1" domain="[('city_id', '=', route_city_id)]" context="{'default_city_id': route_city_id}" options="{'no_quick_create': True, 'no_create_edit': False, 'no_open': False}"/>
<field name="route_area_name" invisible="1"/>
<field name="phone"/>
<field name="mobile"/>
<field name="active"/>
</group>
<group string="Customer and Operation">
<field name="partner_id" string="Related Customer" domain="[('is_company', '=', True)]" context="{'default_is_company': True}" options="{'no_open': False}" required="outlet_operation_mode == 'direct_sale'"/>
<field name="outlet_operation_mode" widget="radio"/>
<field name="effective_financial_policy_label" readonly="1"/>
<field name="direct_sale_pricelist_id" string="Direct Sale Pricelist" invisible="outlet_operation_mode != 'direct_sale'" required="outlet_operation_mode == 'direct_sale'" options="{'no_open': False}"/>
</group>
</group>
<group string="Consignment Configuration" col="2" invisible="outlet_operation_mode != 'consignment'">
<group string="Stock Setup">
<field name="consignment_stock_location_mode"/>
<field name="stock_location_id" invisible="consignment_stock_location_mode != 'select_existing'" domain="[('usage', '=', 'internal'), ('company_id', 'in', [False, company_id])]" options="{'no_create': False, 'no_create_edit': False, 'no_open': False}"/>
<field name="auto_stock_location_preview" readonly="1" invisible="consignment_stock_location_mode != 'auto_create'"/>
<field name="active_stock_tracking"/>
<field name="shelf_credit_limit_amount"/>
</group>
<group string="Commission Policy">
<field name="consignment_commission_mode" widget="radio"/>
<field name="default_commission_rate" string="Commission % / Default %"/>
<field name="commission_line_count" readonly="1" invisible="consignment_commission_mode != 'category_rate'"/>
</group>
</group>
<group string="Category Commission Rules" invisible="outlet_operation_mode != 'consignment' or consignment_commission_mode != 'category_rate'">
<div class="alert alert-info" role="alert">Use one commission percentage per product category. Press Load Product Categories after saving the outlet, then edit each category percentage as needed.</div>
<button name="action_generate_consignment_category_commissions" type="object" string="Load Product Categories" class="btn-primary" invisible="not id"/>
<div class="alert alert-warning" role="alert" invisible="id">Save the outlet first, then use Load Product Categories to create the category commission lines.</div>
<field name="commission_line_ids" nolabel="1">
<list editable="bottom">
<field name="active"/>
<field name="category_id" string="Product Category" options="{'no_create': True, 'no_open': False}"/>
<field name="commission_rate" string="Commission %"/>
<field name="note"/>
</list>
</field>
</group>
<group string="Location Setup" col="2">
<group string="Map Coordinates">
<field name="geo_status" widget="badge" readonly="1" decoration-danger="geo_status == 'missing'" decoration-warning="geo_status == 'unverified'" decoration-success="geo_status == 'verified'"/>
<field name="geo_latitude"/>
<field name="geo_longitude"/>
<field name="geo_display_coordinates" readonly="1"/>
<field name="geo_accuracy_m"/>
</group>
<group string="Map Address and Verification">
<field name="geo_address" placeholder="Optional map/search address..."/>
<field name="geo_source"/>
<field name="geo_verified"/>
<field name="geo_last_update" readonly="1"/>
<field name="geo_place_id"/>
</group>
<div class="alert alert-info" colspan="2" role="alert">Use the location fields here when creating or editing the outlet. Search Address on Map helps find the outlet, then enter Latitude and Longitude and press Verify Location after saving. The separate Outlet Location Review menu remains available for bulk review of missing or unverified outlet locations.</div>
</group>
</sheet>
</form>
</field>
</record>
<record id="action_route_outlet_management" model="ir.actions.act_window">
<field name="name">Outlets</field>
<field name="res_model">route.outlet</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_outlet_management_config_search"/>
<field name="context">{'create': 1, 'edit': 1, 'delete': 0}</field>
</record>
<record id="action_route_outlet_management_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_outlet_management_config_list"/>
<field name="act_window_id" ref="route_core.action_route_outlet_management"/>
</record>
<record id="action_route_outlet_management_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_outlet_management_config_form"/>
<field name="act_window_id" ref="route_core.action_route_outlet_management"/>
</record>
<record id="menu_route_outlet" model="ir.ui.menu">
<field name="action" ref="route_core.action_route_outlet_management"/>
</record>
<record id="view_route_outlet_form_financial_policy" model="ir.ui.view">
<field name="name">route.outlet.form.financial.policy</field>
<field name="model">route.outlet</field>
<field name="inherit_id" ref="route_core.view_route_outlet_form"/>
<field name="arch" type="xml">
<xpath expr="//sheet/notebook" position="inside">
<page name="route_financial_policy_page" string="Financial Policy">
<group string="Commercial Setup" col="2">
<group>
<field name="financial_policy" invisible="1"/>
<field name="consignment_settlement_policy" invisible="1"/>
<field name="outlet_operation_mode" widget="radio"/>
<field name="effective_financial_policy_label" readonly="1"/>
</group>
<group>
<field name="direct_sale_pricelist_id" string="Direct Sale Pricelist" invisible="outlet_operation_mode != 'direct_sale'" required="outlet_operation_mode == 'direct_sale'" options="{'no_open': False}"/>
<field name="consignment_commission_mode" widget="radio" invisible="outlet_operation_mode != 'consignment'"/>
<field name="default_commission_rate" string="Commission % / Default %" invisible="outlet_operation_mode != 'consignment'"/>
<field name="commission_line_count" readonly="1" invisible="outlet_operation_mode != 'consignment' or consignment_commission_mode != 'category_rate'"/>
</group>
</group>
<group string="Consignment Category Commission" invisible="outlet_operation_mode != 'consignment' or consignment_commission_mode != 'category_rate'">
<div class="alert alert-info" role="alert">Use one commission percentage per product category. Press Load Product Categories after saving the outlet, then edit each category percentage as needed.</div>
<button name="action_generate_consignment_category_commissions" type="object" string="Load Product Categories" class="btn-primary" invisible="not id"/>
<field name="commission_line_ids" nolabel="1">
<list editable="bottom">
<field name="active"/>
<field name="category_id" string="Product Category" options="{'no_create': True, 'no_open': False}"/>
<field name="commission_rate" string="Commission %"/>
<field name="note"/>
</list>
</field>
</group>
</page>
<page name="route_location_setup_page" string="Location Setup">
<group string="Map Actions" invisible="not id">
<button name="action_search_outlet_address_on_map" type="object" string="Search Address on Map" class="btn-secondary"/>
<button name="action_open_outlet_map" type="object" string="Open Map" class="btn-primary" invisible="geo_status == 'missing'"/>
<button name="action_open_outlet_navigation" type="object" string="Navigate" class="btn-secondary" invisible="geo_status == 'missing'"/>
<button name="action_verify_outlet_location" type="object" string="Verify Location" class="btn-secondary" invisible="geo_status == 'verified'"/>
<button name="action_mark_outlet_location_unverified" type="object" string="Mark Location Unverified" class="btn-secondary" invisible="geo_status != 'verified'"/>
</group>
<group string="Outlet Location" col="2">
<group>
<field name="geo_status" widget="badge" readonly="1" decoration-danger="geo_status == 'missing'" decoration-warning="geo_status == 'unverified'" decoration-success="geo_status == 'verified'"/>
<field name="geo_latitude"/>
<field name="geo_longitude"/>
<field name="geo_display_coordinates" readonly="1"/>
<field name="geo_accuracy_m"/>
</group>
<group>
<field name="geo_address" placeholder="Optional map/search address..."/>
<field name="geo_source"/>
<field name="geo_verified"/>
<field name="geo_last_update" readonly="1"/>
<field name="geo_place_id"/>
</group>
<div class="alert alert-info" colspan="2" role="alert">Use Search Address on Map to open the outlet in the selected map provider. After confirming the exact outlet position, enter Latitude and Longitude, save, then verify the location.</div>
</group>
</page>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_form_financial_policy" model="ir.ui.view">
<field name="name">route.visit.pda.form.financial.policy</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='line_ids']//field[@name='sold_amount']" position="after">
<field name="route_commission_rate" string="Commission %" readonly="1" optional="hide"/>
<field name="route_commission_amount" string="Commission" readonly="1" optional="hide"/>
<field name="route_net_payable_amount" string="Net Payable" readonly="1" optional="hide"/>
</xpath>
<xpath expr="//field[@name='consignment_current_visit_return_amount']/ancestor::div[contains(@class, 'route_mobile_info_card')][1]" position="after">
<div class="route_mobile_info_card" invisible="visit_execution_mode == 'direct_sales' or consignment_commission_amount == 0">
<div class="route_mobile_info_label">Commission</div>
<div class="route_mobile_info_value">
<field name="consignment_commission_amount" readonly="1" nolabel="1"/>
</div>
</div>
</xpath>
</field>
</record>
<record id="view_route_visit_form_financial_policy" model="ir.ui.view">
<field name="name">route.visit.form.financial.policy</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='line_ids']//field[@name='sold_amount']" position="after">
<field name="route_commission_rate" string="Commission %" readonly="1" optional="hide"/>
<field name="route_commission_amount" string="Commission" readonly="1" optional="hide"/>
<field name="route_net_payable_amount" string="Net Payable" readonly="1" optional="hide"/>
</xpath>
</field>
</record>
<record id="view_sale_order_form_route_financial_policy" model="ir.ui.view">
<field name="name">sale.order.form.route.financial.policy</field>
<field name="model">sale.order</field>
<field name="inherit_id" ref="route_core.view_sale_order_form_route_direct_sale"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='route_outlet_id']" position="after">
<field name="pricelist_id" invisible="route_order_mode != 'direct_sale'" options="{'no_open': False}"/>
</xpath>
</field>
</record>
</odoo>
