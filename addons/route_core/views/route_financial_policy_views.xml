<odoo>
<record id="view_route_outlet_form_financial_policy" model="ir.ui.view">
<field name="name">route.outlet.form.financial.policy</field>
<field name="model">route.outlet</field>
<field name="inherit_id" ref="route_core.view_route_outlet_form"/>
<field name="arch" type="xml">
<xpath expr="//sheet/group/group/field[@name='default_commission_rate']" position="after">
<field name="financial_policy"/>
<field name="consignment_settlement_policy" invisible="outlet_operation_mode != 'consignment'"/>
<field name="effective_financial_policy_label" readonly="1"/>
</xpath>
<xpath expr="//sheet/notebook" position="inside">
<page string="Financial Policy">
<group string="Commercial Setup" col="2">
<group>
<field name="outlet_operation_mode" readonly="1"/>
<field name="financial_policy"/>
<field name="effective_financial_policy_label" readonly="1"/>
</group>
<group>
<field name="direct_sale_pricelist_id" invisible="outlet_operation_mode != 'direct_sale'" options="{'no_open': False}"/>
<field name="default_commission_rate" invisible="outlet_operation_mode != 'consignment'"/>
<field name="consignment_settlement_policy" invisible="outlet_operation_mode != 'consignment'"/>
<field name="commission_line_count" readonly="1" invisible="outlet_operation_mode != 'consignment'"/>
</group>
</group>
<group string="Consignment Category Commission" invisible="outlet_operation_mode != 'consignment'">
<div class="alert alert-info" role="alert">
Define commission percentages by product category. When settlement is set to
<strong>Collect Net After Category Commission</strong>
, the visit due amount is calculated from sold value minus returns and category commission.
</div>
<button name="action_generate_consignment_category_commissions" type="object" string="Load Product Categories" class="btn-primary" invisible="not id"/>
<field name="commission_line_ids" nolabel="1">
<list editable="bottom">
<field name="active"/>
<field name="category_id" options="{'no_create': True, 'no_open': False}"/>
<field name="commission_rate"/>
<field name="note"/>
</list>
</field>
</group>
</page>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_form_financial_policy" model="ir.ui.view">
<field name="name">route.visit.pda.form.financial.policy</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='line_ids']//field[@name='sold_amount']" position="after">
<field name="route_commission_rate" string="Commission %" readonly="1" optional="hide"/>
<field name="route_commission_amount" string="Commission" readonly="1" optional="hide"/>
<field name="route_net_payable_amount" string="Net Payable" readonly="1" optional="hide"/>
</xpath>
<xpath expr="//field[@name='consignment_current_visit_return_amount']/ancestor::div[contains(@class, 'route_mobile_info_card')][1]" position="after">
<div class="route_mobile_info_card" invisible="visit_execution_mode == 'direct_sales' or consignment_commission_amount == 0">
<div class="route_mobile_info_label">Commission</div>
<div class="route_mobile_info_value">
<field name="consignment_commission_amount" readonly="1" nolabel="1"/>
</div>
</div>
</xpath>
</field>
</record>
<record id="view_route_visit_form_financial_policy" model="ir.ui.view">
<field name="name">route.visit.form.financial.policy</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='line_ids']//field[@name='sold_amount']" position="after">
<field name="route_commission_rate" string="Commission %" readonly="1" optional="hide"/>
<field name="route_commission_amount" string="Commission" readonly="1" optional="hide"/>
<field name="route_net_payable_amount" string="Net Payable" readonly="1" optional="hide"/>
</xpath>
</field>
</record>
<record id="view_sale_order_form_route_financial_policy" model="ir.ui.view">
<field name="name">sale.order.form.route.financial.policy</field>
<field name="model">sale.order</field>
<field name="inherit_id" ref="route_core.view_sale_order_form_route_direct_sale"/>
<field name="arch" type="xml">
<xpath expr="//field[@name='route_outlet_id']" position="after">
<field name="pricelist_id" invisible="route_order_mode != 'direct_sale'" options="{'no_open': False}"/>
</xpath>
</field>
</record>
</odoo>
