<odoo>
<record id="view_route_plan_list" model="ir.ui.view">
<field name="name">route.plan.list</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<list string="Route Plans">
<field name="name" string="Plan Ref"/>
<field name="date"/>
<field name="user_id" optional="hide"/>
<field name="vehicle_id"/>
<field name="weekly_schedule_id" optional="show"/>
<field name="planning_finalized" optional="show"/>
<field name="line_count" string="Visits"/>
<field name="visit_count" string="Executed" optional="show"/>
<field name="area_summary" string="Areas" optional="show"/>
<field name="outlet_summary" string="Outlets"/>
<field name="state" string="Status" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</list>
</field>
</record>
<record id="view_route_plan_salesperson_list" model="ir.ui.view">
<field name="name">route.plan.salesperson.list</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<list string="My Daily Plans" create="0" edit="0" delete="0">
<field name="date"/>
<field name="vehicle_id"/>
<field name="weekly_schedule_id" optional="show"/>
<field name="line_count" string="Stops"/>
<field name="visit_count" string="Executed"/>
<field name="planning_finalized" string="Ready"/>
<field name="outlet_summary" string="Planned Outlets"/>
<field name="state" string="Status" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</list>
</field>
</record>
<record id="view_route_plan_salesperson_form" model="ir.ui.view">
<field name="name">route.plan.salesperson.form</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<form string="My Daily Plan" create="0" edit="0" delete="0">
<header>
<button name="action_open_pda_screen" type="object" string="Route Workspace" class="btn-primary"/>
<button name="action_view_visits" type="object" string="Open Visits" class="btn-secondary" invisible="visit_count == 0"/>
<button name="action_open_vehicle_stock_snapshot" type="object" string="Vehicle Stock Snapshot" class="btn-secondary" invisible="not vehicle_id"/>
</header>
<sheet class="route_mobile_compact_sheet">
<div class="oe_title route_mobile_header_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</div>
</div>
<div class="alert alert-info" role="alert" invisible="planning_finalized">This plan is still being prepared by your supervisor. Review the stops now and return after finalization to start execution.</div>
<div class="alert alert-success" role="alert" invisible="not planning_finalized">This daily plan is ready for execution. Use the visit cards below to execute, open, or review visits.</div>
<notebook>
<page string="Overview">
<div class="route_mobile_summary_grid">
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Plan Date</div>
<div class="route_mobile_info_value">
<field name="date" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Vehicle</div>
<div class="route_mobile_info_value">
<field name="vehicle_id" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Weekly Schedule</div>
<div class="route_mobile_info_value">
<field name="weekly_schedule_id" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Source Warehouse</div>
<div class="route_mobile_info_value">
<field name="source_warehouse_id" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Planned Stops</div>
<div class="route_mobile_info_value">
<field name="line_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_info_card">
<div class="route_mobile_info_label">Created Visits</div>
<div class="route_mobile_info_value">
<field name="visit_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_mobile_detail_box">
<div class="route_mobile_detail_label">Ready for Execution</div>
<div class="route_mobile_detail_value">
<field name="planning_finalized" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_mobile_detail_box" invisible="not outlet_summary">
<div class="route_mobile_detail_label">Planned Outlets</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="outlet_summary" readonly="1" nolabel="1"/>
</div>
</div>
</page>
<page string="Planned Visits">
<field name="line_ids" readonly="1">
<kanban class="route_mobile_visit_kanban" create="0" delete="0" quick_create="0">
<field name="area_id"/>
<field name="outlet_id"/>
<field name="partner_id"/>
<field name="state"/>
<field name="visit_id"/>
<field name="skip_reason"/>
<field name="note"/>
<templates>
<t t-name="card">
<div class="route_mobile_visit_card">
<div class="route_mobile_visit_card_head">
<div class="route_mobile_visit_title">
<field name="outlet_id"/>
</div>
<field name="state" widget="badge" decoration-info="state == 'pending'" decoration-warning="state == 'in_progress'" decoration-success="state == 'visited'" decoration-danger="state == 'skipped'"/>
</div>
<div class="route_mobile_visit_meta_grid">
<div class="route_mobile_visit_meta_item">
<div class="route_mobile_visit_meta_label">Area</div>
<div class="route_mobile_visit_meta_value">
<field name="area_id"/>
</div>
</div>
<div class="route_mobile_visit_meta_item">
<div class="route_mobile_visit_meta_label">Customer</div>
<div class="route_mobile_visit_meta_value">
<field name="partner_id"/>
</div>
</div>
</div>
<div class="route_mobile_visit_note" t-if="record.note.raw_value">
<field name="note"/>
</div>
<div class="route_mobile_visit_actions">
<t t-if="record.state.raw_value not in ['visited', 'skipped'] and not record.visit_id.raw_value">
<button name="action_open_skip_visit_wizard" type="object" class="btn btn-light route_mobile_action_btn">Skip Visit</button>
<button name="action_open_or_create_visit" type="object" class="btn btn-primary route_mobile_action_btn">Execute Visit</button>
</t>
<t t-if="record.visit_id.raw_value and record.state.raw_value not in ['visited', 'skipped']">
<button name="action_open_skip_visit_wizard" type="object" class="btn btn-light route_mobile_action_btn">Skip Visit</button>
<button name="action_open_or_create_visit" type="object" class="btn btn-primary route_mobile_action_btn">Open Visit</button>
</t>
<t t-if="record.visit_id.raw_value and record.state.raw_value in ['visited', 'skipped']">
<button name="action_open_or_create_visit" type="object" class="btn btn-secondary route_mobile_action_btn route_mobile_action_btn_full">View Visit</button>
</t>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</page>
<page string="Notes" invisible="not notes">
<field name="notes" readonly="1" nolabel="1"/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_plan_form" model="ir.ui.view">
<field name="name">route.plan.form</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<form string="Route Plan">
<header>
<button name="action_open_pda_screen" type="object" string="Workspace Screen" class="btn-primary"/>
<button name="action_open_pending_visit_review_wizard" type="object" string="Review Pending Visits" class="btn-secondary" invisible="previous_pending_visit_count == 0"/>
<button name="action_finalize_daily_plan" type="object" string="Finalize Daily Plan" class="btn-primary" invisible="planning_finalized or state == 'cancel'"/>
<button name="action_reopen_daily_plan" type="object" string="Reopen Daily Plan" class="btn-secondary" invisible="not planning_finalized or state == 'cancel'"/>
<button name="action_generate_loading_proposal" type="object" string="Generate Loading Proposal" class="btn-primary" invisible="loading_workflow_enabled == False or not planning_finalized or state == 'cancel' or loading_proposal_count > 0" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_view_loading_proposal" type="object" string="Open Loading Proposal" class="btn-secondary" invisible="loading_workflow_enabled == False or loading_proposal_count == 0" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_create_vehicle_transfer_manually" type="object" string="Create Vehicle Transfer Manually" class="btn-secondary" invisible="loading_workflow_mode == 'required' or not planning_finalized or not vehicle_id or state == 'cancel'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_open_vehicle_stock_snapshot" type="object" string="Open Vehicle Stock Snapshot" class="btn-secondary" invisible="not vehicle_id"/>
<button name="action_open_vehicle_closing" type="object" string="Close Vehicle Day" class="btn-secondary" invisible="not planning_finalized or not vehicle_id or state == 'cancel'"/>
</header>
<sheet>
<field name="loading_workflow_mode" invisible="1"/>
<field name="loading_workflow_enabled" invisible="1"/>
<field name="loading_workflow_required" invisible="1"/>
<field name="planning_area_display" invisible="1"/>
<field name="execution_summary_state" invisible="1"/>
<field name="execution_summary_message" invisible="1"/>
<field name="loading_result_state" invisible="1"/>
<field name="loading_result_message" invisible="1"/>
<field name="loading_total_uncovered_qty" invisible="1"/>
<div class="alert alert-warning" role="alert" invisible="not planning_finalized">
<strong>Planning Locked:</strong>
This route plan has been finalized. You cannot edit the plan, add visits, or remove visits until you click
<strong>Reopen Daily Plan</strong>
.
</div>
<div class="alert alert-info" role="alert" invisible="loading_workflow_mode != 'optional'">
<strong>Optional Vehicle Loading:</strong>
Loading Proposal is available for planning help only. You can continue route execution even if the vehicle transfer is created manually later by the warehouse team.
</div>
<div class="alert alert-info" role="alert" invisible="execution_summary_state != 'ready'">
<strong>Execution Not Started:</strong>
<field name="execution_summary_message" readonly="1" nolabel="1" class="oe_inline"/>
</div>
<div class="alert alert-warning" role="alert" invisible="execution_summary_state != 'in_progress'">
<strong>Execution In Progress:</strong>
<field name="execution_summary_message" readonly="1" nolabel="1" class="oe_inline"/>
</div>
<div class="alert alert-info" role="alert" invisible="execution_summary_state != 'partial'">
<strong>Execution Update:</strong>
<field name="execution_summary_message" readonly="1" nolabel="1" class="oe_inline"/>
</div>
<div class="alert alert-success" role="alert" invisible="execution_summary_state != 'completed'">
<strong>Execution Completed:</strong>
<field name="execution_summary_message" readonly="1" nolabel="1" class="oe_inline"/>
</div>
<div class="alert alert-warning" role="alert" invisible="loading_proposal_count == 0 or loading_result_state not in ('draft_manual_review', 'approved_manual_review', 'approved_transfer_partial')" groups="route_core.group_route_supervisor,route_core.group_route_management">
<strong>Loading Review Required:</strong>
<field name="loading_result_message" readonly="1" nolabel="1" class="oe_inline"/>
<span>
Uncovered Qty:
<field name="loading_total_uncovered_qty" readonly="1" nolabel="1" class="oe_inline"/>
</span>
</div>
<div class="alert alert-info" role="alert" invisible="previous_pending_visit_count == 0">
<strong>Previous pending visits detected:</strong>
This area has
<field name="previous_pending_visit_count" readonly="1" class="oe_inline"/>
pending visit(s) from older route plans.
<span invisible="not previous_pending_outlet_summary">
Outlets:
<field name="previous_pending_outlet_summary" readonly="1" class="oe_inline"/>
</span>
Please review them before today's execution.
</div>
<div class="oe_button_box" name="button_box">
<button name="action_view_visits" type="object" class="oe_stat_button" icon="fa-map-marker" invisible="visit_count == 0">
<field name="visit_count" string="Executed Visits" widget="statinfo"/>
</button>
<button name="action_view_loading_proposal" type="object" class="oe_stat_button" icon="fa-truck" invisible="loading_workflow_enabled == False or loading_proposal_count == 0" groups="route_core.group_route_supervisor,route_core.group_route_management">
<field name="loading_proposal_count" string="Loading Proposal" widget="statinfo"/>
</button>
<button name="action_open_vehicle_closing" type="object" class="oe_stat_button" icon="fa-check-square-o" invisible="vehicle_closing_count == 0">
<field name="vehicle_closing_count" string="Vehicle Closings" widget="statinfo"/>
</button>
<button name="action_open_pending_visit_review_wizard" type="object" class="oe_stat_button" icon="fa-history" invisible="previous_pending_visit_count == 0">
<field name="previous_pending_visit_count" string="Previous Pending" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</div>
</div>
<group string="Plan Information" col="2">
<group>
<field name="date" readonly="planning_finalized"/>
<field name="user_id" readonly="planning_finalized"/>
<field name="vehicle_id" readonly="planning_finalized"/>
<field name="source_warehouse_id" readonly="planning_finalized" options="{'no_create': True}"/>
</group>
<group>
<field name="area_id" readonly="planning_finalized"/>
<field name="planning_area_display" string="Planning Area" readonly="1" invisible="not planning_area_display"/>
<field name="area_summary" string="Areas Summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<separator string="Planning Readiness"/>
<div class="route_desktop_summary_grid">
<div class="route_desktop_info_card">
<div class="route_desktop_info_title">Daily Planning</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Ready</span>
<field name="planning_finalized" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row" invisible="not planning_finalized_datetime">
<span class="route_desktop_label">Finalized On</span>
<field name="planning_finalized_datetime" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_desktop_info_card">
<div class="route_desktop_info_title">Pending Review</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Pending Visits</span>
<field name="previous_pending_visit_count" readonly="1" nolabel="1"/>
</div>
<div class="mt8" invisible="previous_pending_visit_count == 0">
<button name="action_open_pending_visit_review_wizard" type="object" string="Review Pending Visits" class="btn btn-secondary btn-sm"/>
</div>
</div>
<div class="route_desktop_info_card" invisible="loading_workflow_enabled == False" groups="route_core.group_route_supervisor,route_core.group_route_management">
<div class="route_desktop_info_title">Vehicle Loading</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Loading Proposals</span>
<field name="loading_proposal_count" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Proposal Status</span>
<field name="loading_proposal_state" string="Proposal Status" readonly="1" nolabel="1" widget="badge" decoration-info="loading_proposal_state == 'draft'" decoration-success="loading_proposal_state == 'approved'" decoration-danger="loading_proposal_state == 'cancelled'"/>
</div>
<div class="route_desktop_stat_row" invisible="loading_proposal_count == 0">
<span class="route_desktop_label">Loading Result</span>
<field name="loading_result_state" string="Loading Result" readonly="1" nolabel="1" widget="badge" decoration-info="loading_result_state in ('draft_transfer_planned', 'draft_no_transfer_needed')" decoration-warning="loading_result_state in ('draft_manual_review', 'approved_manual_review', 'approved_transfer_partial')" decoration-success="loading_result_state in ('approved_transfer_created', 'approved_no_transfer_needed')" decoration-danger="loading_result_state == 'cancelled'"/>
</div>
<div class="route_desktop_stat_row" invisible="loading_proposal_count == 0">
<span class="route_desktop_label">Uncovered Demand</span>
<field name="loading_total_uncovered_qty" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Workflow</span>
<field name="loading_workflow_mode" string="Workflow" readonly="1" nolabel="1" widget="badge"/>
</div>
</div>
<div class="route_desktop_info_card">
<div class="route_desktop_info_title">Vehicle Closing</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Vehicle Closings</span>
<field name="vehicle_closing_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_desktop_wide_info" invisible="not previous_pending_outlet_summary">
<div class="route_desktop_info_title">Previous Pending Outlets</div>
<div class="route_desktop_text_value">
<field name="previous_pending_outlet_summary" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_desktop_wide_info" invisible="loading_proposal_count == 0 or not loading_result_message" groups="route_core.group_route_supervisor,route_core.group_route_management">
<div class="route_desktop_info_title">Loading Result Summary</div>
<div class="route_desktop_text_value">
<field name="loading_result_message" readonly="1" nolabel="1"/>
</div>
</div>
<separator string="Visit Summary"/>
<div class="route_desktop_summary_grid route_desktop_summary_grid_two">
<div class="route_desktop_info_card">
<div class="route_desktop_info_title">Visit Overview</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Visits Count</span>
<field name="line_count" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Pending Visits</span>
<field name="pending_count" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">In Progress Visits</span>
<field name="in_progress_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_desktop_info_card">
<div class="route_desktop_info_title">Execution Results</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Executed Visits</span>
<field name="visit_count" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Completed Visits</span>
<field name="visited_count" readonly="1" nolabel="1"/>
</div>
<div class="route_desktop_stat_row">
<span class="route_desktop_label">Skipped Visits</span>
<field name="skipped_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<notebook>
<page string="Planned Visits">
<group>
<button name="action_open_add_area_outlets_wizard" type="object" string="Add Visits by Area" class="btn-primary" icon="fa-plus" invisible="planning_finalized"/>
<button name="action_load_previous_pending_visits" type="object" string="Load Pending Visits" class="btn-secondary" icon="fa-history" invisible="previous_pending_visit_count == 0"/>
</group>
<field name="line_ids" context="{'default_area_id': area_id}" readonly="planning_finalized">
<list editable="bottom">
<field name="sequence" widget="handle"/>
<field name="area_id"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" readonly="1"/>
<field name="state" string="Visit Status" widget="badge" decoration-info="state == 'pending'" decoration-warning="state == 'in_progress'" decoration-success="state == 'visited'" decoration-danger="state == 'skipped'"/>
<field name="skip_reason" optional="show"/>
<field name="visit_id" string="Follow-up Visit" readonly="1"/>
<field name="note" string="Line Note"/>
<button name="action_open_skip_visit_wizard" type="object" string="Skip Visit" icon="fa-step-forward" invisible="state in ('visited', 'skipped') or visit_id.state == 'done'"/>
<button name="action_reopen_line" type="object" string="Reopen Line" icon="fa-undo" invisible="state != 'skipped'"/>
<button name="action_open_or_create_visit" type="object" string="Execute Visit" icon="fa-play" invisible="visit_id or state == 'skipped'"/>
<button name="action_open_or_create_visit" type="object" string="Open Visit" icon="fa-external-link" invisible="not visit_id or state in ('visited', 'skipped') or visit_id.state in ('done', 'cancel')"/>
<button name="action_open_or_create_visit" type="object" string="View Visit" icon="fa-eye" invisible="not visit_id or (state not in ('visited', 'skipped') and visit_id.state not in ('done', 'cancel'))"/>
</list>
</field>
</page>
<page string="Notes">
<field name="notes" placeholder="Internal notes..." readonly="planning_finalized"/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_plan_search" model="ir.ui.view">
<field name="name">route.plan.search</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<field name="state"/>
<filter name="filter_my_plans" string="My Plans" domain="[('user_id', '=', uid)]"/>
<filter name="filter_today" string="Today" domain="[('date', '=', context_today())]"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<filter name="filter_cancel" string="Cancelled" domain="[('state', 'in', ['cancel', 'cancelled'])]"/>
<filter name="filter_planning_finalized" string="Planning Finalized" domain="[('planning_finalized', '=', True)]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="view_route_plan_salesperson_search" model="ir.ui.view">
<field name="name">route.plan.salesperson.search</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="date"/>
<field name="vehicle_id"/>
<field name="outlet_summary" string="Planned Outlets"/>
<field name="state"/>
<filter name="filter_today" string="Today" domain="[('date', '=', context_today())]"/>
<filter name="filter_planning_finalized" string="Ready for Execution" domain="[('planning_finalized', '=', True)]"/>
<filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<searchpanel>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="view_route_plan_line_pending_supervisor_list" model="ir.ui.view">
<field name="name">route.plan.line.pending.supervisor.list</field>
<field name="model">route.plan.line</field>
<field name="arch" type="xml">
<list string="Pending Visits" create="0" edit="0" delete="0">
<field name="plan_date" string="Plan Date"/>
<field name="plan_id" string="Route Plan"/>
<field name="salesperson_id" string="Salesperson" optional="show"/>
<field name="vehicle_id" string="Vehicle" optional="show"/>
<field name="area_id" string="Area"/>
<field name="outlet_id" string="Outlet"/>
<field name="partner_id" string="Customer" optional="show"/>
<field name="state" string="Status" widget="badge"/>
<field name="skip_reason" optional="show"/>
<field name="visit_id" string="Visit" optional="show"/>
<field name="note" string="Line Note" optional="hide"/>
</list>
</field>
</record>
<record id="view_route_plan_line_pending_supervisor_form" model="ir.ui.view">
<field name="name">route.plan.line.pending.supervisor.form</field>
<field name="model">route.plan.line</field>
<field name="arch" type="xml">
<form string="Pending Visit" create="0" edit="0" delete="0">
<sheet>
<div class="oe_title">
<h1>
<field name="outlet_id" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" readonly="1"/>
</div>
</div>
<group col="2">
<group>
<field name="plan_date" readonly="1"/>
<field name="plan_id" readonly="1"/>
<field name="weekly_schedule_id" readonly="1"/>
<field name="salesperson_id" readonly="1"/>
<field name="vehicle_id" readonly="1"/>
</group>
<group>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1"/>
<field name="visit_id" readonly="1"/>
<field name="skip_reason" readonly="1" invisible="not skip_reason"/>
</group>
</group>
<group string="Notes" invisible="not note">
<field name="note" readonly="1" nolabel="1"/>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_plan_line_pending_supervisor_search" model="ir.ui.view">
<field name="name">route.plan.line.pending.supervisor.search</field>
<field name="model">route.plan.line</field>
<field name="arch" type="xml">
<search>
<field name="plan_date"/>
<field name="plan_id" string="Route Plan"/>
<field name="salesperson_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="area_id" string="Area"/>
<field name="outlet_id" string="Outlet"/>
<field name="partner_id" string="Customer"/>
<filter name="filter_pending_only" string="Pending" domain="[('state', '=', 'pending')]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'salesperson_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_date" string="Plan Date" context="{'group_by': 'plan_date'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<searchpanel>
<field name="salesperson_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="area_id" string="Area" select="multi"/>
<field name="outlet_id" string="Outlet" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_pending_visit_lines" model="ir.actions.act_window">
<field name="name">Pending Visits</field>
<field name="res_model">route.plan.line</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_plan_line_pending_supervisor_search"/>
<field name="domain">[('state', '=', 'pending'), ('plan_id.state', 'not in', ['cancel', 'cancelled'])]</field>
<field name="context">{'create': 0, 'edit': 0, 'delete': 0, 'search_default_filter_pending_only': 1, 'search_default_filter_today_or_older': 1}</field>
</record>
<record id="action_route_pending_visit_lines_list_view" model="ir.actions.act_window.view">
<field name="sequence" eval="1"/>
<field name="view_mode">list</field>
<field name="view_id" ref="route_core.view_route_plan_line_pending_supervisor_list"/>
<field name="act_window_id" ref="route_core.action_route_pending_visit_lines"/>
</record>
<record id="action_route_pending_visit_lines_form_view" model="ir.actions.act_window.view">
<field name="sequence" eval="2"/>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_plan_line_pending_supervisor_form"/>
<field name="act_window_id" ref="route_core.action_route_pending_visit_lines"/>
</record>
<record id="action_route_plan" model="ir.actions.act_window">
<field name="name">Route Plans</field>
<field name="res_model">route.plan</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_plan_search"/>
<field name="context">{'search_default_filter_my_plans': 1, 'search_default_filter_today': 1}</field>
</record>
<menuitem id="menu_route_plan" name="Route Plans" parent="menu_route_visit_root" action="action_route_plan" sequence="20"/>
</odoo>
