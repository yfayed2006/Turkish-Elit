<odoo>
<record id="view_route_plan_list" model="ir.ui.view">
<field name="name">route.plan.list</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<list string="Route Plans">
<field name="name" string="Plan Ref"/>
<field name="date"/>
<field name="user_id" optional="hide"/>
<field name="vehicle_id"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<field name="line_count" string="Visits"/>
<field name="state" string="Status" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</list>
</field>
</record>
<record id="view_route_plan_form" model="ir.ui.view">
<field name="name">route.plan.form</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<form string="Route Plan">
<header>
<button name="action_open_pda_screen" type="object" string="Workspace Screen" class="btn-primary"/>
<button name="action_open_pending_visit_review_wizard" type="object" string="Review Pending Visits" class="btn-secondary" invisible="previous_pending_visit_count == 0"/>
<button name="action_finalize_daily_plan" type="object" string="Finalize Daily Plan" class="btn-primary" invisible="planning_finalized or state == 'cancel'"/>
<button name="action_reopen_daily_plan" type="object" string="Reopen Daily Plan" class="btn-secondary" invisible="not planning_finalized or state == 'cancel'"/>
<button name="action_generate_loading_proposal" type="object" string="Generate Loading Proposal" class="btn-primary" invisible="loading_workflow_enabled == False or not planning_finalized or state == 'cancel' or loading_proposal_count > 0" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_view_loading_proposal" type="object" string="Open Loading Proposal" class="btn-secondary" invisible="loading_workflow_enabled == False or loading_proposal_count == 0" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_create_vehicle_transfer_manually" type="object" string="Create Vehicle Transfer Manually" class="btn-secondary" invisible="loading_workflow_mode == 'required' or not planning_finalized or not vehicle_id or state == 'cancel'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_open_vehicle_stock_snapshot" type="object" string="Open Vehicle Stock Snapshot" class="btn-secondary" invisible="not vehicle_id"/>
<button name="action_open_vehicle_closing" type="object" string="Close Vehicle Day" class="btn-secondary" invisible="not planning_finalized or not vehicle_id or state == 'cancel'"/>
</header>
<sheet>
<field name="loading_workflow_mode" invisible="1"/>
<field name="loading_workflow_enabled" invisible="1"/>
<field name="loading_workflow_required" invisible="1"/>
<div class="alert alert-warning" role="alert" invisible="not planning_finalized">
<strong>Planning Locked:</strong>
This route plan has been finalized. You cannot edit the plan, add visits, or remove visits until you click
<strong>Reopen Daily Plan</strong>
.
</div>
<div class="alert alert-info" role="alert" invisible="loading_workflow_mode != 'optional'">
<strong>Optional Vehicle Loading:</strong>
Loading Proposal is available for planning help only. You can continue route execution even if the vehicle transfer is created manually later by the warehouse team.
</div>
<div class="alert alert-info" role="alert" invisible="previous_pending_visit_count == 0">
<strong>Previous pending visits detected:</strong>
This area has
<field name="previous_pending_visit_count" readonly="1" class="oe_inline"/>
pending visit(s) from older route plans.
<span invisible="not previous_pending_outlet_summary">
Outlets:
<field name="previous_pending_outlet_summary" readonly="1" class="oe_inline"/>
</span>
Please review them before today's execution.
</div>
<div class="oe_button_box" name="button_box">
<button name="action_view_visits" type="object" class="oe_stat_button" icon="fa-map-marker" invisible="visit_count == 0">
<field name="visit_count" string="Executed Visits" widget="statinfo"/>
</button>
<button name="action_view_loading_proposal" type="object" class="oe_stat_button" icon="fa-truck" invisible="loading_workflow_enabled == False or loading_proposal_count == 0" groups="route_core.group_route_supervisor,route_core.group_route_management">
<field name="loading_proposal_count" string="Loading Proposal" widget="statinfo"/>
</button>
<button name="action_open_vehicle_closing" type="object" class="oe_stat_button" icon="fa-check-square-o" invisible="vehicle_closing_count == 0">
<field name="vehicle_closing_count" string="Vehicle Closings" widget="statinfo"/>
</button>
<button name="action_open_pending_visit_review_wizard" type="object" class="oe_stat_button" icon="fa-history" invisible="previous_pending_visit_count == 0">
<field name="previous_pending_visit_count" string="Previous Pending" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
</div>
</div>
<group string="Plan Information" col="2">
<group>
<field name="date" readonly="planning_finalized"/>
<field name="user_id" readonly="planning_finalized"/>
<field name="vehicle_id" readonly="planning_finalized"/>
</group>
<group>
<field name="area_id" readonly="planning_finalized"/>
<field name="area_summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<separator string="Planning Readiness"/>
<group col="6">
<group string="Daily Planning">
<field name="planning_finalized" readonly="1"/>
<field name="planning_finalized_datetime" readonly="1" invisible="not planning_finalized_datetime"/>
</group>
<group string="Pending Review">
<field name="previous_pending_visit_count" readonly="1"/>
<field name="previous_pending_outlet_summary" readonly="1" invisible="not previous_pending_outlet_summary"/>
</group>
<group string="Vehicle Loading" invisible="loading_workflow_enabled == False" groups="route_core.group_route_supervisor,route_core.group_route_management">
<field name="loading_proposal_count" readonly="1"/>
<field name="loading_proposal_state" string="Proposal Status" readonly="1" widget="badge" decoration-info="loading_proposal_state == 'draft'" decoration-success="loading_proposal_state == 'approved'" decoration-danger="loading_proposal_state == 'cancelled'"/>
<field name="loading_workflow_mode" string="Workflow" readonly="1"/>
</group>
<group string="Vehicle Closing">
<field name="vehicle_closing_count" readonly="1"/>
</group>
</group>
<separator string="Visit Summary"/>
<group col="4">
<group string="Visit Overview">
<field name="line_count" readonly="1"/>
<field name="pending_count" readonly="1"/>
<field name="in_progress_count" readonly="1"/>
</group>
<group string="Execution Results">
<field name="visit_count" readonly="1"/>
<field name="visited_count" readonly="1"/>
<field name="skipped_count" readonly="1"/>
</group>
</group>
<notebook>
<page string="Planned Visits">
<group>
<button name="action_open_add_area_outlets_wizard" type="object" string="Add Visits by Area" class="btn-primary" icon="fa-plus" invisible="planning_finalized"/>
<button name="action_load_previous_pending_visits" type="object" string="Load Pending Visits" class="btn-secondary" icon="fa-history" invisible="previous_pending_visit_count == 0"/>
</group>
<field name="line_ids" context="{'default_area_id': area_id}" readonly="planning_finalized">
<list editable="bottom">
<field name="sequence" widget="handle"/>
<field name="area_id"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" readonly="1"/>
<field name="state" string="Visit Status" widget="badge" decoration-info="state == 'pending'" decoration-warning="state == 'in_progress'" decoration-success="state == 'visited'" decoration-danger="state == 'skipped'"/>
<field name="skip_reason" optional="show"/>
<field name="visit_id" string="Follow-up Visit" readonly="1"/>
<field name="note" string="Line Note"/>
<button name="action_open_skip_visit_wizard" type="object" string="Skip Visit" icon="fa-step-forward" invisible="state in ('visited', 'skipped') or visit_id.state == 'done'"/>
<button name="action_reopen_line" type="object" string="Reopen Line" icon="fa-undo" invisible="state != 'skipped'"/>
<button name="action_open_or_create_visit" type="object" string="Execute Visit" icon="fa-play" invisible="visit_id or state == 'skipped'"/>
<button name="action_open_or_create_visit" type="object" string="Open Visit" icon="fa-external-link" invisible="not visit_id or state in ('visited', 'skipped') or visit_id.state in ('done', 'cancel')"/>
<button name="action_open_or_create_visit" type="object" string="View Visit" icon="fa-eye" invisible="not visit_id or (state not in ('visited', 'skipped') and visit_id.state not in ('done', 'cancel'))"/>
</list>
</field>
</page>
<page string="Notes">
<field name="notes" placeholder="Internal notes..." readonly="planning_finalized"/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_plan_search" model="ir.ui.view">
<field name="name">route.plan.search</field>
<field name="model">route.plan</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="area_id"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<field name="state"/>
<filter name="filter_my_plans" string="My Plans" domain="[('user_id', '=', uid)]"/>
<filter name="filter_today" string="Today" domain="[('date', '=', context_today())]"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
<filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
<filter name="filter_cancel" string="Cancelled" domain="[('state', 'in', ['cancel', 'cancelled'])]"/>
<filter name="filter_planning_finalized" string="Planning Finalized" domain="[('planning_finalized', '=', True)]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
<filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_plan" model="ir.actions.act_window">
<field name="name">Route Plans</field>
<field name="res_model">route.plan</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_plan_search"/>
<field name="context">{'search_default_filter_my_plans': 1, 'search_default_filter_today': 1}</field>
</record>
<menuitem id="menu_route_plan" name="Route Plans" parent="menu_route_visit_root" action="action_route_plan" sequence="20"/>
</odoo>
