<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_plan_list" model="ir.ui.view">
        <field name="name">route.plan.list</field>
        <field name="model">route.plan</field>
        <field name="arch" type="xml">
            <list string="Route Plans">
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="vehicle_id"/>
                <field name="area_id"/>
                <field name="line_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_route_plan_form" model="ir.ui.view">
        <field name="name">route.plan.form</field>
        <field name="model">route.plan</field>
        <field name="arch" type="xml">
            <form string="Route Plan">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_visits"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-map-marker"
                            invisible="visit_count == 0"
                        >
                            <field name="visit_count" string="Visits" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="vehicle_id"/>
                        </group>
                        <group>
                            <field name="area_id"/>
                            <field name="state"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Plan Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="outlet_id"/>
                                    <field name="area_id" readonly="1"/>
                                    <field name="partner_id" readonly="1"/>
                                    <field name="visit_id" readonly="1"/>
                                    <field name="state"/>
                                    <field name="note"/>
                                    <button
                                        name="action_open_or_create_visit"
                                        type="object"
                                        string="Open/Create Visit"
                                        icon="fa-external-link"
                                    />
                                </list>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_route_plan_search" model="ir.ui.view">
        <field name="name">route.plan.search</field>
        <field name="model">route.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="vehicle_id"/>
                <field name="area_id"/>

                <filter name="filter_my_plans" string="My Plans" domain="[('user_id', '=', uid)]"/>
                <filter name="filter_today" string="Today" domain="[('date', '=', context_today())]"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
            </search>
        </field>
    </record>

    <record id="action_route_plan" model="ir.actions.act_window">
        <field name="name">Route Plans</field>
        <field name="res_model">route.plan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_route_plan_search"/>
    </record>

    <menuitem
        id="menu_route_plan"
        name="Route Plans"
        parent="menu_route_visit_root"
        action="action_route_plan"
        sequence="20"
    />

</odoo>
