<odoo>
<record id="view_route_loading_proposal_list" model="ir.ui.view">
<field name="name">route.loading.proposal.list</field>
<field name="model">route.loading.proposal</field>
<field name="arch" type="xml">
<list string="Vehicle Loading Proposals">
<field name="name"/>
<field name="plan_id"/>
<field name="plan_date"/>
<field name="vehicle_id"/>
<field name="planned_outlet_count"/>
<field name="product_count"/>
<field name="total_required_qty"/>
<field name="total_vehicle_balance_qty" optional="show"/>
<field name="total_suggested_qty"/>
<field name="total_approved_qty"/>
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'approved'" decoration-danger="state == 'cancelled'"/>
<field name="transfer_state" widget="badge" optional="show"/>
</list>
</field>
</record>
<record id="view_route_loading_proposal_form" model="ir.ui.view">
<field name="name">route.loading.proposal.form</field>
<field name="model">route.loading.proposal</field>
<field name="arch" type="xml">
<form string="Vehicle Loading Proposal">
<header>
<button name="action_refresh_from_plan" type="object" string="Refresh from Final Plan" class="btn-secondary" invisible="state != 'draft'"/>
<button name="action_open_vehicle_stock_snapshot" type="object" string="Open Vehicle Stock Snapshot" class="btn-secondary" invisible="not vehicle_id"/>
<button name="action_approve" type="object" string="Approve and Create Transfer" class="btn-primary" invisible="state != 'draft'"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state == 'draft'"/>
<button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state == 'cancelled'"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_open_route_plan" type="object" class="oe_stat_button" icon="fa-road">
<span class="o_stat_text">Route Plan</span>
</button>
<button name="action_view_transfer" type="object" class="oe_stat_button" icon="fa-exchange" invisible="transfer_count == 0">
<field name="transfer_count" string="Internal Transfer" widget="statinfo"/>
</button>
<button name="action_open_vehicle_stock_snapshot" type="object" class="oe_stat_button" icon="fa-cubes" invisible="not vehicle_id">
<span class="o_stat_text">Vehicle Stock Snapshot</span>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'approved'" decoration-danger="state == 'cancelled'"/>
</div>
</div>
<group string="Proposal Information" col="2">
<group>
<field name="plan_id" readonly="1"/>
<field name="plan_date" readonly="1"/>
<field name="vehicle_id" readonly="1"/>
<field name="user_id" readonly="1"/>
</group>
<group>
<field name="planning_finalized" readonly="1"/>
<field name="planning_finalized_datetime" readonly="1" invisible="not planning_finalized_datetime"/>
<field name="source_location_id" readonly="state != 'draft'"/>
<field name="destination_location_id" readonly="1"/>
<field name="picking_id" readonly="1" invisible="transfer_count == 0"/>
<field name="approval_datetime" readonly="1" invisible="not approval_datetime"/>
<field name="transfer_state" string="Transfer Status" readonly="1" invisible="transfer_count == 0" widget="badge"/>
</group>
</group>
<separator string="Loading Summary"/>
<group col="4">
<group string="Scope">
<field name="planned_outlet_count" readonly="1"/>
<field name="product_count" readonly="1"/>
<field name="line_count" readonly="1"/>
</group>
<group string="Quantities">
<field name="total_required_qty" readonly="1"/>
<field name="total_vehicle_balance_qty" readonly="1"/>
<field name="total_suggested_qty" readonly="1"/>
<field name="total_approved_qty" readonly="1"/>
</group>
<group string="Values">
<field name="total_required_value" readonly="1"/>
<field name="total_approved_value" readonly="1"/>
</group>
</group>
<notebook>
<page string="Proposal Lines">
<field name="line_ids" nolabel="1">
<list editable="bottom" create="0" delete="0">
<field name="product_id" readonly="1"/>
<field name="barcode" readonly="1" optional="show"/>
<field name="uom_id" readonly="1"/>
<field name="planned_outlet_count" readonly="1"/>
<field name="movement_profile" readonly="1" optional="show"/>
<field name="recent_sales_baseline_qty" readonly="1" optional="show"/>
<field name="outlet_balance_qty" readonly="1"/>
<field name="current_outlet_need_qty" readonly="1"/>
<field name="open_shortage_qty" readonly="1"/>
<field name="total_required_qty" readonly="1"/>
<field name="vehicle_available_qty" readonly="1"/>
<field name="source_available_qty" readonly="1" optional="show"/>
<field name="earliest_source_expiry_date" readonly="1" optional="show"/>
<field name="source_lot_summary" readonly="1" optional="show"/>
<field name="suggested_load_qty" readonly="1"/>
<field name="approved_qty" readonly="parent.state != 'draft'"/>
<field name="unit_price" readonly="1" optional="show"/>
<field name="required_value" readonly="1" optional="show"/>
<field name="approved_value" readonly="1" optional="show"/>
<field name="outlet_names" readonly="1" optional="hide"/>
<field name="basis_note" readonly="1" optional="hide"/>
</list>
</field>
</page>
<page string="Notes">
<field name="note" readonly="state != 'draft'" placeholder="Internal notes..."/>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_route_loading_proposal_search" model="ir.ui.view">
<field name="name">route.loading.proposal.search</field>
<field name="model">route.loading.proposal</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="plan_id"/>
<field name="plan_date"/>
<field name="vehicle_id"/>
<field name="user_id"/>
<field name="state"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
<filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
<separator/>
<filter name="group_by_plan_date" string="Plan Date" context="{'group_by': 'plan_date'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
</search>
</field>
</record>
<record id="action_route_loading_proposal" model="ir.actions.act_window">
<field name="name">Vehicle Loading Proposals</field>
<field name="res_model">route.loading.proposal</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="view_route_loading_proposal_search"/>
</record>
<menuitem id="menu_route_loading_proposal" name="Vehicle Loading Proposals" parent="menu_route_visit_root" action="action_route_loading_proposal" sequence="25"/>
</odoo>
