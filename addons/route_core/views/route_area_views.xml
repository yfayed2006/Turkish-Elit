<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_area_tree" model="ir.ui.view">
        <field name="name">route.area.tree</field>
        <field name="model">route.area</field>
        <field name="arch" type="xml">
            <list string="Route Areas">
                <field name="name"/>
                <field name="code"/>
                <field name="visit_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_area_form" model="ir.ui.view">
        <field name="name">route.area.form</field>
        <field name="model">route.area</field>
        <field name="arch" type="xml">
            <form string="Route Area">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_visits"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-map-marker"
                        >
                            <field name="visit_count" string="Visits" widget="statinfo"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_area" model="ir.actions.act_window">
        <field name="name">Areas</field>
        <field name="res_model">route.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_route_configuration"
        name="Configuration"
        parent="menu_route_visit_root"
        sequence="50"
    />

    <menuitem
        id="menu_route_area"
        name="Areas"
        parent="menu_route_configuration"
        action="action_route_area"
        sequence="10"
    />

</odoo>
