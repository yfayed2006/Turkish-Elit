<odoo>
<record id="view_route_cheque_followup_kanban" model="ir.ui.view">
<field name="name">route.cheque.followup.kanban</field>
<field name="model">route.visit.payment</field>
<field name="priority" eval="20"/>
<field name="arch" type="xml">
<kanban class="route_pda_payment_kanban route_cheque_control_kanban" create="0" edit="0" delete="0">
<field name="source_document_ref"/>
<field name="settlement_document_ref"/>
<field name="outlet_id"/>
<field name="area_id"/>
<field name="salesperson_id"/>
<field name="payment_date"/>
<field name="amount"/>
<field name="cheque_physical_total_amount"/>
<field name="cheque_physical_allocation_count"/>
<field name="cheque_physical_display_ref"/>
<field name="cheque_physical_source_summary"/>
<field name="cheque_physical_settlement_summary"/>
<field name="cheque_physical_open_due_amount"/>
<field name="cheque_physical_is_primary"/>
<field name="payment_mode"/>
<field name="state"/>
<field name="cheque_number"/>
<field name="bank_name"/>
<field name="cheque_date"/>
<field name="cheque_holder_name"/>
<field name="cheque_followup_state"/>
<field name="cheque_followup_state_label"/>
<field name="cheque_followup_due_label"/>
<field name="cheque_financial_state"/>
<field name="cheque_financial_state_label"/>
<field name="cheque_collection_effect_bucket"/>
<field name="cheque_open_due_amount"/>
<field name="cheque_needs_followup"/>
<field name="route_cheque_accounting_enabled"/>
<field name="route_cheque_accounting_state"/>
<field name="route_cheque_accounting_state_label"/>
<field name="route_cheque_accounting_move_count"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_payment_card route_cheque_control_card">
<div class="route_pda_payment_head route_cheque_control_head">
<div>
<div class="route_pda_payment_title">
<t t-esc="record.cheque_physical_display_ref.value or record.settlement_document_ref.value or record.source_document_ref.value or 'Cheque'"/>
</div>
<div class="route_pda_payment_subtitle">
<t t-if="record.outlet_id.raw_value" t-esc="record.outlet_id.value"/>
<t t-if="record.outlet_id.raw_value and record.salesperson_id.raw_value"> • </t>
<t t-if="record.salesperson_id.raw_value" t-esc="record.salesperson_id.value"/>
</div>
</div>
<div class="route_pda_payment_date">
<field name="payment_date"/>
</div>
</div>
<div class="route_pda_payment_badges route_pda_payment_badges_primary">
<span t-attf-class="route_pda_payment_badge route_cheque_status_badge route_cheque_status_#{record.cheque_followup_state.raw_value or 'received'}">
<t>Cheque: </t>
<t t-esc="record.cheque_followup_state_label.value or 'Received'"/>
</span>
<span class="route_pda_payment_badge route_pda_payment_badge_cheque_highlight">
<t t-if="record.cheque_collection_effect_bucket.raw_value == 'open_due'">Balance: Open Due</t>
<t t-if="record.cheque_collection_effect_bucket.raw_value == 'cleared'">Bank: Cleared</t>
<t t-if="record.cheque_collection_effect_bucket.raw_value == 'pending'">Bank: Pending</t>
<t t-if="!record.cheque_collection_effect_bucket.raw_value">Bank: Pending</t>
</span>
<t t-if="record.cheque_needs_followup.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_balance">Needs Follow-up</span>
</t>
<t t-if="record.cheque_physical_allocation_count.raw_value > 1">
<span class="route_pda_payment_badge route_pda_payment_badge_confirmed">
<t t-esc="record.cheque_physical_allocation_count.value"/>
<t> Allocations</t>
</span>
</t>
<t t-if="record.route_cheque_accounting_enabled.raw_value">
<span t-attf-class="route_pda_payment_badge #{record.route_cheque_accounting_state.raw_value == 'not_posted' ? 'route_pda_payment_badge_pending' : 'route_pda_payment_badge_confirmed'}">
<t>Accounting: </t>
<t t-esc="record.route_cheque_accounting_state_label.value or 'Accounting'"/>
</span>
</t>
</div>
<div class="route_pda_payment_metrics route_cheque_control_metrics">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cheque Amount</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_physical_total_amount"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cheque</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_number"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Bank</span>
<span class="route_pda_payment_metric_value">
<field name="bank_name"/>
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cheque Date</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_date"/>
</span>
</div>
<t t-if="record.cheque_physical_allocation_count.raw_value > 1">
<div class="route_pda_payment_metric route_pda_payment_metric_single">
<span class="route_pda_payment_metric_label">Allocation Sources</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_physical_source_summary"/>
</span>
</div>
</t>
</div>
<div class="route_cheque_control_actions">
<button name="action_cheque_mark_deposited" type="object" class="btn btn-sm btn-secondary" invisible="state != 'confirmed' or cheque_followup_state not in [False, 'received']">Mark Deposited</button>
<button name="action_cheque_mark_cleared" type="object" class="btn btn-sm btn-success" invisible="state != 'confirmed' or cheque_followup_state != 'deposited'">Mark Cleared</button>
<button name="action_cheque_mark_bounced" type="object" class="btn btn-sm btn-warning" invisible="state != 'confirmed' or cheque_followup_state != 'deposited'">Mark Bounced</button>
<button name="action_cheque_mark_cancelled" type="object" class="btn btn-sm btn-secondary" invisible="state != 'confirmed' or cheque_followup_state != 'deposited'">Cancel Cheque</button>
<button name="action_route_post_cheque_accounting" type="object" class="btn btn-sm btn-primary" invisible="state != 'confirmed' or cheque_followup_state != 'deposited' or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'">Post Received Entry</button>
<button name="action_route_post_cheque_accounting" type="object" class="btn btn-sm btn-primary" invisible="state != 'confirmed' or cheque_followup_state != 'cleared' or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'">Post Bank Clearance Entry</button>
<button name="action_route_post_cheque_accounting" type="object" class="btn btn-sm btn-primary" invisible="state != 'confirmed' or cheque_followup_state not in ['bounced', 'cancelled'] or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'">Post Open Due Entry</button>
<button name="action_route_open_cheque_accounting_moves" type="object" class="btn btn-sm btn-light" invisible="route_cheque_accounting_move_count == 0">Entries</button>
<button name="action_cheque_reset_received" type="object" class="btn btn-sm btn-light" invisible="state != 'confirmed' or cheque_followup_state in [False, 'received'] or route_cheque_accounting_move_count != 0">Reset</button>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_route_cheque_followup_list" model="ir.ui.view">
<field name="name">route.cheque.followup.list</field>
<field name="model">route.visit.payment</field>
<field name="priority" eval="20"/>
<field name="arch" type="xml">
<list string="Cheque Follow-up" create="0" edit="0" delete="0">
<field name="cheque_physical_display_ref" string="Cheque Reference"/>
<field name="source_document_ref" string="Source" optional="hide"/>
<field name="settlement_document_ref" string="Settlement" optional="hide"/>
<field name="outlet_id"/>
<field name="salesperson_id"/>
<field name="payment_date"/>
<field name="cheque_physical_total_amount" string="Cheque Amount"/>
<field name="cheque_physical_allocation_count" string="Allocations" optional="show"/>
<field name="cheque_physical_source_summary" string="Allocation Sources" optional="show"/>
<field name="cheque_number" string="Cheque No."/>
<field name="bank_name" string="Bank"/>
<field name="cheque_date" string="Cheque Date"/>
<field name="cheque_followup_state" string="Cheque Lifecycle Status" widget="badge" decoration-info="cheque_followup_state == False or cheque_followup_state == 'received'" decoration-warning="cheque_followup_state == 'deposited'" decoration-success="cheque_followup_state == 'cleared'" decoration-danger="cheque_followup_state == 'bounced'" decoration-muted="cheque_followup_state == 'cancelled'"/>
<field name="cheque_followup_due_label" string="Bank Due / Result"/>
<field name="cheque_collection_effect_bucket" string="Customer Balance Effect" widget="badge" optional="show" decoration-info="cheque_collection_effect_bucket == 'pending'" decoration-success="cheque_collection_effect_bucket == 'cleared'" decoration-danger="cheque_collection_effect_bucket == 'open_due'"/>
<field name="cheque_financial_state" string="Detailed Cheque Effect" optional="hide"/>
<field name="cheque_open_due_amount" string="Open Due" optional="hide"/>
<field name="route_cheque_accounting_state" string="Accounting" widget="badge" optional="show" decoration-muted="route_cheque_accounting_state == 'disabled'" decoration-warning="route_cheque_accounting_state == 'not_posted'" decoration-success="route_cheque_accounting_state in ['received_posted', 'cleared_posted', 'open_due_posted']"/>
<button name="action_cheque_mark_deposited" type="object" string="Mark Deposited" invisible="state != 'confirmed' or cheque_followup_state not in [False, 'received']"/>
<button name="action_cheque_mark_cleared" type="object" string="Mark Cleared" invisible="state != 'confirmed' or cheque_followup_state != 'deposited'"/>
<button name="action_cheque_mark_bounced" type="object" string="Mark Bounced" invisible="state != 'confirmed' or cheque_followup_state != 'deposited'"/>
</list>
</field>
</record>
<record id="view_route_cheque_followup_form" model="ir.ui.view">
<field name="name">route.cheque.followup.form</field>
<field name="model">route.visit.payment</field>
<field name="priority" eval="20"/>
<field name="arch" type="xml">
<form string="Cheque Follow-up" create="0" delete="0" class="route_pda_payment_form route_cheque_control_form">
<header>
<button name="action_cheque_mark_deposited" string="Mark Deposited" type="object" class="btn-secondary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state not in [False, 'received']"/>
<button name="action_cheque_mark_cleared" string="Mark Cleared" type="object" class="btn-success" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state != 'deposited'"/>
<button name="action_cheque_mark_bounced" string="Mark Bounced" type="object" class="btn-warning" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state != 'deposited'"/>
<button name="action_cheque_mark_cancelled" string="Cancel Cheque" type="object" class="btn-secondary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state != 'deposited'"/>
<button name="action_route_post_cheque_accounting" string="Post Received Entry" type="object" class="btn-primary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state != 'deposited' or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'"/>
<button name="action_route_post_cheque_accounting" string="Post Bank Clearance Entry" type="object" class="btn-primary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state != 'cleared' or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'"/>
<button name="action_route_post_cheque_accounting" string="Post Open Due Entry" type="object" class="btn-primary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state not in ['bounced', 'cancelled'] or route_cheque_accounting_enabled == False or route_cheque_accounting_state != 'not_posted'"/>
<button name="action_route_open_cheque_accounting_moves" string="Accounting Entries" type="object" class="btn-secondary" invisible="route_cheque_accounting_move_count == 0"/>
<button name="action_cheque_reset_received" string="Reset to Received" type="object" class="btn-secondary" invisible="state != 'confirmed' or payment_mode != 'cheque' or cheque_followup_state in [False, 'received'] or route_cheque_accounting_move_count != 0"/>
<field name="cheque_followup_state" widget="statusbar" statusbar_visible="received,deposited,cleared,bounced,cancelled"/>
</header>
<sheet class="route_pda_payment_sheet route_cheque_control_sheet">
<field name="payment_mode" invisible="1"/>
<field name="state" invisible="1"/>
<field name="currency_id" invisible="1"/>
<field name="cheque_physical_is_primary" invisible="1"/>
<field name="cheque_physical_total_amount" invisible="1"/>
<field name="cheque_physical_allocation_count" invisible="1"/>
<field name="cheque_physical_display_ref" invisible="1"/>
<field name="cheque_physical_source_summary" invisible="1"/>
<field name="cheque_physical_settlement_summary" invisible="1"/>
<field name="cheque_physical_open_due_amount" invisible="1"/>
<field name="cheque_financial_state" invisible="1"/>
<field name="cheque_financial_state_label" invisible="1"/>
<field name="cheque_collection_effect_bucket" invisible="1"/>
<field name="cheque_open_due_amount" invisible="1"/>
<field name="cheque_needs_followup" invisible="1"/>
<field name="route_cheque_accounting_enabled" invisible="1"/>
<field name="route_cheque_accounting_state" invisible="1"/>
<field name="route_cheque_accounting_state_label" invisible="1"/>
<field name="route_cheque_accounting_move_count" invisible="1"/>
<div class="alert alert-warning" invisible="not cheque_needs_followup">
<strong>Cheque needs follow-up.</strong>
This cheque no longer covers the collection amount, so its amount is treated as open due for the outlet until another collection is made.
</div>
<div class="route_pda_payment_summary_grid">
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Physical Cheque Amount</div>
<div class="route_pda_info_value route_pda_money_value">
<field name="cheque_physical_total_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Bank Due / Result</div>
<div class="route_pda_info_value">
<field name="cheque_followup_due_label" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Payment Status</div>
<div>
<field name="state" readonly="1" widget="badge" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Financial Effect</div>
<div class="route_pda_info_value">
<field name="cheque_financial_state_label" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Customer Balance Effect</div>
<div>
<field name="cheque_collection_effect_bucket" readonly="1" widget="badge" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card" invisible="not cheque_needs_followup">
<div class="route_pda_info_label">Open Due From Physical Cheque</div>
<div class="route_pda_info_value route_pda_money_value">
<field name="cheque_physical_open_due_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card" invisible="route_cheque_accounting_enabled == False">
<div class="route_pda_info_label">Accounting State</div>
<div class="route_pda_info_value">
<field name="route_cheque_accounting_state_label" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card" invisible="route_cheque_accounting_move_count == 0">
<div class="route_pda_info_label">Accounting Entries</div>
<div class="route_pda_info_value">
<field name="route_cheque_accounting_move_count" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_group route_cheque_control_section">
<div class="route_pda_group_title">Cheque Details</div>
<div class="route_pda_payment_summary_grid route_cheque_control_detail_grid">
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cheque Number</div>
<div class="route_pda_info_value">
<field name="cheque_number" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cheque Bank</div>
<div class="route_pda_info_value">
<field name="bank_name" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cheque Date</div>
<div class="route_pda_info_value">
<field name="cheque_date" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cheque Holder</div>
<div class="route_pda_info_value">
<field name="cheque_holder_name" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Allocation Lines</div>
<div class="route_pda_info_value">
<field name="cheque_physical_allocation_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_payment_summary_card" invisible="cheque_physical_allocation_count &lt;= 1"
<div class="route_pda_info_label">Allocation Sources</div>
<div class="route_pda_info_value route_pda_info_value_left">
<field name="cheque_physical_source_summary" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Source Document</div>
<div class="route_pda_info_value">
<field name="source_document_ref" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Settlement Visit</div>
<div class="route_pda_info_value">
<field name="settlement_document_ref" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Outlet</div>
<div class="route_pda_info_value">
<field name="outlet_id" readonly="1" nolabel="1" options="{'no_open': True}"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Salesperson</div>
<div class="route_pda_info_value">
<field name="salesperson_id" readonly="1" nolabel="1" options="{'no_open': True}"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_cheque_control_section">
<div class="route_pda_group_title">Follow-up Trail</div>
<div class="route_pda_payment_summary_grid route_cheque_control_trail_grid">
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Deposited At</div>
<div class="route_pda_info_value">
<field name="cheque_deposited_at" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cleared At</div>
<div class="route_pda_info_value">
<field name="cheque_cleared_at" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Bounced At</div>
<div class="route_pda_info_value">
<field name="cheque_bounced_at" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Cancelled At</div>
<div class="route_pda_info_value">
<field name="cheque_cancelled_at" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Last Update</div>
<div class="route_pda_info_value">
<field name="cheque_followup_updated_at" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Updated By</div>
<div class="route_pda_info_value">
<field name="cheque_followup_updated_by_id" readonly="1" nolabel="1" options="{'no_open': True}"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_payment_summary_card">
<div class="route_pda_info_label">Cheque Details / Reason</div>
<div class="route_pda_info_value route_pda_info_value_left">
<field name="cheque_note" readonly="1" nolabel="1"/>
</div>
</div>
</div>
</div>
<div class="route_pda_group route_cheque_control_section" invisible="route_cheque_accounting_enabled == False">
<div class="route_pda_group_title">Accounting Entries</div>
<div class="route_pda_payment_summary_grid route_cheque_control_accounting_grid">
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Accounting State</div>
<div class="route_pda_info_value">
<field name="route_cheque_accounting_state_label" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_payment_summary_card">
<div class="route_pda_info_label">Entries Count</div>
<div class="route_pda_info_value">
<field name="route_cheque_accounting_move_count" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_payment_summary_card">
<div class="route_pda_info_label">Received Accounting Entry</div>
<div class="route_pda_info_value route_pda_info_value_left">
<field name="route_cheque_received_move_id" readonly="1" nolabel="1" options="{'no_create': True}"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_payment_summary_card">
<div class="route_pda_info_label">Cleared Accounting Entry</div>
<div class="route_pda_info_value route_pda_info_value_left">
<field name="route_cheque_cleared_move_id" readonly="1" nolabel="1" options="{'no_create': True}"/>
</div>
</div>
<div class="route_pda_info_card route_pda_info_card_full route_pda_payment_summary_card">
<div class="route_pda_info_label">Open Due Accounting Entry</div>
<div class="route_pda_info_value route_pda_info_value_left">
<field name="route_cheque_open_due_move_id" readonly="1" nolabel="1" options="{'no_create': True}"/>
</div>
</div>
</div>
</div>
