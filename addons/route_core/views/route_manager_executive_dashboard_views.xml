<odoo>
<record id="view_route_manager_executive_dashboard_form" model="ir.ui.view">
<field name="name">route.manager.executive.dashboard.form</field>
<field name="model">route.manager.executive.dashboard</field>
<field name="arch" type="xml">
<form string="Manager Executive Dashboard" create="0" delete="0" class="route_supervisor_performance_dashboard_form route_manager_executive_dashboard_form">
<header>
<button name="action_refresh_dashboard" type="object" string="Refresh" icon="fa-refresh"/>
<button name="action_print_pdf_snapshot" type="object" string="Print PDF Snapshot" icon="fa-print"/>
<button name="action_open_supervisor_dashboard" type="object" string="Supervisor Dashboard" icon="fa-dashboard" class="btn-primary"/>
<button name="action_open_dashboard_configuration" type="object" string="Dashboard Setup" icon="fa-sliders"/>
<button name="action_customize_dashboard" type="object" string="Customize Dashboard" icon="fa-eye"/>
<button name="action_open_daily_closing" type="object" string="Daily Closing" icon="fa-lock"/>
<button name="action_open_visits" type="object" string="Visits" icon="fa-calendar-check-o"/>
<button name="action_open_collections" type="object" string="Collections" icon="fa-money"/>
<button name="action_open_promises" type="object" string="Promises" icon="fa-calendar-o"/>
<button name="action_open_sales_orders" type="object" string="Sales Orders" icon="fa-shopping-cart" invisible="not show_direct_sale_sections"/>
<button name="action_open_returns" type="object" string="Returns" icon="fa-undo" invisible="not show_direct_return_sections and not show_consignment_sections"/>
<button name="action_open_location_review" type="object" string="Location Risk" icon="fa-map-marker" invisible="not show_location_sections"/>
<button name="action_open_vehicle_issues" type="object" string="Vehicle Risk" icon="fa-truck" invisible="not show_vehicle_closing_sections"/>
<button name="action_open_closing_records" type="object" string="Closing Records" icon="fa-folder-open-o"/>
</header>
<sheet>
<div class="oe_title mb-2">
<span class="text-muted small">Manager Executive Dashboard</span>
<h1 class="mb-1">Executive Command Center</h1>
<p class="text-muted mb-0">Management KPIs and visual analytics for sales, collections, profit, outlets, products, areas, and operational risk.</p>
</div>
<h4 class="mt-2 mb-2">Executive Filters</h4>
<div class="row g-2 mb-3 route_dashboard_filter_cards">
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Period</span>
<field name="period_filter" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100 route_dashboard_focus_filter_card">
<span class="text-muted small d-block">Focus Mode</span>
<field name="dashboard_focus_mode" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">From</span>
<field name="date_from" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">To</span>
<field name="date_to" nolabel="1"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Salesperson</span>
<field name="salesperson_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Vehicle</span>
<field name="vehicle_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">City</span>
<field name="city_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Area</span>
<field name="area_id" nolabel="1" domain="[('city_id', '=', city_id)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Outlet</span>
<field name="outlet_id" nolabel="1" domain="[('active', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
<div class="col-6 col-lg-2">
<div class="border rounded p-2 bg-white h-100">
<span class="text-muted small d-block">Company</span>
<field name="company_id" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
</div>
</div>
</div>
<div class="route_dashboard_focus_hint mb-3">
<i class="fa fa-info-circle"/>
<span>Focus Mode remembers your personal choice on this dashboard only. It filters enabled widgets; Dashboard Setup and Customize Dashboard still control what is allowed to appear.</span>
</div>
<field name="currency_id" invisible="1"/>
<field name="show_direct_sale_sections" invisible="1"/>
<field name="show_consignment_sections" invisible="1"/>
<field name="show_outlet_comparison_sections" invisible="1"/>
<field name="show_direct_return_sections" invisible="1"/>
<field name="show_location_sections" invisible="1"/>
<field name="show_vehicle_closing_sections" invisible="1"/>
<field name="show_loading_sections" invisible="1"/>
<field name="show_stock_transfer_sections" invisible="1"/>
<field name="show_lot_expiry_sections" invisible="1"/>
<field name="drill_all_visit_count" invisible="1"/>
<field name="drill_completed_visit_count" invisible="1"/>
<field name="drill_unfinished_visit_count" invisible="1"/>
<field name="drill_not_started_visit_count" invisible="1"/>
<field name="drill_open_due_visit_count" invisible="1"/>
<field name="drill_open_due_amount" invisible="1"/>
<field name="drill_collection_count" invisible="1"/>
<field name="drill_collection_amount" invisible="1"/>
<field name="drill_open_promise_count" invisible="1"/>
<field name="drill_open_promise_amount" invisible="1"/>
<field name="drill_due_promise_count" invisible="1"/>
<field name="drill_due_promise_amount" invisible="1"/>
<field name="drill_sales_order_count" invisible="1"/>
<field name="drill_sales_order_amount" invisible="1"/>
<field name="drill_return_count" invisible="1"/>
<field name="drill_return_amount" invisible="1"/>
<field name="drill_return_transfer_count" invisible="1"/>
<field name="drill_refill_transfer_count" invisible="1"/>
<field name="drill_loading_proposal_count" invisible="1"/>
<field name="drill_pending_transfer_count" invisible="1"/>
<field name="drill_top_product_count" invisible="1"/>
<field name="drill_returned_product_count" invisible="1"/>
<field name="drill_outlet_count" invisible="1"/>
<field name="drill_top_sales_outlet_count" invisible="1"/>
<field name="drill_highest_due_outlet_count" invisible="1"/>
<field name="drill_risk_outlet_count" invisible="1"/>
<field name="drill_location_review_count" invisible="1"/>
<field name="drill_vehicle_issue_count" invisible="1"/>
<field name="drill_closing_record_count" invisible="1"/>
<div class="route_dash_drilldown_panel route_dash_manager_drilldown_panel">
<div class="route_dash_drilldown_head">
<div>
<strong>Smart Executive Drill-down Actions</strong>
<span>Open filtered management records using the same executive period, salesperson, vehicle, city, area, and outlet filters.</span>
</div>
</div>
<div class="route_dash_drilldown_grid">
<button name="action_open_supervisor_dashboard" type="object" class="route_dash_drill_btn route_dash_drill_primary">
<span class="route_dash_drill_icon fa fa-dashboard"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Supervisor Dashboard</span>
<span class="route_dash_drill_metric">
<span>Open</span>
</span>
</span>
</button>
<button name="action_open_daily_closing" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-lock"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Daily Closing</span>
<span class="route_dash_drill_metric">
<field name="drill_closing_record_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_visits" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-calendar-check-o"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Visits</span>
<span class="route_dash_drill_metric">
<field name="drill_all_visit_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_unfinished_visits" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-exclamation-circle"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Unfinished Visits</span>
<span class="route_dash_drill_metric">
<field name="drill_unfinished_visit_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_completed_visits" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-check-circle"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Completed Visits</span>
<span class="route_dash_drill_metric">
<field name="drill_completed_visit_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_open_due_visits" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-money"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Open Due Visits</span>
<span class="route_dash_drill_metric">
<field name="drill_open_due_visit_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_open_due_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_collections" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-money"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Collections</span>
<span class="route_dash_drill_metric">
<field name="drill_collection_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_collection_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_promises" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-calendar-o"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Open Promises</span>
<span class="route_dash_drill_metric">
<field name="drill_open_promise_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_open_promise_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_due_overdue_promises" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-bell"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Due Promises</span>
<span class="route_dash_drill_metric">
<field name="drill_due_promise_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_due_promise_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_sales_orders" type="object" class="route_dash_drill_btn" invisible="not show_direct_sale_sections">
<span class="route_dash_drill_icon fa fa-shopping-cart"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Sales Orders</span>
<span class="route_dash_drill_metric">
<field name="drill_sales_order_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_sales_order_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_returns" type="object" class="route_dash_drill_btn" invisible="not show_direct_return_sections and not show_consignment_sections">
<span class="route_dash_drill_icon fa fa-undo"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Returns</span>
<span class="route_dash_drill_metric">
<field name="drill_return_count" nolabel="1" readonly="1"/>
<span class="route_dash_metric_sep">•</span>
<field name="drill_return_amount" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
</span>
</span>
</button>
<button name="action_open_pending_transfers" type="object" class="route_dash_drill_btn" invisible="not show_stock_transfer_sections">
<span class="route_dash_drill_icon fa fa-exchange"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Pending Transfers</span>
<span class="route_dash_drill_metric">
<field name="drill_pending_transfer_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_top_selling_products" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-cube"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Top Products</span>
<span class="route_dash_drill_metric">
<field name="drill_top_product_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_top_returned_products" type="object" class="route_dash_drill_btn" invisible="not show_direct_return_sections and not show_consignment_sections">
<span class="route_dash_drill_icon fa fa-reply"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Returned Products</span>
<span class="route_dash_drill_metric">
<field name="drill_returned_product_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_dashboard_outlets" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-map-signs"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Outlets</span>
<span class="route_dash_drill_metric">
<field name="drill_outlet_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_top_sales_outlets" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-line-chart"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Top Sales Outlets</span>
<span class="route_dash_drill_metric">
<field name="drill_top_sales_outlet_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_highest_due_outlets" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-warning"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Highest Due Outlets</span>
<span class="route_dash_drill_metric">
<field name="drill_highest_due_outlet_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_high_risk_outlets" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-bolt"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Risk Outlets</span>
<span class="route_dash_drill_metric">
<field name="drill_risk_outlet_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_location_review" type="object" class="route_dash_drill_btn" invisible="not show_location_sections">
<span class="route_dash_drill_icon fa fa-map-marker"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Location Risk</span>
<span class="route_dash_drill_metric">
<field name="drill_location_review_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_vehicle_issues" type="object" class="route_dash_drill_btn" invisible="not show_vehicle_closing_sections">
<span class="route_dash_drill_icon fa fa-truck"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Vehicle Risk</span>
<span class="route_dash_drill_metric">
<field name="drill_vehicle_issue_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
<button name="action_open_closing_records" type="object" class="route_dash_drill_btn">
<span class="route_dash_drill_icon fa fa-folder-open-o"/>
<span class="route_dash_drill_content">
<span class="route_dash_drill_label">Closing Records</span>
<span class="route_dash_drill_metric">
<field name="drill_closing_record_count" nolabel="1" readonly="1"/>
</span>
</span>
</button>
</div>
</div>
<field name="executive_overview_html" nolabel="1" readonly="1" widget="html"/>
<field name="period_comparison_html" nolabel="1" readonly="1" widget="html"/>
<field name="commercial_health_html" nolabel="1" readonly="1" widget="html"/>
<field name="market_ranking_html" nolabel="1" readonly="1" widget="html"/>
<field name="executive_risk_html" nolabel="1" readonly="1" widget="html"/>
</sheet>
</form>
</field>
</record>
<record id="server_action_open_route_manager_executive_dashboard" model="ir.actions.server">
<field name="name">Manager Executive Dashboard</field>
<field name="model_id" ref="route_core.model_route_manager_executive_dashboard"/>
<field name="state">code</field>
<field name="code">action = env["route.manager.executive.dashboard"].action_open_manager_dashboard()</field>
</record>
<menuitem id="menu_route_manager_executive_dashboard" name="Manager Executive Dashboard" parent="route_core.menu_route_management_workspace" action="route_core.server_action_open_route_manager_executive_dashboard" sequence="1" groups="route_core.group_route_management"/>
</odoo>
