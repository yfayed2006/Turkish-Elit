<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_vehicle_list" model="ir.ui.view">
        <field name="name">route.vehicle.list</field>
        <field name="model">route.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="code"/>
                <field name="name"/>
                <field name="plate_no"/>
                <field name="driver_name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_vehicle_form" model="ir.ui.view">
        <field name="name">route.vehicle.form</field>
        <field name="model">route.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="plate_no"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="driver_name"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">route.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_route_vehicle"
        name="Vehicles"
        parent="menu_route_configuration"
        action="action_route_vehicle"
        sequence="20"
    />

</odoo>
