<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_vehicle_list" model="ir.ui.view">
        <field name="name">route.vehicle.list</field>
        <field name="model">route.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="code"/>
                <field name="name"/>
                <field name="plate_no"/>
                <field name="driver_name"/>
                <field name="last_visit_date"/>
                <field name="last_sale_order_id"/>
                <field name="visit_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_route_vehicle_form" model="ir.ui.view">
        <field name="name">route.vehicle.form</field>
        <field name="model">route.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="%(route_core.action_route_visit)d"
                            type="action"
                            class="oe_stat_button"
                            icon="fa-map-marker"
                            context="{'search_default_vehicle_id': active_id, 'default_vehicle_id': active_id}"
                        >
                            <field name="visit_count" string="Visits" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="plate_no"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="driver_name"/>
                        </group>
                    </group>

                    <group string="Latest Activity">
                        <group>
                            <field name="last_visit_id" readonly="1"/>
                            <field name="last_visit_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_sale_order_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Visits">
                            <field name="visit_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="outlet_id"/>
                                    <field name="partner_id"/>
                                    <field name="area_id"/>
                                    <field name="user_id"/>
                                    <field name="state"/>
                                    <field name="sale_order_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">route.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_route_vehicle"
        name="Vehicles"
        parent="menu_route_configuration"
        action="action_route_vehicle"
        sequence="20"
    />

</odoo>
