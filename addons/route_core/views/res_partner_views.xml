<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_company_form_route_return_locations" model="ir.ui.view">
        <field name="name">res.company.form.route.return.locations</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Route Returns">
                    <group string="Return Destination Locations">
                        <field name="return_damaged_location_id"/>
                        <field name="return_near_expiry_location_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
