<record id="view_route_custody_accounting_work_queue_search" model="ir.ui.view">
<field name="name">route.custody.accounting.work.queue.search</field>
<field name="model">route.custody.accounting.work.queue</field>
<field name="arch" type="xml">
<search string="Accounting Work Queue">
<field name="salesperson_id"/>
<field name="workflow_state"/>
<separator/>
<filter name="filter_open_work" string="Open Work" domain="[('total_work_count', '>', 0)]"/>
<filter name="filter_cash_work" string="Cash Work" domain="['|', '|', ('cash_with_salesperson_count', '>', 0), ('cash_waiting_receipt_count', '>', 0), ('cash_received_not_posted_count', '>', 0)]"/>
<filter name="filter_cheque_work" string="Cheque Work" domain="['|', '|', '|', '|', '|', ('cheque_with_salesperson_count', '>', 0), ('cheque_waiting_receipt_count', '>', 0), ('cheque_received_not_posted_count', '>', 0), ('bank_pending_count', '>', 0), ('bounced_followup_count', '>', 0), ('cancelled_followup_count', '>', 0)]"/>
<filter name="filter_with_salesperson" string="With Salespeople" domain="['|', ('cash_with_salesperson_count', '>', 0), ('cheque_with_salesperson_count', '>', 0)]"/>
<filter name="filter_waiting_receipt" string="Waiting Receipt" domain="['|', ('cash_waiting_receipt_count', '>', 0), ('cheque_waiting_receipt_count', '>', 0)]"/>
<filter name="filter_received_not_posted" string="Received Not Posted" domain="['|', ('cash_received_not_posted_count', '>', 0), ('cheque_received_not_posted_count', '>', 0)]"/>
<filter name="filter_bank_pending" string="Bank Pending" domain="[('bank_pending_count', '>', 0)]"/>
<filter name="filter_followup" string="Follow-up" domain="[('open_followup_count', '>', 0)]"/>
</search>
</field>
</record>
