<odoo>
<record id="view_route_custody_accounting_work_queue_kanban" model="ir.ui.view">
<field name="name">route.custody.accounting.work.queue.kanban</field>
<field name="model">route.custody.accounting.work.queue</field>
<field name="arch" type="xml">
<kanban class="route_pda_payment_kanban route_cheque_control_kanban route_custody_work_queue_kanban route_custody_work_queue_dashboard_kanban route_custody_accounting_work_queue_wide" create="0" edit="0" delete="0" sample="0" default_order="is_company_summary desc, total_work_count desc, salesperson_id asc, last_activity_at desc">
<field name="name"/>
<field name="salesperson_id"/>
<field name="is_company_summary"/>
<field name="company_id"/>
<field name="currency_id"/>
<field name="last_activity_at"/>
<field name="workflow_state"/>
<field name="cash_with_salesperson_amount"/>
<field name="cash_with_salesperson_count"/>
<field name="cheque_with_salesperson_amount"/>
<field name="cheque_with_salesperson_count"/>
<field name="cash_waiting_receipt_amount"/>
<field name="cash_waiting_receipt_count"/>
<field name="cheque_waiting_receipt_amount"/>
<field name="cheque_waiting_receipt_count"/>
<field name="cash_received_not_posted_amount"/>
<field name="cash_received_not_posted_count"/>
<field name="cheque_received_not_posted_amount"/>
<field name="cheque_received_not_posted_count"/>
<field name="bank_pending_amount"/>
<field name="bank_pending_count"/>
<field name="bounced_followup_amount"/>
<field name="bounced_followup_count"/>
<field name="cancelled_followup_amount"/>
<field name="cancelled_followup_count"/>
<field name="open_followup_amount"/>
<field name="open_followup_count"/>
<field name="total_with_salesperson_amount"/>
<field name="total_waiting_receipt_amount"/>
<field name="total_received_not_posted_amount"/>
<field name="total_work_amount"/>
<field name="total_work_count"/>
<templates>
<t t-name="card">
<div t-attf-class="o_kanban_record route_pda_payment_card route_cheque_control_card route_custody_monitor_card route_custody_work_queue_card #{record.is_company_summary.raw_value ? 'route_custody_work_queue_overview_card' : 'route_custody_work_queue_salesperson_card'}">
<div class="route_pda_payment_head route_cheque_control_head">
<div>
<div class="route_pda_payment_title">
<field name="name"/>
</div>
<div class="route_pda_payment_subtitle">
<t t-if="record.is_company_summary.raw_value"> Company custody overview across all salespeople </t>
<t t-if="!record.is_company_summary.raw_value">
<t t-if="record.total_work_count.raw_value">
<t t-esc="record.total_work_count.value"/>
<t> open work items</t>
</t>
<t t-if="!record.total_work_count.raw_value">No open work</t>
</t>
</div>
</div>
<div class="route_pda_payment_date">
<field name="last_activity_at"/>
</div>
</div>
<div class="route_pda_payment_badges route_pda_payment_badges_primary route_custody_monitor_badges">
<span class="route_pda_payment_badge route_pda_payment_badge_confirmed">
<t>Open Work: </t>
<t t-esc="record.total_work_count.value or 0"/>
</span>
<t t-if="record.cash_with_salesperson_count.raw_value or record.cheque_with_salesperson_count.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_pending">With Salespeople</span>
</t>
<t t-if="record.cash_waiting_receipt_count.raw_value or record.cheque_waiting_receipt_count.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_cheque_highlight">Waiting Receipt</span>
</t>
<t t-if="record.cash_received_not_posted_count.raw_value or record.cheque_received_not_posted_count.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_pending">Received Not Posted</span>
</t>
<t t-if="record.bank_pending_count.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_cheque_highlight">Bank Pending</span>
</t>
<t t-if="record.open_followup_count.raw_value">
<span class="route_pda_payment_badge route_pda_payment_badge_balance">Follow-up</span>
</t>
</div>
<div t-attf-class="route_pda_payment_metrics route_cheque_control_metrics route_custody_monitor_metrics #{record.is_company_summary.raw_value ? 'route_custody_work_queue_summary_metrics' : 'route_custody_work_queue_person_metrics'}">
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cash With Salespeople</span>
<span class="route_pda_payment_metric_value">
<field name="cash_with_salesperson_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.cash_with_salesperson_count.value or 0"/>
lines
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cheques With Salespeople</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_with_salesperson_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.cheque_with_salesperson_count.value or 0"/>
cheques
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cash Waiting Receipt</span>
<span class="route_pda_payment_metric_value">
<field name="cash_waiting_receipt_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.cash_waiting_receipt_count.value or 0"/>
lines
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cheques Waiting Receipt</span>
<span class="route_pda_payment_metric_value">
<field name="cheque_waiting_receipt_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.cheque_waiting_receipt_count.value or 0"/>
cheques
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Received Not Posted</span>
<span class="route_pda_payment_metric_value">
<field name="total_received_not_posted_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="(record.cash_received_not_posted_count.raw_value || 0) + (record.cheque_received_not_posted_count.raw_value || 0)"/>
items
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Bank Pending</span>
<span class="route_pda_payment_metric_value">
<field name="bank_pending_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.bank_pending_count.value or 0"/>
cheques
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Bounced / Follow-up</span>
<span class="route_pda_payment_metric_value">
<field name="bounced_followup_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.bounced_followup_count.value or 0"/>
cheques
</span>
</div>
<div class="route_pda_payment_metric">
<span class="route_pda_payment_metric_label">Cancelled / Open Due</span>
<span class="route_pda_payment_metric_value">
<field name="cancelled_followup_amount"/>
</span>
<span class="route_pda_payment_metric_note">
<t t-esc="record.cancelled_followup_count.value or 0"/>
cheques
</span>
</div>
</div>
<div t-attf-class="route_cheque_control_actions route_collection_custody_actions route_custody_actions route_custody_work_queue_actions #{record.is_company_summary.raw_value ? 'route_custody_work_queue_summary_actions' : 'route_custody_work_queue_person_actions'}">
<button name="action_open_all_work" type="object" class="btn btn-sm btn-primary">Open Work</button>
<button name="action_open_with_salesperson" type="object" class="btn btn-sm btn-light" invisible="not cash_with_salesperson_count and not cheque_with_salesperson_count">With Salespeople</button>
<button name="action_open_waiting_receipt" type="object" class="btn btn-sm btn-secondary" invisible="not cash_waiting_receipt_count and not cheque_waiting_receipt_count">Waiting Receipt</button>
<button name="action_open_received_not_posted" type="object" class="btn btn-sm btn-secondary" invisible="not cash_received_not_posted_count and not cheque_received_not_posted_count">Received Not Posted</button>
<button name="action_open_bank_pending" type="object" class="btn btn-sm btn-light" invisible="not bank_pending_count">Bank Pending</button>
<button name="action_open_followup" type="object" class="btn btn-sm btn-warning" invisible="not open_followup_count">Follow-up</button>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
