<odoo>
<record id="view_route_visit_form_document_links_tab" model="ir.ui.view">
<field name="name">route.visit.form.document.links.tab</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="inside">
<page string="Documents">
<group>
<group>
<field name="sale_order_id" readonly="1"/>
<field name="refill_picking_id" readonly="1"/>
</group>
<group>
<field name="sale_order_count" readonly="1"/>
<field name="sale_delivery_count" readonly="1"/>
<field name="return_transfer_count" readonly="1"/>
<field name="refill_picking_count" readonly="1"/>
<field name="shortage_count" readonly="1"/>
</group>
</group>
<group col="5">
<button name="action_view_sale_order" type="object" string="Open Sale Order" class="btn-primary"/>
<button name="action_view_sale_deliveries" type="object" string="Open Sales Deliveries" class="btn-secondary"/>
<button name="action_view_return_transfers" type="object" string="Open Return Transfers" class="btn-secondary"/>
<button name="action_view_refill_transfer" type="object" string="Open Refill Transfer" class="btn-secondary"/>
<button name="action_view_shortages" type="object" string="Open Generated Shortage" class="btn-secondary"/>
</group>
</page>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_form_document_links_tab" model="ir.ui.view">
<field name="name">route.visit.pda.form.document.links.tab</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="inside">
<page string="Documents">
<group>
<group>
<field name="sale_order_id" readonly="1"/>
<field name="refill_picking_id" readonly="1"/>
</group>
<group>
<field name="sale_order_count" readonly="1"/>
<field name="sale_delivery_count" readonly="1"/>
<field name="return_transfer_count" readonly="1"/>
<field name="refill_picking_count" readonly="1"/>
<field name="shortage_count" readonly="1"/>
</group>
</group>
<group col="5">
<button name="action_view_sale_order" type="object" string="Open Sale Order" class="btn-primary"/>
<button name="action_view_sale_deliveries" type="object" string="Open Sales Deliveries" class="btn-secondary"/>
<button name="action_view_return_transfers" type="object" string="Open Return Transfers" class="btn-secondary"/>
<button name="action_view_refill_transfer" type="object" string="Open Refill Transfer" class="btn-secondary"/>
<button name="action_view_shortages" type="object" string="Open Generated Shortage" class="btn-secondary"/>
</group>
</page>
</xpath>
</field>
</record>
</odoo>
