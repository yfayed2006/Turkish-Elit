<odoo>
<record id="view_route_visit_form_document_links_page" model="ir.ui.view">
<field name="name">route.visit.form.document.links.page</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="inside">
<page string="Documents">
<group>
<group string="Direct Links">
<field name="sale_order_count" invisible="1"/>
<field name="sale_delivery_count" invisible="1"/>
<field name="return_transfer_count" invisible="1"/>
<field name="refill_picking_count" invisible="1"/>
<field name="shortage_count" invisible="1"/>
<field name="sale_order_id" readonly="1"/>
<field name="sale_delivery_id" readonly="1"/>
<field name="refill_picking_id" readonly="1"/>
<field name="generated_shortage_id" readonly="1"/>
</group>
<group string="Open Actions">
<button name="action_view_sale_order" string="Open Sale Order" type="object" class="btn btn-primary" invisible="sale_order_count == 0"/>
<button name="action_view_sale_deliveries" string="Open Sales Delivery" type="object" class="btn btn-secondary" invisible="sale_delivery_count == 0"/>
<button name="action_view_return_transfers" string="Open Return Transfers" type="object" class="btn btn-secondary" invisible="return_transfer_count == 0"/>
<button name="action_view_refill_transfer" string="Open Refill Transfer" type="object" class="btn btn-secondary" invisible="refill_picking_count == 0"/>
<button name="action_view_shortages" string="Open Generated Shortage" type="object" class="btn btn-secondary" invisible="shortage_count == 0"/>
</group>
</group>
</page>
</xpath>
</field>
</record>
