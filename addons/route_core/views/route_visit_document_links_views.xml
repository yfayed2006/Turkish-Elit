<odoo>
<record id="view_route_visit_form_document_links" model="ir.ui.view">
<field name="name">route.visit.form.document.links</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_form"/>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="inside">
<page string="Documents">
<group>
<group string="Direct Documents">
<field name="sale_order_id" readonly="1"/>
<button name="action_view_sale_order" string="Open Sale Order" type="object" class="btn-primary" invisible="not sale_order_id"/>
<field name="refill_picking_id" readonly="1"/>
<button name="action_view_refill_transfer" string="Open Refill Transfer" type="object" class="btn-secondary" invisible="not refill_picking_id"/>
</group>
<group string="Generated Documents">
<field name="sale_delivery_count" readonly="1"/>
<button name="action_view_sale_deliveries" string="Open Sales Deliveries" type="object" class="btn-secondary" invisible="sale_delivery_count == 0"/>
<field name="return_transfer_count" readonly="1"/>
<button name="action_view_return_transfers" string="Open Return Transfers" type="object" class="btn-secondary" invisible="return_transfer_count == 0"/>
<field name="shortage_count" readonly="1"/>
<button name="action_view_shortages" string="Open Generated Shortage" type="object" class="btn-secondary" invisible="shortage_count == 0"/>
</group>
</group>
</page>
</xpath>
</field>
</record>
<record id="view_route_visit_pda_form_document_links" model="ir.ui.view">
<field name="name">route.visit.pda.form.document.links</field>
<field name="model">route.visit</field>
<field name="inherit_id" ref="route_core.view_route_visit_pda_form"/>
<field name="priority" eval="200"/>
<field name="arch" type="xml">
<xpath expr="//notebook" position="inside">
<page string="Documents">
<group>
<group string="Direct Documents">
<field name="sale_order_id" readonly="1"/>
<button name="action_view_sale_order" string="Open Sale Order" type="object" class="btn-primary" invisible="not sale_order_id"/>
<field name="refill_picking_id" readonly="1"/>
<button name="action_view_refill_transfer" string="Open Refill Transfer" type="object" class="btn-secondary" invisible="not refill_picking_id"/>
</group>
<group string="Generated Documents">
<field name="sale_delivery_count" readonly="1"/>
<button name="action_view_sale_deliveries" string="Open Sales Deliveries" type="object" class="btn-secondary" invisible="sale_delivery_count == 0"/>
<field name="return_transfer_count" readonly="1"/>
<button name="action_view_return_transfers" string="Open Return Transfers" type="object" class="btn-secondary" invisible="return_transfer_count == 0"/>
<field name="shortage_count" readonly="1"/>
<button name="action_view_shortages" string="Open Generated Shortage" type="object" class="btn-secondary" invisible="shortage_count == 0"/>
</group>
</group>
</page>
</xpath>
</field>
</record>
</odoo>
