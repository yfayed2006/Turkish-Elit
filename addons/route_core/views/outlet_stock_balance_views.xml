<odoo>
<record id="view_outlet_stock_balance_kanban" model="ir.ui.view">
<field name="name">outlet.stock.balance.kanban</field>
<field name="model">outlet.stock.balance</field>
<field name="arch" type="xml">
<kanban class="route_pda_mobile_stock_kanban route_pda_mobile_stock_kanban_outlet" create="0" edit="0" delete="0">
<field name="outlet_id"/>
<field name="outlet_code"/>
<field name="route_city_id"/>
<field name="area_id"/>
<field name="product_id"/>
<field name="product_categ_id"/>
<field name="barcode"/>
<field name="qty"/>
<field name="product_image_128"/>
<field name="lot_names"/>
<field name="nearest_expiry_date"/>
<field name="last_updated_at"/>
<templates>
<t t-name="card">
<div class="oe_kanban_global_click o_kanban_record route_pda_stock_card">
<div class="route_pda_stock_card_top">
<div class="route_pda_stock_thumb_wrap">
<field name="product_image_128" widget="image" class="route_pda_stock_thumb" options="{'size': [128, 128], 'preview_image': 'product_image_128'}"/>
</div>
<div class="route_pda_stock_qty_wrap">
<div class="route_pda_stock_qty">
<field name="qty"/>
</div>
<div class="route_pda_stock_qty_label">Qty</div>
</div>
</div>
<div class="route_pda_stock_name">
<field name="product_id"/>
</div>
<div class="route_pda_stock_meta">
<field name="outlet_id"/>
<span t-if="record.outlet_code.raw_value">
•
<field name="outlet_code"/>
</span>
</div>
<div class="route_pda_stock_meta" t-if="record.route_city_id.raw_value or record.area_id.raw_value">
<span t-if="record.route_city_id.raw_value">
<field name="route_city_id"/>
</span>
<span t-if="record.route_city_id.raw_value and record.area_id.raw_value"> / </span>
<span t-if="record.area_id.raw_value">
<field name="area_id"/>
</span>
</div>
<div class="route_pda_stock_meta" t-if="record.product_categ_id.raw_value">
Category:
<field name="product_categ_id"/>
</div>
<div class="route_pda_stock_meta" t-if="record.lot_names.raw_value">
Lot:
<field name="lot_names"/>
</div>
<div class="route_pda_stock_meta" t-if="record.nearest_expiry_date.raw_value">
Expiry:
<field name="nearest_expiry_date"/>
</div>
</div>
</t>
</templates>
</kanban>
</field>
</record>
<record id="view_outlet_stock_balance_list" model="ir.ui.view">
<field name="name">outlet.stock.balance.list</field>
<field name="model">outlet.stock.balance</field>
<field name="arch" type="xml">
<list string="Consignment Outlets Stock" create="0" edit="0" delete="0" default_order="last_updated_at desc, outlet_id, product_id">
<field name="outlet_id"/>
<field name="area_id" optional="show"/>
<field name="route_city_id" optional="hide"/>
<field name="product_id"/>
<field name="qty"/>
<field name="barcode" optional="hide"/>
<field name="lot_names" optional="hide"/>
<field name="nearest_expiry_date" optional="hide"/>
<field name="unit_price" optional="hide"/>
<field name="last_updated_at" optional="show"/>
<field name="last_visit_id" optional="hide"/>
</list>
</field>
</record>
<record id="view_outlet_stock_balance_form" model="ir.ui.view">
<field name="name">outlet.stock.balance.form</field>
<field name="model">outlet.stock.balance</field>
<field name="arch" type="xml">
<form string="Consignment Outlet Stock" create="0" edit="0" delete="0">
<sheet>
<group col="1">
<group string="Stock Summary" col="1">
<field name="outlet_id"/>
<field name="product_id"/>
<field name="qty"/>
<field name="unit_price"/>
</group>
</group>
<notebook>
<page string="Outlet Details">
<group col="1">
<field name="outlet_code" readonly="1"/>
<field name="route_city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
</group>
</page>
<page string="Tracking">
<group col="1">
<field name="barcode" readonly="1"/>
<field name="product_categ_id" readonly="1"/>
<field name="lot_names" readonly="1"/>
<field name="nearest_expiry_date" readonly="1"/>
<field name="nearest_alert_date" readonly="1"/>
</group>
</page>
<page string="History">
<group col="1">
<field name="last_visit_id"/>
<field name="last_updated_at" readonly="1"/>
</group>
</page>
</notebook>
</sheet>
</form>
</field>
</record>
<record id="view_outlet_stock_balance_search" model="ir.ui.view">
<field name="name">outlet.stock.balance.search</field>
<field name="model">outlet.stock.balance</field>
<field name="arch" type="xml">
<search string="Consignment Outlets Stock">
<field name="outlet_id"/>
<field name="outlet_code"/>
<field name="route_city_id"/>
<field name="area_id"/>
<field name="product_id"/>
<field name="product_categ_id"/>
<field name="barcode"/>
<field name="last_visit_id"/>
<filter name="filter_has_qty" string="Has Quantity" domain="[('qty', '>', 0)]"/>
<filter name="filter_zero_qty" string="Zero Quantity" domain="[('qty', '=', 0)]"/>
<filter name="filter_with_last_visit" string="With Last Visit" domain="[('last_visit_id', '!=', False)]"/>
<separator/>
<filter name="group_by_city" string="City" context="{'group_by': 'route_city_id'}"/>
<filter name="group_by_area" string="Area" context="{'group_by': 'area_id'}"/>
<filter name="group_by_outlet" string="Outlet" context="{'group_by': 'outlet_id'}"/>
<filter name="group_by_product_category" string="Product Category" context="{'group_by': 'product_categ_id'}"/>
<filter name="group_by_product" string="Product" context="{'group_by': 'product_id'}"/>
<filter name="group_by_last_visit" string="Last Visit" context="{'group_by': 'last_visit_id'}"/>
<searchpanel>
<field name="route_city_id" string="City" icon="fa-building" select="multi"/>
<field name="area_id" string="Area" icon="fa-map" select="multi"/>
<field name="outlet_id" string="Outlet" icon="fa-store" select="multi"/>
<field name="product_categ_id" string="Category" icon="fa-tags" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_outlet_stock_balance" model="ir.actions.act_window">
<field name="name">Outlet Stock Balances</field>
<field name="res_model">outlet.stock.balance</field>
<field name="view_mode">kanban,list,form</field>
<field name="search_view_id" ref="view_outlet_stock_balance_search"/>
</record>
<menuitem id="menu_outlet_stock_balance" name="Outlet Stock Balances" parent="menu_route_visit_root" action="action_outlet_stock_balance" sequence="60"/>
</odoo>
