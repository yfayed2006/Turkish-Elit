<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_outlet_stock_balance_list" model="ir.ui.view">
        <field name="name">outlet.stock.balance.list</field>
        <field name="model">outlet.stock.balance</field>
        <field name="arch" type="xml">
            <list>
                <field name="outlet_id"/>
                <field name="product_id"/>
                <field name="barcode"/>
                <field name="qty"/>
                <field name="unit_price"/>
                <field name="last_visit_id"/>
                <field name="last_updated_at"/>
            </list>
        </field>
    </record>

    <record id="view_outlet_stock_balance_form" model="ir.ui.view">
        <field name="name">outlet.stock.balance.form</field>
        <field name="model">outlet.stock.balance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="outlet_id"/>
                            <field name="product_id"/>
                            <field name="barcode" readonly="1"/>
                        </group>
                        <group>
                            <field name="qty"/>
                            <field name="unit_price"/>
                            <field name="last_visit_id"/>
                            <field name="last_updated_at" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_outlet_stock_balance" model="ir.actions.act_window">
        <field name="name">Outlet Stock Balances</field>
        <field name="res_model">outlet.stock.balance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_outlet_stock_balance"
        name="Outlet Stock Balances"
        parent="menu_route_visit_root"
        action="action_outlet_stock_balance"
        sequence="60"/>
</odoo>
