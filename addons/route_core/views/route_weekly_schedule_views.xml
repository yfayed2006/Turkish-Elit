<record id="view_route_weekly_schedule_search" model="ir.ui.view">
<field name="name">route.weekly.schedule.search</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<search>
<field name="name" string="Schedule Reference"/>
<field name="week_start_date" readonly="state != 'draft'"/>
<field name="user_id" readonly="state != 'draft'"/>
<field name="vehicle_id" readonly="state != 'draft'"/>
<field name="template_id"/>
<field name="state"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_generated" string="Daily Plans Generated" domain="[('state', '=', 'plans_generated')]"/>
<filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="view_route_weekly_schedule_salesperson_search" model="ir.ui.view">
<field name="name">route.weekly.schedule.salesperson.search</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<search>
<field name="name" string="Schedule Reference"/>
<field name="week_start_date"/>
<field name="vehicle_id"/>
<field name="outlet_summary" string="Planned Outlets"/>
<field name="state"/>
<filter name="filter_current_week" string="Current Week" domain="[('week_start_date', '<=', context_today()), ('week_end_date', '>=', context_today())]"/>
<filter name="filter_generated" string="Daily Plans Ready" domain="[('state', '=', 'plans_generated')]"/>
<filter name="filter_draft" string="Awaiting Planning" domain="[('state', '=', 'draft')]"/>
<searchpanel>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
</searchpanel>
</search>
</field>
</record>
