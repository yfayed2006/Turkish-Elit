<odoo>
<data>
<record id="view_route_weekly_schedule_list" model="ir.ui.view">
<field name="name">route.weekly.schedule.list</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<list>
<field name="name" string="Schedule Reference"/>
<field name="week_start_date"/>
<field name="week_end_date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="template_id" string="Weekly Template" optional="show"/>
<field name="city_summary" string="Cities" optional="show"/>
<field name="area_summary" string="Areas" optional="show"/>
<field name="outlet_summary" string="Outlets"/>
<field name="line_count" string="Stops"/>
<field name="generated_plan_count" string="Daily Plans"/>
<field name="state" widget="badge"/>
</list>
</field>
</record>
<record id="view_route_weekly_schedule_form" model="ir.ui.view">
<field name="name">route.weekly.schedule.form</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<form string="Generated Weekly Schedule">
<header>
<button name="action_generate_daily_plans" type="object" string="Generate Daily Plans" class="btn-primary" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_copy_to_next_week" type="object" string="Copy to Next Week" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_open_template" type="object" string="Open Weekly Template" class="btn-secondary"/>
<button name="action_open_daily_plans" type="object" string="Open Daily Plans" class="btn-secondary"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_cancel_schedule" type="object" string="Cancel" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_open_template" type="object" class="oe_stat_button" icon="fa-copy">
<div class="o_stat_info">
<span class="o_stat_text">Weekly Template</span>
</div>
</button>
<button name="action_open_daily_plans" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
<field name="generated_plan_count" string="Daily Plans" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge"/>
</div>
</div>
<div class="alert alert-info" role="alert"> This screen is a dated weekly schedule created from a template. Each tab represents one weekday, and each row should appear only under its own day. </div>
<div class="alert alert-warning" role="alert" invisible="skipped_finalized_plan_count == 0">
<strong>Finalized Daily Plans Protected:</strong>
<field name="skipped_finalized_plan_count" class="oe_inline" readonly="1"/>
day(s) were linked to already finalized daily plans and were skipped during sync to protect operational data.
</div>
<group string="Weekly Planning" col="2">
<group>
<field name="week_start_date"/>
<field name="week_end_date" readonly="1"/>
<field name="template_id" options="{'no_create': True}"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="source_warehouse_id" options="{'no_create': True}"/>
</group>
<group>
<field name="company_id" readonly="1"/>
<field name="off_day" readonly="1"/>
<field name="off_day_stop_count" readonly="1"/>
<field name="skipped_finalized_plan_count" readonly="1"/>
<field name="city_summary" readonly="1"/>
<field name="area_summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<separator string="Scheduled Weekly Stops"/>
<notebook>
<page string="Monday">
<field name="monday_line_ids" context="{'default_weekday': 'monday'}" domain="[('weekday', '=', 'monday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Tuesday">
<field name="tuesday_line_ids" context="{'default_weekday': 'tuesday'}" domain="[('weekday', '=', 'tuesday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Wednesday">
<field name="wednesday_line_ids" context="{'default_weekday': 'wednesday'}" domain="[('weekday', '=', 'wednesday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Thursday">
<field name="thursday_line_ids" context="{'default_weekday': 'thursday'}" domain="[('weekday', '=', 'thursday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Friday">
<field name="friday_line_ids" context="{'default_weekday': 'friday'}" domain="[('weekday', '=', 'friday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Saturday">
<field name="saturday_line_ids" context="{'default_weekday': 'saturday'}" domain="[('weekday', '=', 'saturday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
<page string="Sunday">
<field name="sunday_line_ids" context="{'default_weekday': 'sunday'}" domain="[('weekday', '=', 'sunday')]">
<list editable="bottom" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="sequence" widget="handle"/>
<field name="visit_date" readonly="1"/>
<field name="city_id"/>
<field name="area_id" domain="[('city_id', '=', city_id)]"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" optional="show"/>
<field name="visit_mode" optional="show"/>
<field name="generated_plan_id" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
</page>
</notebook>
<group string="Notes">
<field name="notes" placeholder="Weekly supervisor notes..."/>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_weekly_schedule_search" model="ir.ui.view">
<field name="name">route.weekly.schedule.search</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<search>
<field name="name" string="Schedule Reference"/>
<field name="week_start_date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="template_id"/>
<field name="state"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_generated" string="Daily Plans Generated" domain="[('state', '=', 'plans_generated')]"/>
<filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_weekly_schedule" model="ir.actions.act_window">
<field name="name">Weekly Schedules</field>
<field name="res_model">route.weekly.schedule</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_weekly_schedule_search"/>
</record>
<record id="action_route_weekly_schedule_salesperson" model="ir.actions.act_window">
<field name="name">My Weekly Schedule</field>
<field name="res_model">route.weekly.schedule</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_weekly_schedule_search"/>
<field name="domain">[('user_id', '=', uid), ('state', '!=', 'cancelled')]</field>
<field name="context">{'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
</data>
</odoo>
