<record id="view_route_weekly_schedule_form" model="ir.ui.view">
<field name="name">route.weekly.schedule.form</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<form string="Generated Weekly Schedule">
<header>
<button name="action_generate_daily_plans" type="object" string="Generate Daily Plans" class="btn-primary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'draft'"/>
<button name="action_copy_to_next_week" type="object" string="Copy to Next Week" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state == 'cancelled'"/>
<button name="action_open_template" type="object" string="Open Weekly Template" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_open_daily_plans" type="object" string="Open Daily Plans" class="btn-secondary" invisible="generated_plan_count == 0"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state != 'plans_generated'"/>
<button name="action_cancel_schedule" type="object" string="Cancel" class="btn-secondary" groups="route_core.group_route_supervisor,route_core.group_route_management" invisible="state == 'cancelled'"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_open_template" type="object" class="oe_stat_button" icon="fa-copy" groups="route_core.group_route_supervisor,route_core.group_route_management">
<div class="o_stat_info">
<span class="o_stat_text">Weekly Template</span>
</div>
</button>
<button name="action_open_daily_plans" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
<field name="generated_plan_count" string="Daily Plans" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge"/>
</div>
</div>
<div class="alert alert-info" role="alert"> This screen is a dated weekly schedule created from a saved template. Each tab represents one weekday. Review the schedule first, then generate daily plans. </div>
<div class="alert alert-warning" role="alert" invisible="state == 'draft'">
<strong>Planning Locked:</strong>
This weekly schedule is now read-only because daily plans have already been generated from it. To change this week safely, use
<strong>Reset to Draft</strong>
only before any daily plan is finalized or any visit starts. Otherwise, edit the daily route plans directly.
</div>
<div class="alert alert-warning" role="alert" invisible="skipped_finalized_plan_count == 0">
<strong>Finalized Daily Plans Protected:</strong>
<field name="skipped_finalized_plan_count" class="oe_inline" readonly="1"/>
day(s) were linked to already finalized daily plans and were skipped during sync to protect operational data.
</div>
<group string="Weekly Planning" col="2">
<group>
<field name="week_start_date" readonly="state != 'draft'"/>
<field name="week_end_date" readonly="1"/>
<field name="template_id" options="{'no_create': True}" readonly="state != 'draft'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<field name="user_id" readonly="state != 'draft'"/>
<field name="vehicle_id" readonly="state != 'draft'"/>
<field name="source_warehouse_id" options="{'no_create': True}" readonly="state != 'draft'"/>
</group>
<group>
<field name="company_id" readonly="1"/>
<field name="off_day" readonly="1"/>
<field name="off_day_stop_count" readonly="1"/>
<field name="skipped_finalized_plan_count" readonly="1"/>
<field name="city_summary" readonly="1"/>
<field name="area_summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<separator string="Scheduled Weekly Stops"/>
<notebook>
<page string="Monday">
<div class="mb-2">
<button name="action_open_day_stop_wizard" type="object" string="Add a line" class="btn-primary" context="{'default_weekday': 'monday'}" invisible="not id or state != 'draft'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</div>
<field name="monday_line_ids" readonly="state != 'draft'" context="{'default_weekday': 'monday'}" domain="[('weekday', '=', 'monday')]">
<list create="0" delete="1" decoration-warning="is_off_day" decoration-muted="finalized_plan_skip">
<field name="is_off_day" column_invisible="1"/>
<field name="finalized_plan_skip" column_invisible="1"/>
<field name="weekday" column_invisible="1"/>
<field name="visit_date" readonly="1"/>
<field name="city_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="generated_plan_id" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
