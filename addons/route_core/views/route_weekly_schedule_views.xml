<odoo>
<data>
<record id="view_route_weekly_schedule_list" model="ir.ui.view">
<field name="name">route.weekly.schedule.list</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<list>
<field name="name"/>
<field name="week_start_date"/>
<field name="week_end_date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="template_id" optional="show"/>
<field name="city_summary" string="Cities" optional="show"/>
<field name="area_summary" string="Areas" optional="show"/>
<field name="outlet_summary" string="Outlets"/>
<field name="line_count"/>
<field name="generated_plan_count"/>
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'plans_generated'" decoration-danger="state == 'cancelled'"/>
</list>
</field>
</record>
<record id="view_route_weekly_schedule_form" model="ir.ui.view">
<field name="name">route.weekly.schedule.form</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<form string="Weekly Route Schedule">
<header>
<button name="action_generate_daily_plans" type="object" string="Generate Daily Plans" class="btn-primary" invisible="state == 'cancelled' or line_count == 0" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_copy_to_next_week" type="object" string="Copy to Next Week" class="btn-secondary" invisible="state == 'cancelled'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_open_daily_plans" type="object" string="Open Daily Plans" class="btn-secondary" invisible="generated_plan_count == 0"/>
<button name="action_reset_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state != 'plans_generated'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
<button name="action_cancel_schedule" type="object" string="Cancel" class="btn-secondary" invisible="state == 'cancelled'" groups="route_core.group_route_supervisor,route_core.group_route_management"/>
</header>
<sheet>
<div class="oe_button_box" name="button_box">
<button name="action_open_daily_plans" type="object" class="oe_stat_button" icon="fa-calendar-check-o" invisible="generated_plan_count == 0">
<field name="generated_plan_count" string="Daily Plans" widget="statinfo"/>
</button>
</div>
<div class="oe_title">
<h1>
<field name="name" readonly="1"/>
</h1>
<div class="mt8">
<field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'plans_generated'" decoration-danger="state == 'cancelled'"/>
</div>
</div>
<group string="Weekly Planning" col="2">
<group>
<field name="week_start_date" readonly="state == 'cancelled'"/>
<field name="week_end_date" readonly="1"/>
<field name="template_id" readonly="state == 'cancelled'" options="{'no_create': True}"/>
<field name="user_id" readonly="state == 'cancelled'"/>
<field name="vehicle_id" readonly="state == 'cancelled'"/>
<field name="source_warehouse_id" readonly="state == 'cancelled'" options="{'no_create': True}"/>
</group>
<group>
<field name="company_id" readonly="1"/>
<field name="off_day" readonly="1"/>
<field name="city_summary" readonly="1"/>
<field name="area_summary" readonly="1"/>
<field name="outlet_summary" readonly="1"/>
</group>
</group>
<div class="alert alert-info" role="alert" invisible="not off_day">
<strong>Weekly Off Day:</strong>
<field name="off_day" readonly="1" class="oe_inline"/>
is skipped automatically during daily plan generation.
</div>
<separator string="Scheduled Weekly Stops"/>
<field name="line_ids" readonly="state == 'cancelled'">
<list editable="bottom">
<field name="sequence" widget="handle"/>
<field name="weekday"/>
<field name="visit_date" readonly="1"/>
<field name="city_id" readonly="1" optional="show"/>
<field name="area_id"/>
<field name="outlet_id" domain="[('area_id', '=', area_id)]"/>
<field name="partner_id" readonly="1" optional="show"/>
<field name="visit_mode" readonly="1" optional="show"/>
<field name="generated_plan_id" readonly="1" optional="show"/>
<field name="note" string="Line Note" optional="show"/>
</list>
</field>
<group string="Notes">
<field name="notes" placeholder="Weekly supervisor notes..." readonly="state == 'cancelled'"/>
</group>
</sheet>
</form>
</field>
</record>
<record id="view_route_weekly_schedule_search" model="ir.ui.view">
<field name="name">route.weekly.schedule.search</field>
<field name="model">route.weekly.schedule</field>
<field name="arch" type="xml">
<search>
<field name="name"/>
<field name="week_start_date"/>
<field name="user_id"/>
<field name="vehicle_id"/>
<field name="template_id"/>
<field name="city_summary" string="Cities"/>
<field name="area_summary" string="Areas"/>
<field name="outlet_summary" string="Outlets"/>
<field name="state"/>
<filter name="filter_current_week" string="Current Week" domain="[('week_start_date', '<=', context_today()), ('week_end_date', '>=', context_today())]"/>
<filter name="filter_upcoming" string="Upcoming" domain="[('week_start_date', '>=', context_today())]"/>
<filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
<filter name="filter_generated" string="Plans Generated" domain="[('state', '=', 'plans_generated')]"/>
<filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
<separator/>
<filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
<filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
<filter name="group_by_week" string="Week Start" context="{'group_by': 'week_start_date'}"/>
<filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
<searchpanel>
<field name="user_id" string="Salesperson"/>
<field name="vehicle_id" string="Vehicle"/>
<field name="search_city_ids" string="Cities" select="multi"/>
<field name="search_area_ids" string="Areas" select="multi"/>
<field name="search_outlet_ids" string="Outlets" select="multi"/>
</searchpanel>
</search>
</field>
</record>
<record id="action_route_weekly_schedule" model="ir.actions.act_window">
<field name="name">Weekly Route Planning</field>
<field name="res_model">route.weekly.schedule</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_weekly_schedule_search"/>
<field name="context">{'search_default_filter_current_week': 1}</field>
</record>
<record id="action_route_weekly_schedule_salesperson" model="ir.actions.act_window">
<field name="name">My Weekly Schedule</field>
<field name="res_model">route.weekly.schedule</field>
<field name="view_mode">list,form</field>
<field name="search_view_id" ref="route_core.view_route_weekly_schedule_search"/>
<field name="domain">[('user_id', '=', uid), ('state', '!=', 'cancelled')]</field>
<field name="context">{'search_default_filter_current_week': 1, 'create': 0, 'edit': 0, 'delete': 0}</field>
</record>
</data>
</odoo>
