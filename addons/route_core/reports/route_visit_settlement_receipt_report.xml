<odoo>
<record id="paperformat_route_visit_settlement_receipt" model="report.paperformat">
<field name="name">Direct Stop Settlement Receipt</field>
<field name="default" eval="False"/>
<field name="format">A4</field>
<field name="orientation">Portrait</field>
<field name="margin_top">12</field>
<field name="margin_bottom">12</field>
<field name="margin_left">10</field>
<field name="margin_right">10</field>
<field name="header_line" eval="False"/>
<field name="header_spacing">4</field>
<field name="dpi">96</field>
</record>
<record id="action_report_route_visit_settlement_receipt" model="ir.actions.report">
<field name="name">Direct Stop Settlement Receipt</field>
<field name="model">route.visit</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">route_core.report_route_visit_settlement_receipt</field>
<field name="report_file">route_core.report_route_visit_settlement_receipt</field>
<field name="print_report_name">'Settlement Receipt - %s' % (object.name or '')</field>
<field name="paperformat_id" ref="route_core.paperformat_route_visit_settlement_receipt"/>
</record>
<template id="report_route_visit_settlement_receipt">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">
<t t-call="web.basic_layout">
<div class="page" style="font-size:12px; color:#1f2937;">
<t t-set="summary" t-value="doc._get_direct_stop_receipt_summary()"/>
<t t-set="payment_breakdown" t-value="doc._get_direct_stop_receipt_payment_breakdown()"/>
<t t-set="previous_due_lines" t-value="doc._get_direct_stop_receipt_previous_due_lines()"/>
<t t-set="sale_orders" t-value="doc._get_direct_stop_receipt_sale_orders()"/>
<t t-set="sale_lines" t-value="doc._get_direct_stop_receipt_sale_lines()"/>
<t t-set="returns" t-value="doc._get_direct_stop_receipt_returns()"/>
<t t-set="return_lines" t-value="doc._get_direct_stop_receipt_return_lines()"/>
<t t-set="payments" t-value="doc._get_direct_stop_receipt_payments()"/>
<t t-set="currency_label" t-value="doc.currency_id.name or ''"/>
<t t-set="sale_total" t-value="sum(line['subtotal'] for line in sale_lines) if sale_lines else 0.0"/>
<t t-set="return_total" t-value="sum(line['subtotal'] for line in return_lines) if return_lines else 0.0"/>
<t t-set="payment_total" t-value="sum(payment.amount or 0.0 for payment in payments) if payments else 0.0"/>
<t t-set="credit_policy_label" t-value="dict(doc._fields['direct_stop_credit_policy'].selection).get(doc.direct_stop_credit_policy) if doc.direct_stop_credit_policy else 'Not required'"/>
<div style="border:1px solid #cbd5e1; background:#ffffff; margin-bottom:14px;">
<table style="width:100%; border-collapse:collapse; table-layout:fixed;">
<tr>
<td style="width:64%; padding:16px 18px; vertical-align:top; border-right:1px solid #e5e7eb;">
<div style="font-size:11px; letter-spacing:0.6px; text-transform:uppercase; color:#0f766e; font-weight:700; margin-bottom:6px;">Route Core</div>
<div style="font-size:25px; font-weight:700; color:#111827; line-height:1.15; margin-bottom:6px;">Settlement Receipt</div>
<div style="font-size:12px; color:#475569; line-height:1.55; margin-bottom:10px;">Official direct stop summary for sale, return, and confirmed settlement activity.</div>
<div style="font-size:11px; color:#475569; line-height:1.6;">
<div>
<strong t-esc="doc.company_id.name or '-'"/>
</div>
<div t-if="doc.company_id.partner_id and doc.company_id.partner_id.contact_address" t-esc="doc.company_id.partner_id.contact_address"/>
<div t-if="doc.company_id.phone or doc.company_id.email or doc.company_id.website">
<span t-if="doc.company_id.phone" t-esc="doc.company_id.phone"/>
<t t-if="doc.company_id.phone and (doc.company_id.email or doc.company_id.website)"> | </t>
<span t-if="doc.company_id.email" t-esc="doc.company_id.email"/>
<t t-if="doc.company_id.email and doc.company_id.website"> | </t>
<span t-if="doc.company_id.website" t-esc="doc.company_id.website"/>
</div>
</div>
</td>
<td style="width:36%; padding:16px 18px; vertical-align:top; text-align:right; background:#f8fafc;">
<div t-if="doc.company_id.logo" style="margin-bottom:12px;">
<img t-att-src="image_data_uri(doc.company_id.logo)" style="max-height:52px; max-width:150px; object-fit:contain;" alt="Company Logo"/>
</div>
<div style="display:inline-block; text-align:left; min-width:190px; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.5px; margin-bottom:4px;">Receipt Meta</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Visit No:</strong>
<span t-esc="doc.name or '-'"/>
</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Receipt Ref:</strong>
<span t-esc="doc.name or '-'"/>
</div>
<div style="font-size:12px;">
<strong>Generated:</strong>
<span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/>
</div>
</div>
</td>
</tr>
</table>
</div>
<table style="width:100%; border-collapse:collapse; margin-bottom:14px; border:1px solid #cbd5e1;">
<tr>
<td colspan="4" style="padding:9px 12px; background:#ecfeff; color:#155e75; font-weight:700; font-size:13px; border-bottom:1px solid #cbd5e1;">Visit Summary</td>
</tr>
<tr>
<td style="width:18%; padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Outlet</td>
<td style="width:32%; padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.outlet_id"/>
</td>
<td style="width:18%; padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Customer</td>
<td style="width:32%; padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.partner_id"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Salesperson</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.user_id"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Vehicle</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.vehicle_id"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Visit Date</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.date"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Area</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.area_id"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Start DateTime</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.start_datetime" t-field="doc.start_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.start_datetime">-</span>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">End DateTime</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.end_datetime" t-field="doc.end_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.end_datetime">-</span>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Sale Order No.</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary['sale_order_ref'] or '-'"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Return No.</td>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary['return_ref'] or '-'"/>
</td>
</tr>
<tr>
<td style="padding:8px 12px; font-weight:700; color:#334155;">Execution Mode</td>
<td style="padding:8px 12px;">
<span t-esc="doc.visit_execution_mode_label or '-'"/>
</td>
<td style="padding:8px 12px; font-weight:700; color:#334155;">Receipt Currency</td>
<td style="padding:8px 12px;">
<span t-esc="currency_label or '-'"/>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:separate; border-spacing:8px; margin:0 -8px 10px -8px;">
<tr>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Previous Due</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary['previous_due'], currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">
Since:
<span t-esc="summary['previous_due_since'] or '-'"/>
</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Direct Sales Total</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary['current_sale'], currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Confirmed sale value in this stop.</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Direct Returns Total</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary['current_return'], currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Approved return value in this stop.</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Current Stop Net</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary['net_current_stop'], currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Direct sales minus direct returns.</div>
</td>
</tr>
<tr>
<td style="border:1px solid #bfdbfe; background:#eff6ff; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#1d4ed8; letter-spacing:0.4px; margin-bottom:6px;">Total Due Now</div>
<div style="font-size:20px; font-weight:700; color:#1e3a8a;" t-esc="'%.2f %s' % (summary['grand_total_due'], currency_label)"/>
<div style="font-size:10px; color:#1d4ed8; margin-top:5px;">Previous due plus current stop net amount.</div>
</td>
<td style="border:1px solid #bbf7d0; background:#f0fdf4; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#15803d; letter-spacing:0.4px; margin-bottom:6px;">Collected Now</div>
<div style="font-size:20px; font-weight:700; color:#166534;" t-esc="'%.2f %s' % (summary['settled_amount'], currency_label)"/>
<div style="font-size:10px; color:#15803d; margin-top:5px;">Confirmed cash collection in this stop.</div>
</td>
<td style="border:1px solid #fecaca; background:#fef2f2; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#b91c1c; letter-spacing:0.4px; margin-bottom:6px;">Remaining After Collection</div>
<div style="font-size:20px; font-weight:700; color:#991b1b;" t-esc="'%.2f %s' % (summary.get('immediate_remaining_amount', summary['remaining_amount']), currency_label)"/>
<div style="font-size:10px; color:#b91c1c; margin-top:5px;">Total due minus collected cash for this stop.</div>
</td>
<td style="border:1px solid #e5e7eb; background:#fafafa; padding:10px 12px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Promise Amount / Credit</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % ((summary['promise_amount'] or summary['credit_amount']), currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">
<span t-if="summary['latest_promise_date']">
Promise Date:
<span t-esc="summary['latest_promise_date']"/>
</span>
<span t-if="not summary['latest_promise_date']">
Policy:
<span t-esc="credit_policy_label"/>
</span>
</div>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:collapse; margin-bottom:14px; border:1px solid #cbd5e1;">
<tr>
<td colspan="5" style="padding:9px 12px; background:#f8fafc; color:#334155; font-weight:700; font-size:13px; border-bottom:1px solid #cbd5e1;">Settlement Breakdown</td>
</tr>
<tr style="background:#f8fafc;">
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Cash</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Bank Transfer</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">POS</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Deferred Collected</td>
<td style="padding:8px 12px; font-weight:700; border-bottom:1px solid #e5e7eb;">Promised Amount</td>
</tr>
<tr>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['cash'], currency_label)"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['bank'], currency_label)"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['pos'], currency_label)"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['deferred'], currency_label)"/>
<td style="padding:8px 12px; border-bottom:1px solid #e5e7eb;" t-esc="'%.2f %s' % (payment_breakdown['totals']['promise'], currency_label)"/>
</tr>
<tr>
<td colspan="3" style="padding:8px 12px;">
<strong>Latest Promise Date:</strong>
<span t-esc="payment_breakdown['latest_promise_date'] or '-'"/>
</td>
<td colspan="2" style="padding:8px 12px;">
<strong>Current Promise Status:</strong>
<span t-esc="payment_breakdown['latest_promise_status'] or '-'"/>
</td>
</tr>
</table>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:14px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Open Previous Due Lines</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Visit Ref</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Date</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not previous_due_lines">
<td colspan="3" style="padding:10px; color:#64748b;">No previous due lines.</td>
</tr>
<tr t-foreach="previous_due_lines" t-as="line">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['visit_ref']"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['date'] or '-'"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (line['amount'], currency_label)"/>
</tr>
</tbody>
</table>
</div>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:12px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Direct Sale Orders</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Order Ref</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Order Date</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Total</th>
</tr>
</thead>
<tbody>
<tr t-if="not sale_orders">
<td colspan="3" style="padding:10px; color:#64748b;">No direct sale orders.</td>
</tr>
<tr t-foreach="sale_orders" t-as="order">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="order.name"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="order.date_order"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-field="order.amount_total"/>
</td>
</tr>
</tbody>
</table>
</div>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:14px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Sold Products</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Order Ref</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Barcode</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Product</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Qty</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">UoM</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Unit Price</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not sale_lines">
<td colspan="7" style="padding:10px; color:#64748b;">No sale products.</td>
</tr>
<tr t-foreach="sale_lines" t-as="line">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['order_ref']"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['barcode'] or '-'"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['product_name']"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % line['quantity']"/>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['uom_name']"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (line['unit_price'], currency_label)"/>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (line['subtotal'], currency_label)"/>
</tr>
</tbody>
<tfoot t-if="sale_lines">
<tr>
<td colspan="6" style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;">Total Sold Amount</td>
<td style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;" t-esc="'%.2f %s' % (sale_total, currency_label)"/>
</tr>
</tfoot>
</table>
</div>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:12px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Direct Returns</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Return Ref</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Date</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Total</th>
</tr>
</thead>
<tbody>
<tr t-if="not returns">
<td colspan="3" style="padding:10px; color:#64748b;">No direct returns.</td>
</tr>
<tr t-foreach="returns" t-as="ret">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="ret.name"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="ret.return_date"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-field="ret.amount_total"/>
</td>
</tr>
</tbody>
</table>
</div>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:14px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Returned Products</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Return Ref</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Barcode</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Product</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Qty</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">UoM</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Reason</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Unit Price</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not return_lines">
<td colspan="8" style="padding:10px; color:#64748b;">No return products.</td>
</tr>
<tr t-foreach="return_lines" t-as="line">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['return_ref']"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['barcode'] or '-'"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['product_name']"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % line['quantity']"/>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['uom_name']"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="line['reason'] or '-'"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (line['unit_price'], currency_label)"/>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (line['subtotal'], currency_label)"/>
</tr>
</tbody>
<tfoot t-if="return_lines">
<tr>
<td colspan="7" style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;">Total Returned Amount</td>
<td style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;" t-esc="'%.2f %s' % (return_total, currency_label)"/>
</tr>
</tfoot>
</table>
</div>
<div style="margin-top:10px; border:1px solid #dbe3ec; margin-bottom:16px;">
<div style="padding:8px 10px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Confirmed Settlement Payments</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Payment Date</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Mode</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Scenario</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Promise Date</th>
<th style="text-align:right; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Promise Amount</th>
<th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Reference</th>
</tr>
</thead>
<tbody>
<tr t-if="not payments">
<td colspan="7" style="padding:10px; color:#64748b;">No confirmed settlement payments.</td>
</tr>
<tr t-foreach="payments" t-as="payment">
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.payment_date"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['payment_mode'].selection).get(payment.payment_mode)"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['collection_type'].selection).get(payment.collection_type)"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.amount"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.promise_date"/>
</td>
<td style="padding:8px 10px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-esc="'%.2f %s' % ((payment.effective_promise_amount or payment.promise_amount or 0.0), currency_label or '')"/>
</td>
<td style="padding:8px 10px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.reference"/>
</td>
</tr>
</tbody>
<tfoot t-if="payments">
<tr>
<td colspan="3" style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;">Total Confirmed Payments</td>
<td style="padding:8px 10px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;" t-esc="'%.2f %s' % (payment_total, currency_label)"/>
<td colspan="3" style="background:#f8fafc; border-top:1px solid #dbe3ec;"> </td>
</tr>
</tfoot>
</table>
</div>
<div style="border:1px solid #dbe3ec; padding:12px 14px; margin-bottom:14px; background:#f8fafc;">
<div style="font-weight:700; margin-bottom:6px; color:#0f172a;">Acknowledgement</div>
<div style="font-size:11px; color:#475569; line-height:1.6;">This receipt confirms the direct stop sale, return, and settlement entries captured for this visit. Any remaining balance or promised amount shown above remains open according to the approved settlement policy.</div>
</div>
<table style="width:100%; border-collapse:collapse; margin-top:18px;">
<tr>
<td style="width:48%; vertical-align:top; padding-right:10px;">
<div style="border:1px solid #cbd5e1; padding:12px; min-height:112px; background:#ffffff;">
<div style="font-weight:700; margin-bottom:20px; color:#0f172a;">Outlet Signature</div>
<div style="height:42px; border-bottom:1px solid #94a3b8; margin-bottom:10px;"/>
<div style="font-size:11px; color:#475569;">Name:</div>
<div style="font-size:11px; color:#475569; margin-top:6px;">Date:</div>
</div>
</td>
<td style="width:4%;"> </td>
<td style="width:48%; vertical-align:top; padding-left:10px;">
<div style="border:1px solid #cbd5e1; padding:12px; min-height:112px; background:#ffffff;">
<div style="font-weight:700; margin-bottom:20px; color:#0f172a;">Salesperson Signature</div>
<div style="height:42px; border-bottom:1px solid #94a3b8; margin-bottom:10px;"/>
<div style="font-size:11px; color:#475569;">
Name:
<span t-field="doc.user_id"/>
</div>
<div style="font-size:11px; color:#475569; margin-top:6px;">
Date:
<span t-field="doc.date"/>
</div>
</div>
</td>
</tr>
</table>
</div>
</t>
</t>
</t>
</template>
<record id="paperformat_route_visit_consignment_receipt" model="report.paperformat">
<field name="name">Consignment Visit Receipt</field>
<field name="default" eval="False"/>
<field name="format">A4</field>
<field name="orientation">Portrait</field>
<field name="margin_top">12</field>
<field name="margin_bottom">12</field>
<field name="margin_left">10</field>
<field name="margin_right">10</field>
<field name="header_line" eval="False"/>
<field name="header_spacing">4</field>
<field name="dpi">96</field>
</record>
<record id="action_report_route_visit_consignment_receipt" model="ir.actions.report">
<field name="name">Consignment Visit Receipt</field>
<field name="model">route.visit</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">route_core.report_route_visit_consignment_receipt</field>
<field name="report_file">route_core.report_route_visit_consignment_receipt</field>
<field name="print_report_name">'Consignment Visit Receipt - %s' % (object.name or '')</field>
<field name="paperformat_id" ref="route_core.paperformat_route_visit_consignment_receipt"/>
</record>
<template id="report_route_visit_consignment_receipt">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">
<t t-call="web.basic_layout">
<div class="page" style="font-size:12px; color:#1f2937;">
<t t-set="summary" t-value="doc._get_consignment_receipt_summary()"/>
<t t-set="payments" t-value="doc._get_consignment_receipt_payments()"/>
<t t-set="items" t-value="doc._get_consignment_receipt_line_items()"/>
<t t-set="currency_label" t-value="doc.currency_id.name or ''"/>
<t t-set="total_outlet_due" t-value="summary.get('total_outlet_due', summary.get('current_due', 0.0))"/>
<t t-set="current_sale" t-value="summary.get('visit_sale_amount', 0.0)"/>
<t t-set="returned_value" t-value="summary.get('returned_value', 0.0)"/>
<t t-set="commission_amount" t-value="summary.get('commission_amount', 0.0)"/>
<t t-set="gross_after_returns_amount" t-value="summary.get('gross_after_returns_amount', current_sale - returned_value)"/>
<t t-set="refill_value" t-value="summary.get('refill_value', 0.0)"/>
<t t-set="confirmed_payment_total" t-value="summary.get('confirmed_payment_total', 0.0)"/>
<t t-set="current_visit_net" t-value="summary.get('current_visit_net', current_sale - returned_value)"/>
<t t-set="total_outstanding_after_collection" t-value="summary.get('total_outstanding_after_collection', (total_outlet_due - confirmed_payment_total) if (total_outlet_due - confirmed_payment_total) > 0.0 else 0.0)"/>
<div style="border:1px solid #cbd5e1; background:#ffffff; margin-bottom:10px;">
<table style="width:100%; border-collapse:collapse; table-layout:fixed;">
<tr>
<td style="width:64%; padding:14px 16px; vertical-align:top; border-right:1px solid #e5e7eb;">
<div style="font-size:11px; letter-spacing:0.6px; text-transform:uppercase; color:#0f766e; font-weight:700; margin-bottom:6px;">Route Core</div>
<div style="font-size:25px; font-weight:700; color:#111827; line-height:1.15; margin-bottom:4px;">Settlement Receipt</div>
<div style="font-size:11px; font-weight:700; color:#0f766e; text-transform:uppercase; letter-spacing:0.4px; margin-bottom:8px;">Consignment Visit</div>
<div style="font-size:12px; color:#475569; line-height:1.45; margin-bottom:8px;">Official consignment visit summary for stock movement, sale value, returns, refill activity, and confirmed collection records.</div>
<div style="font-size:11px; color:#475569; line-height:1.6;">
<div>
<strong t-esc="doc.company_id.name or '-'"/>
</div>
<div t-if="doc.company_id.partner_id and doc.company_id.partner_id.contact_address" t-esc="doc.company_id.partner_id.contact_address"/>
<div t-if="doc.company_id.phone or doc.company_id.email or doc.company_id.website">
<span t-if="doc.company_id.phone" t-esc="doc.company_id.phone"/>
<t t-if="doc.company_id.phone and (doc.company_id.email or doc.company_id.website)"> | </t>
<span t-if="doc.company_id.email" t-esc="doc.company_id.email"/>
<t t-if="doc.company_id.email and doc.company_id.website"> | </t>
<span t-if="doc.company_id.website" t-esc="doc.company_id.website"/>
</div>
</div>
</td>
<td style="width:36%; padding:14px 16px; vertical-align:top; text-align:right; background:#f8fafc;">
<div t-if="doc.company_id.logo" style="margin-bottom:12px;">
<img t-att-src="image_data_uri(doc.company_id.logo)" style="max-height:52px; max-width:150px; object-fit:contain;" alt="Company Logo"/>
</div>
<div style="display:inline-block; text-align:left; min-width:190px; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.5px; margin-bottom:4px;">Receipt Meta</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Visit No:</strong>
<span t-esc="doc.name or '-'"/>
</div>
<div style="font-size:12px; margin-bottom:4px;">
<strong>Receipt Ref:</strong>
<span t-esc="doc.name or '-'"/>
</div>
<div style="font-size:12px;">
<strong>Generated:</strong>
<span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/>
</div>
</div>
</td>
</tr>
</table>
</div>
<table style="width:100%; border-collapse:collapse; margin-bottom:10px; border:1px solid #cbd5e1;">
<tr>
<td colspan="4" style="padding:9px 12px; background:#ecfeff; color:#155e75; font-weight:700; font-size:13px; border-bottom:1px solid #cbd5e1;">Visit Summary</td>
</tr>
<tr>
<td style="width:18%; padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Outlet</td>
<td style="width:32%; padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.outlet_id"/>
</td>
<td style="width:18%; padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Customer</td>
<td style="width:32%; padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.partner_id"/>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Salesperson</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.user_id"/>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Vehicle</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.vehicle_id"/>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Visit Date</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.date"/>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Area</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-field="doc.area_id"/>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Start DateTime</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.start_datetime" t-field="doc.start_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.start_datetime">-</span>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">End DateTime</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-if="doc.end_datetime" t-field="doc.end_datetime" t-options="{'widget': 'datetime'}"/>
<span t-if="not doc.end_datetime">-</span>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Sale Order No.</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary.get('sale_order_ref') or '-'"/>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Refill Transfer</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary.get('refill_ref') or '-'"/>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Return No.</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-esc="summary.get('return_refs') or '-'"/>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-bottom:1px solid #e5e7eb;">Execution Mode</td>
<td style="padding:6px 10px; border-bottom:1px solid #e5e7eb;">
<span t-esc="doc.visit_execution_mode_label or '-'"/>
</td>
</tr>
<tr>
<td style="padding:6px 10px; font-weight:700; color:#334155;">Receipt Currency</td>
<td colspan="3" style="padding:6px 10px;">
<span t-esc="currency_label or '-'"/>
</td>
</tr>
<tr t-if="commission_amount">
<td style="padding:6px 10px; font-weight:700; color:#334155; border-top:1px solid #e5e7eb;">Gross After Returns</td>
<td style="padding:6px 10px; border-top:1px solid #e5e7eb;">
<span t-esc="'%.2f %s' % (gross_after_returns_amount, currency_label)"/>
</td>
<td style="padding:6px 10px; font-weight:700; color:#334155; border-top:1px solid #e5e7eb;">Category Commission</td>
<td style="padding:6px 10px; border-top:1px solid #e5e7eb;">
<span t-esc="'%.2f %s' % (commission_amount, currency_label)"/>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:separate; border-spacing:6px; margin:0 -6px 8px -6px;">
<tr>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Total Outlet Due</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (total_outlet_due, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Outlet balance before confirming new collections.</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Current Visit Sale</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (current_sale, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Calculated from sold quantities in this visit.</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Returned Value</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (returned_value, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Recorded return value in this visit.</div>
</td>
<td style="width:25%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; letter-spacing:0.4px; margin-bottom:6px;">Refill Value</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (refill_value, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Transferred stock value from vehicle to outlet.</div>
</td>
</tr>
<tr>
<td style="border:1px solid #bbf7d0; background:#f0fdf4; padding:6px 8px;">
<div style="font-size:10px; text-transform:uppercase; color:#15803d; margin-bottom:6px;">Collected Amount</div>
<div style="font-size:20px; font-weight:700; color:#166534;" t-esc="'%.2f %s' % (summary.get('settled_amount', 0.0), currency_label)"/>
</td>
<td style="border:1px solid #fecaca; background:#fef2f2; padding:6px 8px;">
<div style="font-size:10px; text-transform:uppercase; color:#b91c1c; margin-bottom:6px;">Current Visit Remaining</div>
<div style="font-size:20px; font-weight:700; color:#991b1b;" t-esc="'%.2f %s' % (summary.get('current_visit_remaining', summary.get('remaining_amount', 0.0)), currency_label)"/>
</td>
<td style="border:1px solid #e5e7eb; background:#fafafa; padding:6px 8px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Promise Amount</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (summary.get('promise_amount', 0.0), currency_label)"/>
</td>
<td style="border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Confirmed Payments</div>
<div style="font-size:20px; font-weight:700; color:#0f172a;" t-esc="'%.0f' % (len(payments) if payments else 0)"/>
</td>
</tr>
</table>
<table style="width:100%; border-collapse:separate; border-spacing:6px; margin:0 -6px 8px -6px;">
<tr>
<td style="width:50%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Current Visit Net</div>
<div style="font-size:18px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (current_visit_net, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Current visit sale minus returns and category commission.</div>
</td>
<td style="width:50%; border:1px solid #dbe3ec; background:#ffffff; padding:6px 8px; vertical-align:top;">
<div style="font-size:10px; text-transform:uppercase; color:#64748b; margin-bottom:6px;">Total Outlet Balance After Collection</div>
<div style="font-size:18px; font-weight:700; color:#0f172a;" t-esc="'%.2f %s' % (total_outstanding_after_collection, currency_label)"/>
<div style="font-size:10px; color:#64748b; margin-top:5px;">Total outlet due minus confirmed cash collection in this visit.</div>
</td>
</tr>
</table>
<div style="margin-top:8px; border:1px solid #dbe3ec; margin-bottom:16px;">
<div style="padding:6px 8px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Confirmed Payments</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Payment Date</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Mode</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Scenario</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Amount</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Promise Date</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Promise Amount</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Reference</th>
</tr>
</thead>
<tbody>
<tr t-if="not payments">
<td colspan="7" style="padding:10px; color:#64748b;">No confirmed payments.</td>
</tr>
<tr t-foreach="payments" t-as="payment">
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.payment_date"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['payment_mode'].selection).get(payment.payment_mode)"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="dict(payment._fields['collection_type'].selection).get(payment.collection_type)"/>
</td>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.amount"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.promise_date"/>
</td>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;">
<span t-esc="'%.2f %s' % ((payment.effective_promise_amount or payment.promise_amount or 0.0), currency_label or '')"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-field="payment.reference"/>
</td>
</tr>
</tbody>
<tfoot t-if="payments">
<tr>
<td colspan="3" style="padding:6px 8px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;">Total Confirmed Payments</td>
<td style="padding:6px 8px; text-align:right; font-weight:700; background:#f8fafc; border-top:1px solid #dbe3ec;" t-esc="'%.2f %s' % (confirmed_payment_total, currency_label)"/>
<td colspan="3" style="background:#f8fafc; border-top:1px solid #dbe3ec;"> </td>
</tr>
</tfoot>
</table>
</div>
<div style="margin-top:8px; border:1px solid #dbe3ec; margin-bottom:10px;">
<div style="padding:6px 8px; background:#f8fafc; font-weight:700; font-size:13px; border-bottom:1px solid #dbe3ec;">Visit Line Summary</div>
<table style="width:100%; border-collapse:collapse;">
<thead>
<tr>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Barcode</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Product</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Lot</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Expiry</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Prev.</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Counted</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Sold</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Returned</th>
<th style="text-align:left; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Return Route</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Supplied</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Unit Price</th>
<th style="text-align:right; padding:6px 8px; border-bottom:1px solid #e5e7eb; background:#fcfcfd;">Sold Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not items">
<td colspan="11" style="padding:10px; color:#64748b;">No visit lines with activity.</td>
</tr>
<tr t-foreach="items" t-as="item">
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="item.get('barcode') or '-'"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="item.get('product_name') or '-'"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9; white-space:nowrap;">
<span t-esc="item.get('lot_display') or item.get('lot_name') or '-'"/>
</td>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="item.get('expiry_date') or '-'"/>
</td>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % (item.get('display_previous_qty', item.get('previous_qty', 0.0)) or 0.0)"/>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % (item.get('counted_qty', 0.0) or 0.0)"/>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % (item.get('sold_qty', 0.0) or 0.0)"/>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % (item.get('return_qty', 0.0) or 0.0)"/>
<td style="padding:6px 8px; border-bottom:1px solid #f1f5f9;">
<span t-esc="item.get('return_route_label') or '-'"/>
</td>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f' % (item.get('supplied_qty', 0.0) or 0.0)"/>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (item.get('unit_price', 0.0) or 0.0, currency_label)"/>
<td style="padding:6px 8px; text-align:right; border-bottom:1px solid #f1f5f9;" t-esc="'%.2f %s' % (item.get('sold_amount', 0.0) or 0.0, currency_label)"/>
</tr>
</tbody>
</table>
</div>
<div style="border:1px solid #dbe3ec; padding:12px 14px; margin-bottom:10px; background:#f8fafc;">
<div style="font-weight:700; margin-bottom:6px; color:#0f172a;">Acknowledgement</div>
<div style="font-size:11px; color:#475569; line-height:1.6;">This receipt confirms the consignment visit stock movement, sale value, collection, return, and refill entries captured for this visit. Any remaining or promised amount shown above remains open according to the confirmed collection records.</div>
</div>
<table style="width:100%; border-collapse:collapse; margin-top:18px;">
<tr>
<td style="width:48%; vertical-align:top; padding-right:10px;">
<div style="border:1px solid #cbd5e1; padding:12px; min-height:96px; background:#ffffff;">
<div style="font-weight:700; margin-bottom:20px; color:#0f172a;">Outlet Signature</div>
<div style="height:42px; border-bottom:1px solid #94a3b8; margin-bottom:10px;"/>
<div style="font-size:11px; color:#475569;">Name:</div>
<div style="font-size:11px; color:#475569; margin-top:6px;">Date:</div>
</div>
</td>
<td style="width:4%;"> </td>
<td style="width:48%; vertical-align:top; padding-left:10px;">
<div style="border:1px solid #cbd5e1; padding:12px; min-height:96px; background:#ffffff;">
<div style="font-weight:700; margin-bottom:20px; color:#0f172a;">Salesperson Signature</div>
<div style="height:42px; border-bottom:1px solid #94a3b8; margin-bottom:10px;"/>
<div style="font-size:11px; color:#475569;">
Name:
<span t-field="doc.user_id"/>
</div>
<div style="font-size:11px; color:#475569; margin-top:6px;">
Date:
<span t-field="doc.date"/>
</div>
</div>
</td>
</tr>
</table>
</div>
</t>
</t>
</t>
</template>
</odoo>
