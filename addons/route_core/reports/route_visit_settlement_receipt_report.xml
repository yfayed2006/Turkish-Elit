<odoo>
<record id="action_report_route_visit_settlement_receipt" model="ir.actions.report">
<field name="name">Direct Stop Settlement Receipt</field>
<field name="model">route.visit</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">route_core.report_route_visit_settlement_receipt</field>
<field name="report_file">route_core.report_route_visit_settlement_receipt</field>
<field name="print_report_name">'Settlement Receipt - %s' % (object.name or '')</field>
</record>
<template id="report_route_visit_settlement_receipt">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">
<t t-call="web.external_layout">
<div class="page">
<h2>Direct Stop Settlement Receipt</h2>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:16px;">
<tbody>
<tr>
<td>
<strong>Visit</strong>
</td>
<td>
<span t-field="doc.name"/>
</td>
<td>
<strong>Visit Date</strong>
</td>
<td>
<span t-field="doc.date"/>
</td>
</tr>
<tr>
<td>
<strong>Outlet</strong>
</td>
<td>
<span t-field="doc.outlet_id"/>
</td>
<td>
<strong>Customer</strong>
</td>
<td>
<span t-field="doc.partner_id"/>
</td>
</tr>
<tr>
<td>
<strong>Salesperson</strong>
</td>
<td>
<span t-field="doc.user_id"/>
</td>
<td>
<strong>Vehicle</strong>
</td>
<td>
<span t-field="doc.vehicle_id"/>
</td>
</tr>
<tr>
<td>
<strong>Area</strong>
</td>
<td>
<span t-field="doc.area_id"/>
</td>
<td>
<strong>Execution Mode</strong>
</td>
<td>
<span t-esc="doc.visit_execution_mode_label or ''"/>
</td>
</tr>
</tbody>
</table>
<t t-set="summary" t-value="doc._get_direct_stop_receipt_summary()"/>
<h3>Financial Summary</h3>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:16px;">
<tbody>
<tr>
<td>
<strong>Previous Due</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['previous_due']"/>
</td>
<td>
<strong>Previous Due Since</strong>
</td>
<td>
<span t-esc="summary['previous_due_since'] or '-'"/>
</td>
</tr>
<tr>
<td>
<strong>Current Sale</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['current_sale']"/>
</td>
<td>
<strong>Current Return</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['current_return']"/>
</td>
</tr>
<tr>
<td>
<strong>Net Current Stop</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['net_current_stop']"/>
</td>
<td>
<strong>Grand Total Due</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['grand_total_due']"/>
</td>
</tr>
<tr>
<td>
<strong>Settled Amount</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['settled_amount']"/>
</td>
<td>
<strong>Remaining Amount</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['remaining_amount']"/>
</td>
</tr>
<tr t-if="summary['credit_amount']">
<td>
<strong>Customer Credit</strong>
</td>
<td>
<span t-esc="'%.2f' % summary['credit_amount']"/>
</td>
<td>
<strong>Credit Policy</strong>
</td>
<td>
<span t-esc="dict(doc._fields['direct_stop_credit_policy'].selection).get(doc.direct_stop_credit_policy) if doc.direct_stop_credit_policy else '-'"/>
</td>
</tr>
</tbody>
</table>
<h3>Open Previous Due Lines</h3>
<t t-set="previous_due_lines" t-value="doc._get_direct_stop_receipt_previous_due_lines()"/>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:16px;">
<thead>
<tr>
<th>Visit Ref</th>
<th>Date</th>
<th class="text-end">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not previous_due_lines">
<td colspan="3">No previous due lines.</td>
</tr>
<tr t-foreach="previous_due_lines" t-as="line">
<td>
<span t-esc="line['visit_ref']"/>
</td>
<td>
<span t-esc="line['date'] or '-'"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['amount']"/>
</td>
</tr>
</tbody>
</table>
<h3>Direct Sale Orders</h3>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:12px;">
<thead>
<tr>
<th>Order Ref</th>
<th>Order Date</th>
<th class="text-end">Total</th>
</tr>
</thead>
<tbody>
<tr t-if="not doc._get_direct_stop_receipt_sale_orders()">
<td colspan="3">No direct sale orders.</td>
</tr>
<tr t-foreach="doc._get_direct_stop_receipt_sale_orders()" t-as="order">
<td>
<span t-field="order.name"/>
</td>
<td>
<span t-field="order.date_order"/>
</td>
<td class="text-end">
<span t-field="order.amount_total"/>
</td>
</tr>
</tbody>
</table>
<t t-set="sale_lines" t-value="doc._get_direct_stop_receipt_sale_lines()"/>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:16px;">
<thead>
<tr>
<th>Order Ref</th>
<th>Barcode</th>
<th>Product</th>
<th class="text-end">Qty</th>
<th>UoM</th>
<th class="text-end">Unit Price</th>
<th class="text-end">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not sale_lines">
<td colspan="7">No sale products.</td>
</tr>
<tr t-foreach="sale_lines" t-as="line">
<td>
<span t-esc="line['order_ref']"/>
</td>
<td>
<span t-esc="line['barcode'] or '-'"/>
</td>
<td>
<span t-esc="line['product_name']"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['quantity']"/>
</td>
<td>
<span t-esc="line['uom_name']"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['unit_price']"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['subtotal']"/>
</td>
</tr>
</tbody>
</table>
<h3>Direct Returns</h3>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:12px;">
<thead>
<tr>
<th>Return Ref</th>
<th>Date</th>
<th class="text-end">Total</th>
</tr>
</thead>
<tbody>
<tr t-if="not doc._get_direct_stop_receipt_returns()">
<td colspan="3">No direct returns.</td>
</tr>
<tr t-foreach="doc._get_direct_stop_receipt_returns()" t-as="ret">
<td>
<span t-field="ret.name"/>
</td>
<td>
<span t-field="ret.return_date"/>
</td>
<td class="text-end">
<span t-field="ret.amount_total"/>
</td>
</tr>
</tbody>
</table>
<t t-set="return_lines" t-value="doc._get_direct_stop_receipt_return_lines()"/>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:16px;">
<thead>
<tr>
<th>Return Ref</th>
<th>Barcode</th>
<th>Product</th>
<th class="text-end">Qty</th>
<th>UoM</th>
<th>Reason</th>
<th class="text-end">Unit Price</th>
<th class="text-end">Amount</th>
</tr>
</thead>
<tbody>
<tr t-if="not return_lines">
<td colspan="8">No return products.</td>
</tr>
<tr t-foreach="return_lines" t-as="line">
<td>
<span t-esc="line['return_ref']"/>
</td>
<td>
<span t-esc="line['barcode'] or '-'"/>
</td>
<td>
<span t-esc="line['product_name']"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['quantity']"/>
</td>
<td>
<span t-esc="line['uom_name']"/>
</td>
<td>
<span t-esc="line['reason'] or '-'"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['unit_price']"/>
</td>
<td class="text-end">
<span t-esc="'%.2f' % line['subtotal']"/>
</td>
</tr>
</tbody>
</table>
<h3>Confirmed Settlement Payments</h3>
<table class="table table-sm table-bordered" style="width:100%; margin-bottom:18px;">
<thead>
<tr>
<th>Payment Date</th>
<th>Mode</th>
<th>Scenario</th>
<th class="text-end">Amount</th>
<th>Promise Date</th>
<th class="text-end">Promise Amount</th>
<th>Reference</th>
</tr>
</thead>
<tbody>
<tr t-if="not doc._get_direct_stop_receipt_payments()">
<td colspan="7">No confirmed settlement payments.</td>
</tr>
<tr t-foreach="doc._get_direct_stop_receipt_payments()" t-as="payment">
<td>
<span t-field="payment.payment_date"/>
</td>
<td>
<span t-esc="dict(payment._fields['payment_mode'].selection).get(payment.payment_mode)"/>
</td>
<td>
<span t-esc="dict(payment._fields['collection_type'].selection).get(payment.collection_type)"/>
</td>
<td class="text-end">
<span t-field="payment.amount"/>
</td>
<td>
<span t-field="payment.promise_date"/>
</td>
<td class="text-end">
<span t-field="payment.promise_amount"/>
</td>
<td>
<span t-field="payment.reference"/>
</td>
</tr>
</tbody>
</table>
<div style="margin-top:28px;">
<table style="width:100%; border-collapse:collapse;">
<tr>
<td style="width:48%; vertical-align:top;">
<strong>Outlet Signature</strong>
<div style="height:70px; border-bottom:1px solid #000; margin-top:24px;"/>
<div>Name:</div>
<div>Date:</div>
</td>
<td style="width:4%;"/>
<td style="width:48%; vertical-align:top;">
<strong>Salesperson Signature</strong>
<div style="height:70px; border-bottom:1px solid #000; margin-top:24px;"/>
<div>
Name:
<span t-field="doc.user_id"/>
</div>
<div>
Date:
<span t-field="doc.date"/>
</div>
</td>
</tr>
</table>
</div>
</div>
</t>
</t>
</t>
</template>
</odoo>
