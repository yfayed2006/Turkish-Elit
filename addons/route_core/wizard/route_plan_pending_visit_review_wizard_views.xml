<odoo>
<record id="view_route_plan_pending_visit_review_wizard_form" model="ir.ui.view">
<field name="name">route.plan.pending.visit.review.wizard.form</field>
<field name="model">route.plan.pending.visit.review.wizard</field>
<field name="arch" type="xml">
<form string="Review Pending Visits">
<sheet>
<group col="2">
<field name="plan_id" readonly="1"/>
<field name="pending_count" readonly="1"/>
</group>
<div class="alert alert-warning" role="alert">
<strong>Supervisor review required:</strong>
Choose whether each pending visit should be carried forward to the current plan, rescheduled to another date, or cancelled.
</div>
<field name="review_line_ids" nolabel="1">
<list editable="bottom" create="0" delete="0">
<field name="source_plan_date" readonly="1"/>
<field name="source_plan_id" readonly="1"/>
<field name="area_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="visit_id" readonly="1" optional="show"/>
<field name="decision"/>
<field name="reschedule_date" readonly="decision != 'reschedule'"/>
<field name="supervisor_note"/>
</list>
</field>
</sheet>
<footer>
<button name="action_confirm" type="object" string="Apply Decisions" class="btn-primary"/>
<button string="Discard" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
