<odoo>
<record id="view_route_plan_add_area_outlets_wizard_form" model="ir.ui.view">
<field name="name">route.plan.add.area.outlets.wizard.form</field>
<field name="model">route.plan.add.area.outlets.wizard</field>
<field name="arch" type="xml">
<form string="Add Visits by Area">
<sheet>
<group col="2">
<field name="plan_id" readonly="1"/>
<field name="area_id"/>
</group>
<group string="Outlets">
<field name="available_outlet_ids" invisible="1"/>
<field name="outlet_ids" widget="many2many_tags" domain="[('id', 'in', available_outlet_ids)]" options="{'no_create': True, 'no_create_edit': True, 'no_open': False}" placeholder="Select outlets assigned to this plan scope"/>
</group>
<div class="text-muted"> Select an area first. The list shows only outlets matching this plan's salesperson and vehicle, excluding outlets already added to the plan. </div>
</sheet>
<footer>
<button name="action_select_all_outlets" type="object" string="Select All" class="btn-secondary"/>
<button name="action_clear_selection" type="object" string="Clear Selection" class="btn-secondary"/>
<button name="action_add_selected_outlets" type="object" string="Save" class="btn-primary"/>
<button string="Discard" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
