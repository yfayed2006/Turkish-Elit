<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_plan_add_area_outlets_wizard_form" model="ir.ui.view">
        <field name="name">route.plan.add.area.outlets.wizard.form</field>
        <field name="model">route.plan.add.area.outlets.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Visits by Area">
                <sheet>
                    <group>
                        <field name="plan_id" readonly="1"/>
                        <field name="area_id"/>
                        <field name="outlet_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_select_all_outlets" string="Select All Outlets" type="object" class="btn-secondary"/>
                    <button name="action_add_selected_outlets" string="Add Visits" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_route_plan_add_area_outlets_wizard" model="ir.actions.act_window">
        <field name="name">Add Visits by Area</field>
        <field name="res_model">route.plan.add.area.outlets.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
