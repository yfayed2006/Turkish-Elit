<odoo>
<record id="view_route_visit_statement_wizard_form" model="ir.ui.view">
<field name="name">route.visit.statement.wizard.form</field>
<field name="model">route.visit.statement.wizard</field>
<field name="arch" type="xml">
<form string="Statement of Account" create="0" edit="0" delete="0" class="route_pda_statement_form">
<sheet class="route_pda_statement_sheet route_pda_payment_sheet">
<field name="can_continue_to_collection" invisible="1"/>
<field name="opened_from_payment_wizard" invisible="1"/>
<div class="route_pda_statement_section">
<div class="route_pda_group_title route_pda_payment_section_title">Visit Context</div>
<div class="route_pda_statement_grid">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit</span>
<field name="visit_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Outlet</span>
<field name="outlet_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Customer</span>
<field name="partner_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit Date</span>
<field name="visit_date" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Salesperson</span>
<field name="user_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Vehicle</span>
<field name="vehicle_id" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_statement_section">
<div class="route_pda_group_title route_pda_payment_section_title">Collection Summary</div>
<div class="route_pda_statement_grid route_pda_statement_grid_summary">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Previous Due</span>
<field name="previous_due_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit Sale</span>
<field name="current_visit_sale_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit Returns</span>
<field name="current_visit_return_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="current_visit_commission_amount == 0">
<span class="route_pda_payment_meta_label">Commission</span>
<field name="current_visit_commission_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Current Visit Net</span>
<field name="net_amount_for_visit" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Total Outlet Due</span>
<field name="amount_due_now" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Suggested Cash Collection</span>
<field name="suggested_collection_now" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Expected Remaining After Collection</span>
<field name="expected_remaining_after_payment" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_statement_section">
<div class="route_pda_group_title route_pda_payment_section_title">Payment and Promise Snapshot</div>
<div class="route_pda_statement_grid route_pda_statement_grid_snapshot">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Prev Confirmed Payments</span>
<field name="previous_confirmed_payment_count" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Prev Confirmed Amount</span>
<field name="previous_confirmed_payment_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Open Promises</span>
<field name="open_promise_count" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Open Promise Amount</span>
<field name="open_promise_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Overdue Promises</span>
<field name="overdue_promise_count" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Overdue Promise Amount</span>
<field name="overdue_promise_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Last Payment Date</span>
<field name="last_payment_date" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Last Payment Amount</span>
<field name="last_payment_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Next Promise Date</span>
<field name="next_promise_date" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Next Promise Amount</span>
<field name="next_promise_amount" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_statement_info" role="alert"> This statement is for review. Total Outlet Due is the outlet balance before the new collection. Current Visit Net is this visit sale minus returns. Suggested Cash Collection is the cash amount recommended to collect now. Expected Remaining After Collection is the amount that will stay open after the collection decision. The full settlement receipt remains available after the visit is finished. </div>
</sheet>
<footer class="route_pda_statement_footer">
<button name="action_print_statement_pdf" string="Print Statement" type="object" class="btn-primary"/>
<button name="action_continue_to_collection" string="Back to Collection" type="object" class="btn-secondary" invisible="not opened_from_payment_wizard"/>
<button name="action_continue_to_collection" string="Continue to Collection" type="object" class="btn-secondary" invisible="opened_from_payment_wizard or not can_continue_to_collection"/>
<button string="Close" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
