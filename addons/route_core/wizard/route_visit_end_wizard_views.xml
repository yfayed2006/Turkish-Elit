<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_end_wizard_form" model="ir.ui.view">
        <field name="name">route.visit.end.wizard.form</field>
        <field name="model">route.visit.end.wizard</field>
        <field name="arch" type="xml">
            <form string="End Visit">
                <sheet>
                    <group>
                        <field name="visit_id" readonly="1"/>
                        <field
                            name="reason"
                            placeholder="Write the reason here if the visit will be ended without sale..."
                        />
                    </group>
                    <footer>
                        <button
                            name="action_create_sale_order"
                            string="Create Sale Order"
                            type="object"
                            class="btn-primary"
                        />
                        <button
                            name="action_end_without_sale"
                            string="End Without Sale"
                            type="object"
                        />
                        <button
                            name="action_cancel"
                            string="Cancel"
                            type="object"
                            special="cancel"
                        />
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_route_visit_end_wizard" model="ir.actions.act_window">
        <field name="name">End Visit</field>
        <field name="res_model">route.visit.end.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
