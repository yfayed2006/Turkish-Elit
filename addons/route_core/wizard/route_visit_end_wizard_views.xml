<odoo>
<record id="view_route_visit_end_wizard_form" model="ir.ui.view">
<field name="name">route.visit.end.wizard.form</field>
<field name="model">route.visit.end.wizard</field>
<field name="arch" type="xml">
<form string="Finish Visit">
<sheet>
<field name="has_sale_qty" invisible="1"/>
<field name="has_operational_activity" invisible="1"/>
<field name="reason_required" invisible="1"/>
<div class="alert alert-info" role="alert">
<field name="finish_hint" readonly="1" nolabel="1"/>
</div>
<group>
<field name="visit_id" readonly="1"/>
<field name="reason" placeholder="Optional note, or required reason when there was no sale and no activity..."/>
</group>
</sheet>
<footer>
<button name="action_create_sale_order" string="Create Sale Order" type="object" class="btn-primary" invisible="not has_sale_qty"/>
<button name="action_end_without_sale" string="Finish Visit" type="object" class="btn-primary"/>
<button name="action_cancel" string="Cancel" type="object" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_visit_end_wizard" model="ir.actions.act_window">
<field name="name">Finish Visit</field>
<field name="res_model">route.visit.end.wizard</field>
<field name="view_mode">form</field>
<field name="target">new</field>
</record>
</odoo>
