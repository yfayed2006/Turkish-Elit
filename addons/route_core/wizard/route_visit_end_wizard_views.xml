<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_route_visit_end_wizard_form" model="ir.ui.view">
        <field name="name">route.visit.end.wizard.form</field>
        <field name="model">route.visit.end.wizard</field>
        <field name="arch" type="xml">
            <form string="End Visit Options">
                <sheet>
                    <group>
                        <field name="message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_sale_order"
                            string="Create Sale Order"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_end_without_sale"
                            string="End Without Sale"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
