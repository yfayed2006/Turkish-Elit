<odoo>
<record id="view_route_plan_skip_visit_wizard_form" model="ir.ui.view">
<field name="name">route.plan.skip.visit.wizard.form</field>
<field name="model">route.plan.skip.visit.wizard</field>
<field name="arch" type="xml">
<form string="Skip Visit">
<sheet>
<group col="2">
<field name="plan_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
</group>
<group>
<field name="reason" required="1"/>
<field name="note" placeholder="Optional note about why this visit was skipped..."/>
</group>
</sheet>
<footer>
<button name="action_confirm_skip" type="object" string="Confirm Skip" class="btn-primary"/>
<button string="Discard" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
