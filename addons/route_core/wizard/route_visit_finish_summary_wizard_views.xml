<odoo>
<record id="view_route_visit_finish_summary_wizard_form" model="ir.ui.view">
<field name="name">route.visit.finish.summary.wizard.form</field>
<field name="model">route.visit.finish.summary.wizard</field>
<field name="arch" type="xml">
<form string="Stop Finished" create="0" edit="0" delete="0">
<sheet>
<field name="is_direct_sales_stop" invisible="1"/>
<field name="currency_id" invisible="1"/>
<field name="finish_message" readonly="1" nolabel="1" widget="html"/>
<group col="2">
<group>
<field name="visit_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1"/>
</group>
<group>
<field name="user_id" readonly="1"/>
<field name="visit_date" readonly="1"/>
<field name="end_datetime" readonly="1"/>
</group>
</group>
<group string="Direct Stop Status" col="2" invisible="not is_direct_sales_stop">
<group>
<field name="sale_status_label" string="Sale Decision" readonly="1"/>
<field name="return_status_label" string="Return Decision" readonly="1"/>
<field name="credit_policy_label" string="Credit Handling" readonly="1"/>
</group>
<group>
<field name="direct_stop_order_count" readonly="1"/>
<field name="direct_stop_return_count" readonly="1"/>
<field name="direct_stop_credit_amount" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
</group>
<group string="Settlement Summary" col="4" invisible="not is_direct_sales_stop">
<field name="direct_stop_previous_due_amount" readonly="1"/>
<field name="direct_stop_sales_total" readonly="1"/>
<field name="direct_stop_returns_total" readonly="1"/>
<field name="direct_stop_current_net_amount" readonly="1"/>
<field name="direct_stop_grand_due_amount" readonly="1"/>
<field name="direct_stop_settlement_paid_amount" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" readonly="1"/>
<field name="direct_stop_credit_amount" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
</sheet>
<footer>
<button name="action_print_receipt" string="Print Settlement Receipt" type="object" class="btn-primary" invisible="not is_direct_sales_stop"/>
<button name="action_send_whatsapp_outlet" string="WhatsApp Outlet" type="object" class="btn-secondary" invisible="not is_direct_sales_stop"/>
<button name="action_send_whatsapp_supervisor" string="WhatsApp Supervisor" type="object" class="btn-secondary" invisible="not is_direct_sales_stop"/>
<button name="action_close" string="Done" type="object" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_visit_finish_summary_wizard" model="ir.actions.act_window">
<field name="name">Stop Finished</field>
<field name="res_model">route.visit.finish.summary.wizard</field>
<field name="view_mode">form</field>
<field name="target">new</field>
</record>
</odoo>
