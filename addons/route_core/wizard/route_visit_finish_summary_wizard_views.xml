<odoo>
<record id="view_route_visit_finish_summary_wizard_form" model="ir.ui.view">
<field name="name">route.visit.finish.summary.wizard.form</field>
<field name="model">route.visit.finish.summary.wizard</field>
<field name="arch" type="xml">
<form string="Visit Finished" create="0" edit="0" delete="0">
<sheet>
<field name="is_direct_sales_stop" invisible="1"/>
<field name="currency_id" invisible="1"/>
<group col="2">
<group>
<field name="visit_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
<field name="partner_id" readonly="1"/>
<field name="user_id" readonly="1"/>
</group>
<group>
<field name="visit_date" readonly="1"/>
<field name="end_datetime" readonly="1"/>
<field name="sale_status_label" string="Sale Decision" readonly="1" invisible="not is_direct_sales_stop"/>
<field name="return_status_label" string="Return Decision" readonly="1" invisible="not is_direct_sales_stop"/>
</group>
</group>
<group string="Settlement Summary" col="4" invisible="not is_direct_sales_stop">
<field name="direct_stop_previous_due_amount" readonly="1"/>
<field name="direct_stop_previous_due_since_display" string="Previous Due Since" readonly="1"/>
<field name="direct_stop_sales_total" readonly="1"/>
<field name="direct_stop_returns_total" readonly="1" invisible="not direct_stop_returns_total"/>
<field name="direct_stop_current_net_amount" readonly="1"/>
<field name="direct_stop_grand_due_amount" readonly="1"/>
<field name="direct_stop_settlement_paid_amount" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" readonly="1"/>
<field name="direct_stop_order_count" readonly="1" invisible="not direct_stop_order_count"/>
<field name="direct_stop_return_count" readonly="1" invisible="not direct_stop_return_count"/>
<field name="direct_stop_credit_amount" readonly="1" invisible="not direct_stop_credit_amount"/>
</group>
<group string="Visit Summary" col="4" invisible="is_direct_sales_stop">
<field name="consignment_current_due_amount" string="Current Due" readonly="1"/>
<field name="consignment_collected_amount" string="Collected" readonly="1"/>
<field name="consignment_remaining_amount" string="Remaining" readonly="1"/>
<field name="consignment_promise_amount" string="Promise Amount" readonly="1"/>
</group>
<group string="Visit Documents" col="4" invisible="is_direct_sales_stop">
<field name="consignment_sale_order_ref" string="Sale Order" readonly="1"/>
<field name="consignment_refill_ref" string="Refill Transfer" readonly="1"/>
<field name="consignment_return_refs" string="Return Transfers" readonly="1"/>
<field name="consignment_execution_mode_label" string="Execution Mode" readonly="1"/>
</group>
<group string="Confirmed Payments" invisible="is_direct_sales_stop">
<field name="consignment_payment_count" string="Confirmed Payments" readonly="1"/>
<field name="consignment_payment_summary_html" readonly="1" nolabel="1" widget="html"/>
</group>
<group>
<field name="finish_message" readonly="1" nolabel="1" widget="html"/>
</group>
</sheet>
<footer>
<button name="action_print_receipt" string="Print Receipt" type="object" class="btn-primary"/>
<button name="action_send_whatsapp_outlet" string="WhatsApp Outlet" type="object" class="btn-secondary"/>
<button name="action_send_whatsapp_supervisor" string="WhatsApp Supervisor" type="object" class="btn-secondary"/>
<button name="action_close" string="Done" type="object" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_visit_finish_summary_wizard" model="ir.actions.act_window">
<field name="name">Visit Finished</field>
<field name="res_model">route.visit.finish.summary.wizard</field>
<field name="view_mode">form</field>
<field name="view_id" ref="view_route_visit_finish_summary_wizard_form"/>
<field name="target">new</field>
</record>
</odoo>
