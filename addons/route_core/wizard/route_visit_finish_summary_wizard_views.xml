<odoo>
<record id="view_route_visit_finish_summary_wizard_form" model="ir.ui.view">
<field name="name">route.visit.finish.summary.wizard.form</field>
<field name="model">route.visit.finish.summary.wizard</field>
<field name="arch" type="xml">
<form string="Visit Finished" create="0" edit="0" delete="0">
<sheet>
<field name="is_direct_sales_stop" invisible="1"/>
<field name="currency_id" invisible="1"/>
<field name="show_return_section" invisible="1"/>
<field name="show_credit_section" invisible="1"/>
<field name="show_previous_due" invisible="1"/>
<field name="show_sale_orders" invisible="1"/>
<group col="2">
<group>
<field name="visit_id" string="Visit" readonly="1"/>
<field name="outlet_id" string="Outlet" readonly="1"/>
<field name="partner_id" string="Customer" readonly="1"/>
<field name="user_id" string="Salesperson" readonly="1"/>
</group>
<group>
<field name="visit_date" string="Visit Date" readonly="1"/>
<field name="end_datetime" string="End DateTime" readonly="1"/>
<field name="sale_status_label" string="Sale Decision" readonly="1" invisible="not is_direct_sales_stop"/>
<field name="return_status_label" string="Return Decision" readonly="1" invisible="not is_direct_sales_stop"/>
</group>
</group>
<group string="Settlement Summary" col="2" invisible="not is_direct_sales_stop">
<group>
<field name="direct_stop_sales_total" string="Sales Total" readonly="1"/>
<field name="direct_stop_returns_total" string="Returns Total" readonly="1" invisible="not show_return_section"/>
<field name="direct_stop_current_net_amount" string="Net Current Stop" readonly="1"/>
<field name="direct_stop_grand_due_amount" string="Grand Total Due" readonly="1"/>
</group>
<group>
<field name="direct_stop_settlement_paid_amount" string="Collected" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" string="Remaining" readonly="1"/>
<field name="direct_stop_previous_due_amount" string="Previous Due" readonly="1" invisible="not show_previous_due"/>
<field name="direct_stop_credit_amount" string="Return Credit" readonly="1" invisible="not show_credit_section"/>
</group>
</group>
<group>
<field name="finish_message" string="Finish Message" readonly="1" nolabel="0" widget="html"/>
</group>
</sheet>
<footer>
<button name="action_print_receipt" string="Print Receipt" type="object" class="btn-primary" invisible="not is_direct_sales_stop"/>
<button name="action_send_whatsapp_outlet" string="WhatsApp Outlet" type="object" class="btn-secondary" invisible="not is_direct_sales_stop"/>
<button name="action_send_whatsapp_supervisor" string="WhatsApp Supervisor" type="object" class="btn-secondary" invisible="not is_direct_sales_stop"/>
<button name="action_close" string="Done" type="object" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
