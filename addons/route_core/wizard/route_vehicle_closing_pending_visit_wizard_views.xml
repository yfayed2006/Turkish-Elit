<odoo>
<record id="view_route_vehicle_closing_pending_visit_wizard_form" model="ir.ui.view">
<field name="name">route.vehicle.closing.pending.visit.wizard.form</field>
<field name="model">route.vehicle.closing.pending.visit.wizard</field>
<field name="arch" type="xml">
<form string="Resolve Pending Visits Before Vehicle Closing">
<sheet>
<div class="alert alert-warning" role="alert">
<strong>Pending visits detected:</strong>
choose how to resolve each pending visit before closing the vehicle day. Visits that are carried forward or rescheduled will be created on another route plan, and the current day's line will be closed so the vehicle day can finish correctly.
</div>
<group col="4">
<field name="closing_id" readonly="1"/>
<field name="plan_id" readonly="1"/>
<field name="plan_date" readonly="1"/>
<field name="vehicle_id" readonly="1"/>
<field name="user_id" readonly="1"/>
<field name="pending_count" readonly="1"/>
</group>
<field name="line_ids" nolabel="1">
<list editable="bottom" create="0" delete="0">
<field name="outlet_id" readonly="1"/>
<field name="area_id" readonly="1" optional="show"/>
<field name="existing_visit_id" readonly="1" optional="show"/>
<field name="decision"/>
<field name="target_date"/>
<field name="note" readonly="1" optional="show"/>
</list>
</field>
</sheet>
<footer>
<button name="action_apply_resolution" type="object" string="Apply and Close Day" class="btn-primary"/>
<button string="Discard" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
