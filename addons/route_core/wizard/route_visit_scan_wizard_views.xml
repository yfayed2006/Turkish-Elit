<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_route_visit_scan_wizard_form" model="ir.ui.view">
        <field name="name">route.visit.scan.wizard.form</field>
        <field name="model">route.visit.scan.wizard</field>
        <field name="arch" type="xml">
            <form string="Scan Barcode">
                <group>
                    <group>
                        <field name="visit_id" readonly="1"/>
                        <field name="scan_mode" readonly="1"/>
                        <field name="barcode" placeholder="Type or paste barcode here"/>
                        <field name="quantity"/>
                        <field name="scanned_uom_id"/>
                        <field name="expiry_date" invisible="scan_mode != 'count'"/>
                    </group>

                    <group>
                        <field name="detected_product_id" readonly="1"/>
                        <field name="base_uom_id" readonly="1"/>
                        <field name="detected_scan_type" readonly="1"/>
                        <field name="counted_increase" readonly="1" invisible="scan_mode != 'count'"/>
                        <field name="expiry_days_left" readonly="1" invisible="scan_mode != 'count' or not expiry_date"/>

                        <field name="is_near_expiry" readonly="1" invisible="1"/>
                        <field name="is_expired" readonly="1" invisible="1"/>
                        <field name="requires_expiry_decision" readonly="1" invisible="1"/>
                        <field name="requires_return_route" readonly="1" invisible="1"/>
                        <field name="add_to_near_expiry_return" invisible="1"/>
                    </group>
                </group>

                <group string="Expiry Decision" invisible="scan_mode != 'count' or not requires_expiry_decision">
                    <group>
                        <field name="expiry_decision_help" readonly="1" nolabel="1"/>

                        <!-- Expired product: show fixed Return text only -->
                        <div invisible="not is_expired">
                            <span class="o_form_label">Expiry Decision</span>
                            <div class="mt-1">Return</div>
                        </div>

                        <!-- Near expiry only -->
                        <field name="near_expiry_decision" widget="radio" invisible="is_expired"/>

                        <field
                            name="return_route"
                            invisible="not requires_return_route"
                            required="requires_return_route"
                        />
                    </group>
                </group>

                <group string="Return Route" invisible="scan_mode != 'return'">
                    <group>
                        <field name="return_route"/>
                    </group>
                </group>

                <group string="Last Scan Result" invisible="scan_mode != 'count'">
                    <group>
                        <field name="last_product_id" readonly="1"/>
                        <field name="last_counted_qty" readonly="1"/>
                    </group>
                </group>

                <group string="Last Return Result" invisible="scan_mode != 'return'">
                    <group>
                        <field name="last_product_id" readonly="1"/>
                        <field name="last_return_qty" readonly="1"/>
                        <field name="last_return_route" readonly="1"/>
                    </group>
                </group>

                <footer>
                    <button
                        name="action_scan_and_add"
                        type="object"
                        string="Scan / Add"
                        class="btn-primary"
                    />
                    <button
                        name="action_done"
                        type="object"
                        string="Done"
                        class="btn-secondary"
                    />
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
