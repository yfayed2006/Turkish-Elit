<odoo>
<record id="view_route_visit_collect_payment_wizard_form" model="ir.ui.view">
<field name="name">route.visit.collect.payment.wizard.form</field>
<field name="model">route.visit.collect.payment.wizard</field>
<field name="arch" type="xml">
<form string="Collect Payment" create="0" edit="0" delete="0">
<sheet>
<field name="show_return_credit_handling" invisible="1"/>
<field name="show_collection_decision" invisible="1"/>
<field name="show_note_field" invisible="1"/>
<field name="show_full_payment_help" invisible="1"/>
<field name="show_partial_payment_help" invisible="1"/>
<field name="show_defer_help" invisible="1"/>
<field name="show_next_visit_help" invisible="1"/>
<field name="show_credit_only_help" invisible="1"/>
<field name="show_no_payment_due_help" invisible="1"/>
<field name="show_close_settlement_button" invisible="1"/>
<field name="show_save_draft_button" invisible="1"/>
<group string="Visit Financial Summary" col="4" invisible="is_direct_sales_stop">
<field name="visit_id" readonly="1"/>
<field name="visit_net_due_amount" readonly="1"/>
<field name="visit_collected_amount" readonly="1"/>
<field name="visit_remaining_due" readonly="1"/>
</group>
<group string="Direct Sales Settlement Summary" col="4" invisible="not is_direct_sales_stop">
<field name="is_direct_sales_stop" invisible="1"/>
<field name="visit_id" readonly="1"/>
<field name="direct_stop_previous_due_amount" string="Previous Due" readonly="1"/>
<field name="direct_stop_previous_due_since_date" readonly="1"/>
<field name="direct_stop_sales_total" string="Current Stop Gross Sale" readonly="1"/>
<field name="direct_stop_returns_total" string="Current Stop Returns" readonly="1"/>
<field name="direct_stop_current_net_amount" string="Current Stop Net" readonly="1"/>
<field name="direct_stop_grand_due_amount" string="Amount Due Now" readonly="1"/>
<field name="direct_stop_settlement_paid_amount" string="Collected Now" readonly="1"/>
<field name="direct_stop_settlement_remaining_amount" string="Immediate Remaining" readonly="1"/>
</group>
<group string="Return Credit Handling" col="2" invisible="not show_return_credit_handling">
<group>
<field name="direct_stop_credit_amount" readonly="1"/>
<field name="direct_stop_credit_policy"/>
</group>
<group>
<field name="direct_stop_credit_note" placeholder="Add note for customer credit, cash refund, or next stop carry-forward..."/>
</group>
</group>
<separator string="Collection Decision" invisible="not show_collection_decision"/>
<group col="2" invisible="not show_collection_decision">
<group>
<field name="collection_type" widget="radio"/>
<field name="payment_mode"/>
<field name="payment_date"/>
<field name="amount" invisible="collection_type in ('defer_date', 'next_visit')"/>
<field name="due_date" invisible="collection_type != 'defer_date'"/>
<field name="promise_date" invisible="collection_type == 'full'"/>
<field name="promise_amount" invisible="collection_type == 'full'"/>
</group>
<group>
<field name="reference" invisible="payment_mode in ('cash', 'deferred')"/>
<field name="bank_name" invisible="payment_mode != 'bank'"/>
<field name="pos_terminal" invisible="payment_mode != 'pos'"/>
</group>
</group>
<group invisible="not show_note_field">
<field name="note" placeholder="Add note for partial payment, deferment, or next visit collection..."/>
</group>
<div class="alert alert-info mt-3" role="alert" invisible="not show_full_payment_help"> Full payment will save the full remaining due amount as draft settlement entries for confirmation. When you reopen this window later, the summary reflects any saved draft or confirmed settlement entries. </div>
<div class="alert alert-warning mt-3" role="alert" invisible="not show_partial_payment_help"> Partial payment will save the collected amount as draft settlement entries and keep the remaining balance as promised unpaid amount. Reopening this window later will show the updated summary after those saved draft entries are applied. </div>
<div class="alert alert-info mt-3" role="alert" invisible="not is_direct_sales_stop"> Direct stop collection uses automatic allocation. The saved payment is distributed to the oldest unpaid balances first, then to the current stop. Review the Source Document column in the payment lines to see the allocation breakdown. </div>
<div class="alert alert-warning mt-3" role="alert" invisible="not show_defer_help"> Defer to date will save a zero-amount draft settlement with a required due date, promise amount, and note. </div>
<div class="alert alert-warning mt-3" role="alert" invisible="not show_next_visit_help"> Carry to next visit will save a zero-amount draft settlement with a required promise date, promise amount, and note. </div>
<div class="alert alert-info mt-3" role="alert" invisible="not show_credit_only_help"> No cash collection is required. Choose how to settle the return credit, then save. </div>
<div class="alert alert-info mt-3" role="alert" invisible="not show_no_payment_due_help"> No payment is due on this visit. Review the settlement summary, then close this window to continue finishing the stop. </div>
</sheet>
<footer>
<button name="action_open_statement_of_account" string="Statement of Account" type="object" class="btn-secondary"/>
<button name="action_save_payment" string="Save Draft" type="object" class="btn-primary" invisible="not show_save_draft_button"/>
<button name="action_close_settlement" string="Close Settlement" type="object" class="btn-primary" invisible="not show_close_settlement_button"/>
<button string="Cancel" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
