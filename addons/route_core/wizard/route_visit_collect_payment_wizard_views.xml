<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_route_visit_collect_payment_wizard_form" model="ir.ui.view">
        <field name="name">route.visit.collect.payment.wizard.form</field>
        <field name="model">route.visit.collect.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Collect Payment" create="0" edit="0" delete="0">
                <sheet>
                    <group string="Visit Summary" col="3">
                        <field name="visit_id" readonly="1"/>
                        <field name="visit_net_due_amount" readonly="1"/>
                        <field name="visit_collected_amount" readonly="1"/>
                        <field name="visit_remaining_due" readonly="1"/>
                    </group>

                    <group string="Collection Decision" col="2">
                        <group>
                            <field name="payment_date"/>
                            <field name="collection_type" widget="radio"/>
                            <field name="payment_mode"/>
                            <field name="amount" invisible="collection_type in ('defer_date', 'next_visit')"/>
                            <field name="due_date" invisible="collection_type != 'defer_date'"/>
                        </group>
                        <group>
                            <field name="reference" invisible="payment_mode == 'cash'"/>
                            <field name="bank_name" invisible="payment_mode != 'bank'"/>
                            <field name="pos_terminal" invisible="payment_mode != 'pos'"/>
                            <field
                                name="note"
                                placeholder="Add useful note for partial / deferred / next visit cases..."
                            />
                        </group>
                    </group>

                    <div class="alert alert-info mt-3" role="alert" invisible="collection_type != 'full'">
                        Full payment will draft the full remaining due amount for later confirmation.
                    </div>
                    <div class="alert alert-warning mt-3" role="alert" invisible="collection_type != 'partial'">
                        Partial payment keeps the remaining amount open on the visit. Add a note explaining the carried-forward balance.
                    </div>
                    <div class="alert alert-warning mt-3" role="alert" invisible="collection_type != 'defer_date'">
                        Deferred payment creates a zero-amount collection decision with a required due date and note.
                    </div>
                    <div class="alert alert-warning mt-3" role="alert" invisible="collection_type != 'next_visit'">
                        Carry to next visit creates a zero-amount collection decision. Add a note explaining why collection moves to the next visit.
                    </div>
                </sheet>
                <footer>
                    <button name="action_save_payment" string="Save Payment Draft" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
