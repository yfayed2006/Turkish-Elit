<odoo>
<record id="view_route_visit_collect_payment_wizard_form" model="ir.ui.view">
<field name="name">route.visit.collect.payment.wizard.form</field>
<field name="model">route.visit.collect.payment.wizard</field>
<field name="arch" type="xml">
<form string="Collect Payment" create="0" edit="0" delete="0" class="route_pda_statement_form">
<sheet class="route_pda_payment_sheet route_pda_collect_payment_sheet">
<field name="is_direct_sales_stop" invisible="1"/>
<field name="show_return_credit_handling" invisible="1"/>
<field name="show_collection_decision" invisible="1"/>
<field name="show_note_field" invisible="1"/>
<field name="show_full_payment_help" invisible="1"/>
<field name="show_partial_payment_help" invisible="1"/>
<field name="show_defer_help" invisible="1"/>
<field name="show_next_visit_help" invisible="1"/>
<field name="show_credit_only_help" invisible="1"/>
<field name="show_no_payment_due_help" invisible="1"/>
<field name="show_close_settlement_button" invisible="1"/>
<field name="show_save_draft_button" invisible="1"/>
<field name="show_single_payment_fields" invisible="1"/>
<field name="show_split_payment_lines" invisible="1"/>
<field name="show_partial_payment_plan" invisible="1"/>
<field name="payment_line_total" invisible="1"/>
<field name="payment_line_remaining" invisible="1"/>
<div class="route_pda_payment_section" invisible="is_direct_sales_stop">
<div class="route_pda_group_title route_pda_payment_section_title">Visit Financial Summary</div>
<div class="route_pda_statement_grid route_pda_statement_grid_summary">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit</span>
<field name="visit_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Gross Sold Value</span>
<field name="visit_gross_sale_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="visit_return_amount == 0">
<span class="route_pda_payment_meta_label">Returns Value</span>
<field name="visit_return_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="visit_commission_amount == 0">
<span class="route_pda_payment_meta_label">Commission</span>
<field name="visit_commission_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Current Visit Net</span>
<field name="visit_net_due_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Collected</span>
<field name="visit_collected_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Current Visit Remaining</span>
<field name="visit_remaining_due" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_payment_section" invisible="not is_direct_sales_stop">
<div class="route_pda_group_title route_pda_payment_section_title">Direct Sales Settlement Summary</div>
<div class="route_pda_statement_grid route_pda_statement_grid_summary">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Visit</span>
<field name="visit_id" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Previous Due</span>
<field name="direct_stop_previous_due_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Previous Due Since</span>
<field name="direct_stop_previous_due_since_date" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Current Stop Gross Sale</span>
<field name="direct_stop_sales_total" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="not direct_stop_returns_total">
<span class="route_pda_payment_meta_label">Current Stop Returns</span>
<field name="direct_stop_returns_total" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Current Stop Net</span>
<field name="direct_stop_current_net_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Total Due Now</span>
<field name="direct_stop_grand_due_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Collected Now</span>
<field name="direct_stop_settlement_paid_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Remaining After Collection</span>
<field name="direct_stop_settlement_remaining_amount" readonly="1" nolabel="1"/>
</div>
</div>
</div>
<div class="route_pda_payment_section" invisible="not show_return_credit_handling">
<div class="route_pda_group_title route_pda_payment_section_title">Return Credit Handling</div>
<div class="route_pda_payment_meta_grid route_pda_payment_decision_grid">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Credit Balance</span>
<field name="direct_stop_credit_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Return Credit Settlement</span>
<field name="direct_stop_credit_policy" nolabel="1"/>
</div>
</div>
<div class="route_pda_payment_note_wrap">
<field name="direct_stop_credit_note" widget="text" nolabel="1" placeholder="Add note for customer credit, cash refund, or next stop carry-forward..."/>
</div>
</div>
<div class="route_pda_payment_section" invisible="not show_collection_decision">
<div class="route_pda_group_title route_pda_payment_section_title">Collection Decision</div>
<div class="route_pda_payment_radio_wrap">
<field name="collection_type" widget="radio" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_grid route_pda_payment_decision_grid" invisible="collection_type != 'full'">
<div class="route_pda_payment_meta_item route_pda_payment_meta_item_wide">
<span class="route_pda_payment_meta_label">Payment Structure</span>
<field name="settlement_mode" widget="radio" nolabel="1"/>
</div>
</div>
<div class="route_pda_payment_meta_grid route_pda_payment_decision_grid" invisible="not show_single_payment_fields">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Payment Mode</span>
<field name="payment_mode" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Payment Date</span>
<field name="payment_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="collection_type in ('defer_date', 'next_visit')">
<span class="route_pda_payment_meta_label">Amount</span>
<field name="amount" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="collection_type != 'defer_date'">
<span class="route_pda_payment_meta_label">Deferred Due Date</span>
<field name="due_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="collection_type == 'full'">
<span class="route_pda_payment_meta_label">Promise To Pay Date</span>
<field name="promise_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="collection_type == 'full'">
<span class="route_pda_payment_meta_label">Promise To Pay Amount</span>
<field name="promise_amount" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode not in ('bank', 'pos')">
<span class="route_pda_payment_meta_label">Reference</span>
<field name="reference" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'bank'">
<span class="route_pda_payment_meta_label">Bank Name</span>
<field name="bank_name" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'pos'">
<span class="route_pda_payment_meta_label">POS Terminal</span>
<field name="pos_terminal" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Cheque Number</span>
<field name="cheque_number" nolabel="1" placeholder="Type cheque number"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Cheque Bank</span>
<field name="bank_name" nolabel="1" placeholder="Type bank name"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Cheque Date</span>
<field name="cheque_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Cheque Holder</span>
<field name="cheque_holder_name" nolabel="1" placeholder="Optional drawer / holder name"/>
</div>
<div class="route_pda_payment_meta_item route_pda_payment_meta_item_wide" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Cheque Details</span>
<field name="cheque_note" widget="text" nolabel="1" placeholder="Optional cheque details, branch, or remarks..."/>
</div>
</div>
<div invisible="not show_partial_payment_plan">
<div class="route_pda_group_title route_pda_payment_section_title">Collect Now</div>
<div class="route_pda_statement_grid route_pda_statement_grid_summary">
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Current Visit Remaining</span>
<field name="direct_stop_grand_due_amount" readonly="1" nolabel="1" invisible="not is_direct_sales_stop"/>
<field name="visit_remaining_due" readonly="1" nolabel="1" invisible="is_direct_sales_stop"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Collected Now</span>
<field name="amount" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Deferred Balance</span>
<field name="promise_amount" readonly="1" nolabel="1"/>
</div>
</div>
<div class="route_pda_payment_meta_grid route_pda_payment_decision_grid">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Now Payment Mode</span>
<field name="payment_mode" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Now Collection Date</span>
<field name="payment_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode not in ('bank', 'pos')">
<span class="route_pda_payment_meta_label">Now Reference</span>
<field name="reference" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'bank'">
<span class="route_pda_payment_meta_label">Now Bank Name</span>
<field name="bank_name" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'pos'">
<span class="route_pda_payment_meta_label">Now POS Terminal</span>
<field name="pos_terminal" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Now Cheque Number</span>
<field name="cheque_number" nolabel="1" placeholder="Type cheque number"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Now Cheque Bank</span>
<field name="bank_name" nolabel="1" placeholder="Type bank name"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Now Cheque Date</span>
<field name="cheque_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Now Cheque Holder</span>
<field name="cheque_holder_name" nolabel="1" placeholder="Optional drawer / holder name"/>
</div>
<div class="route_pda_payment_meta_item route_pda_payment_meta_item_wide" invisible="payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Now Cheque Details</span>
<field name="cheque_note" widget="text" nolabel="1" placeholder="Optional cheque details, branch, or remarks..."/>
</div>
</div>
<div class="route_pda_group_title route_pda_payment_section_title">Deferred Balance Plan</div>
<div class="route_pda_payment_meta_grid route_pda_payment_decision_grid">
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Deferred Amount</span>
<field name="promise_amount" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Expected Collection Date</span>
<field name="promise_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Expected Payment Mode</span>
<field name="deferred_payment_mode" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode not in ('bank', 'pos')">
<span class="route_pda_payment_meta_label">Deferred Reference</span>
<field name="deferred_reference" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'bank'">
<span class="route_pda_payment_meta_label">Deferred Bank Name</span>
<field name="deferred_bank_name" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'pos'">
<span class="route_pda_payment_meta_label">Deferred POS Terminal</span>
<field name="deferred_pos_terminal" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Deferred Cheque Number</span>
<field name="deferred_cheque_number" nolabel="1" placeholder="Type post-dated cheque number"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Deferred Cheque Bank</span>
<field name="deferred_bank_name" nolabel="1" placeholder="Type bank name"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Deferred Cheque Date</span>
<field name="deferred_cheque_date" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item" invisible="deferred_payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Deferred Cheque Holder</span>
<field name="deferred_cheque_holder_name" nolabel="1" placeholder="Optional drawer / holder name"/>
</div>
<div class="route_pda_payment_meta_item route_pda_payment_meta_item_wide" invisible="deferred_payment_mode != 'cheque'">
<span class="route_pda_payment_meta_label">Deferred Cheque Details</span>
<field name="deferred_cheque_note" widget="text" nolabel="1" placeholder="Optional cheque details, branch, or remarks..."/>
</div>
</div>
<div class="route_pda_statement_info route_pda_statement_info_warning" role="alert"> This section separates what is collected now from the carried-forward balance. If a post-dated cheque is received for the deferred balance, record it under Deferred Balance Plan. </div>
</div>
<div invisible="not show_split_payment_lines">
<div class="route_pda_group_title route_pda_payment_section_title">Split Payment Lines</div>
<div class="route_pda_statement_grid route_pda_statement_grid_summary">
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Total Due Now</span>
<field name="direct_stop_grand_due_amount" readonly="1" nolabel="1" invisible="not is_direct_sales_stop"/>
<field name="visit_remaining_due" readonly="1" nolabel="1" invisible="is_direct_sales_stop"/>
</div>
<div class="route_pda_payment_meta_item">
<span class="route_pda_payment_meta_label">Payment Lines Total</span>
<field name="payment_line_total" readonly="1" nolabel="1"/>
</div>
<div class="route_pda_payment_meta_item route_pda_info_card_emphasis">
<span class="route_pda_payment_meta_label">Remaining To Allocate</span>
<field name="payment_line_remaining" readonly="1" nolabel="1"/>
</div>
</div>
<field name="payment_line_ids" nolabel="1" class="route_pda_split_payment_lines" context="{'default_payment_date': payment_date, 'default_amount': payment_line_remaining}">
<list editable="bottom" create="1" delete="1">
<field name="currency_id" column_invisible="1"/>
<field name="payment_mode"/>
<field name="amount"/>
<field name="payment_date"/>
<field name="reference" optional="show" invisible="payment_mode not in ('bank', 'pos')"/>
<field name="bank_name" optional="show" invisible="payment_mode not in ('bank', 'cheque')"/>
<field name="pos_terminal" optional="show" invisible="payment_mode != 'pos'"/>
<field name="cheque_number" optional="show" invisible="payment_mode != 'cheque'"/>
<field name="cheque_date" optional="show" invisible="payment_mode != 'cheque'"/>
<field name="cheque_holder_name" optional="show" invisible="payment_mode != 'cheque'"/>
<field name="cheque_note" optional="show" invisible="payment_mode != 'cheque'"/>
</list>
<form string="Payment Line">
<sheet>
<group>
<group>
<field name="payment_mode"/>
<field name="amount"/>
<field name="payment_date"/>
<field name="reference" invisible="payment_mode == 'cash'"/>
</group>
<group>
<field name="bank_name" invisible="payment_mode not in ('bank', 'cheque')"/>
<field name="pos_terminal" invisible="payment_mode != 'pos'"/>
<field name="cheque_number" invisible="payment_mode != 'cheque'"/>
<field name="cheque_date" invisible="payment_mode != 'cheque'"/>
<field name="cheque_holder_name" invisible="payment_mode != 'cheque'"/>
</group>
</group>
<group invisible="payment_mode != 'cheque'">
<field name="cheque_note"/>
</group>
</sheet>
</form>
</field>
<div class="route_pda_statement_info" role="alert"> Split Payment is for full settlements paid by more than one instrument, such as Cash + Cheque, POS + Cash, or multiple cheques. Each cheque will become an independent custody card after payment confirmation. </div>
</div>
</div>
<div class="route_pda_payment_section" invisible="not show_note_field">
<div class="route_pda_group_title route_pda_payment_section_title">Collection Note</div>
<div class="route_pda_payment_note_wrap">
<field name="note" widget="text" nolabel="1" placeholder="Add note for partial payment, deferment, or next visit collection..."/>
</div>
</div>
<div class="route_pda_statement_info" role="alert" invisible="not show_full_payment_help"> Full payment will save the full remaining due amount as draft settlement entries for confirmation. </div>
<div class="route_pda_statement_info route_pda_statement_info_warning" role="alert" invisible="not show_partial_payment_help"> Partial payment will save the collected amount now and keep the remaining current visit balance as an open promise. </div>
<div class="route_pda_statement_info" role="alert" invisible="not is_direct_sales_stop"> Direct stop collection uses automatic allocation. Review the payment lines later to see how the saved amount was allocated. </div>
<div class="route_pda_statement_info route_pda_statement_info_warning" role="alert" invisible="not show_defer_help"> Defer to date will save a zero-amount draft settlement with a required due date, promise amount, and note. </div>
<div class="route_pda_statement_info route_pda_statement_info_warning" role="alert" invisible="not show_next_visit_help"> Carry to next visit will save a zero-amount draft settlement with a required promise date, promise amount, and note. </div>
<div class="route_pda_statement_info" role="alert" invisible="not show_credit_only_help"> No cash collection is required. Choose how to settle the return credit, then save. </div>
<div class="route_pda_statement_info" role="alert" invisible="not show_no_payment_due_help"> No payment is due on this visit. Review the summary, then close this window to continue. </div>
</sheet>
<footer class="route_pda_statement_footer">
<button name="action_open_statement_of_account" string="Statement of Account" type="object" class="btn-secondary"/>
<button name="action_save_payment" string="Save Draft" type="object" class="btn-primary" invisible="not show_save_draft_button"/>
<button name="action_close_settlement" string="Close Settlement" type="object" class="btn-primary" invisible="not show_close_settlement_button"/>
<button string="Cancel" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
