<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_finish_visit_warning_wizard_form" model="ir.ui.view">
        <field name="name">finish.visit.warning.wizard.form</field>
        <field name="model">finish.visit.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Finish Visit Warning">
                <group>
                    <field name="visit_id" readonly="1"/>
                    <field name="message" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_create_sale_order"
                            string="Create Sale Order"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_finish_anyway"
                            string="Finish Anyway"
                            type="object"
                            class="btn-secondary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
