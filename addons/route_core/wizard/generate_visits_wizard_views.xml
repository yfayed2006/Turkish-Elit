<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_generate_visits_wizard_form" model="ir.ui.view">
        <field name="name">generate.visits.wizard.form</field>
        <field name="model">generate.visits.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Visits">
                <group>
                    <field name="route_id" readonly="1"/>
                    <field name="visit_date"/>
                </group>
                <footer>
                    <button name="action_generate"
                            string="Generate"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_generate_visits_wizard" model="ir.actions.act_window">
        <field name="name">Generate Visits</field>
        <field name="res_model">generate.visits.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
