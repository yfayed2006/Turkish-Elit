<odoo>
<record id="view_route_visit_whatsapp_share_wizard_form" model="ir.ui.view">
<field name="name">route.visit.whatsapp.share.wizard.form</field>
<field name="model">route.visit.whatsapp.share.wizard</field>
<field name="arch" type="xml">
<form string="Share Receipt">
<sheet class="route_mobile_compact_sheet">
<field name="visit_id" invisible="1"/>
<div class="route_mobile_detail_box route_mobile_detail_box_subtle">
<div class="route_mobile_detail_label">WhatsApp Number</div>
<div class="route_mobile_detail_value">
<field name="phone_number" placeholder="Example: 905386232611"/>
</div>
</div>
<div class="route_mobile_detail_box route_mobile_detail_box_subtle">
<div class="route_mobile_detail_label">Message Preview</div>
<div class="route_mobile_detail_value route_mobile_wrap_value">
<field name="message_preview" readonly="1" nolabel="1"/>
</div>
</div>
</sheet>
<footer>
<button name="action_share_receipt" string="Share Receipt" type="object" class="btn-primary"/>
<button string="Cancel" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_visit_whatsapp_share_wizard" model="ir.actions.act_window">
<field name="name">Share Receipt</field>
<field name="res_model">route.visit.whatsapp.share.wizard</field>
<field name="view_mode">form</field>
<field name="view_id" ref="view_route_visit_whatsapp_share_wizard_form"/>
<field name="target">new</field>
</record>
</odoo>
