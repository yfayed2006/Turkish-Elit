<odoo>
<record id="view_route_visit_geo_reason_wizard_form" model="ir.ui.view">
<field name="name">route.visit.geo.reason.wizard.form</field>
<field name="model">route.visit.geo.reason.wizard</field>
<field name="arch" type="xml">
<form string="Outside Zone Reason" class="route_geo_reason_mobile_wizard">
<sheet>
<div class="alert alert-warning route_geo_reason_notice" role="alert"> You are outside the allowed outlet radius. Choose a reason to continue starting the visit. </div>
<div class="route_geo_reason_section_title">Visit Location Review</div>
<div class="route_geo_reason_review_cards">
<div class="route_geo_reason_card">
<div class="route_geo_reason_card_label">Visit</div>
<field name="visit_id" readonly="1" nolabel="1"/>
</div>
<div class="route_geo_reason_card">
<div class="route_geo_reason_card_label">Outlet</div>
<field name="outlet_id" readonly="1" nolabel="1"/>
</div>
<div class="route_geo_reason_card">
<div class="route_geo_reason_card_label">Location Status</div>
<field name="geo_checkin_status" readonly="1" nolabel="1" widget="badge"/>
</div>
<div class="route_geo_reason_card">
<div class="route_geo_reason_card_label">Distance from Outlet</div>
<field name="geo_checkin_distance_display" readonly="1" nolabel="1"/>
</div>
<div class="route_geo_reason_card">
<div class="route_geo_reason_card_label">Allowed Radius (m)</div>
<field name="route_geo_checkin_radius_m" readonly="1" nolabel="1"/>
</div>
</div>
<group string="Required Reason" class="route_geo_reason_required_group">
<field name="reason_code" required="1"/>
<field name="reason_note" placeholder="Optional details. Required when reason is Other."/>
</group>
</sheet>
<footer>
<button name="action_confirm_and_start_visit" string="Confirm Reason and Start Visit" type="object" class="btn-primary"/>
<button string="Cancel" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
</odoo>
