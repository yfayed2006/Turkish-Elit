<odoo>
<record id="view_route_visit_first_consignment_wizard_form" model="ir.ui.view">
<field name="name">route.visit.first.consignment.wizard.form</field>
<field name="model">route.visit.first.consignment.wizard</field>
<field name="arch" type="xml">
<form string="First Consignment Setup" class="route_first_consignment_wizard">
<sheet>
<div class="route_first_consignment_intro">
<div class="route_first_consignment_title">First consignment visit</div>
<div class="route_first_consignment_text">No previous shelf stock was found. Choose how the salesperson should continue this first consignment visit.</div>
</div>
<group col="2" class="route_first_consignment_snapshot">
<group>
<field name="visit_id" readonly="1"/>
<field name="outlet_id" readonly="1"/>
</group>
<group>
<field name="vehicle_id" readonly="1"/>
<field name="source_location_id" readonly="1"/>
<field name="outlet_location_id" readonly="1"/>
</group>
</group>
<group>
<field name="setup_mode" widget="radio"/>
<field name="help_text" readonly="1" nolabel="1"/>
<field name="has_vehicle_stock" invisible="1"/>
</group>
<div class="alert alert-warning" role="alert" invisible="setup_mode != 'vehicle_refill' or has_vehicle_stock"> No positive vehicle stock was found for this visit vehicle. Use empty shelf balance or continue visit only. </div>
<group string="Products to place from vehicle" invisible="setup_mode != 'vehicle_refill'">
<field name="line_ids" nolabel="1">
<list editable="bottom" create="1" delete="1">
<field name="product_id"/>
<field name="available_qty" readonly="1"/>
<field name="quantity"/>
<field name="uom_id" readonly="1" optional="show"/>
<field name="unit_price" optional="hide"/>
</list>
</field>
</group>
</sheet>
<footer>
<button name="action_apply" type="object" string="Apply Setup" class="btn-primary"/>
<button string="Cancel" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_visit_first_consignment_wizard" model="ir.actions.act_window">
<field name="name">First Consignment Setup</field>
<field name="res_model">route.visit.first.consignment.wizard</field>
<field name="view_mode">form</field>
<field name="target">new</field>
</record>
</odoo>
