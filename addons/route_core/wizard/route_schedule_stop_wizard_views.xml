<odoo>
<data>
<record id="view_route_schedule_stop_wizard_form" model="ir.ui.view">
<field name="name">route.schedule.stop.wizard.form</field>
<field name="model">route.schedule.stop.wizard</field>
<field name="arch" type="xml">
<form string="Add Weekly Stops">
<sheet>
<div class="oe_title">
<h2>
<field name="title" readonly="1" nolabel="1"/>
</h2>
</div>
<group col="2">
<group>
<field name="weekday_label" readonly="1"/>
<field name="city_id" options="{'no_create': True, 'no_create_edit': True}"/>
<field name="area_id" options="{'no_create': True, 'no_create_edit': True}"/>
<field name="available_outlet_ids" invisible="1"/>
<field name="outlet_ids" widget="many2many_tags" domain="[('id', 'in', available_outlet_ids)]" options="{'no_create': True, 'no_create_edit': True}" placeholder="Choose one or more outlets for this day"/>
<field name="note" placeholder="Optional note for the selected stops..."/>
</group>
<group>
<field name="template_id" invisible="not template_id" readonly="1"/>
<field name="schedule_id" invisible="not schedule_id" readonly="1"/>
<div class="text-muted" colspan="2">
Only outlets not already used on this weekday are shown here. Use
<strong>Add All Outlets Under Area</strong>
to load every remaining outlet in the selected area, then remove any outlet you do not want before saving.
</div>
</group>
</group>
</sheet>
<footer>
<button name="action_select_all_area_outlets" type="object" string="Add All Outlets Under Area" class="btn-secondary"/>
<button name="action_clear_selection" type="object" string="Clear Selection" class="btn-secondary"/>
<button name="action_save" type="object" string="Save" class="btn-primary"/>
<button string="Discard" special="cancel" class="btn-secondary"/>
</footer>
</form>
</field>
</record>
<record id="action_route_schedule_stop_wizard" model="ir.actions.act_window">
<field name="name">Add Weekly Stops</field>
<field name="res_model">route.schedule.stop.wizard</field>
<field name="view_mode">form</field>
<field name="view_id" ref="route_core.view_route_schedule_stop_wizard_form"/>
<field name="target">new</field>
</record>
</data>
</odoo>
